---
const checklistItems = [
	{ title: 'Service page structure', sub: 'Pages organized around real treatments and audiences, not internal departments.' },
	{ title: 'Metadata patterns', sub: 'Titles, descriptions, and schema tuned for healthcare service queries.' },
	{ title: 'Internal linking', sub: 'Pages reinforce each other so visitors and search engines find the right next page.' },
	{ title: 'Local keyword targeting', sub: 'City, region, and service language woven into the content — not stuffed.' },
	{ title: 'Google Business Profile alignment', sub: 'Your GBP, location pages, and on-site service pages tell one coherent story.' },
	{ title: 'Content foundation', sub: 'A blog and resource structure ready to grow with FAQs, condition guides, and patient education.' },
];
---

<section id="seo" class="section seo-visibility" aria-labelledby="seo-visibility-heading">
	<div class="site-container site-container--wide">
		<header class="seo-visibility__head">
			<p class="eyebrow">Local Visibility</p>
			<h2 id="seo-visibility-heading" class="display-lg">
				Built to be found by patients
				<span class="seo-visibility__head-soft">and understood by search engines.</span>
			</h2>
			<p class="lead seo-visibility__lead">
				Visibility isn't a magic plugin. It's clear service pages, real local language, and content patterns search engines can parse. We build that into the Foundation, not bolt it on after launch.
			</p>
		</header>

		<ul class="seo-visibility__grid" aria-label="Visibility foundation checklist">
			{
				checklistItems.map((item) => (
					<li class="seo-visibility__item">
						<span class="seo-visibility__check" aria-hidden="true">
							<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M4 10.5l4 4 8-9" />
							</svg>
						</span>
						<div class="seo-visibility__text">
							<p class="seo-visibility__item-title">{item.title}</p>
							<p class="seo-visibility__item-sub">{item.sub}</p>
						</div>
					</li>
				))
			}
		</ul>

		<footer class="seo-visibility__foot">
			<p class="seo-visibility__note">
				<strong>No ranking guarantees, no gimmicks.</strong> Just a foundation search engines and patients can understand.
			</p>
			<a class="seo-visibility__cta" href="/seo">
				See Local Visibility service
				<span aria-hidden="true">&rarr;</span>
			</a>
		</footer>
	</div>
</section>

<style>
	.seo-visibility {
		padding-block: var(--section-spacing);
		background:
			linear-gradient(180deg, transparent 0%, var(--lane-foundation-tint) 100%),
			var(--color-white);
	}

	.seo-visibility__head {
		display: grid;
		gap: 1.1rem;
		max-width: 60rem;
		margin: 0 0 clamp(2rem, 4vw, 3rem);
	}

	.seo-visibility__head-soft {
		display: block;
		color: var(--lane-foundation-ink);
		font-weight: 650;
	}

	.seo-visibility__lead {
		max-width: 52rem;
		color: var(--color-muted);
	}

	.seo-visibility__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin: 0 0 clamp(1.75rem, 3vw, 2.25rem);
		padding: 0;
		list-style: none;
	}

	.seo-visibility__item {
		display: grid;
		grid-template-columns: 2rem 1fr;
		gap: 0.85rem;
		padding: 1.1rem 1.2rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-white);
		box-shadow: var(--shadow-card);
	}

	.seo-visibility__check {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 10px;
		background: var(--lane-foundation-tint);
		color: var(--lane-foundation-ink);
	}

	.seo-visibility__check svg {
		width: 1rem;
		height: 1rem;
	}

	.seo-visibility__text {
		display: grid;
		gap: 0.2rem;
	}

	.seo-visibility__item-title {
		margin: 0;
		color: var(--color-text);
		font-size: 0.96rem;
		font-weight: 650;
		letter-spacing: -0.015em;
	}

	.seo-visibility__item-sub {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.85rem;
		line-height: 1.5;
	}

	.seo-visibility__foot {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem;
		padding: 1.1rem 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-white);
	}

	.seo-visibility__note {
		margin: 0;
		max-width: 38rem;
		color: var(--color-text);
		font-size: 0.92rem;
		line-height: 1.5;
	}

	.seo-visibility__note strong {
		color: var(--lane-foundation-ink);
		font-weight: 700;
	}

	.seo-visibility__cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 650;
		letter-spacing: -0.01em;
		transition: gap var(--transition-base);
	}

	.seo-visibility__cta:hover {
		gap: 0.6rem;
	}

	.seo-visibility__cta span {
		display: inline-block;
		transition: transform var(--transition-base);
	}

	.seo-visibility__cta:hover span {
		transform: translateX(3px);
	}

	@media (max-width: 1024px) {
		.seo-visibility__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 620px) {
		.seo-visibility__grid {
			grid-template-columns: 1fr;
		}

		.seo-visibility__foot {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
