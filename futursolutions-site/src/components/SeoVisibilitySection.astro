---
const checklistItems = [
	'Service page structure',
	'Metadata',
	'Internal linking',
	'Local keyword targeting',
	'Google Business Profile alignment',
	'Blog/content foundation',
];
---

<section class="section seo-visibility" aria-labelledby="seo-visibility-heading">
	<div class="site-container seo-visibility__inner">
		<div class="seo-visibility__content">
			<p class="eyebrow">Local visibility</p>
			<h2 id="seo-visibility-heading">Built to be understood by patients and search engines.</h2>
			<p class="lead">
				Your site should make it easy for people to find your services, understand your value, and take the next step. We structure pages around real search intent, local visibility, and clear service education.
			</p>
			<p class="seo-visibility__note">
				No ranking guarantees or gimmicks. Just a clear foundation search engines and patients can understand.
			</p>
		</div>

		<div class="seo-visibility__card card">
			<div class="seo-visibility__card-header">
				<span aria-hidden="true"></span>
				<h3>Local visibility foundation</h3>
			</div>
			<ul>
				{checklistItems.map((item) => (
					<li>
						<span aria-hidden="true">✓</span>
						{item}
					</li>
				))}
			</ul>
		</div>
	</div>
</section>

<style>
	.seo-visibility {
		background: var(--color-accent-light);
	}

	.seo-visibility__inner {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.72fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: center;
	}

	.seo-visibility__content {
		max-width: 760px;
	}

	.seo-visibility__content h2 {
		max-width: 780px;
	}

	.seo-visibility__note {
		max-width: 560px;
		margin-top: 1.5rem;
		padding-left: 1rem;
		border-left: 3px solid var(--color-accent);
		color: var(--color-accent-dark);
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1.6;
	}

	.seo-visibility__card {
		padding: clamp(1.25rem, 3vw, 1.75rem);
		border-radius: 18px;
		box-shadow: 0 22px 58px rgba(15, 23, 42, 0.06);
	}

	.seo-visibility__card-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
	}

	.seo-visibility__card-header span {
		width: 0.7rem;
		height: 0.7rem;
		border-radius: 999px;
		background: var(--color-accent);
		box-shadow: 0 0 0 6px var(--color-accent-light);
	}

	.seo-visibility__card h3 {
		margin-bottom: 0;
		font-size: 1.25rem;
		letter-spacing: -0.025em;
	}

	.seo-visibility__card ul {
		display: grid;
		gap: 0.85rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.seo-visibility__card li {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		color: var(--color-text);
		font-size: 0.9625rem;
		font-weight: 600;
	}

	.seo-visibility__card li span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.35rem;
		height: 1.35rem;
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.78rem;
		font-weight: 800;
	}

	@media (max-width: 860px) {
		.seo-visibility__inner {
			grid-template-columns: 1fr;
		}
	}
</style>
