---
import { beforeAfterCases } from '../data/aurea';
---

<section id="results" class="aurea-section aurea-section--warm" aria-labelledby="results-heading">
	<div class="aurea-container">
		<div class="ba__intro">
			<p class="aurea-eyebrow">Realistic Results</p>
			<h2 id="results-heading">Real patients. Real outcomes. Realistic expectations.</h2>
			<p class="aurea-lead">
				Every result starts with a consultation and a personalized plan. These examples represent the kind of improvement patients can expect.
			</p>
		</div>
		<div class="ba__grid">
			{
				beforeAfterCases.map((c) => (
					<article class="ba__card aurea-card">
						<div class="ba__images">
							<div class="ba__side ba__side--before">
								<div class="ba__texture" aria-hidden="true"></div>
								<span class="ba__label">Before</span>
							</div>
							<div class="ba__divider" aria-hidden="true"></div>
							<div class="ba__side ba__side--after">
								<span class="ba__label">After</span>
							</div>
						</div>
						<div class="ba__body">
							<div class="ba__meta">
								<span class="ba__area">{c.area}</span>
								<span class="ba__treatment">{c.treatment}</span>
							</div>
							<p>{c.description}</p>
						</div>
					</article>
				))
			}
		</div>

		<div class="ba__cta">
			<a href="/demos/med-spa/contact" class="aurea-btn aurea-btn--champagne">
				See what&rsquo;s possible &mdash; Book a Consultation
			</a>
			<a href="/demos/med-spa/results" class="ba__cta-link">
				View All Results &rarr;
			</a>
		</div>

		<p class="ba__disclaimer">
			Individual results vary. Images are placeholders for demonstration purposes. A consultation is required to determine candidacy for any treatment.
		</p>
	</div>
</section>

<style>
	.ba__intro {
		max-width: 700px;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	.ba__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.ba__card {
		overflow: hidden;
	}

	/* ── Image area ── */
	.ba__images {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		height: 200px;
	}

	.ba__side {
		position: relative;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		padding-bottom: 0.75rem;
	}

	.ba__side--before {
		background: color-mix(in srgb, var(--aurea-stone) 28%, var(--aurea-ivory));
		overflow: hidden;
	}

	.ba__texture {
		position: absolute;
		inset: 0;
		background: repeating-linear-gradient(
			0deg,
			transparent,
			transparent 5px,
			color-mix(in srgb, var(--aurea-stone) 18%, transparent) 5px,
			color-mix(in srgb, var(--aurea-stone) 18%, transparent) 6px
		);
		opacity: 0.5;
	}

	.ba__side--after {
		background: linear-gradient(
			175deg,
			color-mix(in srgb, var(--aurea-sage) 22%, var(--aurea-ivory)),
			color-mix(in srgb, var(--aurea-sage) 8%, var(--aurea-ivory)) 80%
		);
	}

	.ba__divider {
		width: 1px;
		background: var(--aurea-border);
	}

	.ba__label {
		position: relative;
		z-index: 1;
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--aurea-muted);
		opacity: 0.7;
	}

	/* ── Body ── */
	.ba__body {
		padding: 1.35rem;
	}

	.ba__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
		margin-bottom: 0.65rem;
	}

	.ba__area {
		font-family: var(--aurea-font-heading);
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--aurea-charcoal);
	}

	.ba__treatment {
		display: inline-flex;
		padding: 0.22rem 0.55rem;
		border: 1px solid var(--aurea-border);
		border-radius: 999px;
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--aurea-muted);
	}

	.ba__body > p {
		font-size: 0.88rem;
		line-height: 1.55;
		color: var(--aurea-muted);
	}

	/* ── CTA & disclaimer ── */
	.ba__cta {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		margin-top: 2.5rem;
		text-align: center;
	}

	.ba__cta-link {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--aurea-charcoal);
	}

	.ba__cta-link:hover {
		color: var(--aurea-champagne);
	}

	.ba__disclaimer {
		margin-top: 1.75rem;
		font-size: 0.82rem;
		font-style: italic;
		color: var(--aurea-muted);
		opacity: 0.75;
		text-align: center;
	}

	@media (max-width: 900px) {
		.ba__grid {
			grid-template-columns: 1fr;
			max-width: 480px;
		}
	}
</style>
