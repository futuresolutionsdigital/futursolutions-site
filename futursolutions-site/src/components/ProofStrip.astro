---
const methods = [
	{
		step: '01',
		icon: 'strategy',
		title: 'Strategy before design',
		text: 'We clarify the offer, audience, service structure, and conversion path before a pixel is designed.',
	},
	{
		step: '02',
		icon: 'target',
		title: 'Conversion-first build',
		text: 'Each section has a job: clarify, build trust, answer objections, or move the visitor forward.',
	},
	{
		step: '03',
		icon: 'cms',
		title: 'Editable where it matters',
		text: 'Key content areas stay manageable, scalable, and ready for the pages and resources you add next.',
	},
	{
		step: '04',
		icon: 'link',
		title: 'Systems-ready launch',
		text: 'Forms, tracking, CRM, and follow-up paths are wired before launch, so leads do not disappear after the form.',
	},
];

const processSteps = ['Diagnose', 'Clarify', 'Design', 'Connect', 'Launch', 'Improve'];

const stack = ['Astro', 'TypeScript', 'Vercel', 'Sanity', 'GoHighLevel'];
---

<section class="section-tight proof-strip" aria-labelledby="proof-strip-heading">
	<div class="site-container site-container--wide">
		<div class="proof-strip__statement">
			<p class="eyebrow">The build method</p>
			<h2 id="proof-strip-heading" class="proof-strip__headline">
				<span class="proof-strip__headline-line">No theme reskins.</span>
				<span class="proof-strip__headline-line">No black-box&nbsp;handoff.</span>
				<span class="proof-strip__headline-line">No dead launch.</span>
				<span class="proof-strip__headline-soft">A FutureSolutions site is planned around your offer, your visitor journey, and the system behind the form, so launch day is not where the strategy ends.</span>
			</h2>
			<p class="proof-strip__callout">
				<span class="proof-strip__callout-mark" aria-hidden="true">!</span>
				A pretty website is not enough if the offer is unclear, the CTA is buried, or the lead goes nowhere after submitting a form.
			</p>
		</div>

		<ol class="proof-strip__grid" aria-label="How we build">
			{
				methods.map((p) => (
					<li class="proof-card">
						<div class="proof-card__head">
							<div class="proof-card__icon" aria-hidden="true">
								{p.icon === 'strategy' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
										<circle cx="12" cy="12" r="9" />
										<path d="M15.5 8.5l-2 5-5 2 2-5z" />
									</svg>
								)}
								{p.icon === 'target' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
										<circle cx="12" cy="12" r="9" />
										<circle cx="12" cy="12" r="5" />
										<circle cx="12" cy="12" r="1.5" fill="currentColor" />
									</svg>
								)}
								{p.icon === 'cms' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
										<ellipse cx="12" cy="6" rx="7" ry="3" />
										<path d="M5 6v6c0 1.66 3.13 3 7 3s7-1.34 7-3V6M5 12v6c0 1.66 3.13 3 7 3s7-1.34 7-3v-6" />
									</svg>
								)}
								{p.icon === 'link' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
										<path d="M10 14a4 4 0 0 0 5.66 0l3-3a4 4 0 0 0-5.66-5.66l-1.5 1.5" />
										<path d="M14 10a4 4 0 0 0-5.66 0l-3 3a4 4 0 0 0 5.66 5.66l1.5-1.5" />
									</svg>
								)}
							</div>
							<span class="proof-card__step">Method {p.step}</span>
						</div>
						<h3 class="proof-card__title">{p.title}</h3>
						<p class="proof-card__text">{p.text}</p>
					</li>
				))
			}
		</ol>

		<div class="proof-process" aria-label="Our end-to-end delivery flow">
			<p class="proof-process__label">The delivery flow</p>
			<ol class="proof-process__track">
				{processSteps.map((s, i) => (
					<>
						<li class="proof-process__step">{s}</li>
						{i < processSteps.length - 1 && (
							<li class="proof-process__arrow" aria-hidden="true">&rarr;</li>
						)}
					</>
				))}
			</ol>
		</div>

		<p class="proof-strip__closing">Built to launch cleanly, stay editable, and improve after traffic starts.</p>

		<div class="proof-strip__stack" aria-label="Technology and tooling we build with">
			<span class="proof-strip__stack-label">Built with</span>
			<ul class="proof-strip__stack-list">
				{stack.map((s) => <li>{s}</li>)}
			</ul>
		</div>
	</div>
</section>

<style>
	.proof-strip {
		position: relative;
		background:
			radial-gradient(ellipse 60% 70% at 90% 110%, color-mix(in srgb, var(--lane-audit) 18%, transparent), transparent 65%),
			linear-gradient(180deg, var(--lane-custom-ink) 0%, var(--lane-custom) 100%);
		color: var(--color-white);
	}

	.proof-strip .eyebrow {
		color: color-mix(in srgb, var(--lane-audit-tint) 90%, var(--color-white));
	}

	.proof-strip__statement {
		max-width: 64ch;
		margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
	}

	.proof-strip__callout {
		display: flex;
		align-items: flex-start;
		gap: 0.7rem;
		max-width: 60ch;
		margin: 1.5rem 0 0;
		padding: 0.95rem 1.15rem;
		border: 1px solid color-mix(in srgb, var(--lane-audit) 40%, transparent);
		border-left-width: 3px;
		border-radius: var(--radius-sm);
		background: color-mix(in srgb, var(--lane-audit) 12%, transparent);
		color: color-mix(in srgb, var(--color-white) 92%, transparent);
		font-size: 0.98rem;
		font-weight: 500;
		line-height: 1.5;
	}

	.proof-strip__callout-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 1.35rem;
		height: 1.35rem;
		margin-top: 0.05rem;
		border-radius: 999px;
		background: var(--lane-audit);
		color: var(--lane-custom-ink);
		font-size: 0.85rem;
		font-weight: 800;
	}

	.proof-strip__headline {
		margin: 0;
		color: var(--color-white);
		font-size: clamp(1.85rem, 1.4rem + 1.85vw, 2.6rem);
		font-weight: 700;
		letter-spacing: -0.035em;
		line-height: 1.18;
	}

	.proof-strip__headline-line {
		display: block;
	}

	.proof-strip__headline-soft {
		display: block;
		margin-top: 1rem;
		color: color-mix(in srgb, var(--color-white) 94%, transparent);
		font-size: clamp(1.05rem, 0.92rem + 0.55vw, 1.18rem);
		font-weight: 500;
		letter-spacing: -0.018em;
		line-height: 1.5;
	}

	.proof-strip__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.25rem;
		margin: 0 0 clamp(3rem, 5vw, 4rem) 0;
		padding: 0;
		list-style: none;
	}

	.proof-card {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		padding: 1.5rem;
		border: 1px solid color-mix(in srgb, var(--color-white) 18%, transparent);
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--color-white) 8%, transparent);
		backdrop-filter: blur(2px);
		transition: border-color var(--transition-base), background-color var(--transition-base), transform 320ms var(--ease-out-quart);
	}

	.proof-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--lane-audit) 60%, transparent);
		background: color-mix(in srgb, var(--color-white) 14%, transparent);
	}

	.proof-card__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 0.55rem;
	}

	.proof-card__step {
		color: color-mix(in srgb, var(--lane-audit-tint) 84%, var(--color-white));
		font-size: 0.68rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.proof-card__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		border: 1px solid color-mix(in srgb, var(--lane-audit) 38%, transparent);
		border-radius: 10px;
		background: color-mix(in srgb, var(--lane-audit) 14%, transparent);
		color: var(--lane-audit-tint);
	}

	.proof-card__icon svg {
		width: 1.15rem;
		height: 1.15rem;
	}

	.proof-card__title {
		margin: 0;
		color: var(--color-white);
		font-size: 1.05rem;
		font-weight: 650;
		letter-spacing: -0.02em;
	}

	.proof-card__text {
		margin: 0;
		color: color-mix(in srgb, var(--color-white) 92%, transparent);
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.proof-process {
		margin: 0 0 clamp(2.5rem, 4vw, 3.5rem) 0;
	}

	.proof-process__label {
		margin: 0 0 0.9rem;
		color: color-mix(in srgb, var(--lane-audit-tint) 84%, var(--color-white));
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.proof-process__track {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 0.4rem;
		margin: 0;
		padding: 0;
		list-style: none;
		counter-reset: process;
	}

	.proof-process__step {
		counter-increment: process;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.95rem;
		border: 1px solid color-mix(in srgb, var(--color-white) 18%, transparent);
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-white) 7%, transparent);
		color: var(--color-white);
		font-size: 0.85rem;
		font-weight: 650;
		letter-spacing: -0.005em;
		white-space: nowrap;
	}

	.proof-process__step::before {
		content: counter(process, decimal-leading-zero);
		color: color-mix(in srgb, var(--lane-audit-tint) 85%, var(--color-white));
		font-size: 0.7rem;
		font-weight: 800;
		font-variant-numeric: tabular-nums;
	}

	.proof-process__arrow {
		color: color-mix(in srgb, var(--color-white) 45%, transparent);
		font-size: 0.9rem;
		font-weight: 700;
	}

	.proof-strip__closing {
		max-width: 60ch;
		margin: 0 0 1.5rem;
		color: color-mix(in srgb, var(--color-white) 68%, transparent);
		font-size: 0.95rem;
		font-weight: 500;
		line-height: 1.55;
	}

	.proof-strip__stack {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1.25rem;
		padding-top: 1.5rem;
		border-top: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent);
	}

	.proof-strip__stack-label {
		color: color-mix(in srgb, var(--lane-audit-tint) 84%, var(--color-white));
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.proof-strip__stack-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem 1.25rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.proof-strip__stack-list li {
		color: var(--color-white);
		font-size: 0.92rem;
		font-weight: 600;
		letter-spacing: -0.005em;
	}

	@media (max-width: 980px) {
		.proof-strip__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.proof-strip__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
