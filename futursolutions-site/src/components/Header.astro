---
const currentPath = Astro.url.pathname;
const navItems = [
	{
		label: 'Demos',
		href: '/templates',
		isActive: currentPath === '/templates' || currentPath.startsWith('/templates/'),
	},
	{
		label: 'Solutions',
		href: '/services',
		isActive: currentPath === '/services' || currentPath.startsWith('/services/'),
	},
	// Phase 4 builds /industries/[slug] pages
	{ label: 'Industries', href: '#', isActive: false, isPlaceholder: true },
	// Phase 4 builds /work
	{ label: 'Work', href: '#', isActive: false, isPlaceholder: true },
	{
		label: 'Resources',
		href: '/resources',
		isActive: currentPath === '/resources' || currentPath.startsWith('/resources/'),
	},
	{
		label: 'Audit',
		href: '/audit',
		isActive: currentPath === '/audit' || currentPath.startsWith('/audit'),
	},
];
---

<header class="site-header">
	<div class="site-container site-header__inner">
		<a class="site-header__brand" href="/" aria-label="FutureSolutions home">
			<span>Future</span>
			<span>Solutions</span>
		</a>
		<nav class="site-header__nav" aria-label="Main navigation">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class:list={{ 'is-active': item.isActive, 'is-placeholder': item.isPlaceholder }}
						aria-current={item.isActive ? 'page' : undefined}
						aria-disabled={item.isPlaceholder ? 'true' : undefined}
						title={item.isPlaceholder ? 'Coming soon' : undefined}
					>
						{item.label}
					</a>
				))
			}
		</nav>
		<div class="site-header__actions">
			<a class="site-header__audit-link" href="/audit">Get a Website Audit</a>
			{/* Real CTA target will be a Cal.com (or similar) booking link; placeholder for now */}
			<a class="site-header__cta" href="#" title="Strategy call booking link coming soon">
				Book a Strategy Call
			</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		background: color-mix(in srgb, var(--color-bg) 92%, transparent);
		border-bottom: 1px solid var(--color-border);
		backdrop-filter: blur(16px);
	}

	.site-header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		min-height: 5rem;
	}

	.site-header__brand {
		display: inline-flex;
		align-items: baseline;
		gap: 0.25rem;
		color: var(--color-text);
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: -0.035em;
		white-space: nowrap;
	}

	.site-header__brand span:last-child {
		color: var(--color-accent-dark);
	}

	.site-header__nav {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 1.1rem;
		margin-left: auto;
		color: var(--color-muted);
		font-size: 0.9rem;
		font-weight: 600;
	}

	.site-header__nav a {
		position: relative;
		padding-block: 0.35rem;
		white-space: nowrap;
	}

	.site-header__nav a:hover,
	.site-header__nav a.is-active {
		color: var(--color-text);
	}

	.site-header__nav a.is-placeholder {
		opacity: 0.55;
		cursor: not-allowed;
	}

	.site-header__nav a.is-placeholder:hover {
		color: var(--color-muted);
	}

	.site-header__nav a.is-active::after {
		position: absolute;
		right: 0;
		bottom: 0;
		left: 0;
		height: 2px;
		border-radius: 999px;
		background: var(--color-accent);
		content: '';
	}

	.site-header__actions {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.site-header__audit-link {
		display: inline-flex;
		align-items: center;
		color: var(--color-muted);
		font-size: 0.85rem;
		font-weight: 700;
		text-decoration: underline;
		text-decoration-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
		text-underline-offset: 0.3em;
		white-space: nowrap;
	}

	.site-header__audit-link:hover {
		color: var(--color-accent-dark);
		text-decoration-color: var(--color-accent);
	}

	.site-header__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.4rem;
		padding: 0.65rem 0.95rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 34%, var(--color-border));
		border-radius: var(--radius-sm);
		background: var(--color-white);
		color: var(--color-text);
		font-size: 0.875rem;
		font-weight: 700;
		line-height: 1;
		white-space: nowrap;
	}

	.site-header__cta:hover {
		border-color: var(--color-accent);
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
	}

	@media (max-width: 1140px) {
		.site-header__inner {
			gap: 1rem;
		}

		.site-header__nav {
			gap: 0.85rem;
			font-size: 0.84rem;
		}

		.site-header__audit-link {
			font-size: 0.8rem;
		}
	}

	@media (max-width: 980px) {
		.site-header__audit-link {
			display: none;
		}
	}

	@media (max-width: 860px) {
		.site-header__nav {
			display: none;
		}

		.site-header__inner {
			min-height: 4.5rem;
		}
	}

	@media (max-width: 440px) {
		.site-header__cta {
			padding-inline: 0.75rem;
			font-size: 0.8125rem;
		}
	}

	@media (max-width: 380px) {
		.site-header__cta {
			display: none;
		}
	}
</style>
