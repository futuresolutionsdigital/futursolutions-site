---
const currentPath = Astro.url.pathname;

type NavChild = { label: string; href: string; description?: string };
type NavItem = { label: string; href: string; children?: NavChild[] };

// Website Foundations is the core sell, so it gets a direct top-level link
// (to the live, clickable Foundation library) rather than being buried. The
// remaining depth lives in dropdowns so the offer ladder and industry pages
// are discoverable without crowding the bar.
const navItems: NavItem[] = [
	{ label: 'Website Foundations', href: '/templates' },
	{
		label: 'Solutions',
		href: '/services',
		children: [
			{
				label: 'Website Foundations',
				href: '/services/template-setup',
				description: 'Premium customized website foundations built from proven frameworks.',
			},
			{
				label: 'Signature Custom Websites',
				href: '/services/custom-healthcare-websites',
				description: 'Custom strategy, architecture, design, and build for more complex brands.',
			},
			{
				label: 'Growth Systems',
				href: '/services/growth-systems',
				description: 'CRM, booking, follow-up, reporting, and lead routing.',
			},
			{
				label: 'Website Management',
				href: '/services/ongoing-optimization',
				description: 'Ongoing updates, optimization, reporting, and system support.',
			},
			{
				label: 'Local Visibility',
				href: '/services/local-visibility',
				description: 'Service structure, metadata, and content for local discovery.',
			},
			{ label: 'All Solutions', href: '/services' },
		],
	},
	{
		label: 'Industries',
		href: '/industries',
		children: [
			{ label: 'Health & Wellness', href: '/industries/wellness-functional-medicine' },
			{ label: 'Med Spas', href: '/industries/med-spas' },
			{ label: 'Hormone / TRT Clinics', href: '/industries/hormone-trt-clinics' },
			{ label: 'Solo Practices', href: '/industries/solo-practices' },
			{ label: 'Professional Associations', href: '/industries/healthcare-associations' },
			{ label: 'All Industries', href: '/industries' },
		],
	},
	{
		label: 'Resources',
		href: '/resources',
		children: [
			{ label: 'All Resources', href: '/resources' },
			{ label: 'SEO & Local Visibility', href: '/services/local-visibility' },
			{ label: 'Free Website & Lead Flow Snapshot', href: '/audit' },
		],
	},
	{ label: 'About', href: '/about' },
];

const isItemActive = (item: NavItem): boolean => {
	const hrefs = [item.href, ...(item.children?.map((c) => c.href) ?? [])];
	return hrefs.some((h) => currentPath === h || currentPath.startsWith(`${h}/`));
};
---

<header class="site-header" data-header>
	<div class="site-container site-header__inner">
		<a class="site-header__brand" href="/" aria-label="FutureSolutions home">
			<span class="site-header__mark" aria-hidden="true">
				<span class="site-header__mark-shape"></span>
			</span>
			<span class="site-header__wordmark">FutureSolutions</span>
		</a>
		<nav class="site-header__nav" aria-label="Main navigation">
			{
				navItems.map((item) =>
					item.children ? (
						<div class="site-header__navitem" data-dropdown>
							<button
								type="button"
								class:list={['site-header__navlink site-header__navtrigger', { 'is-active': isItemActive(item) }]}
								aria-expanded="false"
								aria-haspopup="true"
								data-dropdown-trigger
							>
								{item.label}
								<span class="site-header__caret" aria-hidden="true" />
							</button>
							<div class="site-header__dropdown" data-dropdown-panel>
								<div class="site-header__dropdown-inner">
									{item.children.map((child) => (
										<a href={child.href} class="site-header__dropdown-link">
											<span class="site-header__dropdown-title">{child.label}</span>
											{child.description && (
												<span class="site-header__dropdown-desc">{child.description}</span>
											)}
										</a>
									))}
								</div>
							</div>
						</div>
					) : (
						<a
							href={item.href}
							class:list={['site-header__navlink', { 'is-active': isItemActive(item) }]}
							aria-current={isItemActive(item) ? 'page' : undefined}
						>
							{item.label}
						</a>
					)
				)
			}
		</nav>
		<div class="site-header__actions">
			<a class="site-header__cta" href="/audit">
				Get My Free Snapshot
				<span class="site-header__cta-arrow" aria-hidden="true">&rarr;</span>
			</a>
		</div>
		<button
			class="site-header__burger"
			type="button"
			aria-expanded="false"
			aria-controls="mobile-nav"
			aria-label="Toggle navigation"
			data-burger
		>
			<span class="site-header__burger-bar"></span>
			<span class="site-header__burger-bar"></span>
			<span class="site-header__burger-bar"></span>
		</button>
	</div>

	<div class="site-header__mobile-panel" id="mobile-nav" data-mobile-panel>
		<nav class="site-header__mobile-nav" aria-label="Mobile navigation">
			{
				navItems.map((item) =>
					item.children ? (
						<div class="site-header__mobile-group" data-accordion>
							<button
								type="button"
								class="site-header__mobile-acc-trigger"
								aria-expanded="false"
								data-accordion-trigger
							>
								{item.label}
								<span class="site-header__caret" aria-hidden="true" />
							</button>
							<div class="site-header__mobile-acc-panel" data-accordion-panel>
								{item.children.map((child) => (
									<a href={child.href} class="site-header__mobile-sublink">
										{child.label}
									</a>
								))}
							</div>
						</div>
					) : (
						<a
							href={item.href}
							class:list={{ 'is-active': isItemActive(item) }}
							aria-current={isItemActive(item) ? 'page' : undefined}
						>
							{item.label}
						</a>
					)
				)
			}
		</nav>
		<div class="site-header__mobile-actions">
			<a class="button button-secondary site-header__mobile-btn" href="/templates">Explore Website Foundations</a>
			<a class="button button-primary site-header__mobile-btn" href="/audit">Get My Free Snapshot</a>
		</div>
	</div>
</header>

<script>
	const header = document.querySelector('[data-header]');
	const burger = document.querySelector('[data-burger]');
	const panel = document.querySelector('[data-mobile-panel]');

	if (burger && panel && header) {
		burger.addEventListener('click', () => {
			const open = header.classList.toggle('is-mobile-open');
			burger.setAttribute('aria-expanded', String(open));
		});
		// Navigating via a real link closes the mobile panel; accordion toggle
		// buttons are <button>s, so they are intentionally excluded here.
		panel.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => {
				header.classList.remove('is-mobile-open');
				burger.setAttribute('aria-expanded', 'false');
			});
		});
	}

	// Desktop dropdowns: hover is handled in CSS; click + keyboard drive
	// aria-expanded for accessibility.
	const dropdowns = Array.from(document.querySelectorAll('[data-dropdown]'));
	const closeAllDropdowns = () => {
		dropdowns.forEach((dd) => {
			const trigger = dd.querySelector('[data-dropdown-trigger]');
			if (trigger) trigger.setAttribute('aria-expanded', 'false');
		});
	};
	dropdowns.forEach((dd) => {
		const trigger = dd.querySelector('[data-dropdown-trigger]');
		if (!trigger) return;
		trigger.addEventListener('click', () => {
			const isOpen = trigger.getAttribute('aria-expanded') === 'true';
			closeAllDropdowns();
			trigger.setAttribute('aria-expanded', String(!isOpen));
		});
	});
	document.addEventListener('click', (event) => {
		const target = event.target;
		if (target instanceof Element && !target.closest('[data-dropdown]')) {
			closeAllDropdowns();
		}
	});
	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') closeAllDropdowns();
	});

	// Mobile accordions.
	document.querySelectorAll('[data-accordion]').forEach((acc) => {
		const trigger = acc.querySelector('[data-accordion-trigger]');
		if (!trigger) return;
		trigger.addEventListener('click', () => {
			const isOpen = acc.classList.toggle('is-open');
			trigger.setAttribute('aria-expanded', String(isOpen));
		});
	});
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		background: color-mix(in srgb, var(--color-bg) 88%, transparent);
		border-bottom: 1px solid var(--color-border-soft);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.site-header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		min-height: 4.5rem;
	}

	.site-header__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		color: var(--color-text);
		font-size: 1.02rem;
		font-weight: 700;
		letter-spacing: -0.04em;
		white-space: nowrap;
		transition: opacity var(--transition-base);
	}

	.site-header__brand:hover {
		opacity: 0.78;
	}

	.site-header__mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.65rem;
		height: 1.65rem;
		border-radius: 7px;
		background: var(--color-text);
		flex-shrink: 0;
		transition: transform 320ms var(--ease-out-quart);
	}

	.site-header__brand:hover .site-header__mark {
		transform: rotate(-90deg);
	}

	.site-header__mark-shape {
		display: block;
		width: 0.55rem;
		height: 0.55rem;
		background: var(--color-white);
		transform: rotate(45deg);
	}

	.site-header__wordmark {
		font-feature-settings: "ss01", "cv11";
	}

	.site-header__nav {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 1.35rem;
		margin-left: auto;
		color: var(--color-muted);
		font-size: 0.9rem;
		font-weight: 500;
		letter-spacing: -0.005em;
	}

	.site-header__navitem {
		position: relative;
		display: inline-flex;
	}

	.site-header__navlink {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 0.32rem;
		padding-block: 0.35rem;
		color: var(--color-muted);
		font-family: inherit;
		font-size: inherit;
		font-weight: inherit;
		letter-spacing: inherit;
		white-space: nowrap;
		transition: color var(--transition-base);
	}

	.site-header__navtrigger {
		border: none;
		background: none;
		cursor: pointer;
	}

	.site-header__navlink:hover,
	.site-header__navlink.is-active {
		color: var(--color-text);
	}

	.site-header__navlink.is-active::after {
		position: absolute;
		right: 0;
		bottom: -2px;
		left: 0;
		height: 2px;
		border-radius: 999px;
		background: var(--color-text);
		content: '';
	}

	.site-header__caret {
		display: inline-block;
		width: 0.4rem;
		height: 0.4rem;
		border-right: 1.5px solid currentColor;
		border-bottom: 1.5px solid currentColor;
		transform: translateY(-1px) rotate(45deg);
		opacity: 0.65;
		transition: transform 200ms var(--ease-out-quart);
	}

	/* ═══ Desktop dropdown ═══ */
	.site-header__dropdown {
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%);
		padding-top: 0.55rem;
		min-width: 19rem;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition: opacity 180ms var(--ease-out-quart);
		z-index: 20;
	}

	.site-header__dropdown-inner {
		display: grid;
		gap: 0.1rem;
		padding: 0.5rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: 0 14px 36px rgba(15, 23, 42, 0.13), 0 2px 8px rgba(15, 23, 42, 0.06);
		transform: translateY(-6px);
		transition: transform 180ms var(--ease-out-quart);
	}

	.site-header__navitem:hover .site-header__dropdown,
	.site-header__navitem:focus-within .site-header__dropdown,
	.site-header__navtrigger[aria-expanded='true'] + .site-header__dropdown {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
	}

	.site-header__navitem:hover .site-header__dropdown-inner,
	.site-header__navitem:focus-within .site-header__dropdown-inner,
	.site-header__navtrigger[aria-expanded='true'] + .site-header__dropdown .site-header__dropdown-inner {
		transform: translateY(0);
	}

	.site-header__navtrigger[aria-expanded='true'] .site-header__caret {
		transform: translateY(1px) rotate(-135deg);
	}

	.site-header__dropdown-link {
		display: grid;
		gap: 0.12rem;
		padding: 0.6rem 0.7rem;
		border-radius: var(--radius-sm);
		transition: background var(--transition-base);
	}

	.site-header__dropdown-link:hover {
		background: color-mix(in srgb, var(--color-text) 5%, transparent);
	}

	.site-header__dropdown-title {
		color: var(--color-text);
		font-size: 0.9rem;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.site-header__dropdown-desc {
		color: var(--color-muted);
		font-size: 0.8rem;
		line-height: 1.4;
	}

	.site-header__actions {
		display: flex;
		align-items: center;
		gap: 1.1rem;
	}

	.site-header__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		min-height: 2.45rem;
		padding: 0.6rem 1rem;
		border-radius: var(--radius-sm);
		background: var(--color-text);
		color: var(--color-white);
		font-size: 0.875rem;
		font-weight: 600;
		line-height: 1;
		white-space: nowrap;
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.08) inset, 0 6px 18px rgba(15, 23, 42, 0.18);
		transition: transform 220ms var(--ease-out-quart),
			background-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.site-header__cta:hover {
		background: var(--color-ink);
		transform: translateY(-1px);
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.1) inset, 0 10px 24px rgba(15, 23, 42, 0.24);
	}

	.site-header__cta-arrow {
		display: inline-block;
		font-size: 0.95em;
		font-weight: 500;
		transform: translateY(-0.5px);
		transition: transform 220ms var(--ease-out-quart);
	}

	.site-header__cta:hover .site-header__cta-arrow {
		transform: translate(2px, -0.5px);
	}

	/* ═══ Hamburger button ═══ */
	.site-header__burger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 4px;
		width: 2.25rem;
		height: 2.25rem;
		padding: 0.4rem;
		border: none;
		border-radius: var(--radius-sm);
		background: transparent;
		cursor: pointer;
		-webkit-tap-highlight-color: transparent;
	}

	.site-header__burger-bar {
		display: block;
		width: 100%;
		height: 2px;
		border-radius: 2px;
		background: var(--color-text);
		transition: transform 240ms ease, opacity 200ms ease;
	}

	.is-mobile-open .site-header__burger-bar:nth-child(1) {
		transform: translateY(6px) rotate(45deg);
	}
	.is-mobile-open .site-header__burger-bar:nth-child(2) {
		opacity: 0;
	}
	.is-mobile-open .site-header__burger-bar:nth-child(3) {
		transform: translateY(-6px) rotate(-45deg);
	}

	/* ═══ Mobile panel ═══ */
	.site-header__mobile-panel {
		display: none;
		flex-direction: column;
		gap: 1.25rem;
		padding: 1.25rem var(--container-pad, 1.25rem) 1.75rem;
		border-top: 1px solid var(--color-border-soft);
		background: color-mix(in srgb, var(--color-bg) 96%, transparent);
		max-height: calc(100vh - 4.5rem);
		overflow-y: auto;
	}

	.is-mobile-open .site-header__mobile-panel {
		display: flex;
	}

	.site-header__mobile-nav {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.site-header__mobile-nav > a {
		display: block;
		padding: 0.65rem 0.75rem;
		border-radius: var(--radius-sm);
		color: var(--color-text);
		font-size: 1rem;
		font-weight: 600;
		transition: background var(--transition-base);
	}

	.site-header__mobile-nav > a:hover,
	.site-header__mobile-nav > a.is-active {
		background: color-mix(in srgb, var(--color-text) 5%, transparent);
	}

	.site-header__mobile-nav > a.is-active {
		font-weight: 700;
	}

	.site-header__mobile-acc-trigger {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		padding: 0.65rem 0.75rem;
		border: none;
		border-radius: var(--radius-sm);
		background: transparent;
		color: var(--color-text);
		font-family: inherit;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: background var(--transition-base);
	}

	.site-header__mobile-acc-trigger:hover {
		background: color-mix(in srgb, var(--color-text) 5%, transparent);
	}

	.site-header__mobile-group.is-open .site-header__mobile-acc-trigger .site-header__caret {
		transform: translateY(1px) rotate(-135deg);
	}

	.site-header__mobile-acc-panel {
		display: none;
		flex-direction: column;
		padding: 0.1rem 0 0.4rem 0.5rem;
	}

	.site-header__mobile-group.is-open .site-header__mobile-acc-panel {
		display: flex;
	}

	.site-header__mobile-sublink {
		display: block;
		padding: 0.5rem 0.75rem;
		border-radius: var(--radius-sm);
		color: var(--color-muted);
		font-size: 0.95rem;
		font-weight: 500;
		transition: background var(--transition-base), color var(--transition-base);
	}

	.site-header__mobile-sublink:hover {
		background: color-mix(in srgb, var(--color-text) 5%, transparent);
		color: var(--color-text);
	}

	.site-header__mobile-actions {
		display: grid;
		gap: 0.6rem;
	}

	.site-header__mobile-btn {
		width: 100%;
		justify-content: center;
	}

	@media (max-width: 1140px) {
		.site-header__inner {
			gap: 1rem;
		}

		.site-header__nav {
			gap: 1.05rem;
			font-size: 0.86rem;
		}
	}

	@media (max-width: 920px) {
		.site-header__nav {
			display: none;
		}

		.site-header__actions {
			display: none;
		}

		.site-header__burger {
			display: flex;
		}
	}
</style>
