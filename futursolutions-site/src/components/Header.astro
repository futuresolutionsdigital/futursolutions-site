---
const currentPath = Astro.url.pathname;
// Industries and Work nav entries are intentionally omitted until Phase 4 builds
// /industries/[slug] and /work routes. They will be reintroduced then.
const navItems = [
	{
		label: 'Demos',
		href: '/templates',
		isActive: currentPath === '/templates' || currentPath.startsWith('/templates/'),
	},
	{
		label: 'Solutions',
		href: '/services',
		isActive: currentPath === '/services' || currentPath.startsWith('/services/'),
	},
	{
		label: 'Resources',
		href: '/resources',
		isActive: currentPath === '/resources' || currentPath.startsWith('/resources/'),
	},
	{
		label: 'Audit',
		href: '/audit',
		isActive: currentPath === '/audit' || currentPath.startsWith('/audit'),
	},
];
---

<header class="site-header">
	<div class="site-container site-header__inner">
		<a class="site-header__brand" href="/" aria-label="FutureSolutions home">
			<span class="site-header__mark" aria-hidden="true">
				<span class="site-header__mark-shape"></span>
			</span>
			<span class="site-header__wordmark">FutureSolutions</span>
		</a>
		<nav class="site-header__nav" aria-label="Main navigation">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class:list={{ 'is-active': item.isActive }}
						aria-current={item.isActive ? 'page' : undefined}
					>
						{item.label}
					</a>
				))
			}
		</nav>
		<div class="site-header__actions">
			<a class="site-header__audit-link" href="/templates">Explore Live Demos</a>
			<a class="site-header__cta" href="/audit">
				Get a Website Audit
				<span class="site-header__cta-arrow" aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		background: color-mix(in srgb, var(--color-bg) 88%, transparent);
		border-bottom: 1px solid var(--color-border-soft);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	.site-header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		min-height: 4.5rem;
	}

	.site-header__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		color: var(--color-text);
		font-size: 1.02rem;
		font-weight: 700;
		letter-spacing: -0.04em;
		white-space: nowrap;
		transition: opacity var(--transition-base);
	}

	.site-header__brand:hover {
		opacity: 0.78;
	}

	.site-header__mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.65rem;
		height: 1.65rem;
		border-radius: 7px;
		background: var(--color-text);
		flex-shrink: 0;
		transition: transform 320ms var(--ease-out-quart);
	}

	.site-header__brand:hover .site-header__mark {
		transform: rotate(-90deg);
	}

	.site-header__mark-shape {
		display: block;
		width: 0.55rem;
		height: 0.55rem;
		background: var(--color-white);
		transform: rotate(45deg);
	}

	.site-header__wordmark {
		font-feature-settings: "ss01", "cv11";
	}

	.site-header__nav {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 1.5rem;
		margin-left: auto;
		color: var(--color-muted);
		font-size: 0.9rem;
		font-weight: 500;
		letter-spacing: -0.005em;
	}

	.site-header__nav a {
		position: relative;
		padding-block: 0.35rem;
		white-space: nowrap;
		transition: color var(--transition-base);
	}

	.site-header__nav a:hover,
	.site-header__nav a.is-active {
		color: var(--color-text);
	}

	.site-header__nav a.is-active::after {
		position: absolute;
		right: 0;
		bottom: -2px;
		left: 0;
		height: 2px;
		border-radius: 999px;
		background: var(--color-text);
		content: '';
	}

	.site-header__actions {
		display: flex;
		align-items: center;
		gap: 1.1rem;
	}

	.site-header__audit-link {
		display: inline-flex;
		align-items: center;
		color: var(--color-muted);
		font-size: 0.86rem;
		font-weight: 500;
		white-space: nowrap;
		transition: color var(--transition-base);
	}

	.site-header__audit-link:hover {
		color: var(--color-text);
	}

	.site-header__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		min-height: 2.45rem;
		padding: 0.6rem 1rem;
		border-radius: var(--radius-sm);
		background: var(--color-text);
		color: var(--color-white);
		font-size: 0.875rem;
		font-weight: 600;
		line-height: 1;
		white-space: nowrap;
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.08) inset, 0 6px 18px rgba(15, 23, 42, 0.18);
		transition: transform 220ms var(--ease-out-quart),
			background-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.site-header__cta:hover {
		background: var(--color-ink);
		transform: translateY(-1px);
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.1) inset, 0 10px 24px rgba(15, 23, 42, 0.24);
	}

	.site-header__cta-arrow {
		display: inline-block;
		font-size: 0.95em;
		font-weight: 500;
		transform: translateY(-0.5px);
		transition: transform 220ms var(--ease-out-quart);
	}

	.site-header__cta:hover .site-header__cta-arrow {
		transform: translate(2px, -0.5px);
	}

	@media (max-width: 1140px) {
		.site-header__inner {
			gap: 1rem;
		}

		.site-header__nav {
			gap: 1.15rem;
			font-size: 0.86rem;
		}

		.site-header__audit-link {
			font-size: 0.82rem;
		}
	}

	@media (max-width: 980px) {
		.site-header__audit-link {
			display: none;
		}
	}

	@media (max-width: 860px) {
		.site-header__nav {
			display: none;
		}
	}

	@media (max-width: 440px) {
		.site-header__cta {
			padding-inline: 0.85rem;
			font-size: 0.8125rem;
		}

		.site-header__cta-arrow {
			display: none;
		}
	}

	@media (max-width: 380px) {
		.site-header__cta {
			display: none;
		}
	}
</style>
