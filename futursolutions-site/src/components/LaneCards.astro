---
const featuredLanes = [
	{
		number: '01',
		title: 'Industry Website Foundations',
		summary:
			'Battle-tested website systems for specific practice types. Branded, configured, and shipped in days — not months.',
		bullets: [
			'Solo & private practice, med spa, hormone/TRT, wellness clinic, association',
			'Page architecture, content, SEO, and forms already mapped',
			'Yours to grow into — switch to Custom whenever you outgrow it',
		],
		cta: { label: 'Explore the demo library', href: '/templates' },
	},
	{
		number: '02',
		title: 'Signature Custom Websites',
		summary:
			'A bespoke website system designed around your brand, services, and conversion goals — built like a flagship.',
		bullets: [
			'Custom design system, photography direction, and content strategy',
			'Deeper page architecture and content for multi-location or multi-service practices',
			'Integrated with your booking, EMR/EHR, and growth systems',
		],
		cta: { label: 'See custom build details', href: '/services/custom-healthcare-websites' },
	},
];

const systemLanes = [
	{
		number: '03',
		title: 'Website + Growth Systems',
		summary:
			'The lead capture, booking, and follow-up machinery that turns visits into consultations.',
		bullets: [
			'Forms, booking flows, and consult intake',
			'CRM, pipelines, and lead routing',
			'Email and SMS follow-up sequences',
		],
	},
	{
		number: '04',
		title: 'Practice Operations Setup',
		summary:
			'GoHighLevel-powered backend wired into your website — calendars, automations, pipelines, and reporting.',
		bullets: [
			'Calendars, automations, and reminders',
			'Patient/client journey workflows',
			'Reporting dashboards and KPIs',
		],
	},
	{
		number: '05',
		title: 'Care and Optimization',
		summary:
			'Ongoing partnership to keep the site fast, the content current, and the funnel converting.',
		bullets: [
			'Monthly content, SEO, and conversion refinements',
			'Performance, accessibility, and uptime monitoring',
			'New pages, campaigns, and feature work as you grow',
		],
	},
];
---

<section class="section lanes" aria-labelledby="lanes-heading">
	<div class="site-container site-container--wide">
		<div class="lanes__intro">
			<p class="eyebrow">What we do</p>
			<h2 id="lanes-heading" class="display-lg">
				Five lanes — one studio behind every one of them.
			</h2>
			<p class="lead">
				A complete digital foundation for a modern healthcare or service business — from the website itself, to the lead and booking systems behind it, to the team keeping it sharp month after month.
			</p>
		</div>

		<div class="lanes__featured">
			{
				featuredLanes.map((lane) => (
					<article class="lane-card lane-card--featured">
						<header class="lane-card__header">
							<span class="lane-card__number">{lane.number}</span>
							<span class="lane-card__tag">Website product</span>
						</header>
						<h3 class="lane-card__title">{lane.title}</h3>
						<p class="lane-card__summary">{lane.summary}</p>
						<ul class="lane-card__bullets">
							{lane.bullets.map((b) => (
								<li>
									<span class="lane-card__bullet-mark" aria-hidden="true" />
									<span>{b}</span>
								</li>
							))}
						</ul>
						<a class="lane-card__cta" href={lane.cta.href}>
							{lane.cta.label}
							<span aria-hidden="true">&rarr;</span>
						</a>
					</article>
				))
			}
		</div>

		<div class="lanes__systems">
			{
				systemLanes.map((lane) => (
					<article class="lane-card lane-card--system">
						<header class="lane-card__header">
							<span class="lane-card__number">{lane.number}</span>
							<span class="lane-card__tag lane-card__tag--system">System</span>
						</header>
						<h3 class="lane-card__title lane-card__title--system">{lane.title}</h3>
						<p class="lane-card__summary">{lane.summary}</p>
						<ul class="lane-card__bullets">
							{lane.bullets.map((b) => (
								<li>
									<span class="lane-card__bullet-mark" aria-hidden="true" />
									<span>{b}</span>
								</li>
							))}
						</ul>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.lanes {
		background: var(--color-bg);
	}

	.lanes__intro {
		max-width: 760px;
		margin-bottom: clamp(2.5rem, 4.5vw, 3.75rem);
	}

	.lanes__featured {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
		margin-bottom: 1.25rem;
	}

	.lanes__systems {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.lane-card {
		display: flex;
		flex-direction: column;
		padding: clamp(1.5rem, 2.4vw, 1.85rem);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: var(--shadow-card);
		transition: transform 320ms var(--ease-out-quart),
			border-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.lane-card:hover {
		transform: translateY(-3px);
		border-color: color-mix(in srgb, var(--color-text) 18%, var(--color-border));
		box-shadow: var(--shadow-card-hover);
	}

	.lane-card--featured {
		min-height: clamp(20rem, 30vw, 22rem);
	}

	.lane-card__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5rem;
	}

	.lane-card__number {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-xs);
		background: var(--color-white);
		color: var(--color-text);
		font-size: 0.78rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.05em;
	}

	.lane-card__tag {
		padding: 0.32rem 0.6rem;
		border-radius: 999px;
		background: var(--color-text);
		color: var(--color-white);
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.lane-card__tag--system {
		background: var(--color-bg-secondary);
		border: 1px solid var(--color-border);
		color: var(--color-muted);
	}

	.lane-card__title {
		margin-bottom: 0.8rem;
		font-size: clamp(1.4rem, 1.05rem + 0.9vw, 1.7rem);
		font-weight: 700;
		letter-spacing: -0.035em;
		line-height: 1.15;
	}

	.lane-card__title--system {
		font-size: clamp(1.18rem, 1rem + 0.4vw, 1.32rem);
	}

	.lane-card__summary {
		margin: 0 0 1.35rem 0;
		color: var(--color-muted);
		font-size: 0.975rem;
		line-height: 1.6;
	}

	.lane-card--system .lane-card__summary {
		font-size: 0.9375rem;
	}

	.lane-card__bullets {
		display: grid;
		gap: 0.65rem;
		margin: 0 0 1.5rem 0;
		padding: 0;
		list-style: none;
	}

	.lane-card__bullets li {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.7rem;
		align-items: start;
		color: var(--color-text);
		font-size: 0.91rem;
		line-height: 1.5;
	}

	.lane-card__bullet-mark {
		display: inline-block;
		width: 6px;
		height: 6px;
		margin-top: 0.5rem;
		border-radius: 999px;
		background: var(--color-text);
	}

	.lane-card--system .lane-card__bullet-mark {
		background: var(--color-muted);
	}

	.lane-card__cta {
		margin-top: auto;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--color-text);
		font-size: 0.93rem;
		font-weight: 650;
		letter-spacing: -0.005em;
		transition: gap var(--transition-base);
	}

	.lane-card__cta:hover {
		gap: 0.6rem;
	}

	.lane-card__cta span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.lane-card__cta:hover span {
		transform: translateX(2px);
	}

	@media (max-width: 980px) {
		.lanes__featured {
			grid-template-columns: 1fr;
		}

		.lanes__systems {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 620px) {
		.lane-card {
			padding: 1.4rem;
		}
	}
</style>
