---
const contrasts = [
	{
		label: 'First impression',
		before: 'Looks dated or generic — visitors hesitate and bounce',
		after: 'Credible and modern in the first three seconds',
	},
	{
		label: 'What you offer',
		before: 'Buried in dense paragraphs and clinical jargon',
		after: 'Clear services, framed around the patient outcome',
	},
	{
		label: 'The next step',
		before: 'No obvious way to book — visitors hunt for a phone number',
		after: 'One obvious action on every screen, above the fold',
	},
	{
		label: 'Trust & proof',
		before: 'Credentials and reviews hidden or missing',
		after: 'Proof placed exactly where doubt creeps in',
	},
	{
		label: 'After the form',
		before: 'Lands in an inbox — easy to miss, slow to answer',
		after: 'Captured, routed, and followed up automatically',
	},
];

const chips = [
	{ icon: 'eye', label: 'Credible in 3 seconds' },
	{ icon: 'target', label: 'One clear next step' },
	{ icon: 'bolt', label: 'Captured & followed up' },
];
---

<section class="before-after" aria-labelledby="before-after-heading">
	<div class="site-container site-container--wide">
		<header class="before-after__head">
			<div class="before-after__head-main">
				<p class="eyebrow">The transformation</p>
				<h2 id="before-after-heading" class="display-lg">
					The same practice.
					<span class="before-after__head-accent">A completely different result.</span>
				</h2>
			</div>
			<p class="lead before-after__lead">
				Most healthcare sites look fine and quietly leak patients. Drag the handle to see what changes when the site is built as a system — engineered for trust, clarity, and the next step.
			</p>
		</header>

		<div class="ba-slider" data-ba-slider>
			<!-- AFTER (base layer, full) -->
			<div class="ba-frame ba-frame--after" aria-hidden="true">
				<div class="ba-site ba-site--after">
					<div class="ba-site__bar">
						<span class="ba-site__logo"></span>
						<span class="ba-site__nav"><i></i><i></i><i></i><i></i></span>
						<span class="ba-site__btn">Book</span>
					</div>
					<div class="ba-site__hero">
						<div class="ba-site__hero-copy">
							<span class="ba-site__eyebrow"></span>
							<span class="ba-site__h ba-site__h--1"></span>
							<span class="ba-site__h ba-site__h--2"></span>
							<span class="ba-site__sub"></span>
							<span class="ba-site__sub ba-site__sub--short"></span>
							<span class="ba-site__cta">Book a consult →</span>
							<div class="ba-site__trust"><i></i><i></i><i></i></div>
						</div>
						<div class="ba-site__hero-art">
							<span class="ba-site__hero-badge"></span>
						</div>
					</div>
					<div class="ba-site__cards">
						<span class="ba-site__card"></span>
						<span class="ba-site__card"></span>
						<span class="ba-site__card"></span>
					</div>
				</div>
			</div>

			<!-- BEFORE (top layer, clipped) -->
			<div class="ba-frame ba-frame--before" aria-hidden="true">
				<div class="ba-site ba-site--before">
					<div class="ba-site__bar">
						<span class="ba-site__logo"></span>
						<span class="ba-site__nav"><i></i><i></i><i></i><i></i><i></i></span>
						<span class="ba-site__btn ba-site__btn--weak">Contact</span>
					</div>
					<div class="ba-site__hero ba-site__hero--before">
						<div class="ba-site__hero-copy">
							<span class="ba-site__h ba-site__h--1"></span>
							<span class="ba-site__sub"></span>
							<span class="ba-site__sub"></span>
							<span class="ba-site__sub"></span>
							<span class="ba-site__sub ba-site__sub--short"></span>
						</div>
						<div class="ba-site__hero-art ba-site__hero-art--before"></div>
					</div>
					<div class="ba-site__clutter">
						<span></span><span></span><span></span><span></span>
					</div>
				</div>
			</div>

			<!-- Corner labels -->
			<span class="ba-slider__tag ba-slider__tag--before">Before</span>
			<span class="ba-slider__tag ba-slider__tag--after">After</span>

			<!-- Handle -->
			<div class="ba-slider__handle" data-ba-handle>
				<span class="ba-slider__line"></span>
				<span class="ba-slider__grip">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M9 6l-4 6 4 6M15 6l4 6-4 6" />
					</svg>
				</span>
			</div>

			<input
				class="ba-slider__range"
				type="range"
				min="0"
				max="100"
				value="52"
				aria-label="Reveal the before and after website"
				data-ba-range
			/>
		</div>

		<ul class="ba-chips" aria-label="What the rebuilt site delivers">
			{chips.map((chip) => (
				<li class="ba-chip">
					<span class="ba-chip__icon" aria-hidden="true">
						{chip.icon === 'eye' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" /><circle cx="12" cy="12" r="3" /></svg>
						)}
						{chip.icon === 'target' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9" /><circle cx="12" cy="12" r="5" /><circle cx="12" cy="12" r="1.5" /></svg>
						)}
						{chip.icon === 'bolt' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L4 14h7l-1 8 9-12h-7z" /></svg>
						)}
					</span>
					{chip.label}
				</li>
			))}
		</ul>

		<ul class="before-after__compare">
			<li class="ba-row ba-row--head" aria-hidden="true">
				<span class="ba-row__label"></span>
				<span class="ba-row__col ba-row__col--before">Typical healthcare site</span>
				<span class="ba-row__col ba-row__col--after">Built by FutureSolutions</span>
			</li>
			{contrasts.map((row) => (
				<li class="ba-row">
					<span class="ba-row__label">{row.label}</span>
					<span class="ba-row__before">
						<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
							<path d="M4 4l8 8M12 4l-8 8" />
						</svg>
						{row.before}
					</span>
					<span class="ba-row__after">
						<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 8.5l3.5 3.5L13 5" />
						</svg>
						{row.after}
					</span>
				</li>
			))}
		</ul>
	</div>
</section>

<style>
	.before-after {
		padding-block: var(--section-spacing);
		background: var(--color-white);
	}

	.before-after__head {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.7fr);
		align-items: end;
		gap: clamp(1.5rem, 4vw, 3.5rem);
		margin: 0 0 clamp(2.25rem, 4vw, 3rem);
	}

	.before-after__head-accent {
		display: block;
		color: var(--lane-foundation-ink);
	}

	.before-after__lead {
		max-width: 34rem;
		margin: 0;
	}

	/* ---------- Interactive slider ---------- */
	.ba-slider {
		--pos: 52%;
		position: relative;
		aspect-ratio: 16 / 10;
		max-height: 38rem;
		border-radius: var(--radius-lg);
		overflow: hidden;
		border: 1px solid var(--color-border);
		background: var(--color-bg);
		box-shadow: 0 2px 4px rgba(15, 23, 42, 0.05), 0 40px 80px rgba(15, 23, 42, 0.14);
		user-select: none;
		touch-action: pan-y;
	}

	.ba-frame {
		position: absolute;
		inset: 0;
	}

	.ba-frame--before {
		clip-path: inset(0 calc(100% - var(--pos)) 0 0);
	}

	.ba-site {
		display: flex;
		flex-direction: column;
		gap: clamp(0.6rem, 1.5vw, 1rem);
		width: 100%;
		height: 100%;
		padding: clamp(0.9rem, 2.2vw, 1.6rem);
	}

	.ba-site--after {
		background:
			radial-gradient(ellipse 70% 50% at 80% 0%, var(--lane-foundation-tint), transparent 70%),
			var(--color-white);
	}

	.ba-site--before {
		background: #eceae5;
		filter: saturate(0.55);
	}

	/* top bar */
	.ba-site__bar {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding-bottom: clamp(0.6rem, 1.5vw, 1rem);
		border-bottom: 1px solid var(--color-border-soft);
	}

	.ba-site__logo {
		width: 2rem;
		height: 2rem;
		border-radius: 7px;
		background: var(--lane-foundation);
	}

	.ba-site--before .ba-site__logo {
		background: var(--color-muted-soft);
		border-radius: 4px;
	}

	.ba-site__nav {
		display: flex;
		gap: 0.5rem;
	}

	.ba-site__nav i {
		width: 1.7rem;
		height: 0.42rem;
		border-radius: 999px;
		background: var(--color-text);
		opacity: 0.7;
	}

	.ba-site--before .ba-site__nav i {
		background: var(--color-muted-soft);
		width: 1.4rem;
	}

	.ba-site__btn {
		margin-left: auto;
		padding: 0.4rem 0.85rem;
		border-radius: 999px;
		background: var(--lane-foundation);
		color: var(--color-white);
		font-size: clamp(0.55rem, 1.4vw, 0.72rem);
		font-weight: 800;
		letter-spacing: 0.02em;
	}

	.ba-site__btn--weak {
		background: transparent;
		border: 1px solid var(--color-muted-soft);
		color: var(--color-muted);
		font-weight: 600;
	}

	/* hero */
	.ba-site__hero {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: clamp(0.8rem, 2vw, 1.5rem);
		flex: 1;
		min-height: 0;
	}

	.ba-site__hero--before {
		grid-template-columns: 1fr 0.8fr;
	}

	.ba-site__hero-copy {
		display: flex;
		flex-direction: column;
		gap: clamp(0.4rem, 1vw, 0.7rem);
		justify-content: center;
	}

	.ba-site__eyebrow {
		width: 5rem;
		height: 0.5rem;
		border-radius: 999px;
		background: var(--lane-foundation);
	}

	.ba-site__h {
		height: clamp(0.9rem, 2.4vw, 1.5rem);
		border-radius: 6px;
		background: var(--color-text);
	}

	.ba-site__h--1 { width: 90%; }
	.ba-site__h--2 { width: 62%; }

	.ba-site--before .ba-site__h {
		background: var(--color-muted);
		height: clamp(0.7rem, 1.8vw, 1rem);
	}

	.ba-site__sub {
		width: 100%;
		height: 0.5rem;
		border-radius: 999px;
		background: var(--color-border);
	}

	.ba-site__sub--short { width: 55%; }

	.ba-site__cta {
		margin-top: 0.4rem;
		width: fit-content;
		padding: 0.5rem 1rem;
		border-radius: 8px;
		background: var(--color-text);
		color: var(--color-white);
		font-size: clamp(0.55rem, 1.4vw, 0.74rem);
		font-weight: 800;
		box-shadow: 0 10px 22px rgba(15, 23, 42, 0.2);
	}

	.ba-site__trust {
		display: flex;
		gap: 0.4rem;
		margin-top: 0.5rem;
	}

	.ba-site__trust i {
		width: 2.6rem;
		height: 0.6rem;
		border-radius: 999px;
		background: var(--lane-foundation-tint);
		border: 1px solid color-mix(in srgb, var(--lane-foundation) 25%, transparent);
	}

	.ba-site__hero-art {
		position: relative;
		border-radius: 12px;
		background:
			linear-gradient(150deg, color-mix(in srgb, var(--lane-foundation) 35%, var(--color-white)), color-mix(in srgb, var(--lane-growth) 30%, var(--color-white)));
		border: 1px solid color-mix(in srgb, var(--lane-foundation) 20%, var(--color-border));
	}

	.ba-site__hero-art--before {
		background: repeating-linear-gradient(45deg, #d9d6cf, #d9d6cf 6px, #cfccc4 6px, #cfccc4 12px);
		border-color: var(--color-muted-soft);
	}

	.ba-site__hero-badge {
		position: absolute;
		bottom: 0.7rem;
		left: 0.7rem;
		right: 0.7rem;
		height: 1.6rem;
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.85);
		box-shadow: 0 6px 14px rgba(15, 23, 42, 0.12);
	}

	.ba-site__cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: clamp(0.5rem, 1.4vw, 0.9rem);
	}

	.ba-site__card {
		height: clamp(2rem, 5vw, 3.2rem);
		border-radius: 10px;
		background: var(--color-white);
		border: 1px solid var(--color-border-soft);
		box-shadow: 0 6px 16px rgba(15, 23, 42, 0.05);
	}

	.ba-site__clutter {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.5rem;
	}

	.ba-site__clutter span {
		height: clamp(2rem, 5vw, 3.2rem);
		border-radius: 4px;
		background: repeating-linear-gradient(45deg, #ddd9d2, #ddd9d2 5px, #d3cfc7 5px, #d3cfc7 10px);
	}

	/* corner tags */
	.ba-slider__tag {
		position: absolute;
		top: 1rem;
		z-index: 4;
		padding: 0.35rem 0.8rem;
		border-radius: 999px;
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		backdrop-filter: blur(6px);
	}

	.ba-slider__tag--before {
		left: 1rem;
		background: rgba(60, 56, 50, 0.78);
		color: #fff;
	}

	.ba-slider__tag--after {
		right: 1rem;
		background: color-mix(in srgb, var(--lane-foundation) 85%, black);
		color: #fff;
	}

	/* handle */
	.ba-slider__handle {
		position: absolute;
		top: 0;
		bottom: 0;
		left: var(--pos);
		z-index: 5;
		display: flex;
		align-items: center;
		justify-content: center;
		transform: translateX(-50%);
		pointer-events: none;
	}

	.ba-slider__line {
		position: absolute;
		top: 0;
		bottom: 0;
		width: 3px;
		background: var(--color-white);
		box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.12), 0 0 18px rgba(0,0,0,0.25);
	}

	.ba-slider__grip {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 999px;
		background: var(--color-white);
		color: var(--lane-foundation-ink);
		box-shadow: 0 6px 18px rgba(15, 23, 42, 0.28);
	}

	.ba-slider__grip svg {
		width: 1.3rem;
		height: 1.3rem;
	}

	.ba-slider__range {
		position: absolute;
		inset: 0;
		z-index: 6;
		width: 100%;
		height: 100%;
		margin: 0;
		opacity: 0;
		cursor: ew-resize;
	}

	.ba-slider:focus-within .ba-slider__grip {
		outline: 3px solid color-mix(in srgb, var(--lane-foundation) 55%, transparent);
		outline-offset: 3px;
	}

	/* ---------- impact chips ---------- */
	.ba-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 1.5rem 0 0;
		padding: 0;
		list-style: none;
	}

	.ba-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.6rem 1rem;
		border-radius: 999px;
		background: var(--lane-foundation-tint);
		border: 1px solid color-mix(in srgb, var(--lane-foundation) 26%, var(--color-border));
		color: var(--lane-foundation-ink);
		font-size: 0.9rem;
		font-weight: 700;
	}

	.ba-chip__icon {
		display: inline-flex;
	}

	.ba-chip__icon svg {
		width: 1.1rem;
		height: 1.1rem;
	}

	/* ---------- comparison ---------- */
	.before-after__compare {
		display: grid;
		gap: 0;
		margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
		padding: 0;
		list-style: none;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--color-white);
		box-shadow: var(--shadow-card);
	}

	.ba-row {
		display: grid;
		grid-template-columns: 12rem 1fr 1fr;
		align-items: center;
		gap: 1rem;
		padding: 1.05rem 1.4rem;
		border-top: 1px solid var(--color-border-soft);
	}

	.ba-row--head {
		border-top: none;
		background: var(--color-bg);
		padding-block: 0.85rem;
	}

	.ba-row__col {
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.ba-row__col--before { color: var(--color-muted); }
	.ba-row__col--after { color: var(--lane-foundation-ink); }

	.ba-row:not(.ba-row--head):nth-child(even) {
		background: color-mix(in srgb, var(--color-bg) 45%, var(--color-white));
	}

	.ba-row__label {
		color: var(--color-text);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.03em;
		text-transform: uppercase;
	}

	.ba-row__before,
	.ba-row__after {
		display: inline-flex;
		align-items: flex-start;
		gap: 0.55rem;
		font-size: 0.95rem;
		line-height: 1.45;
	}

	.ba-row__before { color: var(--color-muted); }

	.ba-row__after {
		color: var(--color-text);
		font-weight: 600;
	}

	.ba-row__before svg,
	.ba-row__after svg {
		width: 1.05rem;
		height: 1.05rem;
		margin-top: 0.16rem;
		flex-shrink: 0;
	}

	.ba-row__before svg { color: var(--color-muted-soft); }
	.ba-row__after svg { color: var(--lane-foundation); }

	@media (max-width: 1080px) {
		.before-after__head {
			grid-template-columns: 1fr;
			align-items: start;
		}
	}

	@media (max-width: 760px) {
		.ba-slider {
			aspect-ratio: 4 / 5;
			max-height: none;
		}

		.ba-site__hero {
			grid-template-columns: 1fr;
		}

		.ba-site__hero-art {
			display: none;
		}

		.ba-row {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}

		.ba-row--head {
			display: none;
		}

		.ba-row__before::before {
			content: 'Before: ';
			font-weight: 800;
			color: var(--color-muted-soft);
		}

		.ba-row__after::before {
			content: 'After: ';
			font-weight: 800;
			color: var(--lane-foundation-ink);
		}
	}
</style>

<script>
	(() => {
		const sliders = document.querySelectorAll('[data-ba-slider]');
		sliders.forEach((slider) => {
			const range = slider.querySelector('[data-ba-range]');
			if (!(range instanceof HTMLInputElement)) return;
			const setPos = (val) => {
				slider.style.setProperty('--pos', `${val}%`);
			};
			setPos(range.value);
			range.addEventListener('input', () => setPos(range.value));
		});
	})();
</script>
