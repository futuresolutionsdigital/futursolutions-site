---
// Side-by-side before/after of a healthcare website. Left = a generic,
// brochure-style site that quietly leaks leads. Right = a FutureSolutions
// website system: clear offer, service paths, trust near decisions, a
// booking CTA, and a lead routed into follow-up. Pure CSS/SVG, no JS.
const beforeNotes = [
	'Vague first impression',
	'Services listed, not guided',
	'CTA buried',
	'Proof hidden',
	'Form goes nowhere',
];

const afterNotes = [
	'Clear offer',
	'Service paths',
	'Trust near decisions',
	'Booking CTA',
	'Lead routed to follow-up',
];

const contrasts = [
	{
		label: 'First impression',
		before: 'Looks clean but generic',
		after: 'Clear who it serves and what to do next',
	},
	{
		label: 'Service clarity',
		before: 'Services are listed without a decision path',
		after: 'Service pages guide visitors by intent',
	},
	{
		label: 'Trust',
		before: 'Proof is hidden or scattered',
		after: 'Reviews, FAQs, credentials, and proof appear near decisions',
	},
	{
		label: 'Conversion',
		before: 'CTA appears occasionally',
		after: 'Primary next step is visible throughout',
	},
	{
		label: 'Follow-up',
		before: 'Form submission disappears into an inbox',
		after: 'Lead connects to CRM, reminders, and nurture',
	},
];
---

<section class="ba" aria-labelledby="before-after-heading">
	<div class="site-container site-container--wide">
		<header class="ba__head">
			<div class="ba__head-main">
				<p class="eyebrow">The better system</p>
				<h2 id="before-after-heading" class="display-lg">
					The same practice.
					<span class="ba__head-accent">A completely different result.</span>
				</h2>
			</div>
			<p class="lead ba__lead">
				Most healthcare websites are built like digital brochures. We structure them like guided decision paths — so visitors understand the offer, see the proof, and know exactly how to take the next step.
			</p>
		</header>

		<div class="ba__compare">
			<!-- ── BEFORE ───────────────────────────────── -->
			<article class="ba__side ba__side--before">
				<div class="ba__side-head">
					<span class="ba__side-tag ba__side-tag--before">Before</span>
					<span class="ba__side-name">Generic healthcare website</span>
				</div>

				{/* Future-ready: swap this CSS browser mockup for an approved "before" image asset when available (keep the .ba-mock wrapper for sizing/shadow). */}
				<div class="ba-mock ba-mock--before" aria-hidden="true">
					<div class="ba-mock__bar">
						<span class="ba-mock__dots"><i></i><i></i><i></i></span>
						<span class="ba-mock__chrome" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6" /></svg>
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
						</span>
						<span class="ba-mock__url"><svg class="ba-mock__lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="2" /><path d="M8 11V8a4 4 0 0 1 8 0v3" /></svg>yourpractice.com</span>
					</div>
					<div class="ba-mock__body">
						<div class="ba-mock__nav">
							<span class="ba-mock__brand">Your Practice</span>
							<span class="ba-mock__links"><i></i><i></i><i></i><i></i></span>
							<span class="ba-mock__nav-weak">Contact</span>
						</div>
						<div class="ba-mock__hero ba-mock__hero--before">
							<p class="ba-mock__h ba-mock__h--vague">Welcome to our practice</p>
							<span class="ba-mock__line"></span>
							<span class="ba-mock__line ba-mock__line--short"></span>
							<span class="ba-mock__hero-img ba-mock__hero-img--before">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2" /><circle cx="8.5" cy="9.5" r="1.5" /><path d="M21 16l-5-5L5 20" /></svg>
							</span>
						</div>
						<p class="ba-mock__sectlabel">Our Services</p>
						<ul class="ba-mock__list">
							<li>General consultation</li>
							<li>Treatments</li>
							<li>Insurance &amp; billing</li>
							<li>About the team</li>
						</ul>
						<span class="ba-mock__weaklink">Contact us &raquo;</span>
						<div class="ba-mock__footer">
							<span class="ba-mock__foot-links"><i></i><i></i><i></i></span>
							<span class="ba-mock__foot-copy"></span>
						</div>
					</div>
				</div>

				<ul class="ba__notes ba__notes--before" aria-label="Why a generic site leaks leads">
					{beforeNotes.map((n) => (
						<li>
							<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4l8 8M12 4l-8 8" /></svg>
							{n}
						</li>
					))}
				</ul>
			</article>

			<div class="ba__transform" aria-hidden="true">
				<span class="ba__transform-line"></span>
				<span class="ba__transform-badge">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h15M13 6l6 6-6 6" /></svg>
				</span>
				<span class="ba__transform-label">Rebuild the path</span>
				<span class="ba__transform-line"></span>
			</div>

			<!-- ── AFTER ────────────────────────────────── -->
			<article class="ba__side ba__side--after">
				<div class="ba__side-head">
					<span class="ba__side-tag ba__side-tag--after">After</span>
					<span class="ba__side-name">FutureSolutions website system</span>
				</div>

				{/* Future-ready: swap this CSS browser mockup for an approved "after" image asset when available (keep the .ba-mock wrapper for sizing/shadow). */}
				<div class="ba-mock ba-mock--after" aria-hidden="true">
					<div class="ba-mock__bar ba-mock__bar--after">
						<span class="ba-mock__dots"><i></i><i></i><i></i></span>
						<span class="ba-mock__chrome" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6" /></svg>
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
						</span>
						<span class="ba-mock__url ba-mock__url--after"><svg class="ba-mock__lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="2" /><path d="M8 11V8a4 4 0 0 1 8 0v3" /></svg>northoak-health.com</span>
						<span class="ba-mock__live"><span class="ba-mock__live-dot"></span>Connected</span>
					</div>
					<div class="ba-mock__body ba-mock__body--after">
						<div class="ba-mock__nav">
							<span class="ba-mock__logo"></span>
							<span class="ba-mock__links"><i></i><i></i><i></i></span>
							<span class="ba-mock__book">Book</span>
						</div>
						<div class="ba-mock__hero ba-mock__hero--after">
							<span class="ba-mock__eyebrow">Primary &amp; preventive care</span>
							<p class="ba-mock__h ba-mock__h--clear">Personalized care with a clearer path forward.</p>
							<div class="ba-mock__cta-row">
								<span class="ba-mock__cta">Book Consultation &rarr;</span>
								<span class="ba-mock__trust">
									<span class="ba-mock__trust-ico">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.4-3 7.3-7 8.5-4-1.2-7-4.1-7-8.5V6z" /><path d="M9 11.5l2 2 4-4" /></svg>
									</span>
									<span class="ba-mock__trust-text">Trust signals visible before the CTA</span>
								</span>
							</div>
							<span class="ba-mock__hero-img ba-mock__hero-img--after">
								<span class="ba-mock__support-ico"></span>
								<span class="ba-mock__support-lines"><span></span><span></span></span>
								<span class="ba-mock__support-chip"></span>
							</span>
						</div>
						<div class="ba-mock__services">
							<span class="ba-mock__service">
								<span class="ba-mock__service-ico"></span>
								<span class="ba-mock__service-title">Weight Loss</span>
								<span class="ba-mock__service-sub">Consultation path</span>
							</span>
							<span class="ba-mock__service">
								<span class="ba-mock__service-ico"></span>
								<span class="ba-mock__service-title">Hormone Support</span>
								<span class="ba-mock__service-sub">Service details</span>
							</span>
							<span class="ba-mock__service">
								<span class="ba-mock__service-ico"></span>
								<span class="ba-mock__service-title">Aesthetics</span>
								<span class="ba-mock__service-sub">Bookable treatment</span>
							</span>
						</div>
						<div class="ba-mock__crm">
							<span class="ba-mock__crm-ico">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6" /></svg>
							</span>
							<span class="ba-mock__crm-text">Lead routed to follow-up</span>
						</div>
						<div class="ba-mock__footer ba-mock__footer--after">
							<span class="ba-mock__foot-brand"></span>
							<span class="ba-mock__foot-links"><i></i><i></i><i></i><i></i></span>
							<span class="ba-mock__foot-copy"></span>
						</div>
					</div>
				</div>

				<ul class="ba__notes ba__notes--after" aria-label="What the rebuilt system does">
					{afterNotes.map((n) => (
						<li>
							<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8.5l3.5 3.5L13 5" /></svg>
							{n}
						</li>
					))}
				</ul>
			</article>
		</div>

		<ul class="ba__table">
			<li class="ba-row ba-row--head" aria-hidden="true">
				<span class="ba-row__label"></span>
				<span class="ba-row__col ba-row__col--before">Generic website</span>
				<span class="ba-row__col ba-row__col--after">FutureSolutions</span>
			</li>
			{contrasts.map((row) => (
				<li class="ba-row">
					<span class="ba-row__label">{row.label}</span>
					<span class="ba-row__before">
						<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4l8 8M12 4l-8 8" /></svg>
						{row.before}
					</span>
					<span class="ba-row__after">
						<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8.5l3.5 3.5L13 5" /></svg>
						{row.after}
					</span>
				</li>
			))}
		</ul>
	</div>
</section>

<style>
	.ba {
		padding-block: var(--section-spacing);
		background: var(--color-white);
	}

	.ba__head {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.7fr);
		align-items: end;
		gap: clamp(1.5rem, 4vw, 3.5rem);
		margin: 0 0 clamp(2.25rem, 4vw, 3.25rem);
	}

	.ba__head-accent {
		display: block;
		color: var(--lane-foundation-ink);
	}

	.ba__lead {
		max-width: 36rem;
		margin: 0;
	}

	/* ── Compare grid ─────────────────────────────────── */
	.ba__compare {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		gap: clamp(1rem, 3vw, 2rem);
	}

	.ba__side {
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		min-width: 0;
	}

	.ba__side-head {
		display: flex;
		align-items: center;
		gap: 0.7rem;
	}

	.ba__side-tag {
		padding: 0.28rem 0.7rem;
		border-radius: 999px;
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.ba__side-tag--before {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		color: var(--color-muted);
	}

	.ba__side-tag--after {
		background: color-mix(in srgb, var(--lane-foundation) 88%, black);
		color: #fff;
	}

	.ba__side-name {
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.ba__side--before .ba__side-name {
		color: var(--color-muted);
	}

	/* transform arrow between the two */
	.ba__transform {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		align-self: center;
		color: var(--lane-foundation);
	}

	.ba__transform-line {
		width: 2px;
		height: 2.5rem;
		background: linear-gradient(var(--color-border), transparent);
	}

	.ba__transform-line:last-child {
		background: linear-gradient(transparent, var(--color-border));
	}

	.ba__transform-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 999px;
		background: var(--color-white);
		border: 1px solid color-mix(in srgb, var(--lane-foundation) 30%, var(--color-border));
		color: var(--lane-foundation-ink);
		box-shadow: var(--shadow-card);
	}

	.ba__transform-badge svg {
		width: 1.4rem;
		height: 1.4rem;
	}

	.ba__transform-label {
		color: var(--lane-foundation-ink);
		font-size: 0.6rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		text-align: center;
		white-space: nowrap;
	}

	/* ── Browser mockup (shared) ──────────────────────── */
	.ba-mock {
		border-radius: var(--radius-md);
		overflow: hidden;
		border: 1px solid var(--color-border);
		background: var(--color-white);
	}

	.ba-mock--before {
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 12px 26px rgba(15, 23, 42, 0.05);
		filter: saturate(0.7);
	}

	.ba-mock--after {
		box-shadow: var(--shadow-lift);
		border-color: color-mix(in srgb, var(--lane-foundation) 22%, var(--color-border));
	}

	.ba-mock__bar {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.55rem 0.8rem;
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border-soft);
	}

	.ba-mock__dots {
		display: inline-flex;
		gap: 0.25rem;
	}

	.ba-mock__dots i {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-muted) 30%, var(--color-white));
	}

	.ba-mock__chrome {
		display: inline-flex;
		align-items: center;
		gap: 0.05rem;
		color: var(--color-muted-soft);
	}

	.ba-mock__chrome svg {
		width: 0.72rem;
		height: 0.72rem;
	}

	.ba-mock__url {
		display: inline-flex;
		align-items: center;
		gap: 0.28rem;
		padding: 0.18rem 0.6rem;
		border-radius: 999px;
		background: var(--color-white);
		border: 1px solid var(--color-border-soft);
		color: var(--color-muted);
		font-size: 0.62rem;
		font-weight: 600;
	}

	.ba-mock__lock {
		width: 0.58rem;
		height: 0.58rem;
		flex-shrink: 0;
		color: var(--color-muted-soft);
	}

	.ba-mock__live {
		margin-left: auto;
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		color: var(--lane-foundation-ink);
		font-size: 0.6rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.ba-mock__live-dot {
		width: 0.4rem;
		height: 0.4rem;
		border-radius: 999px;
		background: var(--lane-foundation);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--lane-foundation) 20%, transparent);
	}

	.ba-mock__body {
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
		padding: 1rem;
		min-height: 17rem;
	}

	.ba-mock__body--before {
		background: #efedea;
	}

	.ba-mock__body--after {
		background:
			radial-gradient(ellipse 80% 55% at 85% 0%, var(--lane-foundation-tint), transparent 70%),
			var(--color-white);
	}

	.ba-mock__nav {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.ba-mock__brand {
		color: var(--color-muted);
		font-size: 0.72rem;
		font-weight: 700;
	}

	.ba-mock__logo {
		width: 1.9rem;
		height: 0.6rem;
		border-radius: 999px;
		background: var(--lane-foundation);
	}

	.ba-mock__links {
		display: inline-flex;
		gap: 0.4rem;
		margin-left: 0.3rem;
	}

	.ba-mock__links i {
		width: 1.2rem;
		height: 0.32rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-text) 14%, var(--color-border));
	}

	/* varied widths so the nav reads like real links of different lengths */
	.ba-mock__links i:nth-child(1) { width: 1rem; }
	.ba-mock__links i:nth-child(2) { width: 1.5rem; }
	.ba-mock__links i:nth-child(3) { width: 1.1rem; }
	.ba-mock__links i:nth-child(4) { width: 1.35rem; }

	.ba-mock--before .ba-mock__links i {
		background: var(--color-muted-soft);
	}

	/* active page indicator: bland on the before side, confident teal on the after */
	.ba-mock--before .ba-mock__links i:first-child {
		background: var(--color-muted);
	}

	.ba-mock--after .ba-mock__links i:first-child {
		background: var(--lane-foundation);
	}

	.ba-mock__nav-weak {
		margin-left: auto;
		color: var(--color-muted-soft);
		font-size: 0.62rem;
		font-weight: 600;
	}

	.ba-mock__book {
		margin-left: auto;
		padding: 0.28rem 0.65rem;
		border-radius: 7px;
		background: var(--color-text);
		color: var(--color-white);
		font-size: 0.6rem;
		font-weight: 800;
	}

	/* hero areas */
	.ba-mock__hero {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.ba-mock__hero--before {
		padding: 0.4rem 0;
	}

	.ba-mock__h {
		margin: 0;
	}

	.ba-mock__h--vague {
		color: var(--color-muted);
		font-size: 0.92rem;
		font-weight: 600;
	}

	.ba-mock__h--clear {
		max-width: 18ch;
		color: var(--color-text);
		font-size: clamp(0.95rem, 0.8rem + 0.6vw, 1.18rem);
		font-weight: 750;
		letter-spacing: -0.025em;
		line-height: 1.15;
	}

	.ba-mock__eyebrow {
		width: fit-content;
		padding: 0.16rem 0.45rem;
		border-radius: 999px;
		background: var(--lane-foundation-tint);
		color: var(--lane-foundation-ink);
		font-size: 0.54rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.ba-mock__line {
		width: 100%;
		height: 0.42rem;
		border-radius: 999px;
		background: var(--color-muted-soft);
		opacity: 0.7;
	}

	.ba-mock__line--short { width: 55%; }

	/* hero visual block — bland stock placeholder (before) vs polished branded image (after) */
	.ba-mock__hero-img {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 2.6rem;
		margin-top: 0.5rem;
		border-radius: 8px;
	}

	.ba-mock__hero-img--before {
		background: #e3e0db;
		border: 1px solid var(--color-border-soft);
		color: var(--color-muted-soft);
	}

	.ba-mock__hero-img--before svg {
		width: 1.3rem;
		height: 1.3rem;
	}

	.ba-mock__hero-img--after {
		justify-content: flex-start;
		gap: 0.5rem;
		padding: 0 0.55rem;
		background: linear-gradient(120deg, color-mix(in srgb, var(--lane-foundation) 18%, var(--color-white)), color-mix(in srgb, var(--lane-foundation-tint) 65%, var(--color-white)));
		border: 1px solid color-mix(in srgb, var(--lane-foundation) 18%, var(--color-border-soft));
	}

	/* subtle trust/support band content so the after block reads as intentional, not empty */
	.ba-mock__support-ico {
		flex-shrink: 0;
		width: 1.35rem;
		height: 1.35rem;
		border-radius: 6px;
		background: color-mix(in srgb, var(--color-white) 65%, var(--lane-foundation-tint));
		border: 1px solid color-mix(in srgb, var(--lane-foundation) 20%, transparent);
	}

	.ba-mock__support-lines {
		display: flex;
		flex: 1;
		flex-direction: column;
		gap: 0.26rem;
		min-width: 0;
	}

	.ba-mock__support-lines span {
		height: 0.3rem;
		border-radius: 999px;
