---
const leakStages = [
	{ label: 'Traffic arrives', tag: 'Starting point', type: 'start' },
	{ label: 'Scans the page', tag: 'Unclear positioning', type: 'leak' },
	{ label: 'Compares services', tag: 'Weak service clarity', type: 'leak' },
	{ label: 'Looks for trust', tag: 'Low trust signals', type: 'leak' },
	{ label: 'Considers booking', tag: 'Buried CTA', type: 'leak' },
	{ label: 'Leaves without booking', tag: 'No follow-up', type: 'lost' },
];

const problems = [
	{
		number: '01',
		category: 'Message clarity',
		title: 'Unclear positioning',
		text: 'Visitors cannot quickly tell who you help, what you offer, or why they should choose you.',
	},
	{
		number: '02',
		category: 'Conversion flow',
		title: 'Weak-converting paths',
		text: 'Pages look polished, but visitors are not guided toward a clear next step.',
	},
	{
		number: '03',
		category: 'Local visibility',
		title: 'Poor local visibility',
		text: 'The site does not fully support service-area search, local intent, or location-based discovery.',
	},
	{
		number: '04',
		category: 'Lead handling',
		title: 'Disconnected follow-up',
		text: 'Inquiries are captured inconsistently — not connected to reminders, nurture, or pipeline tracking.',
	},
];
---

<section class="section section-muted problem-section" aria-labelledby="problem-heading">
	<div class="site-container site-container--wide">
		<header class="problem-section__head">
			<div class="problem-section__head-left">
				<p class="eyebrow">The hidden problem</p>
				<h2 id="problem-heading" class="display-lg">
					Most healthcare websites look fine — and quietly leak leads anyway.
				</h2>
			</div>
			<div class="problem-section__head-right">
				<p>
					A website can look polished and still lose visitors at each decision point — before they understand your services, trust your expertise, or take the next step. We design around those gaps.
				</p>
			</div>
		</header>

		<div class="leak-map" role="img" aria-label="A visitor's path through a typical healthcare website. Traffic arrives as the starting point, then leads commonly leak through unclear positioning, weak service clarity, low trust signals, a buried call-to-action, and no follow-up — until the visitor leaves without booking.">
			<div class="leak-map__head" aria-hidden="true">
				<span class="leak-map__head-label">Where leads leak</span>
				<span class="leak-map__head-legend"><span class="leak-map__head-dot"></span>Common leak point</span>
			</div>
			<ol class="leak-map__track">
				{leakStages.map((s, i) => (
					<li class:list={['leak-map__node', { 'leak-map__node--leak': s.type === 'leak', 'leak-map__node--start': s.type === 'start', 'leak-map__node--end': s.type === 'lost' }]}>
						<span class="leak-map__index">{i + 1}</span>
						<span class="leak-map__label">{s.label}</span>
						{s.type === 'leak' && (
							<span class="leak-map__leak">
								<span class="leak-map__leak-dot" aria-hidden="true"></span>
								{s.tag}
							</span>
						)}
						{s.type === 'start' && <span class="leak-map__start">{s.tag}</span>}
						{s.type === 'lost' && <span class="leak-map__lost">{s.tag}</span>}
					</li>
				))}
			</ol>
		</div>

		<ul class="problem-section__grid" aria-label="Common gaps in healthcare websites">
			{
				problems.map((problem) => (
					<li class="problem-card">
						<header class="problem-card__header">
							<span class="problem-card__number">{problem.number}</span>
						</header>
						<span class="problem-card__category">{problem.category}</span>
						<h3 class="problem-card__title">{problem.title}</h3>
						<p class="problem-card__text">{problem.text}</p>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	.problem-section {
		position: relative;
		background: linear-gradient(180deg, var(--color-bg) 0%, color-mix(in srgb, var(--color-border-soft) 35%, var(--color-bg)) 100%);
		border-block: 1px solid var(--color-border-soft);
	}

	.problem-section__head .eyebrow {
		color: var(--lane-audit-ink);
	}

	.problem-section__head {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: end;
		margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
	}

	.problem-section__head h2 {
		max-width: 22ch;
		margin-bottom: 0;
	}

	.problem-section__head-right p {
		max-width: 36ch;
		margin: 0;
		color: var(--color-muted);
		font-size: 1rem;
		line-height: 1.6;
	}

	.leak-map {
		margin-bottom: clamp(2rem, 3.5vw, 2.75rem);
		padding: 1.4rem 1.5rem 1.6rem;
		border: 1px solid color-mix(in srgb, var(--lane-audit) 20%, var(--color-border));
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: var(--shadow-card);
	}

	.leak-map__head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.25rem;
	}

	.leak-map__head-label {
		color: var(--color-text);
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.leak-map__head-legend {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		color: var(--lane-audit-ink);
		font-size: 0.76rem;
		font-weight: 600;
	}

	.leak-map__head-dot {
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 999px;
		background: var(--lane-audit);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--lane-audit) 22%, transparent);
	}

	.leak-map__track {
		display: grid;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.leak-map__node {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.55rem;
		padding: 0.9rem 0.85rem 1rem;
		border: 1px solid var(--color-border-soft);
		border-radius: var(--radius-md);
		background: var(--color-bg);
	}

	.leak-map__node:not(:last-child)::after {
		content: '';
		position: absolute;
		top: 1.55rem;
		right: calc(-0.25rem - 1px);
		width: 0.45rem;
		height: 0.45rem;
		border-top: 2px solid color-mix(in srgb, var(--lane-audit) 38%, var(--color-border));
		border-right: 2px solid color-mix(in srgb, var(--lane-audit) 38%, var(--color-border));
		transform: translate(50%, -50%) rotate(45deg);
		z-index: 2;
	}

	.leak-map__index {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		border-radius: 8px;
		background: var(--color-white);
		border: 1px solid var(--color-border);
		color: var(--color-muted);
		font-size: 0.72rem;
		font-weight: 800;
		font-variant-numeric: tabular-nums;
	}

	.leak-map__label {
		color: var(--color-text);
		font-size: 0.85rem;
		font-weight: 650;
		letter-spacing: -0.01em;
		line-height: 1.2;
	}

	.leak-map__leak {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-top: auto;
		padding: 0.28rem 0.5rem;
		border: 1px solid color-mix(in srgb, var(--lane-audit) 32%, transparent);
		border-radius: 999px;
		background: var(--lane-audit-tint);
		color: var(--lane-audit-ink);
		font-size: 0.7rem;
		font-weight: 700;
		line-height: 1.1;
	}

	.leak-map__leak-dot {
		width: 0.4rem;
		height: 0.4rem;
		border-radius: 999px;
		background: var(--lane-audit);
	}

	/* Entry tag (teal) — the visitor arrives; this part works */
	.leak-map__start {
		display: inline-flex;
		align-items: center;
		margin-top: auto;
		padding: 0.28rem 0.5rem;
		border: 1px solid color-mix(in srgb, var(--lane-foundation) 26%, var(--color-border));
		border-radius: 999px;
		background: var(--lane-foundation-tint);
		color: var(--lane-foundation-ink);
		font-size: 0.7rem;
		font-weight: 700;
		line-height: 1.1;
	}

	/* Lost tag (charcoal) — the terminal outcome: the lead is gone */
	.leak-map__lost {
		display: inline-flex;
		align-items: center;
		margin-top: auto;
		padding: 0.28rem 0.5rem;
		border: 1px solid var(--color-text);
		border-radius: 999px;
		background: var(--color-text);
		color: var(--color-white);
		font-size: 0.7rem;
		font-weight: 700;
		line-height: 1.1;
	}

	/* Entry node (teal) — healthy starting point */
	.leak-map__node--start {
		border-color: color-mix(in srgb, var(--lane-foundation) 20%, var(--color-border-soft));
		background: color-mix(in srgb, var(--lane-foundation-tint) 45%, var(--color-white));
	}

	.leak-map__node--start .leak-map__index {
		background: var(--lane-foundation-tint);
		border-color: color-mix(in srgb, var(--lane-foundation) 28%, var(--color-border));
		color: var(--lane-foundation-ink);
	}

	/* Leak nodes (amber) — where leads commonly slip away */
	.leak-map__node--leak {
		border-color: color-mix(in srgb, var(--lane-audit) 28%, var(--color-border-soft));
		background: color-mix(in srgb, var(--lane-audit-tint) 40%, var(--color-white));
	}

	/* Lost node (charcoal-edged) — the cost if the leaks go unfixed */
	.leak-map__node--end {
		border-color: color-mix(in srgb, var(--color-text) 22%, var(--color-border));
		background: var(--color-white);
		box-shadow: var(--shadow-card);
	}

	.leak-map__node--end .leak-map__index {
		background: var(--color-text);
		border-color: var(--color-text);
		color: var(--color-white);
	}

	.problem-section__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.25rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.problem-card {
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-white);
		transition: transform 320ms var(--ease-out-quart),
			border-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.problem-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-text) 18%, var(--color-border));
		box-shadow: var(--shadow-card);
	}

	.problem-card__header {
		display: flex;
		align-items: center;
		margin-bottom: 0.85rem;
	}

	.problem-card__category {
		display: block;
		margin-bottom: 0.4rem;
		color: var(--lane-audit-ink);
		font-size: 0.66rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.problem-card__number {
		color: var(--color-muted);
		font-size: 0.74rem;
		font-weight: 800;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.14em;
	}

	.problem-card__title {
		margin: 0 0 0.55rem 0;
		font-size: 1.18rem;
		font-weight: 650;
		letter-spacing: -0.025em;
		line-height: 1.2;
	}

	.problem-card__text {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.93rem;
		line-height: 1.55;
	}

	@media (max-width: 1080px) {
		.problem-section__head {
			grid-template-columns: 1fr;
		}

		.problem-section__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.leak-map__track {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 0.6rem;
		}

		.leak-map__node:nth-child(3)::after {
			display: none;
		}
	}

	@media (max-width: 560px) {
		.problem-section__grid {
			grid-template-columns: 1fr;
		}

		.leak-map__track {
			grid-template-columns: 1fr;
			gap: 0.95rem;
		}

		.leak-map__node {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.6rem 0.7rem;
		}

		.leak-map__leak,
		.leak-map__start,
		.leak-map__lost {
			margin-top: 0;
			margin-left: auto;
		}

		.leak-map__node:not(:last-child)::after {
			top: auto;
			right: auto;
			bottom: calc(-0.7rem - 1px);
			left: 1.65rem;
			transform: translate(-50%, 50%) rotate(135deg);
		}

		.leak-map__node:nth-child(3)::after {
			display: block;
		}
	}
</style>
