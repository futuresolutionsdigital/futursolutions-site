---
const problems = [
	{
		number: '01',
		title: 'Unclear positioning',
		text: 'Visitors cannot quickly tell who you help, what you offer, or why your practice is the right fit.',
	},
	{
		number: '02',
		title: 'Weak conversion paths',
		text: 'Calls-to-action are buried, inconsistent, or disconnected from the way patients actually make decisions.',
	},
	{
		number: '03',
		title: 'Poor local visibility',
		text: 'Search engines lack the service, location, and metadata signals needed to understand your business.',
	},
	{
		number: '04',
		title: 'No backend follow-up',
		text: 'New inquiries land in an inbox instead of a system that qualifies, reminds, and moves people toward booking.',
	},
];
---

<section class="section section-muted problem-section" aria-labelledby="problem-heading">
	<div class="site-container">
		<div class="problem-section__intro">
			<p class="eyebrow">The hidden gap</p>
			<h2 id="problem-heading">Most healthcare websites look fine — but fail where it matters.</h2>
			<p class="lead">
				A modern site can still lose leads through unclear messaging, weak service pages, buried calls-to-action, poor local visibility, and no follow-up system.
			</p>
		</div>

		<div class="problem-section__grid">
			{problems.map((problem) => (
				<article class="card problem-card">
					<span>{problem.number}</span>
					<h3>{problem.title}</h3>
					<p>{problem.text}</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.problem-section__intro {
		max-width: 780px;
	}

	.problem-section__intro h2 {
		max-width: 760px;
	}

	.problem-section__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.problem-card {
		display: flex;
		flex-direction: column;
		min-height: 100%;
		padding: 1.25rem;
	}

	.problem-card span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		margin-bottom: 1.5rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg-secondary);
		color: var(--color-accent-dark);
		font-size: 0.75rem;
		font-weight: 700;
	}

	.problem-card h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	.problem-card p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	@media (max-width: 980px) {
		.problem-section__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 620px) {
		.problem-section__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
