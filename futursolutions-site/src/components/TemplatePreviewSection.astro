---
import { templateSystems } from '../data/templates';
---

<section id="templates" class="section section-muted template-preview" aria-labelledby="template-preview-heading">
	<div class="site-container">
		<div class="template-preview__intro">
			<p class="eyebrow">Demo library</p>
			<h2 id="template-preview-heading">A library of real, working clinic and association websites.</h2>
			<p class="lead">
				Every demo is a launch-ready industry Foundation — not a screenshot, not a theme. Walk through a live build and see how your practice could open day one.
			</p>
		</div>

		<div class="template-preview__grid">
			{templateSystems.map((template, index) => (
				<article class:list={['template-card', 'card', { 'template-card--vt': template.slug === 'hormone-trt' }]}>
					{template.slug === 'hormone-trt' ? (
						<div class="template-card__mockup vt-prev" aria-hidden="true">
							<div class="vt-prev__chrome">
								<span class="vt-prev__dot"></span>
								<span class="vt-prev__dot"></span>
								<span class="vt-prev__dot"></span>
								<span class="vt-prev__label">VANTAGE</span>
							</div>
							<div class="vt-prev__screen">
								<div class="vt-prev__rule"></div>
								<div class="vt-prev__hero-block">
									<span class="vt-prev__tag">MEN'S HEALTH / TRT</span>
									<span class="vt-prev__headline"></span>
									<span class="vt-prev__headline vt-prev__headline--short"></span>
									<span class="vt-prev__cta">START ASSESSMENT</span>
								</div>
								<div class="vt-prev__stats">
									<div style="height:55%"></div>
									<div style="height:80%"></div>
									<div style="height:40%"></div>
									<div style="height:65%"></div>
								</div>
								<div class="vt-prev__diagonal"></div>
							</div>
						</div>
					) : (
						<div class="template-card__mockup" aria-hidden="true">
							<div class="template-card__topbar">
								<span></span>
								<span></span>
								<span></span>
							</div>
							<div class="template-card__screen">
								<div class="template-card__hero-lines">
									<span></span>
									<span></span>
									<span></span>
								</div>
								<div class={`template-card__panel template-card__panel--${index + 1}`}>
									<span></span>
								</div>
								<div class="template-card__tiles">
									<span></span>
									<span></span>
									<span></span>
								</div>
							</div>
						</div>
					)}

					<div class="template-card__content">
						<p class="template-card__category">{template.category}</p>
						<h3>{template.name}</h3>
						<p>{template.shortDescription}</p>
						<div class="template-card__features" aria-label={`${template.name} features`}>
							{template.features.slice(0, 4).map((feature) => <span>{feature}</span>)}
						</div>
						<div class="template-card__actions">
							<a class="template-card__link" href={template.detailUrl}>See Details</a>
							{
								template.demoUrl ? (
									<a class="template-card__link template-card__link--demo" href={template.demoUrl}>View Live Demo</a>
								) : (
									<span class="template-card__demo-status">Demo Coming Soon</span>
								)
							}
							<a class="template-card__link template-card__link--accent" href={template.auditUrl}>
								Get This Customized
							</a>
						</div>
					</div>
				</article>
			))}
		</div>
		<div class="template-preview__cta">
			<a class="button button-secondary" href="/templates">View All Demos</a>
		</div>
	</div>
</section>

<style>
	.template-preview__intro {
		max-width: 780px;
	}

	.template-preview__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.template-card {
		overflow: hidden;
		border-radius: 24px;
		box-shadow: 0 20px 54px rgba(15, 23, 42, 0.05);
	}

	.template-card__mockup {
		padding: 0.85rem;
		border-bottom: 1px solid var(--color-border);
		background:
			linear-gradient(135deg, rgba(230, 240, 239, 0.9), rgba(245, 247, 249, 0.96)),
			var(--color-bg-secondary);
	}

	.template-card__topbar {
		display: flex;
		gap: 0.38rem;
		align-items: center;
		padding: 0.7rem 0.85rem;
		border: 1px solid var(--color-border);
		border-bottom: 0;
		border-radius: 16px 16px 0 0;
		background: rgba(255, 255, 255, 0.84);
	}

	.template-card__topbar span {
		width: 0.46rem;
		height: 0.46rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-muted) 28%, var(--color-white));
	}

	.template-card__screen {
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		gap: 0.8rem;
		min-height: 190px;
		padding: 1rem;
		border: 1px solid var(--color-border);
		border-radius: 0 0 16px 16px;
		background: var(--color-white);
	}

	.template-card__hero-lines {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		justify-content: center;
	}

	.template-card__hero-lines span {
		display: block;
		height: 0.65rem;
		border-radius: 999px;
		background: var(--color-border);
	}

	.template-card__hero-lines span:first-child {
		width: 42%;
		background: var(--color-accent-light);
	}

	.template-card__hero-lines span:nth-child(2) {
		width: 82%;
		height: 1rem;
		background: color-mix(in srgb, var(--color-text) 16%, var(--color-border));
	}

	.template-card__hero-lines span:last-child {
		width: 68%;
	}

	.template-card__panel {
		display: flex;
		align-items: flex-end;
		min-height: 112px;
		padding: 0.65rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
		border-radius: 14px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0)),
			var(--color-accent-light);
	}

	.template-card__panel span {
		width: 72%;
		height: 0.55rem;
		border-radius: 999px;
		background: var(--color-accent);
	}

	.template-card__panel--2 span {
		width: 52%;
	}

	.template-card__panel--3 span {
		width: 86%;
	}

	.template-card__tiles {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.55rem;
	}

	.template-card__tiles span {
		min-height: 2.25rem;
		border: 1px solid var(--color-border);
		border-radius: 12px;
		background: var(--color-bg-secondary);
	}

	.template-card__content {
		padding: 1.35rem;
	}

	.template-card__category {
		margin-bottom: 0.65rem;
		color: var(--color-accent-dark);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.template-card h3 {
		font-size: 1.25rem;
		letter-spacing: -0.025em;
	}

	.template-card__content > p:not(.template-card__category) {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.template-card__features {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1.2rem;
	}

	.template-card__features span {
		display: inline-flex;
		padding: 0.35rem 0.55rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-bg);
		color: var(--color-muted);
		font-size: 0.78rem;
		font-weight: 600;
		line-height: 1;
	}

	.template-card__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		align-items: center;
		margin-top: 1.35rem;
	}

	.template-card__link {
		display: inline-flex;
		color: var(--color-text);
		font-size: 0.9375rem;
		font-weight: 700;
	}

	.template-card__link:hover {
		color: var(--color-accent-dark);
	}

	.template-card__link--demo {
		color: var(--color-accent-dark);
	}

	.template-card__link--accent {
		color: var(--color-accent-dark);
		text-decoration-thickness: 1px;
		text-underline-offset: 2px;
	}

	.template-card__demo-status {
		display: inline-flex;
		padding: 0.35rem 0.55rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-bg);
		color: var(--color-muted);
		font-size: 0.78rem;
		font-weight: 600;
		line-height: 1;
	}

	/* ═══ VANTAGE preview variant ═══ */
	.template-card--vt {
		border-color: rgba(200, 30, 30, 0.18);
	}

	.vt-prev {
		padding: 0;
		border-bottom: none;
		background: #111;
	}

	.vt-prev__chrome {
		display: flex;
		gap: 0.35rem;
		align-items: center;
		padding: 0.6rem 0.8rem;
		background: #0a0a0a;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.vt-prev__dot {
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: #c81e1e;
		opacity: 0.6;
	}

	.vt-prev__label {
		margin-left: auto;
		font-size: 0.48rem;
		font-weight: 800;
		letter-spacing: 0.18em;
		color: rgba(244, 239, 231, 0.2);
		text-transform: uppercase;
	}

	.vt-prev__screen {
		position: relative;
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.8rem;
		padding: 1rem;
		min-height: 190px;
		overflow: hidden;
		background:
			repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255, 255, 255, 0.015) 39px, rgba(255, 255, 255, 0.015) 40px),
			repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255, 255, 255, 0.015) 39px, rgba(255, 255, 255, 0.015) 40px),
			#111;
	}

	.vt-prev__rule {
		grid-column: 1 / -1;
		height: 3px;
		background: #c81e1e;
		border-radius: 2px;
	}

	.vt-prev__hero-block {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		justify-content: center;
	}

	.vt-prev__tag {
		width: fit-content;
		padding: 0.2rem 0.4rem;
		font-size: 0.4rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		color: #c81e1e;
		border: 1px solid rgba(200, 30, 30, 0.25);
		border-radius: 2px;
		text-transform: uppercase;
	}

	.vt-prev__headline {
		display: block;
		width: 85%;
		height: 0.65rem;
		background: rgba(244, 239, 231, 0.7);
		border-radius: 2px;
	}

	.vt-prev__headline--short {
		width: 60%;
		height: 0.55rem;
		background: rgba(244, 239, 231, 0.35);
	}

	.vt-prev__cta {
		width: fit-content;
		margin-top: 0.2rem;
		padding: 0.25rem 0.5rem;
		font-size: 0.38rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		color: #f4efe7;
		background: #c81e1e;
		border-radius: 3px;
		text-transform: uppercase;
	}

	.vt-prev__stats {
		display: flex;
		gap: 4px;
		align-items: flex-end;
		align-self: end;
		height: 60px;
		padding: 0.5rem;
		background: rgba(255, 255, 255, 0.025);
		border: 1px solid rgba(255, 255, 255, 0.04);
		border-radius: 6px;
	}

	.vt-prev__stats div {
		flex: 1;
		min-width: 8px;
		background: rgba(200, 30, 30, 0.4);
		border-radius: 2px 2px 0 0;
	}

	.vt-prev__diagonal {
		position: absolute;
		bottom: -20px;
		right: -20px;
		width: 80px;
		height: 80px;
		background: rgba(200, 30, 30, 0.06);
		transform: rotate(45deg);
		pointer-events: none;
	}

	.template-card--vt .template-card__category {
		color: #c81e1e;
	}

	.template-preview__cta {
		margin-top: 2rem;
	}

	@media (max-width: 1040px) {
		.template-preview__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 700px) {
		.template-preview__grid,
		.template-card__screen {
			grid-template-columns: 1fr;
		}
	}
</style>
