---
import type { ServiceLink } from '../data/serviceDetails';

interface Props {
	services: ServiceLink[];
}

const { services } = Astro.props;
---

<section class="section related-services" aria-labelledby="related-services-heading">
	<div class="site-container">
		<div class="related-services__intro">
			<p class="eyebrow">Related services</p>
			<h2 id="related-services-heading">Natural next steps.</h2>
		</div>
		<div class="related-services__grid">
			{services.map((service) => (
				<a class="card related-services__card" href={service.href}>
					<span>{service.label}</span>
					<small>Explore service</small>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.related-services__intro {
		max-width: 780px;
	}

	.related-services__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.related-services__card {
		display: grid;
		gap: 0.6rem;
		padding: 1.25rem;
		border-radius: 18px;
		transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
	}

	.related-services__card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-accent) 34%, var(--color-border));
		box-shadow: 0 20px 48px rgba(15, 23, 42, 0.06);
	}

	.related-services__card span {
		color: var(--color-text);
		font-size: 1rem;
		font-weight: 800;
		line-height: 1.35;
	}

	.related-services__card small {
		color: var(--color-accent-dark);
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	@media (max-width: 980px) {
		.related-services__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 620px) {
		.related-services__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
