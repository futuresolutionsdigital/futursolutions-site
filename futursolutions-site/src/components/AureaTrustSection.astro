---
import { trustPoints } from '../data/aurea';
---

<section class="aurea-section" aria-labelledby="trust-heading">
	<div class="aurea-container">
		<div class="trust__intro">
			<p class="aurea-eyebrow">Medical Aesthetics</p>
			<h2 id="trust-heading">Beauty, backed by medical judgment.</h2>
			<p class="aurea-lead">
				Every treatment at Aur&eacute;a is personalized, performed under medical oversight, and guided by a philosophy of natural results over trends.
			</p>
		</div>
		<div class="trust__grid">
			{
				trustPoints.map((point) => (
					<article class="trust__card aurea-card">
						<div class="trust__card-accent" aria-hidden="true"></div>
						<h3>{point.title}</h3>
						<p>{point.text}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.trust__intro {
		max-width: 700px;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	.trust__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.trust__card {
		padding: 1.5rem;
	}

	.trust__card-accent {
		width: 2.5rem;
		height: 3px;
		margin-bottom: 1.35rem;
		border-radius: 999px;
		background: var(--aurea-champagne);
	}

	.trust__card h3 {
		font-family: var(--aurea-font-heading);
		font-size: 1.12rem;
	}

	.trust__card p {
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--aurea-muted);
	}

	@media (max-width: 1040px) {
		.trust__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.trust__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
