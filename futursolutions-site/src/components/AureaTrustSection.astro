---
import { trustPoints } from '../data/aurea';
---

<section class="trust" aria-labelledby="trust-heading">
	<div class="aurea-container trust__layout">
		<div class="trust__intro">
			<p class="aurea-eyebrow">Medical Aesthetics</p>
			<h2 id="trust-heading">Beauty, backed by medical judgment.</h2>
			<p class="aurea-lead">
				Every treatment at Aur&eacute;a is personalized, performed under medical oversight, and guided by a philosophy of natural results over trends.
			</p>
			<div class="trust__cta">
				<a href="/demos/med-spa/contact" class="aurea-btn aurea-btn--primary">
					Book a Consultation
				</a>
			</div>
		</div>
		<div class="trust__grid">
			{
				trustPoints.map((point) => (
					<article class="trust__card aurea-card">
						<div class="trust__card-accent" aria-hidden="true"></div>
						<h3>{point.title}</h3>
						<p>{point.text}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.trust {
		padding: clamp(3rem, 6vw, 5rem) 0;
		background: color-mix(in srgb, var(--aurea-sage) 6%, var(--aurea-bg));
	}

	.trust__layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 4vw, 3.5rem);
		align-items: start;
	}

	.trust__intro {
		max-width: 520px;
		position: sticky;
		top: 6rem;
	}

	.trust__cta {
		margin-top: 2rem;
	}

	.trust__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.trust__card {
		padding: 1.75rem;
	}

	.trust__card-accent {
		width: 3rem;
		height: 3px;
		margin-bottom: 1.35rem;
		border-radius: 999px;
		background: var(--aurea-champagne);
	}

	.trust__card h3 {
		font-family: var(--aurea-font-heading);
		font-size: 1.12rem;
		margin-bottom: 0.45rem;
	}

	.trust__card p {
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--aurea-muted);
	}

	@media (max-width: 900px) {
		.trust__layout {
			grid-template-columns: 1fr;
		}
		.trust__intro {
			position: static;
			max-width: 700px;
		}
	}

	@media (max-width: 560px) {
		.trust__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
