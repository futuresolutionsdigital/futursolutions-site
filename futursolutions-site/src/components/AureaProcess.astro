---
import { processSteps } from '../data/aurea';
---

<section class="aurea-section aurea-section--warm" aria-labelledby="process-heading">
	<div class="aurea-container">
		<div class="proc__intro">
			<p class="aurea-eyebrow">First Visit</p>
			<h2 id="process-heading">What to expect on your first visit.</h2>
			<p class="aurea-lead">
				We designed the experience to feel calm, clear, and pressure-free from the moment you reach out.
			</p>
		</div>

		<div class="proc__timeline">
			{processSteps.map((s, i) => (
				<div class:list={['proc__step', { 'proc__step--last': i === processSteps.length - 1 }]}>
					<div class="proc__marker">
						<span class="proc__number">{s.step}</span>
					</div>
					<div class="proc__body">
						<h3 class="proc__title">{s.title}</h3>
						<p class="proc__text">{s.text}</p>
					</div>
				</div>
			))}
		</div>

		<div class="proc__cta">
			<a class="aurea-btn aurea-btn--primary" href="/demos/med-spa/contact">
				Ready to start? Book a Consultation
			</a>
		</div>
	</div>
</section>

<style>
	.proc__intro {
		max-width: 680px;
		margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
	}

	/* Desktop: horizontal timeline */
	.proc__timeline {
		display: flex;
		gap: 0;
	}

	.proc__step {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		position: relative;
	}

	/* Connecting line between steps (desktop) */
	.proc__step::after {
		content: '';
		position: absolute;
		top: 1.25rem;
		left: calc(50% + 1.5rem);
		right: calc(-50% + 1.5rem);
		height: 1px;
		background: var(--aurea-border);
	}

	.proc__step--last::after {
		display: none;
	}

	.proc__marker {
		position: relative;
		z-index: 1;
		margin-bottom: 1.25rem;
	}

	.proc__number {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--aurea-champagne) 15%, var(--aurea-ivory));
		border: 1.5px solid color-mix(in srgb, var(--aurea-champagne) 35%, var(--aurea-border));
		font-size: 0.75rem;
		font-weight: 800;
		color: var(--aurea-champagne);
		letter-spacing: 0.02em;
	}

	.proc__title {
		font-family: var(--aurea-font-heading);
		font-size: 1.15rem;
		font-weight: 600;
		color: var(--aurea-charcoal);
		margin-bottom: 0.5rem;
	}

	.proc__text {
		font-size: 0.88rem;
		line-height: 1.6;
		color: var(--aurea-muted);
		max-width: 220px;
		margin-inline: auto;
	}

	.proc__cta {
		margin-top: clamp(2.5rem, 5vw, 3.5rem);
		text-align: center;
	}

	/* Mobile: vertical timeline with left line */
	@media (max-width: 768px) {
		.proc__timeline {
			flex-direction: column;
			gap: 0;
			padding-left: 1.25rem;
		}

		.proc__step {
			flex-direction: row;
			align-items: flex-start;
			text-align: left;
			gap: 1.25rem;
			padding-bottom: 2rem;
		}

		.proc__step::after {
			content: '';
			position: absolute;
			top: 2.5rem;
			left: 1.25rem;
			right: auto;
			bottom: 0;
			width: 1px;
			height: auto;
		}

		.proc__step--last::after {
			display: none;
		}

		.proc__marker {
			flex-shrink: 0;
			margin-bottom: 0;
		}

		.proc__body {
			padding-top: 0.35rem;
		}

		.proc__text {
			max-width: none;
			margin-inline: 0;
		}
	}
</style>
