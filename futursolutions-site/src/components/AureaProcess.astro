---
import { processSteps } from '../data/aurea';
---

<section class="aurea-section aurea-section--warm" aria-labelledby="process-heading">
	<div class="aurea-container">
		<div class="proc__intro">
			<p class="aurea-eyebrow">First Visit</p>
			<h2 id="process-heading">What to expect on your first visit.</h2>
			<p class="aurea-lead">
				We designed the experience to feel calm, clear, and pressure-free from the moment you reach out.
			</p>
		</div>
		<div class="proc__grid">
			{
				processSteps.map((s) => (
					<article class="proc__card aurea-card">
						<span class="proc__step">{s.step}</span>
						<h3>{s.title}</h3>
						<p>{s.text}</p>
					</article>
				))
			}
		</div>
		<div class="aurea-btn-row">
			<a class="aurea-btn aurea-btn--primary" href="#location">Book Your Consultation</a>
		</div>
	</div>
</section>

<style>
	.proc__intro {
		max-width: 680px;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	.proc__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.proc__card {
		padding: 1.5rem;
	}

	.proc__step {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		margin-bottom: 1.15rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--aurea-champagne) 15%, var(--aurea-ivory));
		border: 1px solid color-mix(in srgb, var(--aurea-champagne) 28%, var(--aurea-border));
		font-size: 0.72rem;
		font-weight: 800;
		color: var(--aurea-champagne);
	}

	.proc__card h3 {
		font-family: var(--aurea-font-heading);
		font-size: 1.1rem;
	}

	.proc__card p {
		font-size: 0.88rem;
		line-height: 1.55;
		color: var(--aurea-muted);
	}

	@media (max-width: 960px) {
		.proc__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.proc__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
