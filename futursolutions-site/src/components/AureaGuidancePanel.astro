---
import { concernPaths } from '../data/aurea';
---

<section id="concerns" class="aurea-section aurea-section--warm" aria-labelledby="guidance-heading">
	<div class="aurea-container">
		<div class="guidance__intro">
			<p class="aurea-eyebrow">Treatment Pathways</p>
			<h2 id="guidance-heading">Not sure where to start?</h2>
			<p class="aurea-lead">
				Choose your main concern and we'll point you toward the best treatment path. Every plan begins with a consultation.
			</p>
		</div>
		<div class="guidance__grid">
			{
				concernPaths.map((item) => (
					<a href={item.href} class="guidance__card aurea-card">
						<div class="guidance__card-concern">{item.concern}</div>
						<p class="guidance__card-desc">{item.description}</p>
						<div class="guidance__card-path">
							<span class="guidance__card-label">Suggested path</span>
							<span class="guidance__card-treatment">{item.suggestedPath}</span>
						</div>
					</a>
				))
			}
		</div>
	</div>
</section>

<style>
	.guidance__intro {
		max-width: 680px;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	.guidance__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.guidance__card {
		display: flex;
		flex-direction: column;
		padding: 1.35rem;
		transition:
			border-color var(--aurea-transition),
			box-shadow var(--aurea-transition),
			transform var(--aurea-transition);
	}

	.guidance__card:hover {
		border-color: color-mix(in srgb, var(--aurea-champagne) 45%, var(--aurea-border));
		box-shadow: 0 16px 44px rgba(36, 35, 33, 0.08);
		transform: translateY(-2px);
	}

	.guidance__card-concern {
		font-family: var(--aurea-font-heading);
		font-size: 1.15rem;
		font-weight: 600;
		color: var(--aurea-charcoal);
		margin-bottom: 0.55rem;
	}

	.guidance__card-desc {
		font-size: 0.88rem;
		line-height: 1.55;
		color: var(--aurea-muted);
		margin-bottom: auto;
		flex: 1;
	}

	.guidance__card-path {
		display: grid;
		gap: 0.25rem;
		margin-top: 1.25rem;
		padding-top: 1rem;
		border-top: 1px solid var(--aurea-border);
	}

	.guidance__card-label {
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--aurea-champagne);
	}

	.guidance__card-treatment {
		font-size: 0.88rem;
		font-weight: 700;
		color: var(--aurea-charcoal);
	}

	@media (max-width: 1080px) {
		.guidance__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.guidance__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
