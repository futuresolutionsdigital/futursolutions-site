---
const processSteps = [
	{
		number: '01',
		title: 'Audit',
		text: 'We review your current website, offer, lead capture, and visibility — and write up what is and is not working.',
		deliverables: ['Site & funnel audit', 'Competitor scan', 'Priority list'],
		duration: 'Week 1',
	},
	{
		number: '02',
		title: 'Strategy',
		text: 'We map the page architecture, content, conversion path, and Growth Systems your practice actually needs.',
		deliverables: ['Sitemap & content plan', 'Lead system design', 'Launch scope'],
		duration: 'Week 1–2',
	},
	{
		number: '03',
		title: 'Build',
		text: 'We design and develop the site with clear structure, fast pages, and the lead and booking system wired in.',
		deliverables: ['Design system', 'Full build', 'CRM + automations'],
		duration: 'Weeks 2–6',
	},
	{
		number: '04',
		title: 'Optimize',
		text: 'We launch, watch the data, and keep tuning the site, content, and funnel as the practice grows.',
		deliverables: ['Launch & QA', 'Monthly tuning', 'Reporting cadence'],
		duration: 'Ongoing',
	},
];
---

<section id="process" class="section process-section" aria-labelledby="process-heading">
	<div class="site-container site-container--wide">
		<div class="process-section__head">
			<div class="process-section__intro">
				<p class="eyebrow">How the work moves</p>
				<h2 id="process-heading" class="display-lg">From audit to launch — and well past it.</h2>
				<p class="lead">
					Every engagement starts the same way: a calm, structured look at the website you have now and the system your practice actually needs. Then we build it.
				</p>
			</div>
			<div class="process-section__intro-meta">
				<div class="process-section__chip">
					<span class="process-section__chip-dot" aria-hidden="true"></span>
					<span>Typical engagement</span>
					<strong>4 – 8 weeks</strong>
				</div>
				<a class="process-section__intro-cta" href="/audit">
					Start with the audit
					<span aria-hidden="true">&rarr;</span>
				</a>
			</div>
		</div>

		<ol class="process-timeline" aria-label="Project process timeline">
			{
				processSteps.map((step, i) => (
					<li class="process-step">
						<div class="process-step__rail" aria-hidden="true">
							<span class="process-step__rail-dot" />
							{i < processSteps.length - 1 && <span class="process-step__rail-line" />}
						</div>
						<article class="process-step__card">
							<header class="process-step__header">
								<span class="process-step__number">{step.number}</span>
								<span class="process-step__duration">{step.duration}</span>
							</header>
							<h3 class="process-step__title">{step.title}</h3>
							<p class="process-step__text">{step.text}</p>
							<ul class="process-step__deliverables" aria-label={`${step.title} deliverables`}>
								{step.deliverables.map((d) => (
									<li>
										<span class="process-step__check" aria-hidden="true">
											<svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
												<polyline points="2,6 5,9 10,3" />
											</svg>
										</span>
										{d}
									</li>
								))}
							</ul>
						</article>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style>
	.process-section {
		background: var(--color-bg);
	}

	.process-section__head {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: end;
		margin-bottom: clamp(2.5rem, 4.5vw, 4rem);
	}

	.process-section__intro h2 {
		max-width: 18ch;
		margin-bottom: 1.25rem;
	}

	.process-section__intro-meta {
		display: grid;
		gap: 1.1rem;
		justify-items: start;
	}

	.process-section__chip {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.55rem 0.9rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-white);
		color: var(--color-text);
		font-size: 0.85rem;
	}

	.process-section__chip-dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 999px;
		background: var(--color-accent);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 18%, transparent);
	}

	.process-section__chip span {
		color: var(--color-muted);
	}

	.process-section__chip strong {
		color: var(--color-text);
		font-weight: 650;
	}

	.process-section__intro-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 650;
		transition: gap var(--transition-base);
	}

	.process-section__intro-cta:hover {
		gap: 0.55rem;
	}

	.process-section__intro-cta span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.process-section__intro-cta:hover span {
		transform: translateX(2px);
	}

	.process-timeline {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.process-step {
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 1.25rem;
		position: relative;
	}

	.process-step__rail {
		position: relative;
		display: flex;
		align-items: center;
		height: 12px;
	}

	.process-step__rail-dot {
		width: 12px;
		height: 12px;
		border: 2px solid var(--color-text);
		border-radius: 999px;
		background: var(--color-bg);
		flex-shrink: 0;
		z-index: 1;
	}

	.process-step__rail-line {
		flex: 1;
		height: 1px;
		margin-left: 0.5rem;
		background: linear-gradient(90deg, var(--color-border) 0%, var(--color-border) 70%, transparent 100%);
	}

	.process-step__card {
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-white);
		box-shadow: var(--shadow-card);
	}

	.process-step__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 0.9rem;
	}

	.process-step__number {
		font-size: 0.75rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.14em;
		color: var(--color-muted);
	}

	.process-step__duration {
		padding: 0.22rem 0.5rem;
		border-radius: 999px;
		background: var(--color-bg-secondary);
		color: var(--color-muted);
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.process-step__title {
		margin: 0 0 0.55rem 0;
		font-size: 1.35rem;
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.2;
	}

	.process-step__text {
		margin: 0 0 1.1rem 0;
		color: var(--color-muted);
		font-size: 0.93rem;
		line-height: 1.6;
	}

	.process-step__deliverables {
		display: grid;
		gap: 0.45rem;
		margin: 0;
		padding-top: 0.85rem;
		border-top: 1px solid var(--color-border-soft);
		list-style: none;
	}

	.process-step__deliverables li {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.55rem;
		align-items: center;
		color: var(--color-text);
		font-size: 0.86rem;
	}

	.process-step__check {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1rem;
		height: 1rem;
		border-radius: 999px;
		background: var(--color-text);
		color: var(--color-white);
	}

	.process-step__check svg {
		width: 0.65rem;
		height: 0.65rem;
	}

	@media (max-width: 980px) {
		.process-section__head {
			grid-template-columns: 1fr;
		}

		.process-timeline {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 620px) {
		.process-timeline {
			grid-template-columns: 1fr;
		}

		.process-step__rail-line {
			display: none;
		}
	}
</style>
