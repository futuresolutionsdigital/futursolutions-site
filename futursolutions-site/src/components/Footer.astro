---
const footerColumns = [
	{
		title: 'Solutions',
		links: [
			{ label: 'Website Foundations', href: '/services/template-setup' },
			{ label: 'Signature Custom Websites', href: '/services/custom-healthcare-websites' },
			{ label: 'Growth Systems', href: '/backend' },
			{ label: 'Website and Systems Audit', href: '/audit' },
			{ label: 'Care and Optimization', href: '/services/ongoing-optimization' },
		],
	},
	{
		title: 'Live demos',
		links: [
			{ label: 'Med Spa', href: '/templates/med-spa' },
			{ label: 'Solo Practice', href: '/templates/solo-practice' },
			{ label: 'Wellness Clinic', href: '/templates/premium-wellness-clinic' },
			{ label: 'Hormone / TRT', href: '/templates/hormone-trt' },
			{ label: 'Association', href: '/templates/association' },
			{ label: 'Browse all Foundations', href: '/templates' },
		],
	},
	{
		title: 'Company',
		links: [
			{ label: 'About', href: '/about' },
			{ label: 'Industries', href: '/industries' },
			{ label: 'Resources', href: '/resources' },
			{ label: 'Contact', href: '/contact' },
			{ label: 'Get a Website Audit', href: '/audit' },
		],
	},
];
---

<footer class="site-footer">
	<div class="site-container">
		<div class="site-footer__grid">
			<div class="site-footer__company">
				<a class="site-footer__brand" href="/">FutureSolutions</a>
				<p>Premium web design and growth systems for clinics, associations, and high-trust service businesses.</p>
				<ul class="site-footer__contact">
					<li>
						<span class="site-footer__contact-label">Email</span>
						<a href="mailto:admin@futuresolutions.io">admin@futuresolutions.io</a>
					</li>
					<li>
						<span class="site-footer__contact-label">Based in</span>
						<span>California, USA · Serving the US</span>
					</li>
				</ul>
			</div>

			{footerColumns.map((column) => (
				<nav class="site-footer__column" aria-label={`${column.title} footer links`}>
					<h2>{column.title}</h2>
					<ul>
						{column.links.map((link) => (
							<li>
								<a href={link.href}>{link.label}</a>
							</li>
						))}
					</ul>
				</nav>
			))}
		</div>

		<div class="site-footer__bottom">
			<p>&copy; {new Date().getFullYear()} Future Solutions Digital LLC. All rights reserved.</p>
			<nav class="site-footer__legal" aria-label="Legal links">
				<a href="/privacy">Privacy Policy</a>
				<a href="/terms">Terms of Service</a>
			</nav>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--color-border);
		background: var(--color-bg);
	}

	.site-footer__grid {
		display: grid;
		grid-template-columns: minmax(240px, 1.4fr) repeat(3, minmax(0, 1fr));
		gap: clamp(2rem, 5vw, 4rem);
		padding-block: clamp(3rem, 6vw, 4.5rem);
	}

	.site-footer__brand {
		display: inline-flex;
		margin-bottom: 0.75rem;
		color: var(--color-text);
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: -0.035em;
	}

	.site-footer p {
		max-width: 360px;
		font-size: 0.9375rem;
		line-height: 1.55;
	}

	.site-footer__contact {
		display: grid;
		gap: 0.6rem;
		margin: 1.25rem 0 0 0;
		padding: 0;
		list-style: none;
	}

	.site-footer__contact li {
		display: grid;
		gap: 0.1rem;
		font-size: 0.9rem;
	}

	.site-footer__contact-label {
		color: var(--color-muted-soft);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.site-footer__contact a {
		color: var(--color-text);
		font-weight: 600;
	}

	.site-footer__contact a:hover {
		color: var(--color-accent-dark);
	}

	.site-footer__column h2 {
		margin-bottom: 1rem;
		color: var(--color-text);
		font-size: 0.8125rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.site-footer__column ul {
		display: grid;
		gap: 0.65rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-footer__column a {
		display: inline-flex;
		color: var(--color-muted);
		font-size: 0.9375rem;
		font-weight: 600;
		line-height: 1.35;
	}

	.site-footer__column a:hover {
		color: var(--color-text);
	}

	.site-footer__bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75rem 1.5rem;
		padding-block: 1.25rem 1.5rem;
		border-top: 1px solid var(--color-border);
	}

	.site-footer__bottom p {
		margin: 0;
		font-size: 0.875rem;
	}

	.site-footer__legal {
		display: flex;
		flex-wrap: wrap;
		gap: 1.25rem;
	}

	.site-footer__legal a {
		color: var(--color-muted);
		font-size: 0.875rem;
		font-weight: 600;
	}

	.site-footer__legal a:hover {
		color: var(--color-text);
	}

	@media (max-width: 900px) {
		.site-footer__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 620px) {
		.site-footer__grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
