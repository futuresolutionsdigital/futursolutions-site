---
const footerColumns = [
	{
		title: 'Services',
		links: [
			{ label: 'Website Templates', href: '/templates' },
			{ label: 'Custom Websites', href: '/services' },
			{ label: 'SEO / Local Visibility', href: '/seo' },
			{ label: 'Backend Systems', href: '/backend' },
			{ label: 'Ongoing Optimization', href: '/services' },
		],
	},
	{
		title: 'Templates',
		links: [
			{ label: 'Med Spa Template', href: '/templates/med-spa' },
			{ label: 'Solo Practice Template', href: '/templates/solo-practice' },
			{ label: 'Association Template', href: '/templates/association' },
			{ label: 'View All Templates', href: '/templates' },
		],
	},
	{
		title: 'Resources',
		links: [
			{ label: 'Resources', href: '/resources' },
			{ label: 'Website Audit', href: '/audit' },
			{ label: 'Services', href: '/services' },
		],
	},
];
---

<footer class="site-footer">
	<div class="site-container">
		<div class="site-footer__grid">
			<div class="site-footer__company">
				<a class="site-footer__brand" href="/">Future Solutions</a>
				<p>Modern healthcare websites, templates, SEO foundations, and backend systems for health and wellness businesses.</p>
			</div>

			{footerColumns.map((column) => (
				<nav class="site-footer__column" aria-label={`${column.title} footer links`}>
					<h2>{column.title}</h2>
					<ul>
						{column.links.map((link) => (
							<li>
								<a href={link.href}>{link.label}</a>
							</li>
						))}
					</ul>
				</nav>
			))}
		</div>

		<div class="site-footer__bottom">
			<p>&copy; {new Date().getFullYear()} Future Solutions. All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--color-border);
		background: var(--color-bg);
	}

	.site-footer__grid {
		display: grid;
		grid-template-columns: minmax(220px, 1.3fr) repeat(3, minmax(0, 1fr));
		gap: clamp(2rem, 5vw, 4rem);
		padding-block: clamp(3rem, 6vw, 4.5rem);
	}

	.site-footer__brand {
		display: inline-flex;
		margin-bottom: 0.75rem;
		color: var(--color-text);
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: -0.035em;
	}

	.site-footer p {
		max-width: 360px;
		font-size: 0.9375rem;
		line-height: 1.55;
	}

	.site-footer__column h2 {
		margin-bottom: 1rem;
		color: var(--color-text);
		font-size: 0.8125rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.site-footer__column ul {
		display: grid;
		gap: 0.65rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-footer__column a {
		display: inline-flex;
		color: var(--color-muted);
		font-size: 0.9375rem;
		font-weight: 600;
		line-height: 1.35;
	}

	.site-footer__column a:hover {
		color: var(--color-accent-dark);
	}

	.site-footer__bottom {
		padding-block: 1.25rem 1.5rem;
		border-top: 1px solid var(--color-border);
	}

	.site-footer__bottom p {
		margin: 0;
		font-size: 0.875rem;
	}

	@media (max-width: 900px) {
		.site-footer__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 620px) {
		.site-footer__grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
