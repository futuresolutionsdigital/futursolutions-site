---
const includes = [
	'Clarity',
	'Trust',
	'Conversion path',
	'Local visibility',
	'Follow-up',
	'Tracking',
];
---

<section id="audit" class="section-loose final-cta section-ink" aria-labelledby="final-cta-heading">
	<div class="dot-grid dot-grid--ink final-cta__dots" aria-hidden="true"></div>
	<div class="final-cta__glow" aria-hidden="true"></div>

	<div class="site-container site-container--wide final-cta__inner">
		<div class="final-cta__main">
			<p class="eyebrow">Start with a free snapshot</p>
			<h2 id="final-cta-heading" class="display-lg final-cta__headline">
				Get a clear snapshot of your website
				<span class="final-cta__headline-soft">and lead flow.</span>
			</h2>
			<p class="lead final-cta__lead">
				I'll review your positioning, service pages, conversion path, local visibility, and follow-up flow, then send a short Loom with the clearest opportunities and best starting point.
			</p>
			<p class="final-cta__microline">Free Loom review. Clear recommendation. No pressure.</p>

			<div class="final-cta__actions">
				<a class="button button-on-ink final-cta__primary" href="/audit">
					Get My Free Snapshot
					<span aria-hidden="true">&rarr;</span>
				</a>
				<a class="button button-on-ink-secondary" href="/templates">Explore Website Foundations</a>
			</div>
		</div>

		<aside class="final-cta__side" aria-label="What I'll review in your free snapshot">
			<p class="final-cta__side-label">What I'll review</p>
			<ul class="final-cta__side-list">
				{
					includes.map((item) => (
						<li>
							<span class="final-cta__side-check" aria-hidden="true">
								<svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<polyline points="2,6 5,9 10,3" />
								</svg>
							</span>
							{item}
						</li>
					))
				}
			</ul>
			<p class="final-cta__side-note">A clear recommendation before you commit to a build.</p>
		</aside>
	</div>
</section>

<style>
	.final-cta {
		position: relative;
		overflow: hidden;
	}

	.final-cta__dots {
		mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, #000 40%, transparent 85%);
		-webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, #000 40%, transparent 85%);
	}

	.final-cta__glow {
		position: absolute;
		top: -10rem;
		left: 50%;
		width: 65rem;
		height: 30rem;
		pointer-events: none;
		background: radial-gradient(ellipse at center, rgba(143, 184, 179, 0.18), transparent 60%);
		transform: translateX(-50%);
		filter: blur(20px);
	}

	.final-cta__inner {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.85fr);
		gap: clamp(2.5rem, 5vw, 4.5rem);
		align-items: start;
	}

	.final-cta__main h2 {
		max-width: 22ch;
		margin-bottom: 1.25rem;
	}

	.final-cta__headline {
		color: var(--color-white);
	}

	.final-cta__headline-soft {
		display: block;
		color: var(--color-ink-muted);
		font-weight: 600;
	}

	.final-cta__lead {
		max-width: 60ch;
		margin: 0 0 0.85rem 0;
	}

	.final-cta__microline {
		max-width: 60ch;
		margin: 0 0 2rem 0;
		color: var(--color-ink-accent);
		font-size: 0.92rem;
		font-weight: 600;
		letter-spacing: 0.005em;
	}

	.final-cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
	}

	.final-cta__primary span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.final-cta__primary:hover span {
		transform: translateX(2px);
	}

	.final-cta__side {
		padding: 1.85rem;
		border: 1px solid var(--color-ink-line-strong);
		border-radius: var(--radius-lg);
		background: var(--color-ink-soft);
	}

	.final-cta__side-label {
		margin: 0 0 1.1rem 0;
		color: var(--color-ink-accent);
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.final-cta__side-list {
		display: grid;
		gap: 0.8rem;
		margin: 0 0 1.5rem 0;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-ink-line);
		list-style: none;
	}

	.final-cta__side-list li {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.7rem;
		align-items: center;
		color: var(--color-ink-text);
		font-size: 0.93rem;
		line-height: 1.45;
	}

	.final-cta__side-check {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.1rem;
		height: 1.1rem;
		border-radius: 999px;
		background: var(--color-ink-accent);
		color: var(--color-ink);
	}

	.final-cta__side-check svg {
		width: 0.7rem;
		height: 0.7rem;
	}

	.final-cta__side-note {
		margin: 0;
		color: var(--color-ink-muted);
		font-size: 0.85rem;
		font-style: italic;
		line-height: 1.5;
	}

	@media (max-width: 980px) {
		.final-cta__inner {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 480px) {
		.final-cta__actions {
			flex-direction: column;
			align-items: stretch;
		}

		.final-cta__actions .button {
			justify-content: center;
		}
	}
</style>
