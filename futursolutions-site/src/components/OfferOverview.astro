---
const offers = [
	{
		lane: 'foundation',
		number: '01',
		title: 'Website Foundations',
		state: 'For outdated sites or fast professional launches',
		priceFrom: 'from $3,500',
		summary:
			'Launch a premium website from a proven FutureSolutions foundation, customized around your brand, services, pages, and lead path.',
		bestFor: 'Solo practices, med spas, wellness brands, clinics, consultants, and service businesses that need a stronger site without a fully custom process.',
		bullets: [
			'Curated demo framework customized to your business',
			'Core pages, service structure, and conversion path',
			'Accessible editing layer for ongoing content updates',
		],
		ctaLabel: 'Explore Website Foundations',
		ctaHref: '/templates',
		flag: 'Most popular',
		flagStyle: 'popular',
		emphasized: true,
	},
	{
		lane: 'custom',
		number: '02',
		title: 'Signature Custom Websites',
		state: 'For established businesses needing a premium custom presence',
		priceFrom: 'from $12,000',
		summary:
			'Create a fully custom website experience around your brand, services, content structure, and customer journey.',
		bestFor: 'Established clinics, associations, professional service businesses, and organizations with unique positioning or more complex content needs.',
		bullets: [
			'Custom design direction and page architecture',
			'Deeper brand, messaging, and content strategy',
			'Built around complex services, audiences, or workflows',
		],
		ctaLabel: 'Plan a Custom Build',
		ctaHref: '/services/custom-healthcare-websites',
		emphasized: false,
	},
	{
		lane: 'growth',
		number: '03',
		title: 'Growth Systems',
		state: 'For teams ready to connect website, CRM, and follow-up',
		priceFrom: 'from $2,500 setup + $500/mo',
		summary:
			'Connect your website to a backend system for lead capture, booking, CRM routing, follow-up, review requests, and reporting.',
		bestFor: 'Businesses that receive inquiries, miss follow-ups, run ads, or need a more organized path from website visitor to booked lead.',
		bullets: [
			'Forms, booking, and CRM pipeline setup',
			'Automated follow-up and lead notifications',
			'Review requests, reporting, and system support',
		],
		note: 'Can be added to a new FutureSolutions website or connected to an existing site.',
		ctaLabel: 'Add a Growth System',
		ctaHref: '/services/growth-systems',
		flag: 'Growth layer',
		flagStyle: 'layer',
		emphasized: false,
	},
];

const stackLayers = [
	{ lane: 'foundation', name: 'Website Foundations', formula: 'Premium website foundation' },
	{ lane: 'custom', name: 'Signature Custom', formula: 'Custom strategy + custom website' },
	{ lane: 'growth', name: 'Growth Systems', formula: 'CRM + booking + follow-up + reporting' },
	{ lane: 'complete', name: 'Complete Growth Build', formula: 'Website + CRM + follow-up + management' },
];
---

<section class="offer-overview" aria-labelledby="offer-overview-heading">
	<div class="site-container site-container--wide">
		<header class="offer-overview__head">
			<p class="eyebrow">Your starting point</p>
			<h2 id="offer-overview-heading" class="display-lg">
				Start with the right website.
				<span class="offer-overview__head-soft">Add the systems when you're ready to grow.</span>
			</h2>
			<p class="lead offer-overview__lead">
				Most clients start with a customized Website Foundation: a premium site built from a proven FutureSolutions framework and tailored to their brand, services, and customer journey. For more complex needs, we offer fully custom builds. For businesses ready to improve lead handling, we connect the website to CRM, booking, follow-up, and reporting.
			</p>
		</header>

		<ul class="offer-overview__grid">
			{
				offers.map((offer) => (
					<li class:list={[`offer-overview__card lane-accent-top lane-accent-top--${offer.lane}`, { 'offer-overview__card--emphasized': offer.emphasized }]}>
						{offer.flag && <span class:list={['offer-overview__flag', `offer-overview__flag--${offer.flagStyle}`]}>{offer.flag}</span>}
						<div class="offer-overview__card-top">
							<span class={`lane-tag lane-tag--${offer.lane}`}>{offer.number}</span>
							<span class={`offer-overview__motif offer-overview__motif--${offer.lane}`} aria-hidden="true">
								{offer.lane === 'foundation' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="5" width="16" height="4" rx="1" /><rect x="4" y="11" width="16" height="4" rx="1" /><rect x="4" y="17" width="10" height="2.5" rx="1" /></svg>
								)}
								{offer.lane === 'custom' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2" /><path d="M3 9h18M9 9v11" /></svg>
								)}
								{offer.lane === 'growth' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="2" /><circle cx="19" cy="6" r="2" /><circle cx="19" cy="18" r="2" /><path d="M7 12h6M13 12l4-5M13 12l4 5" /></svg>
								)}
							</span>
						</div>

						<span class={`offer-overview__state offer-overview__state--${offer.lane}`}>{offer.state}</span>

						<h3 class="offer-overview__card-title">{offer.title}</h3>

						<p class="offer-overview__price">{offer.priceFrom}</p>

						<p class="offer-overview__card-summary">{offer.summary}</p>

						<ul class="offer-overview__bullets">
							{offer.bullets.map((b) => (
								<li>
									<svg
										aria-hidden="true"
										viewBox="0 0 20 20"
										fill="none"
										stroke="currentColor"
										stroke-width="1.8"
										stroke-linejoin="round"
										stroke-linecap="round"
									>
										<path d="M4 10.5l4 4 8-9" />
									</svg>
									<span>{b}</span>
								</li>
							))}
						</ul>

						{offer.note && <p class="offer-overview__note">{offer.note}</p>}

						<div class="offer-overview__best">
							<span class="offer-overview__best-label">Best for</span>
							<p>{offer.bestFor}</p>
						</div>

						<a class="offer-overview__cta" href={offer.ctaHref}>
							{offer.ctaLabel}
							<span aria-hidden="true">&rarr;</span>
						</a>
					</li>
				))
			}
		</ul>

		<div class="offer-overview__stack" aria-label="How the offers build on one another">
			<p class="offer-overview__stack-label">Each offer adds another layer of the system</p>
			<ol class="offer-overview__stack-track">
				{stackLayers.map((layer, i) => (
					<li class={`offer-overview__stack-item offer-overview__stack-item--${layer.lane}`}>
						<span class="offer-overview__stack-name">{layer.name}</span>
						<span class="offer-overview__stack-eq" aria-hidden="true">=</span>
						<span class="offer-overview__stack-formula">{layer.formula}</span>
					</li>
				))}
			</ol>
		</div>

		<aside class="offer-overview__audit lane-accent-top lane-accent-top--audit" aria-label="Free Website and Lead Flow Snapshot">
			<div class="offer-overview__audit-main">
				<span class="lane-tag lane-tag--audit">04 · Free snapshot</span>
				<h3 class="offer-overview__audit-title">Not sure where your website is leaking leads?</h3>
				<p class="offer-overview__audit-copy">
					Start with a free <strong>Website &amp; Lead Flow Snapshot</strong>. I'll review your site, message clarity, lead path, and follow-up flow, then send a short Loom with the biggest opportunities I see and the best starting point.
				</p>
			</div>

			<div class="offer-overview__audit-cta">
				<a class="button button-primary" href="/audit">
					Get a Free Snapshot
					<span aria-hidden="true">&rarr;</span>
				</a>
				<p class="offer-overview__audit-note">Free Loom review · Clear recommendation · No pressure</p>
			</div>
		</aside>
	</div>
</section>

<style>
	.offer-overview {
		padding-block: var(--section-spacing);
		background: var(--color-white);
	}

	.offer-overview__head {
		display: grid;
		gap: 1.1rem;
		max-width: 56rem;
		margin: 0 0 clamp(2.5rem, 5vw, 3.5rem);
	}

	.offer-overview__head-soft {
		display: block;
		color: var(--color-muted);
		font-weight: 650;
	}

	.offer-overview__lead {
		max-width: 52rem;
		color: var(--color-muted);
	}

	.offer-overview__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.25rem;
		margin: 0 0 1.5rem;
		padding: 0;
		list-style: none;
	}

	.offer-overview__card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1.75rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: var(--shadow-card);
		transition: transform 320ms var(--ease-out-quart),
			box-shadow var(--transition-base),
			border-color var(--transition-base);
	}

	.offer-overview__card.lane-accent-top::before {
		height: 5px;
	}

	.offer-overview__card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-card-hover);
	}

	.offer-overview__card.lane-accent-top--foundation:hover {
		border-color: color-mix(in srgb, var(--lane-foundation) 38%, var(--color-border));
	}

	.offer-overview__card.lane-accent-top--custom:hover {
		border-color: color-mix(in srgb, var(--lane-custom) 32%, var(--color-border));
	}

	.offer-overview__card.lane-accent-top--growth:hover {
		border-color: color-mix(in srgb, var(--lane-growth) 38%, var(--color-border));
	}

	.offer-overview__card.lane-accent-top--foundation .offer-overview__bullets svg { color: var(--lane-foundation); }
	.offer-overview__card.lane-accent-top--custom     .offer-overview__bullets svg { color: var(--lane-custom); }
	.offer-overview__card.lane-accent-top--growth     .offer-overview__bullets svg { color: var(--lane-growth); }

	.offer-overview__card--emphasized {
		border-color: color-mix(in srgb, var(--lane-foundation) 42%, var(--color-border));
		box-shadow: 0 0 0 1px color-mix(in srgb, var(--lane-foundation) 24%, transparent), var(--shadow-card);
	}

	.offer-overview__flag {
		position: absolute;
		top: 0;
		right: 1.25rem;
		transform: translateY(-50%);
		padding: 0.28rem 0.6rem;
		border-radius: 999px;
		font-size: 0.66rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	/* Primary/default emphasis — solid Foundation accent */
	.offer-overview__flag--popular {
		background: var(--lane-foundation);
		color: var(--color-white);
		box-shadow: 0 4px 12px color-mix(in srgb, var(--lane-foundation) 30%, transparent);
	}

	/* Add-on/system layer — subtler tinted pill so it reads as supporting, not dominant */
	.offer-overview__flag--layer {
		background: var(--lane-growth-tint);
		color: var(--lane-growth-ink);
		border: 1px solid color-mix(in srgb, var(--lane-growth) 32%, transparent);
	}

	.offer-overview__note {
		margin: -0.25rem 0 0;
		padding-left: 0.85rem;
		border-left: 2px solid color-mix(in srgb, var(--lane-growth) 35%, var(--color-border-soft));
		color: var(--color-muted);
		font-size: 0.82rem;
		font-style: italic;
		line-height: 1.5;
	}

	.offer-overview__stack {
		margin: 0 0 1.5rem;
		padding: 1.25rem 1.5rem 1.4rem;
		border: 1px solid var(--color-border-soft);
		border-radius: var(--radius-lg);
		background: var(--color-bg);
	}

	.offer-overview__stack-label {
		margin: 0 0 1rem;
		color: var(--color-text);
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.offer-overview__stack-track {
		display: grid;
		gap: 0.6rem;
		margin: 0;
		padding: 0;
		list-style: none;
		counter-reset: stack;
	}

	.offer-overview__stack-item {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem 0.9rem;
		padding: 0.85rem 1.1rem;
		border: 1px solid var(--color-border-soft);
		border-left-width: 4px;
		border-radius: var(--radius-sm);
		background: var(--color-white);
	}

	.offer-overview__stack-item--foundation { border-left-color: var(--lane-foundation); }
	.offer-overview__stack-item--custom     { border-left-color: var(--lane-custom); }
	.offer-overview__stack-item--growth      { border-left-color: var(--lane-growth); }
	.offer-overview__stack-item--complete    { border-left-color: var(--lane-audit); background: color-mix(in srgb, var(--lane-audit-tint) 45%, var(--color-white)); }

	.offer-overview__stack-name {
		min-width: 12rem;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.offer-overview__stack-eq {
		color: var(--color-muted);
		font-weight: 700;
	}

	.offer-overview__stack-formula {
		color: var(--color-muted);
		font-size: 0.92rem;
		font-weight: 600;
		letter-spacing: -0.005em;
	}

	.offer-overview__stack-item--growth .offer-overview__stack-formula {
		color: var(--lane-growth-ink);
		font-weight: 700;
	}

	.offer-overview__stack-item--complete .offer-overview__stack-formula {
		color: var(--lane-audit-ink);
		font-weight: 700;
	}

	.offer-overview__card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}

	.offer-overview__motif {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		border-radius: 11px;
		border: 1px solid var(--color-border-soft);
		background: var(--color-bg);
	}

	.offer-overview__motif svg {
		width: 1.3rem;
		height: 1.3rem;
	}

	.offer-overview__motif--foundation { color: var(--lane-foundation-ink); background: var(--lane-foundation-tint); border-color: color-mix(in srgb, var(--lane-foundation) 18%, var(--color-border-soft)); }
	.offer-overview__motif--custom     { color: var(--lane-custom-ink); background: var(--lane-custom-tint); border-color: color-mix(in srgb, var(--lane-custom) 14%, var(--color-border-soft)); }
	.offer-overview__motif--growth     { color: var(--lane-growth-ink); background: var(--lane-growth-tint); border-color: color-mix(in srgb, var(--lane-growth) 18%, var(--color-border-soft)); }

	.offer-overview__state {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		padding: 0.32rem 0.7rem;
		border-radius: 999px;
		font-size: 0.74rem;
		font-weight: 750;
		letter-spacing: -0.005em;
		line-height: 1.2;
	}

	.offer-overview__state--foundation { background: var(--lane-foundation-tint); color: var(--lane-foundation-ink); }
	.offer-overview__state--custom     { background: var(--lane-custom-tint); color: var(--lane-custom-ink); }
	.offer-overview__state--growth     { background: var(--lane-growth-tint); color: var(--lane-growth-ink); }

	.offer-overview__card-title {
		margin: 0;
		font-size: clamp(1.25rem, 1.05rem + 0.5vw, 1.45rem);
		font-weight: 700;
		letter-spacing: -0.025em;
		line-height: 1.25;
	}

	.offer-overview__price {
		margin: -0.35rem 0 0;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 750;
		letter-spacing: -0.01em;
	}

	.offer-overview__card-summary {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.96rem;
		line-height: 1.6;
	}

	.offer-overview__bullets {
		display: grid;
		gap: 0.55rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.offer-overview__bullets li {
		display: grid;
		grid-template-columns: 1rem 1fr;
		gap: 0.55rem;
		align-items: start;
		color: var(--color-text);
		font-size: 0.92rem;
		line-height: 1.5;
	}

	.offer-overview__bullets svg {
		width: 1rem;
		height: 1rem;
		margin-top: 0.2rem;
		color: var(--color-muted);
	}

	.offer-overview__best {
		margin-top: auto;
		padding: 0.85rem 1rem;
		border: 1px solid var(--color-border-soft);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
	}

	.offer-overview__best-label {
		display: block;
		margin-bottom: 0.2rem;
		color: var(--color-muted);
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.offer-overview__best p {
		margin: 0;
		color: var(--color-text);
		font-size: 0.875rem;
		line-height: 1.5;
	}

	.offer-overview__cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 650;
		letter-spacing: -0.01em;
		text-decoration: none;
	}

	.offer-overview__cta:hover {
		gap: 0.6rem;
	}

	.offer-overview__cta span {
		transition: transform var(--transition-base);
	}

	.offer-overview__cta:hover span {
		transform: translateX(3px);
	}

	.offer-overview__audit {
		position: relative;
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		align-items: center;
		gap: clamp(1.5rem, 4vw, 3rem);
		padding: clamp(1.75rem, 4vw, 2.5rem);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: linear-gradient(135deg, var(--color-white) 0%, var(--lane-audit-tint) 100%);
		box-shadow: var(--shadow-card);
	}

	.offer-overview__audit-main {
		display: grid;
		gap: 0.85rem;
	}

	.offer-overview__audit-title {
		margin: 0;
		font-size: clamp(1.4rem, 1.1rem + 0.8vw, 1.75rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.2;
	}

	.offer-overview__audit-copy {
		margin: 0;
		max-width: 44rem;
		color: var(--color-muted);
		font-size: 0.96rem;
		line-height: 1.6;
	}

	.offer-overview__audit-copy strong {
		color: var(--color-text);
		font-weight: 700;
	}

	.offer-overview__audit-cta {
		display: grid;
		gap: 0.65rem;
		justify-items: start;
	}

	.offer-overview__audit-note {
		margin: 0;
		color: var(--lane-audit-ink);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.005em;
	}

	@media (max-width: 1024px) {
		.offer-overview__grid {
			grid-template-columns: 1fr;
		}

		.offer-overview__audit {
			grid-template-columns: 1fr;
		}

		.offer-overview__audit-cta {
			justify-items: start;
		}
	}
</style>
