---
const rows = [
	{ label: 'First impression', note: 'Credible and modern in 3 seconds?', score: 4, potential: 5, status: 'Strong', tone: 'good' },
	{ label: 'Service clarity', note: 'Can visitors tell what you offer?', score: 3, potential: 5, status: 'Needs work', tone: 'warn' },
	{ label: 'Conversion path', note: 'Is the next step obvious everywhere?', score: 2, potential: 5, status: 'Gap', tone: 'gap' },
	{ label: 'Local visibility', note: 'Do you show up in local search?', score: 3, potential: 5, status: 'Needs work', tone: 'warn' },
	{ label: 'Mobile experience', note: 'Fast and clean on a phone?', score: 4, potential: 5, status: 'Strong', tone: 'good' },
	{ label: 'Follow-up system', note: 'Are inquiries captured and nurtured?', score: 1, potential: 5, status: 'Gap', tone: 'gap' },
];

const overall = Math.round((rows.reduce((sum, r) => sum + r.score, 0) / (rows.length * 5)) * 100);
const potential = Math.round((rows.reduce((sum, r) => sum + r.potential, 0) / (rows.length * 5)) * 100);
const dash = 2 * Math.PI * 52;
const filled = (overall / 100) * dash;
const gaps = rows.filter((r) => r.tone === 'gap').length;
---

<section class="scorecard" aria-labelledby="scorecard-heading">
	<div class="site-container site-container--wide scorecard__inner">
		<div class="scorecard__intro">
			<p class="eyebrow">What you'll receive</p>
			<h2 id="scorecard-heading">A clear scorecard — not a vague opinion.</h2>
			<p class="lead">
				Your audit comes back as a structured read on the six things that decide whether a healthcare site converts. You see exactly where you're strong, where you're leaking patients, and what to fix first — with the upside spelled out.
			</p>
			<ul class="scorecard__points">
				<li>
					<span class="scorecard__point-icon" aria-hidden="true"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10.5l4 4 8-9" /></svg></span>
					<span><strong>Scored across six conversion dimensions</strong> — the factors that actually move bookings</span>
				</li>
				<li>
					<span class="scorecard__point-icon" aria-hidden="true"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10.5l4 4 8-9" /></svg></span>
					<span><strong>Prioritized fixes</strong> — what to change first for the biggest gain</span>
				</li>
				<li>
					<span class="scorecard__point-icon" aria-hidden="true"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10.5l4 4 8-9" /></svg></span>
					<span><strong>A recommended next step</strong> — Foundation, Custom, Growth, or nothing urgent</span>
				</li>
			</ul>
			<a class="button button-primary scorecard__cta" href="#audit-form">
				Get your scorecard
				<span aria-hidden="true">&rarr;</span>
			</a>
			<p class="scorecard__cta-note">Free · Delivered within 2 business days · No sales pitch</p>
		</div>

		<figure class="scorecard__card" aria-label="Illustrative example of an audit scorecard">
			<figcaption class="scorecard__card-head">
				<div>
					<span class="scorecard__card-kicker">Website &amp; Systems Audit</span>
					<span class="scorecard__card-title">Sample scorecard</span>
				</div>
				<span class="scorecard__badge">Illustrative</span>
			</figcaption>

			<div class="scorecard__overall">
				<div class="scorecard__ring" role="img" aria-label={`Overall score ${overall} out of 100, potential ${potential}`}>
					<svg viewBox="0 0 120 120">
						<circle class="scorecard__ring-track" cx="60" cy="60" r="52" />
						<circle
							class="scorecard__ring-fill"
							cx="60"
							cy="60"
							r="52"
							style={`stroke-dasharray: ${filled} ${dash}; stroke-dashoffset: 0;`}
						/>
					</svg>
					<div class="scorecard__ring-label">
						<span class="scorecard__ring-num">{overall}</span>
						<span class="scorecard__ring-unit">/ 100 today</span>
					</div>
				</div>
				<div class="scorecard__overall-text">
					<p class="scorecard__overall-title">{gaps} priority gaps found</p>
					<p class="scorecard__overall-sub">Solid foundation, but the conversion path and follow-up are leaking inquiries.</p>
					<span class="scorecard__potential">
						<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l4-4 3 3 4-6M13 4h-2.5M13 4v2.5" /></svg>
						Potential after fixes: <strong>{potential}/100</strong>
					</span>
				</div>
			</div>

			<ul class="scorecard__rows">
				{rows.map((row) => (
					<li class="scorecard__row">
						<span class="scorecard__row-info">
							<span class="scorecard__row-label">{row.label}</span>
							<span class="scorecard__row-note">{row.note}</span>
						</span>
						<span class="scorecard__meter" aria-hidden="true">
							<span class="scorecard__meter-ghost" style={`width: ${row.potential * 20}%`}></span>
							<span class={`scorecard__meter-fill scorecard__meter-fill--${row.tone}`} style={`width: ${row.score * 20}%`}></span>
						</span>
						<span class={`scorecard__status scorecard__status--${row.tone}`}>{row.status}</span>
					</li>
				))}
			</ul>

			<div class="scorecard__deliver">
				<span class="scorecard__deliver-icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z" /><rect x="1" y="5" width="15" height="14" rx="2" /></svg>
				</span>
				<p>Delivered as a <strong>Loom walkthrough + written notes</strong> — clear enough to act on, with or without us.</p>
			</div>
		</figure>
	</div>
</section>

<style>
	.scorecard {
		padding-block: var(--section-spacing);
		background: var(--color-bg);
		border-block: 1px solid var(--color-border);
	}

	.scorecard__inner {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
		align-items: center;
		gap: clamp(2rem, 5vw, 4rem);
	}

	.scorecard__intro {
		max-width: 34rem;
	}

	.scorecard__points {
		display: grid;
		gap: 0.85rem;
		margin: 1.75rem 0 2rem;
		padding: 0;
		list-style: none;
	}

	.scorecard__points li {
		display: grid;
		grid-template-columns: 1.5rem 1fr;
		gap: 0.7rem;
		align-items: start;
		color: var(--color-text);
		font-size: 0.96rem;
		line-height: 1.5;
	}

	.scorecard__points li strong {
		font-weight: 750;
	}

	.scorecard__point-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		margin-top: 0.05rem;
		border-radius: 999px;
		background: var(--lane-foundation-tint);
		color: var(--lane-foundation-ink);
	}

	.scorecard__point-icon svg {
		width: 0.95rem;
		height: 0.95rem;
	}

	.scorecard__cta span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.scorecard__cta:hover span {
		transform: translateX(3px);
	}

	.scorecard__cta-note {
		margin: 0.85rem 0 0;
		color: var(--color-muted);
		font-size: 0.85rem;
		font-weight: 600;
	}

	/* The report card */
	.scorecard__card {
		margin: 0;
		padding: clamp(1.5rem, 3vw, 2.25rem);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: 0 2px 4px rgba(15, 23, 42, 0.05), 0 36px 70px rgba(15, 23, 42, 0.12);
	}

	.scorecard__card-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		padding-bottom: 1.25rem;
		border-bottom: 1px solid var(--color-border-soft);
	}

	.scorecard__card-kicker {
		display: block;
		color: var(--color-muted);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.scorecard__card-title {
		display: block;
		margin-top: 0.25rem;
		color: var(--color-text);
		font-size: 1.25rem;
		font-weight: 800;
		letter-spacing: -0.02em;
	}

	.scorecard__badge {
		flex-shrink: 0;
		padding: 0.28rem 0.6rem;
		border-radius: 999px;
		background: var(--lane-audit-tint);
		border: 1px solid color-mix(in srgb, var(--lane-audit) 30%, transparent);
		color: var(--lane-audit-ink);
		font-size: 0.66rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.scorecard__overall {
		display: flex;
		align-items: center;
		gap: 1.35rem;
		padding: 1.5rem 0;
		border-bottom: 1px solid var(--color-border-soft);
	}

	.scorecard__ring {
		position: relative;
		width: 6.5rem;
		height: 6.5rem;
		flex-shrink: 0;
	}

	.scorecard__ring svg {
		width: 100%;
		height: 100%;
		transform: rotate(-90deg);
	}

	.scorecard__ring-track {
		fill: none;
		stroke: var(--color-border);
		stroke-width: 9;
	}

	.scorecard__ring-fill {
		fill: none;
		stroke: var(--lane-audit);
		stroke-width: 9;
		stroke-linecap: round;
		transition: stroke-dasharray 900ms var(--ease-out-quart);
	}

	.scorecard__ring-label {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		line-height: 1;
	}

	.scorecard__ring-num {
		color: var(--color-text);
		font-size: 1.75rem;
		font-weight: 800;
		letter-spacing: -0.03em;
	}

	.scorecard__ring-unit {
		margin-top: 0.2rem;
		color: var(--color-muted);
		font-size: 0.66rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.scorecard__overall-title {
		margin: 0 0 0.25rem;
		color: var(--color-text);
		font-size: 1.1rem;
		font-weight: 800;
		letter-spacing: -0.015em;
	}

	.scorecard__overall-sub {
		margin: 0 0 0.6rem;
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.5;
	}

	.scorecard__potential {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.3rem 0.65rem;
		border-radius: 999px;
		background: var(--lane-foundation-tint);
		border: 1px solid color-mix(in srgb, var(--lane-foundation) 25%, transparent);
		color: var(--lane-foundation-ink);
		font-size: 0.8rem;
		font-weight: 650;
	}

	.scorecard__potential strong {
		font-weight: 850;
	}

	.scorecard__potential svg {
		width: 0.9rem;
		height: 0.9rem;
	}

	.scorecard__rows {
		display: grid;
		gap: 1rem;
		margin: 1.5rem 0 0;
		padding: 0;
		list-style: none;
	}

	.scorecard__row {
		display: grid;
		grid-template-columns: 11rem 1fr 5.5rem;
		align-items: center;
		gap: 0.9rem;
	}

	.scorecard__row-info {
		display: grid;
		gap: 0.1rem;
	}

	.scorecard__row-label {
		color: var(--color-text);
		font-size: 0.9rem;
		font-weight: 700;
	}

	.scorecard__row-note {
		color: var(--color-muted);
		font-size: 0.74rem;
		line-height: 1.35;
	}

	.scorecard__meter {
		position: relative;
		height: 0.6rem;
		border-radius: 999px;
		background: var(--color-bg-secondary);
		overflow: hidden;
	}

	.scorecard__meter-ghost {
		position: absolute;
		inset: 0 auto 0 0;
		height: 100%;
		border-radius: 999px;
		background: repeating-linear-gradient(90deg, var(--color-border), var(--color-border) 3px, transparent 3px, transparent 6px);
		opacity: 0.7;
	}

	.scorecard__meter-fill {
		position: relative;
		display: block;
		height: 100%;
		border-radius: 999px;
		transition: width 900ms var(--ease-out-quart);
	}

	.scorecard__meter-fill--good { background: var(--lane-foundation); }
	.scorecard__meter-fill--warn { background: var(--lane-audit); }
	.scorecard__meter-fill--gap  { background: #C2553F; }

	.scorecard__status {
		justify-self: end;
		padding: 0.22rem 0.55rem;
		border-radius: 999px;
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.02em;
	}

	.scorecard__status--good { background: var(--lane-foundation-tint); color: var(--lane-foundation-ink); }
	.scorecard__status--warn { background: var(--lane-audit-tint); color: var(--lane-audit-ink); }
	.scorecard__status--gap  { background: #F7E4DF; color: #9B3D2A; }

	.scorecard__deliver {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		margin-top: 1.5rem;
		padding-top: 1.35rem;
		border-top: 1px solid var(--color-border-soft);
	}

	.scorecard__deliver-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		flex-shrink: 0;
		border-radius: 10px;
		background: var(--lane-audit-tint);
		color: var(--lane-audit-ink);
	}

	.scorecard__deliver-icon svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	.scorecard__deliver p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.88rem;
		line-height: 1.5;
	}

	.scorecard__deliver strong {
		color: var(--color-text);
		font-weight: 750;
	}

	@media (max-width: 920px) {
		.scorecard__inner {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 480px) {
		.scorecard__row {
			grid-template-columns: 1fr 4.5rem;
			gap: 0.4rem 0.7rem;
		}

		.scorecard__meter {
			grid-column: 1 / -1;
			order: 3;
		}

		.scorecard__status {
			justify-self: end;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.scorecard__ring-fill,
		.scorecard__meter-fill {
			transition: none;
		}
	}
</style>
