---
import { auditTemplateSlugToName, getTemplateBySlug } from '../data/templates';

const templateMeta: Record<string, { category: string; defaultBizType: string }> = {
	'med-spa': { category: 'Medical Aesthetics', defaultBizType: 'Med Spa' },
	'solo-practice': { category: 'Solo Practice / NP Practice', defaultBizType: 'Solo Practice' },
	'association': { category: 'Healthcare / Association', defaultBizType: 'Healthcare Association' },
	'premium-wellness-clinic': { category: 'Wellness Clinic', defaultBizType: 'Wellness Clinic' },
	'hormone-trt': { category: "Men's Health / TRT", defaultBizType: "Men's Health Clinic" },
};

const businessTypes = ['Med Spa', 'Solo Practice', 'Wellness Clinic', "Men's Health Clinic", 'Functional Medicine', 'Healthcare Association', 'Treatment-Based Clinic', 'Other'];
const primaryGoals = [
	'More bookings or leads',
	'Better website design',
	'Better local visibility',
	'Clearer service pages',
	'Better patient onboarding',
	'Pricing/care model clarity',
	'Better follow-up system',
	'Website Foundation setup',
	'Custom website',
	'Not sure yet',
];
const biggestIssues = [
	'Site feels outdated',
	'Not enough bookings or leads',
	'Not showing up locally',
	'Services are unclear',
	'Booking/contact flow is confusing',
	'Pricing or care model is hard to explain',
	'No follow-up system',
	'Need a more professional image',
	'Other',
];
const servicesOfInterest = [
	'Industry Website Foundation setup',
	'Signature Custom Website',
	'SEO / local visibility',
	'Growth System (lead, booking, follow-up)',
	'Care and Optimization (ongoing)',
	'Not sure yet',
];
const paymentModels = [
	'Insurance-based',
	'Cash-pay / Direct-pay',
	'Membership / Concierge',
	'Mix of insurance and cash-pay',
	'Not sure yet',
];
const preferredNextSteps = [
	'Send me audit notes',
	'Send me a Loom video',
	'I want to book a call',
	'I am just exploring options',
	'Not sure yet',
];
---

<div id="audit-form" class="audit-form-shell card">
	<div
		id="audit-template-interest-banner"
		class="audit-template-interest"
		data-audit-interest="template"
		hidden
		aria-live="polite"
	>
		<p class="audit-template-interest__label">Template selected</p>
		<p class="audit-template-interest__name" id="audit-template-interest-name"></p>
		<p class="audit-template-interest__note">We'll use this context when recommending the right website path.</p>
	</div>

	<div class="audit-form-shell__intro">
		<p class="eyebrow" id="audit-form-eyebrow">Audit request</p>
		<h2 id="audit-form-heading">Tell us what you are working with.</h2>
		<p id="audit-form-desc">Share your current site and goals so we can recommend the right website path for your business.</p>
	</div>

	<form class="audit-form-shell__form" aria-label="Website audit request form" onsubmit="return false">
		<input type="hidden" name="templateInterest" id="field-template-interest" value="" autocomplete="off" />
		<input type="hidden" name="templateName" id="field-template-name" value="" autocomplete="off" />
		<input type="hidden" name="templateCategory" id="field-template-category" value="" autocomplete="off" />
		<input type="hidden" name="source" id="field-source" value="Website Audit Page" autocomplete="off" />
		<input type="hidden" name="leadType" id="field-lead-type" value="Website Audit Request" autocomplete="off" />
		<input type="hidden" name="inquiryType" id="field-inquiry-type" value="website_audit" autocomplete="off" />

		<div class="audit-form-shell__grid">
			<label>
				<span>Name</span>
				<input type="text" name="name" autocomplete="name" />
			</label>

			<label>
				<span>Email</span>
				<input type="email" name="email" autocomplete="email" />
			</label>

			<label>
				<span>Practice or business name</span>
				<input type="text" name="business-name" autocomplete="organization" />
			</label>

			<label>
				<span>Current website URL</span>
				<input type="url" name="website-url" inputmode="url" placeholder="https://" />
			</label>

			<label>
				<span>Business type</span>
				<select name="business-type" id="field-business-type">
					<option value="">Select business type</option>
					{businessTypes.map((type) => <option value={type}>{type}</option>)}
				</select>
			</label>

			<label>
				<span>Location / service area</span>
				<input type="text" name="location" placeholder="City, State" />
			</label>

			<label>
				<span>Primary goal</span>
				<select name="primary-goal">
					<option value="">Select primary goal</option>
					{primaryGoals.map((goal) => <option value={goal}>{goal}</option>)}
				</select>
			</label>

			<label>
				<span>Payment model</span>
				<select name="payment-model">
					<option value="">Select payment model</option>
					{paymentModels.map((model) => <option value={model}>{model}</option>)}
				</select>
			</label>
		</div>

		<label>
			<span>Biggest website issue</span>
			<select name="biggest-website-issue">
				<option value="">Select biggest issue</option>
				{biggestIssues.map((issue) => <option value={issue}>{issue}</option>)}
			</select>
		</label>

		<label>
			<span>Booking or scheduling system (if any)</span>
			<input type="text" name="scheduling-system" placeholder="e.g. Jane App, Calendly, none yet" />
		</label>

		<fieldset class="audit-form-shell__checkboxes">
			<legend>Services of interest</legend>
			<div class="audit-form-shell__checkbox-grid">
				{servicesOfInterest.map((svc) => (
					<label class="audit-form-shell__checkbox-label">
						<input type="checkbox" name="services-of-interest" value={svc} />
						<span>{svc}</span>
					</label>
				))}
			</div>
		</fieldset>

		<label>
			<span>Preferred next step</span>
			<select name="preferred-next-step">
				<option value="">Select preferred next step</option>
				{preferredNextSteps.map((step) => <option value={step}>{step}</option>)}
			</select>
		</label>

		<div class="audit-form-shell__footer">
			<button class="button button-primary" type="button" id="audit-submit-btn">Request My Website Audit</button>
			<p>
				This form is prepared for CRM and scheduling integration. In a live build, submissions route to email, GoHighLevel, or your preferred lead pipeline.
			</p>
		</div>
	</form>
</div>

<script define:vars={{ templateInterestLabels: auditTemplateSlugToName, templateMetaMap: templateMeta }}>
	(() => {
		const allowed = ['med-spa', 'solo-practice', 'association', 'premium-wellness-clinic', 'hormone-trt'];
		const params = typeof window !== 'undefined' ? new URLSearchParams(window.location.search) : null;
		const raw = params && params.get('template');
		const slug = raw && allowed.includes(raw) ? raw : null;

		if (!slug) return;

		const banner = document.getElementById('audit-template-interest-banner');
		const nameEl = document.getElementById('audit-template-interest-name');
		const interestField = document.getElementById('field-template-interest');
		const nameField = document.getElementById('field-template-name');
		const categoryField = document.getElementById('field-template-category');
		const sourceField = document.getElementById('field-source');
		const leadTypeField = document.getElementById('field-lead-type');
		const inquiryField = document.getElementById('field-inquiry-type');
		const headingEl = document.getElementById('audit-form-heading');
		const descEl = document.getElementById('audit-form-desc');
		const eyebrowEl = document.getElementById('audit-form-eyebrow');
		const submitBtn = document.getElementById('audit-submit-btn');
		const bizTypeField = document.getElementById('field-business-type');

		const label = templateInterestLabels[slug] || slug;
		const meta = templateMetaMap[slug];

		if (banner && nameEl) {
			nameEl.textContent = label;
			banner.hidden = false;
		}

		if (interestField instanceof HTMLInputElement) interestField.value = slug;
		if (nameField instanceof HTMLInputElement) nameField.value = label;
		if (categoryField instanceof HTMLInputElement && meta) categoryField.value = meta.category;
		if (sourceField instanceof HTMLInputElement) sourceField.value = '/templates/' + slug;
		if (leadTypeField instanceof HTMLInputElement) leadTypeField.value = 'Template Customization Request';
		if (inquiryField instanceof HTMLInputElement) inquiryField.value = 'template_customization';

		if (eyebrowEl) eyebrowEl.textContent = 'Template customization';
		if (headingEl) headingEl.textContent = 'Customize this template for your practice.';
		if (descEl) descEl.textContent = 'Tell us about your practice, services, and goals. We\u2019ll recommend how to adapt this template around your provider story, pricing model, and patient onboarding process.';
		if (submitBtn) submitBtn.textContent = 'Request Template Customization';

		if (bizTypeField instanceof HTMLSelectElement && meta) {
			for (var i = 0; i < bizTypeField.options.length; i++) {
				if (bizTypeField.options[i].value === meta.defaultBizType) {
					bizTypeField.selectedIndex = i;
					break;
				}
			}
		}
	})();
</script>

<style>
	.audit-template-interest {
		padding: 0.85rem 1rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 32%, var(--color-border));
		border-radius: 14px;
		background: var(--color-accent-light);
		margin-bottom: 1.25rem;
	}

	.audit-template-interest__label {
		margin: 0 0 0.15rem;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-accent-dark);
	}

	.audit-template-interest__name {
		margin: 0 0 0.25rem;
		font-size: 1.05rem;
		font-weight: 800;
		color: var(--color-text);
		line-height: 1.3;
	}

	.audit-template-interest__note {
		margin: 0;
		font-size: 0.82rem;
		line-height: 1.5;
		color: color-mix(in srgb, var(--color-text) 65%, transparent);
	}

	.audit-form-shell {
		padding: clamp(1.35rem, 3vw, 2rem);
		border-radius: 24px;
		box-shadow: 0 24px 70px rgba(15, 23, 42, 0.06);
	}

	.audit-form-shell__intro {
		margin-bottom: 1.5rem;
	}

	.audit-form-shell__intro h2 {
		margin-bottom: 0.75rem;
		font-size: clamp(1.65rem, 1.45rem + 0.8vw, 2rem);
	}

	.audit-form-shell__intro p:not(.eyebrow) {
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.audit-form-shell__form,
	.audit-form-shell__grid,
	.audit-form-shell > form > label {
		display: grid;
		gap: 1rem;
	}

	.audit-form-shell__grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.audit-form-shell label span,
	.audit-form-shell legend {
		color: var(--color-text);
		font-size: 0.875rem;
		font-weight: 700;
	}

	.audit-form-shell > form > label {
		gap: 0.45rem;
	}

	.audit-form-shell__grid label {
		display: grid;
		gap: 0.45rem;
	}

	.audit-form-shell input[type="text"],
	.audit-form-shell input[type="email"],
	.audit-form-shell input[type="url"],
	.audit-form-shell select,
	.audit-form-shell textarea {
		width: 100%;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
		color: var(--color-text);
		font-size: 0.95rem;
		line-height: 1.4;
	}

	.audit-form-shell input[type="text"],
	.audit-form-shell input[type="email"],
	.audit-form-shell input[type="url"],
	.audit-form-shell select {
		min-height: 2.85rem;
		padding: 0.7rem 0.8rem;
	}

	.audit-form-shell textarea {
		resize: vertical;
		min-height: 7rem;
		padding: 0.8rem;
	}

	.audit-form-shell input[type="text"]:focus,
	.audit-form-shell input[type="email"]:focus,
	.audit-form-shell input[type="url"]:focus,
	.audit-form-shell select:focus,
	.audit-form-shell textarea:focus {
		border-color: color-mix(in srgb, var(--color-accent) 55%, var(--color-border));
		outline: none;
		background: var(--color-white);
	}

	.audit-form-shell__checkboxes {
		border: none;
		padding: 0;
		margin: 0;
	}

	.audit-form-shell__checkboxes legend {
		margin-bottom: 0.5rem;
	}

	.audit-form-shell__checkbox-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.45rem;
	}

	.audit-form-shell__checkbox-label {
		display: flex !important;
		align-items: center;
		gap: 0.45rem;
		padding: 0.45rem 0.6rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
		cursor: pointer;
		transition: border-color 0.15s ease, background 0.15s ease;
	}

	.audit-form-shell__checkbox-label:hover {
		border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border));
		background: var(--color-white);
	}

	.audit-form-shell__checkbox-label input[type="checkbox"] {
		width: 1rem;
		height: 1rem;
		flex-shrink: 0;
		accent-color: var(--color-accent-dark);
	}

	.audit-form-shell__checkbox-label span {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--color-text);
		line-height: 1.3;
	}

	.audit-form-shell__footer {
		display: grid;
		gap: 0.8rem;
		margin-top: 0.25rem;
	}

	.audit-form-shell__footer .button {
		width: fit-content;
	}

	.audit-form-shell__footer p {
		max-width: 480px;
		font-size: 0.82rem;
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 55%, transparent);
	}

	@media (max-width: 620px) {
		.audit-form-shell__grid,
		.audit-form-shell__checkbox-grid {
			grid-template-columns: 1fr;
		}

		.audit-form-shell__footer .button {
			width: 100%;
		}
	}
</style>
