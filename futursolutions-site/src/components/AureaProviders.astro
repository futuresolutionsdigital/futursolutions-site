---
import { providers } from '../data/aurea';
---

<section id="providers" class="aurea-section" aria-labelledby="providers-heading">
	<div class="aurea-container">
		<div class="prov__intro">
			<p class="aurea-eyebrow">Our Providers</p>
			<h2 id="providers-heading">Meet the team behind your treatment plan.</h2>
			<p class="aurea-lead">
				Licensed professionals with advanced training in medical aesthetics, committed to natural-looking results and patient-first care.
			</p>
		</div>
		<div class="prov__stack">
			{
				providers.map((provider) => (
					<article class="prov__card aurea-card">
						<div class="prov__avatar-wrap" aria-hidden="true">
							<div class="prov__avatar-ring">
								<div class="prov__avatar">
									<span>{provider.name.split(' ').map((n) => n[0]).join('')}</span>
								</div>
							</div>
						</div>
						<div class="prov__body">
							<div class="prov__header">
								<h3>{provider.name}</h3>
								<span class="prov__cred">{provider.credential}</span>
							</div>
							<div class="prov__details">
								<div class="prov__detail-item">
									<span class="prov__detail-label">Specialty</span>
									<span>{provider.specialty}</span>
								</div>
								<div class="prov__detail-item">
									<span class="prov__detail-label">Known for</span>
									<span>{provider.knownFor}</span>
								</div>
							</div>
							<div class="prov__action">
								<a href="/demos/med-spa/contact" class="aurea-btn aurea-btn--secondary">
									Book with {provider.name.split(' ')[0]} &rarr;
								</a>
							</div>
						</div>
					</article>
				))
			}
		</div>

		<div class="prov__section-cta">
			<a href="/demos/med-spa/providers" class="prov__section-link">Meet All Providers &rarr;</a>
		</div>
	</div>
</section>

<style>
	.prov__intro {
		max-width: 700px;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	.prov__stack {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		max-width: 780px;
	}

	/* ── Horizontal card ── */
	.prov__card {
		display: flex;
		flex-direction: row;
		align-items: stretch;
		overflow: hidden;
	}

	.prov__avatar-wrap {
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 10rem;
		padding: 2rem 1.75rem;
		background: linear-gradient(
			135deg,
			color-mix(in srgb, var(--aurea-stone) 22%, var(--aurea-ivory)),
			var(--aurea-ivory)
		);
	}

	.prov__avatar-ring {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 6.25rem;
		height: 6.25rem;
		border-radius: 999px;
		background: linear-gradient(
			145deg,
			color-mix(in srgb, var(--aurea-champagne) 35%, var(--aurea-white)),
			color-mix(in srgb, var(--aurea-champagne) 12%, var(--aurea-white))
		);
	}

	.prov__avatar {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 5.5rem;
		height: 5.5rem;
		border-radius: 999px;
		background: var(--aurea-white);
		border: 1px solid var(--aurea-border);
		font-family: var(--aurea-font-heading);
		font-size: 1.35rem;
		font-weight: 600;
		color: var(--aurea-charcoal);
		letter-spacing: 0.04em;
	}

	/* ── Body ── */
	.prov__body {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: 1.75rem 2rem;
	}

	.prov__header {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.5rem 0.85rem;
		margin-bottom: 1.15rem;
	}

	.prov__header h3 {
		font-family: var(--aurea-font-heading);
		font-size: 1.3rem;
	}

	.prov__cred {
		font-size: 0.84rem;
		font-weight: 600;
		color: var(--aurea-champagne);
	}

	.prov__details {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		flex: 1;
	}

	.prov__detail-item {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.prov__detail-label {
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--aurea-champagne);
	}

	.prov__detail-item > span:last-child {
		font-size: 0.88rem;
		line-height: 1.55;
		color: var(--aurea-muted);
	}

	.prov__action {
		margin-top: 1.25rem;
	}

	.prov__section-cta {
		margin-top: 2rem;
	}

	.prov__section-link {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--aurea-champagne);
	}

	.prov__section-link:hover {
		color: var(--aurea-charcoal);
	}

	/* ── Responsive ── */
	@media (max-width: 900px) {
		.prov__avatar-wrap {
			min-width: 8rem;
			padding: 1.5rem 1.25rem;
		}
		.prov__avatar-ring {
			width: 5rem;
			height: 5rem;
		}
		.prov__avatar {
			width: 4.25rem;
			height: 4.25rem;
			font-size: 1.1rem;
		}
		.prov__body {
			padding: 1.5rem;
		}
	}

	@media (max-width: 700px) {
		.prov__card {
			flex-direction: column;
		}
		.prov__avatar-wrap {
			min-width: unset;
			min-height: 120px;
			padding: 1.5rem;
		}
		.prov__avatar-ring {
			width: 5rem;
			height: 5rem;
		}
		.prov__avatar {
			width: 4.25rem;
			height: 4.25rem;
		}
		.prov__body {
			padding: 1.5rem;
		}
		.prov__details {
			grid-template-columns: 1fr;
		}
	}
</style>
