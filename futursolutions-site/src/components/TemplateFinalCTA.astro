---
interface Props {
	heading?: string;
	description?: string;
	demoUrl?: string | null;
	auditUrl?: string;
}

const {
	heading = 'Want this Foundation customized for your business?',
	description = 'Walk through the live demo, request customization, or start with a Website Audit for a clear recommendation.',
	demoUrl,
	auditUrl = '/audit',
} = Astro.props;
---

<section class="section template-final-cta" aria-labelledby="template-final-cta-heading">
	<div class="site-container">
		<div class="template-final-cta__card">
			<div>
				<p class="eyebrow">Next step</p>
				<h2 id="template-final-cta-heading">{heading}</h2>
				<p class="lead">{description}</p>
			</div>
			<div class="template-final-cta__actions">
				{demoUrl ? (
					<a class="button button-primary" href={demoUrl}>View Live Demo</a>
				) : (
					<a class="button button-primary" href="/templates">Browse All Foundations</a>
				)}
				<a class="button button-secondary" href={auditUrl}>Get This Customized</a>
				<a class="template-final-cta__audit" href="/audit">
					Or request a Website Audit
					<span aria-hidden="true">&rarr;</span>
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.template-final-cta {
		background: var(--color-accent-light);
	}

	.template-final-cta__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
		border-radius: 20px;
		background: var(--color-text);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.template-final-cta .eyebrow {
		color: color-mix(in srgb, var(--color-accent-light) 84%, var(--color-white));
	}

	.template-final-cta h2,
	.template-final-cta .lead {
		color: var(--color-white);
	}

	.template-final-cta h2 {
		max-width: 760px;
	}

	.template-final-cta .lead {
		max-width: 680px;
		opacity: 0.78;
	}

	.template-final-cta__actions {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		align-items: flex-end;
		justify-content: center;
	}

	.template-final-cta__actions .button-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.22);
		color: var(--color-white);
	}

	.template-final-cta__actions .button-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.38);
		color: var(--color-white);
	}

	.template-final-cta__audit {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: rgba(255, 255, 255, 0.6);
		font-size: 0.82rem;
		font-weight: 600;
		transition: color var(--transition-base), gap var(--transition-base);
	}

	.template-final-cta__audit:hover {
		color: var(--color-white);
		gap: 0.5rem;
	}

	.template-final-cta__audit span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.template-final-cta__audit:hover span {
		transform: translateX(2px);
	}

	@media (max-width: 860px) {
		.template-final-cta__card {
			grid-template-columns: 1fr;
			align-items: start;
		}

		.template-final-cta__actions {
			align-items: flex-start;
			flex-direction: row;
			flex-wrap: wrap;
		}
	}
</style>
