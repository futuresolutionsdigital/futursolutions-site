<section class="aster-section acta" aria-labelledby="final-cta-heading">
	<div class="aster-container">
		<div class="acta__card">
			<p class="aster-eyebrow acta__eyebrow">Get started</p>
			<h2 id="final-cta-heading">Ready for healthcare that feels more personal?</h2>
			<p class="acta__lead">Start with a consultation and find out whether Aster Private Health is the right fit for your goals, concerns, and care preferences.</p>
			<div class="aster-btn-row acta__actions">
				<a class="aster-btn acta__btn-primary" href="#pricing">Book a Consultation</a>
				<a class="aster-btn acta__btn-secondary" href="#pricing">View Pricing</a>
			</div>
		</div>
	</div>
</section>

<style>
.acta { padding-block: clamp(2.5rem, 5vw, 4rem); }
.acta__card { max-width: 680px; margin-inline: auto; padding: clamp(2.5rem, 5vw, 4rem); border-radius: var(--aster-radius-lg); background: var(--aster-aubergine); text-align: center; }
.acta__eyebrow { color: var(--aster-clay) !important; opacity: 0.9; }
.acta__card h2 { color: var(--aster-white); font-family: var(--aster-serif); font-weight: 500; max-width: 500px; margin-inline: auto; }
.acta__lead { max-width: 460px; margin-inline: auto; color: rgba(255,255,255,0.55); font-size: 0.92rem; line-height: 1.65; }
.acta__actions { justify-content: center; }
.acta__btn-primary { background: var(--aster-clay); color: var(--aster-white); }
.acta__btn-primary:hover { background: var(--aster-clay-dark); color: var(--aster-white); }
.acta__btn-secondary { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.75); }
.acta__btn-secondary:hover { background: rgba(255,255,255,0.07); color: var(--aster-white); }
</style>
