<section class="aster-section acta" aria-labelledby="final-cta-heading">
	<div class="aster-container">
		<div class="acta__card">
			<p class="aster-eyebrow acta__eyebrow">Your next step</p>
			<h2 id="final-cta-heading">Healthcare built around you is one conversation away.</h2>
			<p class="acta__lead">Your first visit is 60–75 minutes — enough time to review your health, answer your questions, and leave with a plan that makes sense for your life.</p>
			<div class="aster-btn-row acta__actions">
			<a class="aster-btn acta__btn-primary" href="/demos/solo-practice/new-patients">Book a Consultation</a>
			<a class="aster-btn acta__btn-secondary" href="/demos/solo-practice/pricing">View Pricing</a>
			</div>
			<p class="acta__note">No commitment required. No insurance needed. HSA/FSA may be used when eligible.</p>
		</div>
	</div>
</section>

<style>
.acta { padding-block: clamp(3rem, 6vw, 5rem); }
.acta__card { max-width: 800px; margin-inline: auto; padding: clamp(3rem, 6vw, 5rem) clamp(2.5rem, 5vw, 4rem); border-radius: var(--aster-radius-lg); background: var(--aster-aubergine); text-align: center; }
.acta__eyebrow { color: rgba(255,255,255,0.45) !important; }
.acta__card h2 { color: var(--aster-white); font-family: var(--aster-serif); font-weight: 500; max-width: 560px; margin-inline: auto; font-size: clamp(1.7rem, 1.4rem + 1.2vw, 2.4rem); }
.acta__lead { max-width: 500px; margin-inline: auto; color: rgba(255,255,255,0.5); font-size: 0.92rem; line-height: 1.65; }
.acta__actions { justify-content: center; margin-top: 2rem; }
.acta__btn-primary { background: var(--aster-clay); color: var(--aster-white); min-height: 3.1rem; padding: 0.8rem 1.6rem; font-size: 0.95rem; }
.acta__btn-primary:hover { background: var(--aster-clay-dark); color: var(--aster-white); }
.acta__btn-secondary { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.7); }
.acta__btn-secondary:hover { background: rgba(255,255,255,0.07); color: var(--aster-white); }
.acta__note { margin-top: 1.25rem; color: rgba(255,255,255,0.3); font-size: 0.72rem; font-weight: 500; }
</style>
