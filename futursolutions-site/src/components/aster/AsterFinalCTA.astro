<section class="aster-section aster-final-cta" aria-labelledby="final-cta-heading">
	<div class="aster-container">
		<div class="aster-final-cta__card">
			<p class="aster-eyebrow aster-final-cta__eyebrow">Get started</p>
			<h2 id="final-cta-heading">Ready for healthcare that feels more personal?</h2>
			<p class="aster-final-cta__lead">Start with a consultation and find out whether Aster Private Health is the right fit for your goals, concerns, and care preferences.</p>
			<div class="aster-btn-row aster-final-cta__actions">
				<a class="aster-btn aster-final-cta__btn-primary" href="#pricing">Book a Consultation</a>
				<a class="aster-btn aster-final-cta__btn-secondary" href="#pricing">View Pricing</a>
			</div>
		</div>
	</div>
</section>

<style>
.aster-final-cta { padding-block: clamp(2.5rem, 5vw, 4rem); background: var(--aster-sand); }
.aster-final-cta__card { max-width: 760px; margin-inline: auto; padding: clamp(2rem, 4vw, 3.5rem); border-radius: var(--aster-radius-lg); background: var(--aster-heading); text-align: center; }
.aster-final-cta__eyebrow { color: var(--aster-warm) !important; }
.aster-final-cta__card h2 { color: var(--aster-white); max-width: 560px; margin-inline: auto; }
.aster-final-cta__lead { max-width: 520px; margin-inline: auto; color: rgba(255,255,255,0.6); font-size: 0.95rem; line-height: 1.6; }
.aster-final-cta__actions { justify-content: center; }
.aster-final-cta__btn-primary { background: var(--aster-sage); color: var(--aster-white); }
.aster-final-cta__btn-primary:hover { background: var(--aster-sage-dark); color: var(--aster-white); }
.aster-final-cta__btn-secondary { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.8); }
.aster-final-cta__btn-secondary:hover { background: rgba(255,255,255,0.08); color: var(--aster-white); }
</style>
