---
import { hero, provider } from '../../data/aster';
---

<section class="ah-hero" aria-labelledby="aster-hero-heading">
	<div class="aster-container ah-hero__inner">
		<div class="ah-hero__content">
			<p class="aster-eyebrow">Aster Private Health · Temecula, CA</p>
			<h1 id="aster-hero-heading">{hero.headline}</h1>
			<p class="ah-hero__lead">{hero.lead}</p>
			<div class="aster-btn-row">
				<a class="aster-btn aster-btn--primary" href={hero.primaryCta.href}>{hero.primaryCta.text}</a>
				<a class="aster-btn aster-btn--secondary" href={hero.secondaryCta.href}>{hero.secondaryCta.text}</a>
			</div>
		</div>
		<aside class="ah-hero__aside" aria-label="Provider introduction">
			<div class="ah-hero__provider-note">
				<div class="ah-hero__avatar" aria-hidden="true"><span>{provider.initials}</span></div>
				<p class="ah-hero__note-text"><em>"{provider.quote}"</em></p>
				<p class="ah-hero__note-sig">— {provider.name}</p>
				<p class="ah-hero__note-title">{provider.title}</p>
			</div>
		</aside>
	</div>
	<div class="aster-container">
		<div class="ah-trust">
			{hero.trustStrip.map((item) => (
				<span class="ah-trust__item">{item}</span>
			))}
		</div>
	</div>
</section>

<style>
.ah-hero { padding-block: clamp(4.5rem, 8vw, 7rem) clamp(2.5rem, 4vw, 3.5rem); }
.ah-hero__inner { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: clamp(3rem, 6vw, 6rem); align-items: start; }
.ah-hero__lead { max-width: 520px; color: var(--aster-muted); font-size: clamp(1.02rem, 1rem + 0.2vw, 1.12rem); line-height: 1.7; }
.ah-hero__aside { display: flex; align-items: flex-start; }
.ah-hero__provider-note { padding: clamp(1.5rem, 3vw, 2.25rem); border-left: 3px solid var(--aster-clay); background: var(--aster-paper); border-radius: 0 var(--aster-radius) var(--aster-radius) 0; }
.ah-hero__avatar { display: inline-flex; align-items: center; justify-content: center; width: 3rem; height: 3rem; margin-bottom: 1rem; border-radius: 50%; background: var(--aster-white); border: 1px solid var(--aster-border); }
.ah-hero__avatar span { font-size: 0.75rem; font-weight: 700; color: var(--aster-clay); font-family: var(--aster-serif); }
.ah-hero__note-text { font-family: var(--aster-serif); font-size: clamp(1rem, 0.95rem + 0.25vw, 1.12rem); font-weight: 400; line-height: 1.6; color: var(--aster-heading); margin-bottom: 1rem; }
.ah-hero__note-text em { font-style: italic; }
.ah-hero__note-sig { margin-bottom: 0.15rem; font-size: 0.82rem; font-weight: 700; color: var(--aster-heading); }
.ah-hero__note-title { font-size: 0.72rem; color: var(--aster-muted); }
.ah-trust { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; margin-top: clamp(2.5rem, 5vw, 3.5rem); }
.ah-trust__item { padding: 0.45rem 0.85rem; border: 1px solid var(--aster-border); border-radius: 999px; font-size: 0.75rem; font-weight: 600; color: var(--aster-muted); background: var(--aster-white); }

@media (max-width: 860px) {
	.ah-hero__inner { grid-template-columns: 1fr; }
	.ah-hero__content { text-align: center; }
	.ah-hero__lead { margin-inline: auto; }
	.aster-btn-row { justify-content: center; }
	.ah-hero__provider-note { border-left: none; border-top: 3px solid var(--aster-clay); border-radius: 0 0 var(--aster-radius) var(--aster-radius); }
}
</style>
