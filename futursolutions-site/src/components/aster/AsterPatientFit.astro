---
import { patientFitCards } from '../../data/aster';
---

<section class="aster-section aster-section--paper apf" id="patient-fit" aria-labelledby="patient-fit-heading">
	<div class="aster-container apf__inner">
		<div class="apf__text">
			<p class="aster-eyebrow">Is this right for you?</p>
			<h2 id="patient-fit-heading">This practice exists because a 10-minute visit is not enough.</h2>
			<p class="aster-lead">Aster was built for patients who have felt rushed, confused by their labs, or passed between providers without a clear plan. If any of this sounds familiar, you are not alone.</p>
		</div>
		<div class="apf__list-wrap">
			<div class="apf__list" role="list">
				{patientFitCards.map((card) => (
					<div class="apf__item" role="listitem">
						<span class="apf__check" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 14 14"><path stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" d="M3.5 7.5 6 10l4.5-5"/></svg>
						</span>
						<p>{card.text}</p>
					</div>
				))}
			</div>
			<div class="apf__prompt">
				<p>Sound familiar? That is exactly why this practice exists.</p>
				<a class="aster-btn aster-btn--secondary" href="/demos/solo-practice/how-it-works">Learn How It Works</a>
			</div>
		</div>
	</div>
</section>

<style>
.apf__inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(3rem, 6vw, 5rem); align-items: start; }
.apf__text { max-width: 480px; }
.apf__list-wrap { display: flex; flex-direction: column; gap: 1.5rem; }
.apf__list { display: grid; gap: 0; }
.apf__item { display: flex; align-items: baseline; gap: 0.65rem; padding-block: 0.85rem; border-bottom: 1px solid var(--aster-border); }
.apf__item:first-child { border-top: 1px solid var(--aster-border); }
.apf__check { flex-shrink: 0; color: var(--aster-clay); display: flex; align-items: center; margin-top: 0.1rem; }
.apf__item p { margin: 0; font-size: 0.9rem; font-weight: 500; line-height: 1.5; color: var(--aster-heading); }
.apf__prompt { padding: 1.15rem 1.35rem; background: var(--aster-white); border: 1px solid var(--aster-border); border-radius: var(--aster-radius); display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
.apf__prompt p { margin: 0; font-size: 0.85rem; font-weight: 500; color: var(--aster-text); font-style: italic; }

@media (max-width: 768px) {
	.apf__inner { grid-template-columns: 1fr; }
	.apf__prompt { flex-direction: column; text-align: center; }
}
</style>
