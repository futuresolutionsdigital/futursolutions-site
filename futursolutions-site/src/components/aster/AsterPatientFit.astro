---
import { patientFitCards } from '../../data/aster';
const left = patientFitCards.slice(0, 3);
const right = patientFitCards.slice(3);
---

<section class="aster-section apf" id="patient-fit" aria-labelledby="patient-fit-heading">
	<div class="aster-container apf__inner">
		<div class="apf__text">
			<p class="aster-eyebrow">Is this right for you?</p>
			<h2 id="patient-fit-heading">Built for patients who feel rushed, dismissed, or stuck without a clear plan.</h2>
			<p class="aster-lead">Aster Private Health was designed for people who want something different from traditional healthcare — more time, more clarity, and a real relationship with their provider.</p>
		</div>
		<div class="apf__list" role="list">
			{patientFitCards.map((card) => (
				<div class="apf__item" role="listitem">
					<span class="apf__dash" aria-hidden="true">—</span>
					<p>{card.text}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
.apf__inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(3rem, 6vw, 5rem); align-items: start; }
.apf__text { max-width: 480px; }
.apf__list { display: grid; gap: 0; }
.apf__item { display: flex; align-items: baseline; gap: 0.75rem; padding-block: 1rem; border-bottom: 1px solid var(--aster-border); }
.apf__item:first-child { border-top: 1px solid var(--aster-border); }
.apf__dash { flex-shrink: 0; color: var(--aster-clay); font-weight: 600; font-size: 0.85rem; }
.apf__item p { margin: 0; font-size: 0.92rem; font-weight: 500; line-height: 1.5; color: var(--aster-heading); }

@media (max-width: 768px) { .apf__inner { grid-template-columns: 1fr; } }
</style>
