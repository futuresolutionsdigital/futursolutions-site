---
import { provider } from '../../data/aster';
---

<section class="aster-section apr" id="provider" aria-labelledby="provider-heading">
	<div class="aster-container">
		<div class="apr__card">
			<div class="apr__portrait" aria-hidden="true">
				<div class="apr__avatar"><span>{provider.initials}</span></div>
			</div>
			<div class="apr__body">
				<p class="aster-eyebrow">Meet your provider</p>
				<h2 id="provider-heading">{provider.name}</h2>
				<p class="apr__title">{provider.title}</p>
				<p class="apr__bio">{provider.bio}</p>

				<blockquote class="apr__quote">
					<p>"{provider.quote}"</p>
				</blockquote>

				<ul class="apr__creds">
					{provider.credentials.map((c) => <li>{c}</li>)}
				</ul>

				<div class="aster-btn-row">
					<a class="aster-btn aster-btn--secondary" href={provider.cta.href}>{provider.cta.text}</a>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
.apr__card { display: grid; grid-template-columns: 0.38fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; padding: clamp(2rem, 4vw, 3rem); background: var(--aster-paper); border: 1px solid var(--aster-border); border-radius: var(--aster-radius-lg); }
.apr__portrait { display: flex; justify-content: center; }
.apr__avatar { display: flex; align-items: center; justify-content: center; width: clamp(6rem, 9vw, 9rem); height: clamp(6rem, 9vw, 9rem); border-radius: 50%; background: var(--aster-white); border: 1px solid var(--aster-border); }
.apr__avatar span { font-family: var(--aster-serif); font-size: clamp(1.4rem, 2vw, 2rem); font-weight: 600; color: var(--aster-clay); }
.apr__title { color: var(--aster-clay); font-weight: 600; font-size: 0.88rem; margin-bottom: 0.75rem; }
.apr__bio { max-width: 520px; color: var(--aster-text); font-size: 0.95rem; line-height: 1.7; }
.apr__quote { margin: 1.5rem 0; padding: 1.25rem 1.5rem; background: var(--aster-white); border-radius: var(--aster-radius); border-left: 3px solid var(--aster-clay); }
.apr__quote p { margin: 0; font-family: var(--aster-serif); font-size: 1.05rem; font-style: italic; font-weight: 400; line-height: 1.6; color: var(--aster-heading); }
.apr__creds { display: grid; gap: 0.4rem; padding: 0; margin: 1rem 0 0; list-style: none; }
.apr__creds li { position: relative; padding-left: 1rem; font-size: 0.85rem; font-weight: 500; color: var(--aster-muted); }
.apr__creds li::before { content: '·'; position: absolute; left: 0; color: var(--aster-clay); font-weight: 700; }

@media (max-width: 768px) {
	.apr__card { grid-template-columns: 1fr; text-align: center; }
	.apr__bio { margin-inline: auto; }
	.apr__quote { border-left: none; border-top: 3px solid var(--aster-clay); text-align: left; }
	.apr__creds { justify-items: center; }
	.apr__creds li { padding-left: 0; }
	.apr__creds li::before { display: none; }
	.aster-btn-row { justify-content: center; }
}
</style>
