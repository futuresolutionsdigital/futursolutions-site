---
import { faqs } from '../../data/aster';
---

<section class="aster-section afaq" id="faq" aria-labelledby="faq-heading">
	<div class="aster-container">
		<div class="afaq__intro">
			<p class="aster-eyebrow">FAQ</p>
			<h2 id="faq-heading">Questions before becoming a patient?</h2>
		</div>
		<div class="afaq__list">
			{faqs.map((faq) => (
				<details class="afaq__item">
					<summary class="afaq__question">
						<span>{faq.question}</span>
						<svg class="afaq__icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 18 18" aria-hidden="true"><path stroke="currentColor" stroke-width="1.3" stroke-linecap="round" d="M4.5 7l4.5 4.5L13.5 7"/></svg>
					</summary>
					<div class="afaq__answer"><p>{faq.answer}</p></div>
				</details>
			))}
		</div>
	</div>
</section>

<style>
.afaq__intro { max-width: 520px; margin-bottom: clamp(2rem, 4vw, 3rem); text-align: center; margin-inline: auto; }
.afaq__list { max-width: 680px; margin-inline: auto; }
.afaq__item { border-bottom: 1px solid var(--aster-border); }
.afaq__item:first-child { border-top: 1px solid var(--aster-border); }
.afaq__question { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.1rem 0; cursor: pointer; list-style: none; font-weight: 600; font-size: 0.92rem; color: var(--aster-heading); }
.afaq__question::-webkit-details-marker { display: none; }
.afaq__question::marker { display: none; content: ''; }
.afaq__icon { flex-shrink: 0; color: var(--aster-muted); transition: transform 0.2s ease; }
.afaq__item[open] .afaq__icon { transform: rotate(180deg); }
.afaq__answer { padding-bottom: 1.25rem; }
.afaq__answer p { margin: 0; color: var(--aster-text); font-size: 0.88rem; line-height: 1.7; }
</style>
