---
import { services } from '../../data/aster';
---

<section class="aster-section aster-section--sage-light asvc" id="services" aria-labelledby="services-heading">
	<div class="aster-container">
		<div class="asvc__intro">
			<p class="aster-eyebrow">Services</p>
			<h2 id="services-heading">Care designed around the whole person.</h2>
			<p class="aster-lead">Each area of care is supported by thorough evaluation, personalized planning, and ongoing follow-up.</p>
		</div>
		<div class="asvc__list">
			{services.map((svc, i) => (
				<article class:list={['asvc__item', { 'asvc__item--alt': i % 2 !== 0 }]}>
					<div class="asvc__item-head">
						<h3>{svc.title}</h3>
						<p class="asvc__best">{svc.bestFor}</p>
					</div>
					<div class="asvc__item-body">
						<p>{svc.description}</p>
						<a class="asvc__link" href={svc.href}>
							Learn more
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 14 14" aria-hidden="true"><path stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" d="m5.25 3.5 3.5 3.5-3.5 3.5"/></svg>
						</a>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
.asvc__intro { max-width: 560px; margin-bottom: clamp(2rem, 4vw, 3rem); }
.asvc__list { display: grid; gap: 0; }
.asvc__item { display: grid; grid-template-columns: 0.4fr 1fr; gap: clamp(1.5rem, 3vw, 2.5rem); padding-block: clamp(1.25rem, 2.5vw, 1.75rem); border-bottom: 1px solid color-mix(in srgb, var(--aster-eucalyptus) 20%, var(--aster-border)); }
.asvc__item:first-child { border-top: 1px solid color-mix(in srgb, var(--aster-eucalyptus) 20%, var(--aster-border)); }
.asvc__item-head h3 { margin-bottom: 0.25rem; }
.asvc__best { margin: 0; color: var(--aster-muted); font-size: 0.78rem; font-style: italic; }
.asvc__item-body p { color: var(--aster-text); font-size: 0.9rem; line-height: 1.65; }
.asvc__link { display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.8rem; font-weight: 600; color: var(--aster-clay); }
.asvc__link:hover { color: var(--aster-clay-dark); }

@media (max-width: 620px) { .asvc__item { grid-template-columns: 1fr; gap: 0.5rem; } }
</style>
