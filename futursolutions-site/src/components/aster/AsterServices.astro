---
import { services } from '../../data/aster';
---

<section class="aster-section aster-section--sage-light aster-services" id="services" aria-labelledby="services-heading">
	<div class="aster-container">
		<div class="aster-services__intro">
			<p class="aster-eyebrow">Services</p>
			<h2 id="services-heading">Care designed around the whole person.</h2>
			<p class="aster-lead">Each area of care is supported by thorough evaluation, personalized planning, and ongoing follow-up.</p>
		</div>
		<div class="aster-services__grid">
			{services.map((svc) => (
				<article class="aster-card aster-services__card">
					<h3>{svc.title}</h3>
					<p class="aster-services__desc">{svc.description}</p>
					<p class="aster-services__best"><strong>Best for:</strong> {svc.bestFor}</p>
					<a class="aster-services__link" href={svc.href}>
						Learn More
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 14 14" aria-hidden="true"><path stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" d="m5.25 3.5 3.5 3.5-3.5 3.5"/></svg>
					</a>
				</article>
			))}
		</div>
	</div>
</section>

<style>
.aster-services__intro { max-width: 620px; margin-bottom: clamp(2rem, 4vw, 3rem); }
.aster-services__grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; }
.aster-services__card { display: flex; flex-direction: column; padding: 1.35rem; }
.aster-services__desc { flex: 1; color: var(--aster-muted); font-size: 0.88rem; line-height: 1.55; }
.aster-services__best { font-size: 0.78rem; color: var(--aster-text); margin-bottom: 0.75rem; }
.aster-services__best strong { color: var(--aster-heading); }
.aster-services__link { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.82rem; font-weight: 700; color: var(--aster-sage); }
.aster-services__link:hover { color: var(--aster-sage-dark); }

@media (max-width: 960px) { .aster-services__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
@media (max-width: 520px) { .aster-services__grid { grid-template-columns: 1fr; } }
</style>
