---
import { testimonials } from '../../data/aster';
const featured = testimonials[0];
const rest = testimonials.slice(1);
---

<section class="aster-section atest" id="testimonials" aria-labelledby="testimonials-heading">
	<div class="aster-container">
		<div class="atest__intro">
			<p class="aster-eyebrow">Patient experience</p>
			<h2 id="testimonials-heading">What patients say about their experience.</h2>
		</div>

		<blockquote class="atest__featured">
			<div class="atest__featured-mark" aria-hidden="true">"</div>
			<p class="atest__featured-text">{featured.quote}</p>
			<footer class="atest__featured-attr">— {featured.attribution}</footer>
		</blockquote>

		<div class="atest__grid">
			{rest.map((t) => (
				<blockquote class="atest__card">
					<p class="atest__card-text">"{t.quote}"</p>
					<footer class="atest__card-attr">— {t.attribution}</footer>
				</blockquote>
			))}
		</div>

		<p class="atest__disclaimer">Demo testimonials shown for template presentation only.</p>
	</div>
</section>

<style>
.atest__intro { max-width: 520px; margin-bottom: clamp(2rem, 4vw, 3rem); }

.atest__featured { margin: 0 0 clamp(1.5rem, 3vw, 2rem); padding: clamp(2rem, 4vw, 3rem); background: var(--aster-paper); border: 1px solid var(--aster-border); border-radius: var(--aster-radius-lg); position: relative; }
.atest__featured-mark { font-family: var(--aster-serif); font-size: 4rem; line-height: 1; color: var(--aster-clay); opacity: 0.25; position: absolute; top: 0.75rem; left: 1.5rem; }
.atest__featured-text { margin: 0 0 1rem; font-family: var(--aster-serif); font-size: clamp(1.2rem, 1.05rem + 0.5vw, 1.5rem); font-style: italic; font-weight: 400; line-height: 1.55; color: var(--aster-heading); max-width: 640px; }
.atest__featured-attr { font-family: var(--aster-sans); font-size: 0.82rem; font-weight: 600; color: var(--aster-muted); font-style: normal; }

.atest__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
.atest__card { margin: 0; padding: 1.35rem 1.5rem; background: var(--aster-white); border: 1px solid var(--aster-border); border-radius: var(--aster-radius); display: flex; flex-direction: column; }
.atest__card-text { flex: 1; margin: 0 0 0.75rem; font-family: var(--aster-serif); font-size: 0.95rem; font-style: italic; font-weight: 400; line-height: 1.6; color: var(--aster-heading); }
.atest__card-attr { font-family: var(--aster-sans); font-size: 0.75rem; font-weight: 600; color: var(--aster-muted); font-style: normal; }

.atest__disclaimer { margin-top: 1.25rem; color: var(--aster-muted); font-size: 0.68rem; font-style: italic; }

@media (max-width: 620px) { .atest__grid { grid-template-columns: 1fr; } }
</style>
