---
import { pricingCards, pricingNote } from '../../data/aster';
---

<section class="aster-section aster-section--paper aprx" id="pricing" aria-labelledby="pricing-heading">
	<div class="aster-container">
		<div class="aprx__intro">
			<p class="aster-eyebrow">Pricing</p>
			<h2 id="pricing-heading">Transparent pricing so you can make confident decisions about your care.</h2>
			<p class="aster-lead">No hidden fees. No surprise billing. No insurance complexity. Know exactly what your visit costs before you book.</p>
		</div>
		<div class="aprx__list">
			{pricingCards.map((card) => (
				<div class:list={['aprx__item', { 'aprx__item--featured': card.featured }]}>
					<div class="aprx__item-left">
						<h3>{card.name}</h3>
						<p class="aprx__duration">{card.duration}</p>
						<p class="aprx__desc">{card.description}</p>
					</div>
					<div class="aprx__item-right">
						<span class="aprx__price-note">{card.priceNote}</span>
						<span class="aprx__amount">{card.price}{card.priceSuffix && <small>{card.priceSuffix}</small>}</span>
						<a class:list={['aster-btn', card.featured ? 'aster-btn--primary' : 'aster-btn--secondary']} href="#faq" style="margin-top: 0.75rem;">
							{card.featured ? 'Learn About Membership' : 'Book This Visit'}
						</a>
					</div>
				</div>
			))}
		</div>

		<div class="aprx__details">
			<div class="aprx__detail-card">
				<h3 class="aprx__detail-heading">How payment works</h3>
				<ul class="aprx__detail-list">
					<li>We are a direct-pay practice — no insurance billing complexity</li>
					<li>HSA and FSA funds are accepted and typically eligible</li>
					<li>Superbills provided for possible insurance reimbursement</li>
					<li>Labs, imaging, and prescriptions go through insurance as usual</li>
				</ul>
			</div>
			<p class="aprx__note">{pricingNote}</p>
		</div>

		<div class="aprx__cta-row">
			<a class="aster-btn aster-btn--primary" href="#faq">Book a Consultation</a>
			<a class="aster-btn aster-btn--secondary" href="#faq">Have Pricing Questions?</a>
		</div>
	</div>
</section>

<style>
.aprx__intro { max-width: 600px; margin-bottom: clamp(2.5rem, 5vw, 3.5rem); text-align: center; margin-inline: auto; }
.aprx__list { display: grid; gap: 1rem; max-width: 740px; margin-inline: auto; }
.aprx__item { display: flex; justify-content: space-between; align-items: center; gap: 2rem; padding: 1.65rem 1.85rem; border: 1px solid var(--aster-border); border-radius: var(--aster-radius); background: var(--aster-white); }
.aprx__item--featured { border-color: var(--aster-clay); background: var(--aster-clay-light); box-shadow: 0 4px 20px rgba(167,104,77,0.06); }
.aprx__item-left { flex: 1; }
.aprx__item-left h3 { margin-bottom: 0.2rem; }
.aprx__duration { margin-bottom: 0.5rem; color: var(--aster-muted); font-size: 0.78rem; }
.aprx__desc { margin: 0; color: var(--aster-text); font-size: 0.85rem; line-height: 1.55; }
.aprx__item-right { display: flex; flex-direction: column; align-items: center; text-align: center; flex-shrink: 0; }
.aprx__price-note { font-size: 0.65rem; font-weight: 600; color: var(--aster-muted); text-transform: uppercase; letter-spacing: 0.06em; }
.aprx__amount { font-family: var(--aster-serif); font-size: 1.8rem; font-weight: 600; color: var(--aster-heading); line-height: 1.2; }
.aprx__amount small { font-size: 0.75rem; font-weight: 500; color: var(--aster-muted); font-family: var(--aster-sans); }

.aprx__details { display: grid; grid-template-columns: 1fr; gap: 1rem; max-width: 740px; margin: 2rem auto 0; }
.aprx__detail-card { padding: 1.35rem 1.5rem; border: 1px solid var(--aster-border); border-radius: var(--aster-radius); background: var(--aster-white); }
.aprx__detail-heading { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--aster-clay); margin-bottom: 0.65rem; }
.aprx__detail-list { display: grid; gap: 0.4rem; padding: 0; margin: 0; list-style: none; }
.aprx__detail-list li { position: relative; padding-left: 0.85rem; font-size: 0.85rem; font-weight: 500; color: var(--aster-text); line-height: 1.5; }
.aprx__detail-list li::before { content: ''; position: absolute; left: 0; top: 0.5rem; width: 4px; height: 4px; border-radius: 50%; background: var(--aster-clay); }
.aprx__note { text-align: center; color: var(--aster-muted); font-size: 0.78rem; line-height: 1.55; font-style: italic; }
.aprx__cta-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 2rem; }

@media (max-width: 620px) {
	.aprx__item { flex-direction: column; text-align: center; gap: 1rem; }
	.aprx__item-left { text-align: center; }
}
</style>
