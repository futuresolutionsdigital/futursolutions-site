---
const systemCards = [
	{
		number: '01',
		title: 'Website',
		text: 'Modern, responsive pages built for speed, trust, and clarity.',
	},
	{
		number: '02',
		title: 'Content',
		text: 'Service pages, FAQs, and messaging structured around what visitors need to know before they book.',
	},
	{
		number: '03',
		title: 'Visibility',
		text: 'SEO foundations that help search engines understand your services and location.',
	},
	{
		number: '04',
		title: 'Backend',
		text: 'Forms, booking, CRM, pipelines, and follow-up systems powered by GoHighLevel.',
	},
];
---

<section class="section system-section" aria-labelledby="system-heading">
	<div class="site-container">
		<div class="system-section__intro">
			<p class="eyebrow">The Future Solutions system</p>
			<h2 id="system-heading">A website should not just exist. It should operate.</h2>
			<p class="lead">
				Future Solutions connects clean design, clear content, local visibility, and backend systems into one practical digital foundation.
			</p>
		</div>

		<div class="system-section__grid">
			{systemCards.map((card) => (
				<article class="card system-card">
					<span>{card.number}</span>
					<h3>{card.title}</h3>
					<p>{card.text}</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.system-section {
		background: var(--color-bg);
	}

	.system-section__intro {
		max-width: 760px;
	}

	.system-section__grid {
		position: relative;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.system-section__grid::before {
		position: absolute;
		top: 2.35rem;
		right: 8%;
		left: 8%;
		height: 1px;
		background: var(--color-border);
		content: '';
	}

	.system-card {
		position: relative;
		padding: 1.35rem;
	}

	.system-card span {
		position: relative;
		z-index: 1;
		display: inline-flex;
		margin-bottom: 2.5rem;
		padding: 0.38rem 0.58rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.75rem;
		font-weight: 700;
		line-height: 1;
	}

	.system-card h3 {
		font-size: 1.15rem;
		letter-spacing: -0.02em;
	}

	.system-card p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	@media (max-width: 980px) {
		.system-section__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.system-section__grid::before {
			display: none;
		}
	}

	@media (max-width: 620px) {
		.system-section__grid {
			grid-template-columns: 1fr;
		}

		.system-card span {
			margin-bottom: 1.5rem;
		}
	}
</style>
