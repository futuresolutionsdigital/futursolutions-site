---
import type { TemplateSystem } from '../data/templates';

interface Props {
	templates: TemplateSystem[];
}

const { templates } = Astro.props;

const systemAddonItems = (t: TemplateSystem) => [...t.conversionFeatures, ...t.backendFeatures];
---

<div class="template-quick-view-slot">
	<dialog class="tq-dialog" id="template-quick-view-dialog" aria-modal="true">
		<div class="tq-dialog__panel card">
			<div class="tq-dialog__toolbar">
				<p class="tq-dialog__toolbar-label">Template quick view</p>
				<button type="button" class="tq-dialog__close" data-tq-close aria-label="Close quick view">
					Close<span aria-hidden="true"> ✕</span>
				</button>
			</div>

			{
				templates.map((template) => {
					const addons = systemAddonItems(template);
					const demoSoon = template.demoUrl === null;
					return (
						<div class="tq-panel" data-tq-panel={template.slug} hidden>
							<h2 id={`tq-title-${template.slug}`}>
								{template.name}
							</h2>
							<p class="tq-dialog__lead">{template.shortDescription}</p>
							<p class="tq-summary">{template.quickViewSummary}</p>

							<section class="tq-section" aria-labelledby={`tq-best-${template.slug}`}>
								<h3 id={`tq-best-${template.slug}`}>Best for</h3>
								<ul class="tq-chips">
									{template.businessTypes.slice(0, 5).map((bt) => (
										<li>{bt}</li>
									))}
								</ul>
							</section>

							<section class="tq-section" aria-labelledby={`tq-solves-${template.slug}`}>
								<h3 id={`tq-solves-${template.slug}`}>What this solves</h3>
								<ul class="tq-list">
									{template.problemsSolved.map((problem) => (
										<li>{problem}</li>
									))}
								</ul>
							</section>

							<section class="tq-section" aria-labelledby={`tq-pages-${template.slug}`}>
								<h3 id={`tq-pages-${template.slug}`}>Included pages</h3>
								<ul class="tq-pages">
									{template.includedPages.map((page) => (
										<li>{page}</li>
									))}
								</ul>
							</section>

							<section class="tq-section" aria-labelledby={`tq-addons-${template.slug}`}>
								<h3 id={`tq-addons-${template.slug}`}>System add-ons</h3>
								<ul class="tq-tags">
									{addons.slice(0, 10).map((item) => (
										<li>{item}</li>
									))}
								</ul>
							</section>

							<p class="tq-complex">
								<strong>Complexity:</strong>&nbsp;<span>{template.complexity}</span>
							</p>

							{demoSoon && <p class="tq-demo-flag">Demo coming soon</p>}

							<div class="tq-actions">
								{template.demoUrl ? (
									<>
										<a class="button button-primary" href={template.demoUrl}>
											View Live Demo
										</a>
										<a class="button button-secondary" href={template.auditUrl}>
											Get This Customized
										</a>
									</>
								) : (
									<>
										<a class="button button-primary" href={template.detailUrl}>
											See Details
										</a>
										<a class="button button-secondary" href={template.auditUrl}>
											Get This Customized
										</a>
									</>
								)}
							</div>
						</div>
					);
				})
			}
		</div>
	</dialog>

	<noscript>
		<p class="tq-nojs">
			Saved filters open from “Quick View”; without JavaScript, all templates below stay visible — use See Details or each card’s demo link.
		</p>
	</noscript>
</div>

<script>
	(() => {
		const dialog = document.getElementById('template-quick-view-dialog');
		if (!(dialog instanceof HTMLDialogElement)) return;

		let lastFocused = null;

		const panels = Array.from(dialog.querySelectorAll('[data-tq-panel]'));

		function showPanel(slug) {
			const titleId = `tq-title-${slug}`;
			let found = false;

			panels.forEach((panel) => {
				const isMatch = panel.getAttribute('data-tq-panel') === slug;
				panel.hidden = !isMatch;
				if (isMatch) found = true;
			});

			if (!found) return;

			dialog.setAttribute('aria-labelledby', titleId);

			if (!dialog.open) dialog.showModal();

			queueMicrotask(() => {
				const closeBtn = dialog.querySelector('[data-tq-close]');
				if (closeBtn instanceof HTMLElement) closeBtn.focus();
			});
		}

		document.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;
			const opener = target.closest('[data-template-quick-view]');

			if (!opener || !(opener instanceof HTMLElement)) return;

			const slug = opener.getAttribute('data-template-quick-view');
			if (!slug) return;

			event.preventDefault();
			lastFocused = document.activeElement;
			showPanel(slug);
		});

		dialog.addEventListener('close', () => {
			panels.forEach((panel) => {
				panel.hidden = true;
			});

			const refocus = lastFocused;
			lastFocused = null;

			queueMicrotask(() => {
				if (refocus instanceof HTMLElement) refocus.focus();
			});
		});

		dialog.querySelectorAll('[data-tq-close]').forEach((btn) => {
			btn.addEventListener('click', () => dialog.close());
		});

		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) dialog.close();
		});
	})();
</script>

<style is:global>
	.tq-dialog {
		top: unset;
		right: 0;
		bottom: 0;
		left: unset;
		margin: auto;
		transform: unset;
		width: calc(100% - 3rem);
		max-width: min(520px, 100vw - 2rem);
		max-height: min(94vh, 900px);
		padding: 0;
		overflow: visible;
		border: none;
		background: transparent;
		box-shadow: none;
	}

	.tq-dialog__panel.card {
		display: grid;
		gap: 1rem;
		max-height: min(94vh, 880px);
		overflow: auto;
		padding: clamp(1.35rem, 4vw, 2rem);
		border: 1px solid var(--color-border);
		border-radius: 20px;
		background: var(--color-white);
		box-shadow: 0 30px 80px rgba(15, 23, 42, 0.12);
		margin-left: auto;
	}

	.tq-dialog__toolbar {
		position: sticky;
		top: 0;
		z-index: 1;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		padding-block: 0.15rem;
		border-bottom: 1px solid var(--color-border);
		margin-inline: calc(-1 * clamp(1.35rem, 4vw, 2rem));
		margin-top: calc(-1 * clamp(1rem, 2vw, 1.35rem));
		margin-bottom: 0;
		padding-inline: clamp(1.35rem, 4vw, 2rem);
		padding-bottom: 0.75rem;
		background: linear-gradient(to bottom, var(--color-white) 86%, transparent);
	}

	.tq-dialog__toolbar-label {
		margin: 0;
		color: var(--color-accent-dark);
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.tq-dialog__close {
		padding: 0.35rem 0.6rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
		color: var(--color-text);
		font-size: 0.8125rem;
		font-weight: 800;
		line-height: 1;
		cursor: pointer;
	}

	.tq-dialog__close:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.tq-panel h2 {
		margin-bottom: 0.25rem;
		font-size: 1.5rem;
		letter-spacing: -0.03em;
	}

	.tq-dialog__lead {
		font-size: 1rem;
		line-height: 1.62;
		color: var(--color-muted);
	}

	.tq-summary {
		margin-bottom: 0.25rem;
		font-size: 0.9rem;
		line-height: 1.62;
		color: var(--color-text);
	}

	.tq-section {
		display: grid;
		gap: 0.5rem;
	}

	.tq-section h3 {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent-dark);
	}

	.tq-chips,
	.tq-list,
	.tq-pages,
	.tq-tags {
		display: grid;
		gap: 0.4rem;
		margin: 0;
		padding-inline-start: 1.05rem;
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.5;
	}

	.tq-chips {
		list-style: none;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.tq-chips li {
		display: inline-flex;
		padding: 0.32rem 0.55rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-bg);
		font-weight: 600;
		line-height: 1;
	}

	.tq-tags {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		list-style: none;
		padding: 0;
		gap: 0.4rem;
	}

	.tq-tags li {
		padding: 0.42rem 0.55rem;
		border: 1px solid var(--color-border);
		border-radius: 10px;
		background: var(--color-bg-secondary);
		font-size: 0.82rem;
		font-weight: 600;
	}

	.tq-complex strong {
		font-weight: 800;
	}

	.tq-demo-flag {
		display: inline-flex;
		align-self: start;
		margin: 0;
		padding: 0.32rem 0.55rem;
		border-radius: 999px;
		border: 1px dashed color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.78rem;
		font-weight: 800;
	}

	.tq-actions {
		position: sticky;
		bottom: 0;
		display: grid;
		gap: 0.65rem;
		padding-top: 0.85rem;
		margin-top: 0.75rem;
		border-top: 1px solid var(--color-border);
		background: linear-gradient(to bottom, transparent, var(--color-white));
	}

	.tq-dialog::backdrop {
		background: rgba(15, 23, 42, 0.32);
		backdrop-filter: blur(6px);
	}

	.tq-nojs {
		margin-top: 0.75rem;
		font-size: 0.85rem;
		color: var(--color-muted);
	}

	@media (max-width: 700px) {
		.tq-dialog {
			width: calc(100% - 1.25rem);
			max-width: none;
			margin-right: auto;
			margin-inline: auto;
			top: unset;
			left: unset;
			right: unset;
			bottom: 0;
		}

		.tq-dialog__panel.card {
			max-height: 92vh;
			margin-inline: auto;
		}

		.tq-tags {
			grid-template-columns: 1fr;
		}
	}
</style>
