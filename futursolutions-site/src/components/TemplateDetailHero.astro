---
import type { TemplateSystem } from '../data/templates';

interface Props {
	template: TemplateSystem;
}

const { template } = Astro.props;
---

<section class="section template-detail-hero" aria-labelledby="template-detail-heading">
	<div class="site-container template-detail-hero__inner">
		<div class="template-detail-hero__content">
			<p class="eyebrow">Template System</p>
			<h1 id="template-detail-heading">{template.name}</h1>
			<p class="lead">{template.longDescription || template.shortDescription}</p>
			<div class="button-row">
				<a class="button button-primary" href={template.auditUrl}>Get This Template Customized</a>
				{
					template.demoUrl ? (
						<a class="button button-secondary" href={template.demoUrl}>View Live Demo</a>
					) : (
						<a class="button button-secondary" href="/templates">Back to Templates</a>
					)
				}
			</div>
			<p class="template-detail-hero__meta">Complexity: {template.complexity}</p>
		</div>

		<div class="template-detail-hero__preview card" aria-hidden="true">
			<div class="template-detail-hero__chrome">
				<span></span>
				<span></span>
				<span></span>
			</div>
			<div class="template-detail-hero__screen">
				<div class="template-detail-hero__lines">
					<span></span>
					<span></span>
					<span></span>
				</div>
				<div class="template-detail-hero__panel">
					<span>{template.category}</span>
				</div>
				<div class="template-detail-hero__tiles">
					<span></span>
					<span></span>
					<span></span>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.template-detail-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.template-detail-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 78% 18%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.template-detail-hero__inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(360px, 0.78fr);
		gap: clamp(3rem, 6vw, 5rem);
		align-items: center;
	}

	.template-detail-hero__content {
		max-width: 760px;
	}

	.template-detail-hero__content h1 {
		max-width: 760px;
	}

	.template-detail-hero__meta {
		margin-top: 1.25rem;
		color: var(--color-accent-dark);
		font-size: 0.9375rem;
		font-weight: 700;
	}

	.template-detail-hero__preview {
		overflow: hidden;
		border-radius: 22px;
		box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
	}

	.template-detail-hero__chrome {
		display: flex;
		gap: 0.45rem;
		padding: 0.9rem 1rem;
		border-bottom: 1px solid var(--color-border);
		background: var(--color-bg-secondary);
	}

	.template-detail-hero__chrome span {
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 999px;
		background: var(--color-white);
		border: 1px solid color-mix(in srgb, var(--color-muted) 26%, transparent);
	}

	.template-detail-hero__screen {
		display: grid;
		gap: 1rem;
		padding: 1.3rem;
		background:
			linear-gradient(90deg, rgba(226, 232, 240, 0.45) 1px, transparent 1px),
			linear-gradient(180deg, rgba(226, 232, 240, 0.45) 1px, transparent 1px),
			var(--color-bg);
		background-size: 44px 44px;
	}

	.template-detail-hero__lines {
		display: grid;
		gap: 0.65rem;
		padding: 1rem;
		border: 1px solid var(--color-border);
		border-radius: 14px;
		background: var(--color-white);
	}

	.template-detail-hero__lines span {
		display: block;
		height: 0.7rem;
		border-radius: 999px;
		background: var(--color-border);
	}

	.template-detail-hero__lines span:first-child {
		width: 40%;
		background: var(--color-accent-light);
	}

	.template-detail-hero__lines span:nth-child(2) {
		width: 78%;
		height: 1rem;
		background: color-mix(in srgb, var(--color-text) 16%, var(--color-border));
	}

	.template-detail-hero__lines span:last-child {
		width: 62%;
	}

	.template-detail-hero__panel {
		min-height: 130px;
		display: flex;
		align-items: flex-end;
		padding: 1rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
		border-radius: 16px;
		background: var(--color-accent-light);
	}

	.template-detail-hero__panel span {
		color: var(--color-accent-dark);
		font-size: 0.85rem;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.template-detail-hero__tiles {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.7rem;
	}

	.template-detail-hero__tiles span {
		min-height: 3rem;
		border: 1px solid var(--color-border);
		border-radius: 12px;
		background: var(--color-white);
	}

	@media (max-width: 900px) {
		.template-detail-hero__inner {
			grid-template-columns: 1fr;
		}
	}
</style>
