---
// Slim connective band between major sections. A short downward connector
// implies the guided journey continues, keeping the page from reading as a
// stack of separate blocks.
interface Props {
	text: string;
	tone?: 'default' | 'ink';
}
const { text, tone = 'default' } = Astro.props;
---

<div class:list={['section-bridge', { 'section-bridge--ink': tone === 'ink' }]}>
	<div class="site-container">
		<p class="section-bridge__line">
			<span class="section-bridge__connector" aria-hidden="true"></span>
			<span class="section-bridge__text">{text}</span>
		</p>
	</div>
</div>

<style>
	.section-bridge {
		padding-block: clamp(1.75rem, 3.5vw, 2.75rem);
		background: var(--color-bg);
	}

	.section-bridge--ink {
		background: var(--color-ink);
	}

	.section-bridge__line {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.9rem;
		max-width: 56ch;
		margin: 0 auto;
		text-align: center;
	}

	.section-bridge__connector {
		width: 1px;
		height: 1.75rem;
		background: linear-gradient(180deg, transparent, var(--color-border));
	}

	.section-bridge--ink .section-bridge__connector {
		background: linear-gradient(180deg, transparent, var(--color-ink-line-strong));
	}

	.section-bridge__text {
		color: var(--color-muted);
		font-size: clamp(1rem, 0.95rem + 0.25vw, 1.12rem);
		font-weight: 500;
		line-height: 1.5;
	}

	.section-bridge--ink .section-bridge__text {
		color: var(--color-ink-muted);
	}
</style>
