---
// Slim connective band between major sections. A short downward connector
// implies the guided journey continues, keeping the page from reading as a
// stack of separate blocks.
interface Props {
	text: string;
	tone?: 'default' | 'ink';
	label?: string;
}
const { text, tone = 'default', label } = Astro.props;
---

<div class:list={['section-bridge', { 'section-bridge--ink': tone === 'ink', 'section-bridge--stepped': !!label }]}>
	<div class="site-container">
		<div class="section-bridge__line">
			<span class="section-bridge__connector" aria-hidden="true"></span>
			{label && <span class="section-bridge__label">{label}</span>}
			<p class="section-bridge__text">{text}</p>
			{label && <span class="section-bridge__chevron" aria-hidden="true"></span>}
		</div>
	</div>
</div>

<style>
	.section-bridge {
		padding-block: clamp(1.75rem, 3.5vw, 2.75rem);
		background: var(--color-bg);
	}

	.section-bridge--ink {
		background: var(--color-ink);
	}

	.section-bridge__line {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.9rem;
		max-width: 56ch;
		margin: 0 auto;
		text-align: center;
	}

	.section-bridge__connector {
		width: 1px;
		height: 1.75rem;
		background: linear-gradient(180deg, transparent, var(--color-border));
	}

	.section-bridge--ink .section-bridge__connector {
		background: linear-gradient(180deg, transparent, var(--color-ink-line-strong));
	}

	.section-bridge__label {
		display: inline-flex;
		align-items: center;
		padding: 0.32rem 0.72rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--lane-audit) 26%, var(--color-border));
		background: var(--lane-audit-tint);
		color: var(--lane-audit-ink);
		font-size: 0.68rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.section-bridge--ink .section-bridge__label {
		border-color: var(--color-ink-line-strong);
		background: color-mix(in srgb, var(--color-ink-accent) 14%, transparent);
		color: var(--color-ink-accent);
	}

	.section-bridge__text {
		color: var(--color-muted);
		font-size: clamp(1rem, 0.95rem + 0.25vw, 1.12rem);
		font-weight: 500;
		line-height: 1.5;
		margin: 0;
	}

	/* Labeled "stage" bridge — a more deliberate chapter break */
	.section-bridge--stepped .section-bridge__text {
		max-width: 48ch;
		color: var(--color-text);
		font-size: clamp(1.08rem, 1rem + 0.4vw, 1.28rem);
		font-weight: 500;
		line-height: 1.45;
		letter-spacing: -0.01em;
	}

	.section-bridge--ink .section-bridge__text {
		color: var(--color-ink-muted);
	}

	.section-bridge--ink.section-bridge--stepped .section-bridge__text {
		color: var(--color-ink-soft, #fff);
	}

	.section-bridge__chevron {
		width: 0.58rem;
		height: 0.58rem;
		margin-top: 0.15rem;
		border-right: 2px solid color-mix(in srgb, var(--lane-audit) 55%, var(--color-border));
		border-bottom: 2px solid color-mix(in srgb, var(--lane-audit) 55%, var(--color-border));
		transform: rotate(45deg);
	}

	.section-bridge--ink .section-bridge__chevron {
		border-color: var(--color-ink-accent);
	}
</style>
