---
const systemMap = [
	{
		lane: 'foundation',
		label: 'Website Foundation',
		sub: 'Customizable starting point',
		icon: 'layers',
	},
	{
		lane: 'custom',
		label: 'Signature Custom Website',
		sub: 'Built around your brand',
		icon: 'sparkle',
	},
	{
		lane: 'growth',
		label: 'Growth System',
		sub: 'Forms · Booking · Follow-up',
		icon: 'flow',
	},
	{
		lane: 'audit',
		label: 'Website + Systems Audit',
		sub: 'Free diagnostic',
		icon: 'scope',
	},
];

const tickerItems = [
	'Solo & private practice',
	'Med spas',
	'Hormone / TRT clinics',
	'Wellness clinics',
	'Professional associations',
	'High-trust local services',
];
---

<section class="home-hero" aria-labelledby="homepage-heading">
	<div class="home-hero__grid-bg" aria-hidden="true"></div>
	<div class="home-hero__glow" aria-hidden="true"></div>

	<div class="site-container site-container--wide home-hero__inner">
		<a class="home-hero__kicker" href="/templates">
			<span class="home-hero__kicker-dot" aria-hidden="true"></span>
			<span class="home-hero__kicker-label">New demo</span>
			<span class="home-hero__kicker-text">Explore our premium wellness clinic build — live and clickable</span>
			<span class="home-hero__kicker-arrow" aria-hidden="true">&rarr;</span>
		</a>

		<p class="eyebrow home-hero__eyebrow">Healthcare websites + growth systems</p>

		<h1 id="homepage-heading" class="display-xl home-hero__headline">
			Premium websites and
			<span class="home-hero__headline-accent">Growth Systems</span>
			for healthcare brands.
		</h1>

		<p class="lead home-hero__lead">
			Custom builds, customizable Website Foundations, and CRM-connected lead systems for clinics, wellness brands, associations, and high-trust service businesses.
		</p>

		<div class="home-hero__cta-row">
			<a class="button button-primary home-hero__cta-primary" href="/audit">
				Get a Website Audit
				<span aria-hidden="true">&rarr;</span>
			</a>
			<a class="button button-secondary" href="/templates">Explore Live Demos</a>
		</div>

		<div class="home-hero__system" aria-label="What FutureSolutions builds">
			<div class="home-hero__system-head">
				<p class="home-hero__system-label">What we build</p>
				<span class="home-hero__system-divider" aria-hidden="true"></span>
				<p class="home-hero__system-meta">3 offers · 1 diagnostic</p>
			</div>
			<ul class="home-hero__system-grid">
				{
					systemMap.map((item) => (
						<li class={`home-hero__system-card lane-accent-top lane-accent-top--${item.lane}`}>
							<span class={`lane-icon lane-icon--${item.lane}`} aria-hidden="true">
								{item.icon === 'layers' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
										<path d="M12 3l9 5-9 5-9-5z" />
										<path d="M3 13l9 5 9-5M3 18l9 5 9-5" />
									</svg>
								)}
								{item.icon === 'sparkle' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
										<path d="M12 3v6M12 15v6M3 12h6M15 12h6" />
										<path d="M6 6l3 3M15 15l3 3M18 6l-3 3M9 15l-3 3" />
									</svg>
								)}
								{item.icon === 'flow' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
										<rect x="3" y="4" width="6" height="6" rx="1.5" />
										<rect x="15" y="4" width="6" height="6" rx="1.5" />
										<rect x="9" y="14" width="6" height="6" rx="1.5" />
										<path d="M6 10v2h6M18 10v2h-6" />
									</svg>
								)}
								{item.icon === 'scope' && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
										<circle cx="11" cy="11" r="6" />
										<path d="M16 16l5 5" />
									</svg>
								)}
							</span>
							<div class="home-hero__system-text">
								<p class="home-hero__system-label-inner">{item.label}</p>
								<p class="home-hero__system-sub">{item.sub}</p>
							</div>
						</li>
					))
				}
			</ul>
		</div>
	</div>

	<div class="home-hero__ticker" aria-label="Industries we serve">
		<div class="home-hero__ticker-track">
			{
				[...tickerItems, ...tickerItems].map((item, i) => (
					<span class="home-hero__ticker-item">
						<span class="home-hero__ticker-bullet" aria-hidden="true">&bull;</span>
						{item}
					</span>
				))
			}
		</div>
	</div>
</section>

<style>
	.home-hero {
		position: relative;
		overflow: hidden;
		padding-top: clamp(4rem, 8vw, 6.5rem);
		padding-bottom: 0;
		background: linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 100%);
	}

	.home-hero__grid-bg {
		position: absolute;
		inset: 0;
		pointer-events: none;
		background-image: radial-gradient(rgba(15, 23, 42, 0.055) 1px, transparent 1px);
		background-size: 32px 32px;
		mask-image: radial-gradient(ellipse 70% 55% at 50% 35%, #000 35%, transparent 78%);
		-webkit-mask-image: radial-gradient(ellipse 70% 55% at 50% 35%, #000 35%, transparent 78%);
	}

	.home-hero__glow {
		position: absolute;
		top: -10rem;
		left: 50%;
		width: 60rem;
		height: 32rem;
		pointer-events: none;
		background: radial-gradient(ellipse at center, rgba(95, 143, 139, 0.16), transparent 60%);
		transform: translateX(-50%);
		filter: blur(20px);
	}

	.home-hero__inner {
		position: relative;
		display: grid;
		justify-items: start;
		padding-bottom: clamp(3.5rem, 6vw, 5.25rem);
	}

	.home-hero__kicker {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		margin-bottom: 1.75rem;
		padding: 0.4rem 0.9rem 0.4rem 0.55rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.7);
		backdrop-filter: blur(8px);
		color: var(--color-text);
		font-size: 0.8125rem;
		font-weight: 500;
		line-height: 1;
		transition: border-color var(--transition-base), background-color var(--transition-base);
	}

	.home-hero__kicker:hover {
		border-color: color-mix(in srgb, var(--color-text) 22%, var(--color-border));
		background: var(--color-white);
	}

	.home-hero__kicker-dot {
		display: inline-block;
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 999px;
		background: var(--color-accent);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 18%, transparent);
	}

	.home-hero__kicker-label {
		padding: 0.18rem 0.42rem;
		border-radius: 999px;
		background: var(--color-text);
		color: var(--color-white);
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.home-hero__kicker-text {
		color: var(--color-muted);
	}

	.home-hero__kicker:hover .home-hero__kicker-text {
		color: var(--color-text);
	}

	.home-hero__kicker-arrow {
		margin-left: 0.1rem;
		color: var(--color-muted);
		transition: transform 220ms var(--ease-out-quart);
	}

	.home-hero__kicker:hover .home-hero__kicker-arrow {
		transform: translateX(2px);
		color: var(--color-text);
	}

	.home-hero__eyebrow {
		margin-bottom: 1.1rem;
		color: var(--lane-foundation-ink);
	}

	.home-hero__headline {
		margin-bottom: 1.5rem;
		max-width: 22ch;
	}

	.home-hero__headline-accent {
		display: inline;
		background: linear-gradient(180deg, transparent 62%, var(--lane-growth-tint) 62%);
		background-repeat: no-repeat;
		padding-inline: 0.05em;
	}

	.home-hero__lead {
		max-width: 56ch;
		margin-bottom: 2.25rem;
		font-size: clamp(1.125rem, 1.05rem + 0.4vw, 1.3125rem);
		color: var(--color-muted);
	}

	.home-hero__cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		align-items: center;
		margin-bottom: 3.5rem;
	}

	.home-hero__cta-primary span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.home-hero__cta-primary:hover span {
		transform: translateX(2px);
	}

	.home-hero__system {
		width: 100%;
		margin: 0;
		padding-top: 0.5rem;
	}

	.home-hero__system-head {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		margin: 0 0 1.1rem 0;
	}

	.home-hero__system-label {
		margin: 0;
		color: var(--color-text);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.home-hero__system-divider {
		flex: 1;
		min-width: 1.5rem;
		max-width: 14rem;
		height: 1px;
		background: linear-gradient(90deg, var(--color-border), transparent);
	}

	.home-hero__system-meta {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.04em;
	}

	.home-hero__system-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.home-hero__system-card {
		position: relative;
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		align-items: center;
		gap: 0.95rem;
		padding: 1.2rem 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-white);
		box-shadow: var(--shadow-card);
		transition: transform 320ms var(--ease-out-quart),
			border-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.home-hero__system-card.lane-accent-top::before {
		height: 4px;
	}

	.home-hero__system-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-card-hover);
	}

	.home-hero__system-card.lane-accent-top--foundation:hover { border-color: color-mix(in srgb, var(--lane-foundation) 36%, var(--color-border)); }
	.home-hero__system-card.lane-accent-top--custom:hover     { border-color: color-mix(in srgb, var(--lane-custom) 32%, var(--color-border)); }
	.home-hero__system-card.lane-accent-top--growth:hover     { border-color: color-mix(in srgb, var(--lane-growth) 36%, var(--color-border)); }
	.home-hero__system-card.lane-accent-top--audit:hover      { border-color: color-mix(in srgb, var(--lane-audit) 38%, var(--color-border)); }

	.home-hero__system-card .lane-icon {
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 12px;
	}

	.home-hero__system-card .lane-icon svg {
		width: 1.3rem;
		height: 1.3rem;
		stroke-width: 1.7;
	}

	.home-hero__system-text {
		display: grid;
		gap: 0.2rem;
		min-width: 0;
	}

	.home-hero__system-label-inner {
		margin: 0;
		color: var(--color-text);
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: -0.018em;
		line-height: 1.2;
	}

	.home-hero__system-sub {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.82rem;
		font-weight: 500;
		letter-spacing: -0.005em;
		line-height: 1.4;
	}

	.home-hero__ticker {
		position: relative;
		overflow: hidden;
		padding-block: 1rem;
		border-top: 1px solid var(--color-border-soft);
		border-bottom: 1px solid var(--color-border-soft);
		background: var(--color-white);
	}

	.home-hero__ticker::before,
	.home-hero__ticker::after {
		position: absolute;
		top: 0;
		bottom: 0;
		z-index: 1;
		width: 6rem;
		pointer-events: none;
		content: '';
	}

	.home-hero__ticker::before {
		left: 0;
		background: linear-gradient(90deg, var(--color-white), transparent);
	}

	.home-hero__ticker::after {
		right: 0;
		background: linear-gradient(-90deg, var(--color-white), transparent);
	}

	.home-hero__ticker-track {
		display: flex;
		align-items: center;
		gap: 2.5rem;
		width: max-content;
		animation: ticker-slide 38s linear infinite;
	}

	.home-hero__ticker-item {
		display: inline-flex;
		align-items: center;
		gap: 0.9rem;
		color: var(--color-muted);
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: -0.005em;
		white-space: nowrap;
	}

	.home-hero__ticker-bullet {
		color: var(--color-border);
		font-size: 0.8rem;
	}

	@keyframes ticker-slide {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	@media (prefers-reduced-motion: reduce) {
		.home-hero__ticker-track {
			animation: none;
		}
	}

	@media (max-width: 1080px) {
		.home-hero__system-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.home-hero {
			padding-top: 3.5rem;
		}

		.home-hero__kicker-text {
			display: none;
		}
	}

	@media (max-width: 520px) {
		.home-hero__system-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 480px) {
		.home-hero__cta-row {
			flex-direction: column;
			align-items: stretch;
		}

		.home-hero__cta-row .button {
			justify-content: center;
		}
	}
</style>
