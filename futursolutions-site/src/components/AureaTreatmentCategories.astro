---
import { treatmentCategories } from '../data/aurea';
const [featured, ...rest] = treatmentCategories;
---

<section id="treatments" class="aurea-section" aria-labelledby="categories-heading">
	<div class="aurea-container">
		<div class="cat__intro">
			<p class="aurea-eyebrow">Treatment Categories</p>
			<h2 id="categories-heading">Services designed around outcomes, not upsells.</h2>
			<p class="aurea-lead">
				Every treatment category is built around a specific goal so you can focus on what matters to you.
			</p>
		</div>

		<article class="cat__featured aurea-card">
			<div class="cat__featured-content">
				<h3>{featured.title}</h3>
				<p>{featured.description}</p>
				<div class="cat__popular">
					<span class="cat__popular-label">Popular treatments</span>
					<div class="cat__tags">
						{featured.popularTreatments.map((t) => (
							<span>{t}</span>
						))}
					</div>
				</div>
			<a href="/demos/med-spa/treatments" class="cat__link">
				Explore {featured.title} &rarr;
			</a>
			</div>
			<div class="cat__featured-panel" aria-hidden="true">
				<div class="cat__featured-deco"></div>
			</div>
		</article>

		<div class="cat__grid">
			{
				rest.map((cat) => (
					<article class="cat__card aurea-card">
						<h3>{cat.title}</h3>
						<p>{cat.description}</p>
						<div class="cat__popular">
							<span class="cat__popular-label">Popular treatments</span>
							<div class="cat__tags">
								{cat.popularTreatments.map((t) => (
									<span>{t}</span>
								))}
							</div>
						</div>
						<a href={cat.href} class="cat__link">
							Explore {cat.title} &rarr;
						</a>
					</article>
				))
			}
		</div>

		<div class="cat__cta">
			<a href="/demos/med-spa/treatments" class="aurea-btn aurea-btn--secondary">
				Explore Treatments &rarr;
			</a>
		</div>
	</div>
</section>

<style>
	.cat__intro {
		max-width: 700px;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	/* ── Featured card ── */
	.cat__featured {
		display: grid;
		grid-template-columns: 1fr 1fr;
		overflow: hidden;
		margin-bottom: 0.85rem;
		transition: box-shadow 0.25s ease, transform 0.25s ease;
	}

	.cat__featured:hover {
		box-shadow: 0 16px 48px rgba(36, 35, 33, 0.07);
		transform: translateY(-2px);
	}

	.cat__featured-content {
		display: flex;
		flex-direction: column;
		padding: 2.25rem;
	}

	.cat__featured-content h3 {
		font-family: var(--aurea-font-heading);
		font-size: 1.5rem;
		margin-bottom: 0.6rem;
	}

	.cat__featured-content > p {
		font-size: 0.95rem;
		line-height: 1.65;
		color: var(--aurea-muted);
		flex: 1;
	}

	.cat__featured-panel {
		position: relative;
		background: linear-gradient(
			160deg,
			color-mix(in srgb, var(--aurea-champagne) 12%, var(--aurea-ivory)),
			color-mix(in srgb, var(--aurea-sage) 10%, var(--aurea-ivory))
		);
		overflow: hidden;
	}

	.cat__featured-deco {
		position: absolute;
		inset: 0;
		opacity: 0.35;
		background:
			radial-gradient(circle at 30% 70%, var(--aurea-champagne) 0%, transparent 55%),
			radial-gradient(circle at 80% 25%, var(--aurea-sage) 0%, transparent 50%);
	}

	/* ── 2×2 grid ── */
	.cat__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.cat__card {
		display: flex;
		flex-direction: column;
		padding: 1.75rem;
		transition: box-shadow 0.25s ease, transform 0.25s ease;
	}

	.cat__card:hover {
		box-shadow: 0 16px 48px rgba(36, 35, 33, 0.07);
		transform: translateY(-2px);
	}

	.cat__card h3 {
		font-family: var(--aurea-font-heading);
		font-size: 1.2rem;
		margin-bottom: 0.35rem;
	}

	.cat__card > p {
		font-size: 0.92rem;
		line-height: 1.6;
		color: var(--aurea-muted);
		flex: 1;
	}

	/* ── Shared popular / tags ── */
	.cat__popular {
		margin-top: 1.5rem;
		padding-top: 1.15rem;
		border-top: 1px solid var(--aurea-border);
	}

	.cat__popular-label {
		display: block;
		margin-bottom: 0.6rem;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--aurea-champagne);
	}

	.cat__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.cat__tags span {
		display: inline-flex;
		padding: 0.3rem 0.65rem;
		border: 1px solid var(--aurea-border);
		border-radius: 999px;
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--aurea-muted);
		background: color-mix(in srgb, var(--aurea-ivory) 50%, var(--aurea-white));
		transition: border-color 0.2s, color 0.2s;
	}

	.cat__tags span:hover {
		border-color: var(--aurea-champagne);
		color: var(--aurea-charcoal);
	}

	.cat__link {
		display: inline-flex;
		margin-top: 1.25rem;
		font-size: 0.88rem;
		font-weight: 700;
		color: var(--aurea-charcoal);
	}

	.cat__link:hover {
		color: var(--aurea-champagne);
	}

	.cat__cta {
		margin-top: 2.5rem;
		text-align: center;
	}

	/* ── Responsive ── */
	@media (max-width: 860px) {
		.cat__featured {
			grid-template-columns: 1fr;
		}
		.cat__featured-panel {
			min-height: 140px;
		}
	}

	@media (max-width: 640px) {
		.cat__grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 480px) {
		.cat__featured-panel {
			display: none;
		}
	}
</style>
