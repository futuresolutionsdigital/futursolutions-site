---
import { testimonials } from '../data/aurea';
---

<section class="aurea-section" aria-labelledby="testimonials-heading">
	<div class="aurea-container">
		<div class="test__header">
			<div class="test__intro">
				<p class="aurea-eyebrow">Patient Reviews</p>
				<h2 id="testimonials-heading">What our patients are saying.</h2>
			</div>
			<div class="test__badge">
				<span class="test__badge-rating">4.9 average</span>
				<span class="test__badge-sep">&middot;</span>
				<span class="test__badge-count">200+ reviews</span>
			</div>
		</div>

		<div class="test__grid">
			{testimonials.map((t) => (
				<article class="test__card aurea-card">
					<div class="test__stars" aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
					<blockquote class="test__quote">
						<span class="test__open-quote" aria-hidden="true">&ldquo;</span>
						<p>{t.quote}</p>
					</blockquote>
					<div class="test__source">
						<span class="test__source-dot" aria-hidden="true"></span>
						Verified &mdash; {t.source}
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.test__header {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		gap: 1rem 2rem;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	.test__intro {
		max-width: 600px;
	}

	.test__intro h2 {
		margin-bottom: 0;
	}

	.test__badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.4rem 0.85rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--aurea-champagne) 10%, var(--aurea-ivory));
		border: 1px solid color-mix(in srgb, var(--aurea-champagne) 25%, var(--aurea-border));
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--aurea-muted);
		margin-bottom: 0.35rem;
	}

	.test__badge-rating {
		color: var(--aurea-champagne);
		font-weight: 700;
	}

	.test__badge-sep {
		opacity: 0.4;
	}

	.test__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.test__card {
		display: flex;
		flex-direction: column;
		padding: 2rem;
		transition: box-shadow 0.25s ease;
	}

	.test__card:hover {
		box-shadow: 0 12px 36px rgba(36, 35, 33, 0.06);
	}

	.test__stars {
		margin-bottom: 1rem;
		color: var(--aurea-champagne);
		font-size: 1.1rem;
		letter-spacing: 0.12em;
	}

	.test__quote {
		margin: 0;
		flex: 1;
		position: relative;
	}

	.test__open-quote {
		position: absolute;
		top: -0.5rem;
		left: -0.15rem;
		font-family: var(--aurea-font-heading);
		font-size: 3.5rem;
		line-height: 1;
		color: color-mix(in srgb, var(--aurea-champagne) 30%, transparent);
		pointer-events: none;
		user-select: none;
	}

	.test__quote p {
		font-family: var(--aurea-font-heading);
		font-size: 1.12rem;
		font-weight: 500;
		font-style: italic;
		line-height: 1.6;
		color: var(--aurea-charcoal);
		padding-left: 1.5rem;
	}

	.test__source {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1.25rem;
		padding-top: 1rem;
		border-top: 1px solid var(--aurea-border);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--aurea-muted);
	}

	.test__source-dot {
		width: 6px;
		height: 6px;
		border-radius: 999px;
		background: var(--aurea-champagne);
		flex-shrink: 0;
	}

	@media (max-width: 700px) {
		.test__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
