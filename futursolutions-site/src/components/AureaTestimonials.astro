---
import { testimonials } from '../data/aurea';
---

<section class="aurea-section" aria-labelledby="testimonials-heading">
	<div class="aurea-container">
		<div class="test__intro">
			<p class="aurea-eyebrow">Patient Reviews</p>
			<h2 id="testimonials-heading">What our patients are saying.</h2>
		</div>
		<div class="test__grid">
			{
				testimonials.map((t) => (
					<article class="test__card aurea-card">
						<div class="test__stars" aria-label="5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
						<blockquote>
							<p>&ldquo;{t.quote}&rdquo;</p>
						</blockquote>
						<div class="test__source">{t.source}</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.test__intro {
		max-width: 600px;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	.test__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.85rem;
	}

	.test__card {
		display: flex;
		flex-direction: column;
		padding: 1.35rem;
	}

	.test__stars {
		margin-bottom: 0.85rem;
		color: var(--aurea-champagne);
		font-size: 0.88rem;
		letter-spacing: 0.1em;
	}

	.test__card blockquote {
		margin: 0;
		flex: 1;
	}

	.test__card blockquote p {
		font-family: var(--aurea-font-heading);
		font-size: 1.02rem;
		font-weight: 500;
		font-style: italic;
		line-height: 1.55;
		color: var(--aurea-charcoal);
	}

	.test__source {
		margin-top: 1rem;
		padding-top: 0.85rem;
		border-top: 1px solid var(--aurea-border);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--aurea-muted);
	}

	@media (max-width: 1040px) {
		.test__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.test__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
