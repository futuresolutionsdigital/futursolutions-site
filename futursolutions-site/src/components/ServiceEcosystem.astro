---
const phases = [
	{
		lane: 'foundation',
		phase: 'Attract',
		num: '01',
		title: 'Local Visibility',
		text: 'Structure, content, and local signals bring the right patients to your door.',
		points: ['Service + location pages', 'Google Business Profile', 'Reviews & local signals'],
		href: '/services/local-visibility',
	},
	{
		lane: 'custom',
		phase: 'Establish',
		num: '02',
		title: 'Your website',
		text: 'The core every other service plugs into — built to be credible and clear.',
		points: ['Website Foundation (fast)', 'or Signature Custom (bespoke)', 'Premium, healthcare-aware design'],
		href: '/services',
		core: true,
	},
	{
		lane: 'audit',
		phase: 'Convert',
		num: '03',
		title: 'Conversion paths',
		text: 'Every page guides visitors to one obvious next step — book or inquire.',
		points: ['Clear calls-to-action', 'Friction-free booking', 'Trust placed where it counts'],
		href: '/audit',
	},
	{
		lane: 'growth',
		phase: 'Capture',
		num: '04',
		title: 'Growth System',
		text: 'Forms, booking, CRM, and automated follow-up so no inquiry is ever lost.',
		points: ['Lead capture & routing', 'Automated follow-up', 'Pipeline visibility'],
		href: '/services/growth-systems',
	},
	{
		lane: 'care',
		phase: 'Improve',
		num: '05',
		title: 'Care & Optimization',
		text: 'Ongoing content, SEO, and conversion work keeps the whole system compounding.',
		points: ['Monthly improvements', 'Content & SEO', 'Conversion testing'],
		href: '/services/ongoing-optimization',
	},
];
---

<section class="ecosystem" aria-labelledby="ecosystem-heading">
	<div class="site-container site-container--wide">
		<header class="ecosystem__head">
			<div class="ecosystem__head-main">
				<p class="eyebrow">One connected system</p>
				<h2 id="ecosystem-heading" class="display-lg">Five services. One system that compounds.</h2>
			</div>
			<p class="lead ecosystem__lead">
				Each service works on its own — but they're designed to connect. Your website is the spine; visibility brings people in, conversion paths move them to act, the Growth System captures them, and Care keeps it all improving.
			</p>
		</header>

		<ol class="ecosystem__rail" aria-label="The FutureSolutions service system, attract through improve">
			{phases.map((p) => (
				<li class={`eco-stage eco-stage--${p.lane}${p.core ? ' eco-stage--core' : ''}`}>
					<div class="eco-stage__top">
						<span class="eco-stage__phase">{p.phase}</span>
						<span class="eco-stage__num">{p.num}</span>
					</div>
					<h3 class="eco-stage__title">
						<a href={p.href}>{p.title}</a>
					</h3>
					<p class="eco-stage__text">{p.text}</p>
					<ul class="eco-stage__points">
						{p.points.map((pt) => (
							<li>
								<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8.5l3.5 3.5L13 5" /></svg>
								{pt}
							</li>
						))}
					</ul>
					<span class="eco-stage__arrow" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
					</span>
				</li>
			))}
		</ol>

		<div class="ecosystem__foot">
			<div class="ecosystem__foot-text">
				<span class="ecosystem__foot-kicker">Start anywhere. Expand over time.</span>
				<p>You don't need everything at once. Most clients start with a website or an audit, then layer in visibility, capture, and care as they grow — one system, built to scale with you.</p>
			</div>
			<a class="button button-primary ecosystem__foot-cta" href="/audit">
				Find your starting point
				<span aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</section>

<style>
	.ecosystem {
		padding-block: var(--section-spacing);
		background: var(--color-bg);
		border-block: 1px solid var(--color-border);
	}

	.ecosystem__head {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
		align-items: end;
		gap: clamp(1.5rem, 4vw, 3.5rem);
		margin: 0 0 clamp(2.5rem, 5vw, 3.5rem);
	}

	.ecosystem__lead {
		max-width: 38rem;
		margin: 0;
	}

	/* Rail */
	.ecosystem__rail {
		position: relative;
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.eco-stage {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
		padding: 1.5rem 1.3rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: var(--shadow-card);
		border-top: 4px solid var(--stage-color, var(--color-border));
		transition: transform 320ms var(--ease-out-quart), box-shadow var(--transition-base);
	}

	.eco-stage:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-card-hover);
	}

	.eco-stage--foundation { --stage-color: var(--lane-foundation); --stage-ink: var(--lane-foundation-ink); --stage-tint: var(--lane-foundation-tint); }
	.eco-stage--custom     { --stage-color: var(--lane-custom); --stage-ink: var(--lane-custom-ink); --stage-tint: var(--lane-custom-tint); }
	.eco-stage--audit      { --stage-color: var(--lane-audit); --stage-ink: var(--lane-audit-ink); --stage-tint: var(--lane-audit-tint); }
	.eco-stage--growth     { --stage-color: var(--lane-growth); --stage-ink: var(--lane-growth-ink); --stage-tint: var(--lane-growth-tint); }
	.eco-stage--care       { --stage-color: var(--lane-care); --stage-ink: var(--lane-care-ink); --stage-tint: var(--lane-care-tint); }

	.eco-stage--core {
		background: var(--color-ink);
		border-color: var(--color-ink);
		box-shadow: 0 2px 4px rgba(15, 23, 42, 0.08), 0 24px 50px rgba(15, 23, 42, 0.18);
	}

	.eco-stage__top {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.eco-stage__phase {
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
		background: var(--stage-tint);
		color: var(--stage-ink);
		font-size: 0.68rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.eco-stage__num {
		color: var(--color-muted-soft);
		font-size: 0.8rem;
		font-weight: 800;
		font-variant-numeric: tabular-nums;
	}

	.eco-stage__title {
		margin: 0;
		font-size: 1.18rem;
		font-weight: 750;
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.eco-stage__title a {
		color: var(--color-text);
		text-decoration: none;
	}

	.eco-stage__title a:hover {
		color: var(--stage-ink);
	}

	.eco-stage__text {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.88rem;
		line-height: 1.5;
	}

	.eco-stage__points {
		display: grid;
		gap: 0.4rem;
		margin: 0.2rem 0 0;
		padding: 0;
		list-style: none;
	}

	.eco-stage__points li {
		display: grid;
		grid-template-columns: 1rem 1fr;
		gap: 0.45rem;
		align-items: start;
		color: var(--color-text);
		font-size: 0.82rem;
		font-weight: 600;
		line-height: 1.4;
	}

	.eco-stage__points svg {
		width: 0.95rem;
		height: 0.95rem;
		margin-top: 0.18rem;
		color: var(--stage-color);
	}

	/* core (dark) variants */
	.eco-stage--core .eco-stage__num { color: var(--color-ink-muted); }
	.eco-stage--core .eco-stage__phase {
		background: rgba(255, 255, 255, 0.1);
		color: var(--color-white);
	}
	.eco-stage--core .eco-stage__title a { color: var(--color-white); }
	.eco-stage--core .eco-stage__text { color: var(--color-ink-muted); }
	.eco-stage--core .eco-stage__points li { color: var(--color-ink-text); }
	.eco-stage--core .eco-stage__points svg { color: var(--color-ink-accent); }

	/* connecting arrow between stages */
	.eco-stage__arrow {
		position: absolute;
		top: 50%;
		right: -0.85rem;
		z-index: 3;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.7rem;
		height: 1.7rem;
		transform: translateY(-50%);
		border-radius: 999px;
		background: var(--color-white);
		border: 1px solid var(--color-border);
		color: var(--stage-ink, var(--color-muted));
		box-shadow: var(--shadow-card);
	}

	.eco-stage__arrow svg {
		width: 0.95rem;
		height: 0.95rem;
	}

	.eco-stage:last-child .eco-stage__arrow {
		display: none;
	}

	/* Foot */
	.ecosystem__foot {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem 2.5rem;
		margin-top: clamp(2rem, 4vw, 3rem);
		padding: clamp(1.5rem, 3vw, 2.25rem);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: linear-gradient(135deg, var(--color-white), var(--lane-foundation-tint));
		box-shadow: var(--shadow-card);
	}

	.ecosystem__foot-text {
		max-width: 44rem;
	}

	.ecosystem__foot-kicker {
		display: block;
		margin-bottom: 0.4rem;
		color: var(--lane-foundation-ink);
		font-size: 0.95rem;
		font-weight: 800;
		letter-spacing: -0.01em;
	}

	.ecosystem__foot-text p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.98rem;
		line-height: 1.6;
	}

	.ecosystem__foot-cta {
		flex-shrink: 0;
	}

	.ecosystem__foot-cta span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.ecosystem__foot-cta:hover span {
		transform: translateX(3px);
	}

	@media (max-width: 1100px) {
		.ecosystem__head {
			grid-template-columns: 1fr;
			align-items: start;
		}

		.ecosystem__rail {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.25rem;
		}

		.eco-stage__arrow {
			display: none;
		}
	}

	@media (max-width: 560px) {
		.ecosystem__rail {
			grid-template-columns: 1fr;
		}
	}
</style>
