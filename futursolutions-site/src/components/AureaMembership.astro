---
import { membershipOptions } from '../data/aurea';
---

<section id="membership" class="aurea-section aurea-section--warm" aria-labelledby="membership-heading">
	<div class="aurea-container">
		<div class="mem__intro">
			<p class="aurea-eyebrow">Membership &amp; Packages</p>
			<h2 id="membership-heading">Invest in your skin with a plan that fits.</h2>
			<p class="aurea-lead">
				Maintain your results with structured plans, preferred pricing, and flexible options designed around ongoing care.
			</p>
		</div>

		<div class="mem__grid">
			{membershipOptions.map((opt, i) => (
				<article class:list={['mem__card', 'aurea-card', { 'mem__card--featured': i === 0 }]}>
					<span class="mem__highlight">{opt.highlight}</span>
					<h3>{opt.title}</h3>
					<p>{opt.description}</p>
					<a href="/demos/med-spa/contact" class="mem__link">Inquire &rarr;</a>
				</article>
			))}
		</div>

		<p class="mem__note">
			All membership and package details are discussed during your consultation.
		</p>
	</div>
</section>

<style>
	.mem__intro {
		max-width: 680px;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	.mem__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.mem__card {
		display: flex;
		flex-direction: column;
		padding: 2rem;
	}

	.mem__card--featured {
		border-left: 3px solid var(--aurea-champagne);
	}

	.mem__highlight {
		display: inline-flex;
		align-self: flex-start;
		padding: 0.3rem 0.7rem;
		margin-bottom: 1.15rem;
		border: 1px solid color-mix(in srgb, var(--aurea-champagne) 30%, var(--aurea-border));
		border-radius: 999px;
		background: color-mix(in srgb, var(--aurea-champagne) 8%, var(--aurea-white));
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--aurea-champagne);
	}

	.mem__card h3 {
		font-family: var(--aurea-font-heading);
		font-size: 1.15rem;
		margin-bottom: 0.5rem;
	}

	.mem__card > p {
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--aurea-muted);
		flex: 1;
	}

	.mem__link {
		display: inline-flex;
		margin-top: 1.5rem;
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--aurea-charcoal);
		transition: color 0.15s ease;
	}

	.mem__link:hover {
		color: var(--aurea-champagne);
	}

	.mem__note {
		margin-top: clamp(2rem, 4vw, 2.5rem);
		font-size: 0.85rem;
		font-style: italic;
		color: var(--aurea-muted);
	}

	@media (max-width: 640px) {
		.mem__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
