---
// Credibility section: explains the marketing/system thinking behind the
// builds without any fabricated metrics or testimonials. A horizontal
// "marketing stack" strip is the section's signature visual; the capability
// buckets sit beneath it as lighter supporting detail.
const stack = ['SEO', 'PPC', 'Website', 'Forms', 'CRM', 'Follow-up', 'Reporting'];

const buckets = [
	{
		icon: 'search',
		title: 'SEO-aware structure',
		text: 'Pages are organized to support local discovery, service relevance, and future content growth.',
	},
	{
		icon: 'megaphone',
		title: 'PPC & landing-page thinking',
		text: 'Built with clear offers, CTA hierarchy, and campaign-ready paths in mind.',
	},
	{
		icon: 'layout',
		title: 'Service page strategy',
		text: 'Visitors understand what you offer, who it is for, and what to do next.',
	},
	{
		icon: 'link',
		title: 'CRM & follow-up readiness',
		text: 'Forms connect to a clear lead-handling process instead of disappearing into an inbox.',
	},
	{
		icon: 'chart',
		title: 'Analytics & tracking',
		text: 'The business can see what is working and what needs improvement.',
	},
	{
		icon: 'heart',
		title: 'Healthcare & wellness context',
		text: 'Messaging, trust signals, and structure fit how healthcare and wellness visitors decide.',
	},
];
---

<section class="msys" aria-labelledby="msys-heading">
	<div class="site-container site-container--wide">
		<header class="msys__head">
			<div class="msys__head-left">
				<p class="eyebrow">The thinking behind the build</p>
				<h2 id="msys-heading" class="display-lg">Built by a marketer, not just a designer.</h2>
			</div>
			<p class="msys__head-copy">
				FutureSolutions websites are shaped by the same things that drive real lead generation: service clarity, SEO structure, paid-traffic readiness, booking flow, analytics, and follow-up.
			</p>
		</header>

		<div class="msys__stack" aria-label="Where the website sits in the marketing system">
			<ol class="msys__stack-track">
				{stack.map((s, i) => (
					<>
						<li class:list={['msys__stack-step', { 'msys__stack-step--hero': s === 'Website' }]}>{s}</li>
						{i < stack.length - 1 && <li class="msys__stack-arrow" aria-hidden="true">&rarr;</li>}
					</>
				))}
			</ol>
			<p class="msys__stack-note">The website is the hub — every other channel either feeds it or runs off it.</p>
		</div>

		<ul class="msys__grid" aria-label="How marketing thinking shapes the build">
			{
				buckets.map((b) => (
					<li class="msys__card">
						<span class="msys__icon" aria-hidden="true">
							{b.icon === 'search' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7" /><path d="M16 16l5 5" /></svg>
							)}
							{b.icon === 'megaphone' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11v2a1 1 0 0 0 1 1h3l8 4V6L7 10H4a1 1 0 0 0-1 1z" /><path d="M19 9a3 3 0 0 1 0 6" /></svg>
							)}
							{b.icon === 'layout' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2" /><path d="M3 9h18M9 9v11" /></svg>
							)}
							{b.icon === 'link' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10 14a4 4 0 0 0 5.66 0l3-3a4 4 0 0 0-5.66-5.66l-1.5 1.5" /><path d="M14 10a4 4 0 0 0-5.66 0l-3 3a4 4 0 0 0 5.66 5.66l1.5-1.5" /></svg>
							)}
							{b.icon === 'chart' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20V4M4 20h16M8 16v-4M12 16V8M16 16v-6" /></svg>
							)}
							{b.icon === 'heart' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20s-7-4.5-7-9.5A3.5 3.5 0 0 1 12 7a3.5 3.5 0 0 1 7 3.5C19 15.5 12 20 12 20z" /></svg>
							)}
						</span>
						<div class="msys__card-body">
							<h3 class="msys__card-title">{b.title}</h3>
							<p class="msys__card-text">{b.text}</p>
						</div>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	.msys {
		padding-block: var(--section-spacing);
		background: var(--color-white);
	}

	.msys__head {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: end;
		margin-bottom: clamp(2rem, 4vw, 3rem);
	}

	.msys__head .eyebrow {
		color: var(--lane-growth-ink);
	}

	.msys__head h2 {
		max-width: 16ch;
		margin-bottom: 0;
	}

	.msys__head-copy {
		max-width: 40ch;
		margin: 0;
		color: var(--color-muted);
		font-size: 1.02rem;
		line-height: 1.6;
	}

	/* ── Marketing stack strip ───────────────────────── */
	.msys__stack {
		margin-bottom: clamp(2rem, 4vw, 2.75rem);
		padding: 1.3rem 1.5rem 1.4rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background:
			radial-gradient(ellipse 60% 90% at 38% 0%, var(--lane-growth-tint), transparent 70%),
			var(--color-bg);
	}

	.msys__stack-track {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 0.4rem;
		margin: 0 0 0.85rem;
		padding: 0;
		list-style: none;
	}

	.msys__stack-step {
		padding: 0.5rem 0.95rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-white);
		color: var(--color-muted);
		font-size: 0.88rem;
		font-weight: 650;
		letter-spacing: -0.005em;
		white-space: nowrap;
	}

	.msys__stack-step--hero {
		border-color: transparent;
		background: var(--lane-growth);
		color: var(--color-white);
		box-shadow: 0 8px 20px color-mix(in srgb, var(--lane-growth) 32%, transparent);
	}

	.msys__stack-arrow {
		color: color-mix(in srgb, var(--lane-growth) 55%, var(--color-border));
		font-size: 0.95rem;
		font-weight: 700;
	}

	.msys__stack-note {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.9rem;
		font-weight: 500;
		line-height: 1.5;
	}

	/* ── Capability buckets ──────────────────────────── */
	.msys__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.msys__card {
		display: flex;
		gap: 0.85rem;
		padding: 1.35rem;
		border: 1px solid var(--color-border-soft);
		border-radius: var(--radius-md);
		background: var(--color-white);
		transition: transform 320ms var(--ease-out-quart), border-color var(--transition-base), box-shadow var(--transition-base);
	}

	.msys__card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--lane-growth) 28%, var(--color-border));
		box-shadow: var(--shadow-card);
	}

	.msys__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 2.4rem;
		height: 2.4rem;
		border-radius: 11px;
		background: var(--lane-growth-tint);
		color: var(--lane-growth-ink);
	}

	.msys__icon svg {
		width: 1.2rem;
		height: 1.2rem;
	}

	.msys__card-body {
		display: grid;
		gap: 0.3rem;
		min-width: 0;
	}

	.msys__card-title {
		margin: 0;
		font-size: 1.02rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.msys__card-text {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.88rem;
		line-height: 1.5;
	}

	@media (max-width: 1080px) {
		.msys__head {
			grid-template-columns: 1fr;
			align-items: start;
		}

		.msys__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.msys__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
