---
const stages = [
	{
		lane: 'foundation',
		icon: 'search',
		stage: 'Discovers you',
		question: 'Is this relevant to me?',
		text: 'Found through local search, a referral, or an ad — and your site loads fast and looks the part.',
		leak: 'Slow, invisible, or generic — they never arrive.',
		system: 'Local Visibility',
	},
	{
		lane: 'custom',
		icon: 'page',
		stage: 'Understands the offer',
		question: 'Do they solve my problem?',
		text: 'Clear services, framed around outcomes, tell them they are in the right place within seconds.',
		leak: "Services buried or vague — they can't tell what you do.",
		system: 'Service clarity',
	},
	{
		lane: 'custom',
		icon: 'shield',
		stage: 'Trusts you',
		question: 'Can I trust them?',
		text: 'Premium design, credentials, and real proof earn confidence before they commit.',
		leak: 'Dated or thin proof — they quietly bounce.',
		system: 'Trust + proof',
	},
	{
		lane: 'audit',
		icon: 'cursor',
		stage: 'Takes the step',
		question: 'What do I do next?',
		text: 'One obvious next action — book or inquire — with no friction or dead ends.',
		leak: 'No clear path — they leave to "think about it."',
		system: 'Conversion paths',
	},
	{
		lane: 'growth',
		icon: 'flow',
		stage: 'Gets followed up',
		question: 'Did they respond clearly?',
		text: 'The inquiry is captured, routed, and nurtured automatically — nothing slips through.',
		leak: 'Sits in an inbox — answered too late, if at all.',
		system: 'Growth System',
	},
];
---

<section class="journey section-ink" aria-labelledby="journey-heading">
	<div class="dot-grid dot-grid--ink journey__dots" aria-hidden="true"></div>
	<div class="site-container site-container--wide journey__inner">
		<header class="journey__head">
			<div class="journey__head-main">
				<p class="eyebrow">From visitor to booked client</p>
				<h2 id="journey-heading" class="display-lg journey__headline">
					Every visit is a path.
					<span class="journey__headline-soft">Miss one step and they're gone.</span>
				</h2>
			</div>
			<p class="lead journey__lead">
				A website isn't one moment — it's a journey from "who is this?" to "I'm booked." Each stage is a place visitors quietly drop off. We design every one of them, end to end.
			</p>
		</header>

		<ol class="journey__track" aria-label="The path from visitor to booked client">
			{stages.map((s, i) => (
				<li class={`journey__node journey__node--${s.lane}`}>
					<div class="journey__connector" aria-hidden="true"><span></span></div>
					<div class="journey__node-top">
						<span class={`journey__icon journey__icon--${s.lane}`} aria-hidden="true">
							{s.icon === 'search' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="11" cy="11" r="7" /><path d="M16 16l5 5" />
								</svg>
							)}
							{s.icon === 'page' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M6 3h8l4 4v14H6z" /><path d="M14 3v4h4M9 13h6M9 17h6" />
								</svg>
							)}
							{s.icon === 'shield' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" /><path d="M9 12l2 2 4-4" />
								</svg>
							)}
							{s.icon === 'cursor' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M5 4l6 16 2.5-6.5L20 11z" />
								</svg>
							)}
							{s.icon === 'flow' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<rect x="3" y="4" width="6" height="6" rx="1.5" /><rect x="15" y="4" width="6" height="6" rx="1.5" /><rect x="9" y="14" width="6" height="6" rx="1.5" /><path d="M6 10v2h6M18 10v2h-6" />
								</svg>
							)}
						</span>
						<span class="journey__step">Step {i + 1}</span>
					</div>
					<h3 class="journey__stage">{s.stage}</h3>
					<p class="journey__question"><span class="journey__question-label">They're asking</span>&ldquo;{s.question}&rdquo;</p>
					<p class="journey__text">{s.text}</p>
					<p class="journey__leak">
						<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 4v5M8 11.5v.5" /><circle cx="8" cy="8" r="6.5" /></svg>
						{s.leak}
					</p>
					<span class={`journey__system journey__system--${s.lane}`}>{s.system}</span>
				</li>
			))}

			<li class="journey__node journey__node--booked">
				<div class="journey__connector" aria-hidden="true"><span></span></div>
				<div class="journey__node-top">
					<span class="journey__icon journey__icon--booked" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M4 12l5 5L20 6" />
						</svg>
					</span>
					<span class="journey__step journey__step--final">Result</span>
				</div>
				<h3 class="journey__stage">Booked client</h3>
				<p class="journey__question"><span class="journey__question-label">They decide</span>&ldquo;I'm ready to move forward.&rdquo;</p>
				<p class="journey__text">A new patient on the calendar — not a lead lost to a slow inbox or a confusing page.</p>
				<span class="journey__system journey__system--booked">The whole point</span>
			</li>
		</ol>

		<div class="journey__foot">
			<p class="journey__foot-text">Most studios design one screen. We design the <strong>entire path</strong> that turns a stranger into a booked appointment.</p>
			<a class="button button-on-ink journey__cta" href="/audit">
				See where your path breaks
				<span aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</section>

<style>
	.journey {
		position: relative;
		overflow: hidden;
		padding-block: var(--section-spacing);
	}

	.journey__dots {
		mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, #000 35%, transparent 80%);
		-webkit-mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, #000 35%, transparent 80%);
	}

	.journey__inner {
		position: relative;
	}

	.journey__head {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.75fr);
		align-items: end;
		gap: clamp(1.5rem, 4vw, 3.5rem);
		margin: 0 0 clamp(2.75rem, 5vw, 4rem);
	}

	.journey__headline {
		color: var(--color-white);
	}

	.journey__headline-soft {
		display: block;
		color: var(--color-ink-accent);
		font-weight: 650;
	}

	.journey__lead {
		max-width: 34rem;
		margin: 0;
		color: var(--color-ink-muted);
	}

	.journey__track {
		position: relative;
		display: grid;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		gap: 0.85rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.journey__node {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 1.35rem 1.1rem;
		border: 1px solid var(--color-ink-line-strong);
		border-radius: var(--radius-lg);
		background: var(--color-ink-soft);
		transition: transform 340ms var(--ease-out-quart), border-color var(--transition-base), box-shadow var(--transition-base);
	}

	.journey__node:hover {
		transform: translateY(-5px);
		box-shadow: 0 24px 50px rgba(0, 0, 0, 0.28);
	}

	.journey__node--foundation:hover { border-color: color-mix(in srgb, var(--lane-foundation) 60%, var(--color-ink-line-strong)); }
	.journey__node--custom:hover     { border-color: color-mix(in srgb, var(--lane-care) 60%, var(--color-ink-line-strong)); }
	.journey__node--audit:hover      { border-color: color-mix(in srgb, var(--lane-audit) 60%, var(--color-ink-line-strong)); }
	.journey__node--growth:hover     { border-color: color-mix(in srgb, var(--lane-growth) 60%, var(--color-ink-line-strong)); }
	.journey__node--booked {
		border-color: color-mix(in srgb, var(--lane-foundation) 55%, transparent);
		background: linear-gradient(165deg, var(--color-ink-soft) 0%, color-mix(in srgb, var(--lane-foundation) 20%, var(--color-ink-soft)) 100%);
		box-shadow: 0 0 0 1px color-mix(in srgb, var(--lane-foundation) 25%, transparent), 0 24px 50px rgba(79, 124, 76, 0.18);
	}

	/* animated flowing connector */
	.journey__connector {
		position: absolute;
		top: 3rem;
		right: -1rem;
		width: 1rem;
		height: 2px;
		background: var(--color-ink-line-strong);
		z-index: 2;
		overflow: hidden;
	}

	.journey__connector span {
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, transparent, var(--color-ink-accent), transparent);
		transform: translateX(-100%);
		animation: journeyFlow 2.4s linear infinite;
	}

	.journey__node:nth-child(2) .journey__connector span { animation-delay: 0.4s; }
	.journey__node:nth-child(3) .journey__connector span { animation-delay: 0.8s; }
	.journey__node:nth-child(4) .journey__connector span { animation-delay: 1.2s; }
	.journey__node:nth-child(5) .journey__connector span { animation-delay: 1.6s; }

	@keyframes journeyFlow {
		0% { transform: translateX(-100%); }
		60%, 100% { transform: translateX(100%); }
	}

	.journey__node:last-child .journey__connector {
		display: none;
	}

	.journey__node-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
	}

	.journey__step {
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-ink-accent);
	}

	.journey__step--final {
		color: var(--lane-foundation);
	}

	.journey__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.1rem;
		height: 3.1rem;
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.07);
		border: 1px solid var(--color-ink-line-strong);
		color: var(--color-white);
	}

	.journey__icon svg {
		width: 1.55rem;
		height: 1.55rem;
	}

	.journey__icon--foundation { color: color-mix(in srgb, var(--lane-foundation) 70%, white); }
	.journey__icon--custom     { color: var(--color-white); }
	.journey__icon--audit      { color: color-mix(in srgb, var(--lane-audit) 75%, white); }
	.journey__icon--growth     { color: color-mix(in srgb, var(--lane-growth) 80%, white); }

	.journey__icon--booked {
		background: var(--lane-foundation);
		border-color: var(--lane-foundation);
		color: var(--color-white);
		box-shadow: 0 0 0 6px color-mix(in srgb, var(--lane-foundation) 20%, transparent);
	}

	.journey__stage {
		margin: 0;
		color: var(--color-white);
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.journey__question {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		margin: 0;
		color: var(--color-white);
		font-size: 0.92rem;
		font-style: italic;
		font-weight: 500;
		line-height: 1.35;
	}

	.journey__question-label {
		font-size: 0.62rem;
		font-style: normal;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-ink-accent);
	}

	.journey__text {
		margin: 0;
		color: var(--color-ink-muted);
		font-size: 0.9rem;
		line-height: 1.55;
	}

	.journey__leak {
		display: flex;
		align-items: flex-start;
		gap: 0.45rem;
		margin: 0;
		padding: 0.6rem 0.7rem;
		border-radius: 9px;
		background: color-mix(in srgb, #C2553F 16%, transparent);
		border: 1px solid color-mix(in srgb, #C2553F 32%, transparent);
		color: color-mix(in srgb, #E8A593 90%, white);
		font-size: 0.78rem;
		font-weight: 600;
		line-height: 1.4;
	}

	.journey__leak svg {
		width: 0.95rem;
		height: 0.95rem;
		margin-top: 0.1rem;
		flex-shrink: 0;
	}

	.journey__system {
		margin-top: auto;
		width: fit-content;
		padding: 0.3rem 0.65rem;
		border-radius: 999px;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		background: rgba(255, 255, 255, 0.06);
		color: var(--color-ink-text);
		border: 1px solid var(--color-ink-line);
	}

	.journey__system--foundation { color: color-mix(in srgb, var(--lane-foundation) 60%, white); }
	.journey__system--audit      { color: color-mix(in srgb, var(--lane-audit) 70%, white); }
	.journey__system--growth     { color: color-mix(in srgb, var(--lane-growth) 75%, white); }
	.journey__system--booked {
		background: var(--lane-foundation);
		border-color: var(--lane-foundation);
		color: var(--color-white);
	}

	.journey__foot {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem 2rem;
		margin-top: clamp(2.25rem, 4vw, 3rem);
		padding-top: clamp(1.75rem, 3vw, 2.25rem);
		border-top: 1px solid var(--color-ink-line);
	}

	.journey__foot-text {
		max-width: 42rem;
		margin: 0;
		color: var(--color-ink-text);
		font-size: 1.05rem;
		font-weight: 500;
		line-height: 1.5;
	}

	.journey__foot-text strong {
		color: var(--color-white);
		font-weight: 750;
	}

	.journey__cta span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.journey__cta:hover span {
		transform: translateX(3px);
	}

	@media (max-width: 1280px) {
		.journey__track {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 1rem;
		}

		.journey__connector {
			display: none;
		}
	}

	@media (max-width: 1100px) {
		.journey__head {
			grid-template-columns: 1fr;
			align-items: start;
		}
	}

	@media (max-width: 760px) {
		.journey__track {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1rem;
		}
	}

	@media (max-width: 520px) {
		.journey__track {
			grid-template-columns: 1fr;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.journey__connector span {
			animation: none;
			transform: translateX(0);
			opacity: 0.5;
		}
	}
</style>
