---
const stages = [
	{
		lane: 'foundation',
		icon: 'search',
		stage: 'Discover',
		question: 'Is this relevant to me?',
		risk: 'Weak local visibility',
		fix: 'Search-ready entry points',
	},
	{
		lane: 'custom',
		icon: 'page',
		stage: 'Understand',
		question: 'Do they solve my problem?',
		risk: 'Services feel generic',
		fix: 'Pages organized by intent',
	},
	{
		lane: 'custom',
		icon: 'shield',
		stage: 'Trust',
		question: 'Can I trust this provider?',
		risk: 'Proof is hidden',
		fix: 'Trust near decision points',
	},
	{
		lane: 'audit',
		icon: 'cursor',
		stage: 'Act',
		question: 'What do I do next?',
		risk: 'CTA is buried',
		fix: 'Clear booking, call, and form paths',
	},
	{
		lane: 'growth',
		icon: 'flow',
		stage: 'Follow-Up',
		question: 'Did they respond clearly?',
		risk: 'Leads sit in an inbox',
		fix: 'CRM routing and nurture',
	},
	{
		lane: 'booked',
		icon: 'check',
		stage: 'Book',
		question: 'Am I ready to move forward?',
		risk: 'Too much friction',
		fix: 'Clear confirmation and next step',
	},
];
---

<section class="journey section-ink" aria-labelledby="journey-heading">
	<div class="dot-grid dot-grid--ink journey__dots" aria-hidden="true"></div>
	<div class="site-container site-container--wide journey__inner">
		<header class="journey__head">
			<div class="journey__head-main">
				<p class="eyebrow">From visitor to booked client</p>
				<h2 id="journey-heading" class="display-lg journey__headline">
					Every visit is a path.
					<span class="journey__headline-soft">Miss one step and they're gone.</span>
				</h2>
			</div>
			<p class="lead journey__lead">
				A website isn't one moment — it's a journey from "who is this?" to "I'm booked." Each stage is a place visitors can quietly drop off. We design the path end to end.
			</p>
		</header>

		<ol class="journey__track" aria-label="The path from visitor to booked client">
			{stages.map((s, i) => (
				<li class={`journey__node journey__node--${s.lane}`}>
					<div class="journey__connector" aria-hidden="true"><span></span></div>
					<div class="journey__node-top">
						<span class={`journey__icon journey__icon--${s.lane}`} aria-hidden="true">
							{s.icon === 'search' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="11" cy="11" r="7" /><path d="M16 16l5 5" />
								</svg>
							)}
							{s.icon === 'page' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M6 3h8l4 4v14H6z" /><path d="M14 3v4h4M9 13h6M9 17h6" />
								</svg>
							)}
							{s.icon === 'shield' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" /><path d="M9 12l2 2 4-4" />
								</svg>
							)}
							{s.icon === 'cursor' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M5 4l6 16 2.5-6.5L20 11z" />
								</svg>
							)}
							{s.icon === 'flow' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<rect x="3" y="4" width="6" height="6" rx="1.5" /><rect x="15" y="4" width="6" height="6" rx="1.5" /><rect x="9" y="14" width="6" height="6" rx="1.5" /><path d="M6 10v2h6M18 10v2h-6" />
								</svg>
							)}
							{s.icon === 'check' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 12l5 5L20 6" />
								</svg>
							)}
						</span>
						<span class:list={['journey__step', { 'journey__step--final': s.lane === 'booked' }]}>
							{s.lane === 'booked' ? 'Outcome' : `Step ${i + 1}`}
						</span>
					</div>
					<h3 class="journey__stage">{s.stage}</h3>
					<p class="journey__question"><span class="journey__question-label">They're asking</span>&ldquo;{s.question}&rdquo;</p>
					<div class="journey__rf">
						<p class="journey__risk"><span class="journey__rf-tag">Risk</span>{s.risk}</p>
						<p class="journey__fix"><span class="journey__rf-tag">Fix</span>{s.fix}</p>
					</div>
				</li>
			))}
		</ol>

		<div class="journey__foot">
			<p class="journey__foot-text">Most studios design one screen. We design the <strong>entire path</strong> that turns a stranger into a booked appointment.</p>
			<a class="button button-on-ink journey__cta" href="/audit">
				See where your path breaks
				<span aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</section>

<style>
	.journey {
		position: relative;
		overflow: hidden;
		padding-block: var(--section-spacing);
		/* Muted teal-gray route line that threads the whole journey */
		--journey-rail: color-mix(in srgb, var(--lane-foundation) 34%, var(--color-ink-line-strong));
		--journey-rail-accent: color-mix(in srgb, var(--lane-foundation) 70%, white);
	}

	.journey__dots {
		mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, #000 35%, transparent 80%);
		-webkit-mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, #000 35%, transparent 80%);
	}

	.journey__inner {
		position: relative;
	}

	.journey__head {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) minmax(0, 0.75fr);
		align-items: end;
		gap: clamp(1.5rem, 4vw, 3.5rem);
		margin: 0 0 clamp(2.75rem, 5vw, 4rem);
	}

	.journey__headline {
		color: var(--color-white);
	}

	.journey__headline-soft {
		display: block;
		color: var(--color-ink-accent);
		font-weight: 650;
	}

	.journey__lead {
		max-width: 34rem;
		margin: 0;
		color: var(--color-ink-muted);
	}

	.journey__track {
		position: relative;
		display: grid;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		gap: 0.85rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.journey__node {
		--node-pad: 1.1rem;
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 1.35rem var(--node-pad);
		border: 1px solid var(--color-ink-line-strong);
		border-radius: var(--radius-lg);
		background: var(--color-ink-soft);
		transition: transform 340ms var(--ease-out-quart), border-color var(--transition-base), box-shadow var(--transition-base);
	}

	/* Route line that runs through each node at the icon's center, bleeding to the
	   card edges so it visibly connects to the gap connectors on either side. */
	.journey__node-top::before {
		content: '';
		position: absolute;
		top: 1.55rem;
		left: calc(-1 * var(--node-pad));
		right: calc(-1 * var(--node-pad));
		height: 2px;
		transform: translateY(-50%);
		background: var(--journey-rail);
		z-index: 0;
	}

	/* The path terminates inside the Book node — stop the rail at the check node */
	.journey__node:last-child .journey__node-top::before {
		right: auto;
		width: calc(var(--node-pad) + 3.1rem);
		background: linear-gradient(90deg, var(--journey-rail), var(--journey-rail-accent));
	}

	.journey__node:hover {
		transform: translateY(-5px);
		box-shadow: 0 24px 50px rgba(0, 0, 0, 0.28);
	}

	.journey__node--foundation:hover { border-color: color-mix(in srgb, var(--lane-foundation) 60%, var(--color-ink-line-strong)); }
	.journey__node--custom:hover     { border-color: color-mix(in srgb, var(--lane-care) 60%, var(--color-ink-line-strong)); }
	.journey__node--audit:hover      { border-color: color-mix(in srgb, var(--lane-audit) 60%, var(--color-ink-line-strong)); }
	.journey__node--growth:hover     { border-color: color-mix(in srgb, var(--lane-growth) 60%, var(--color-ink-line-strong)); }
	.journey__node--booked {
		border-color: color-mix(in srgb, var(--lane-foundation) 55%, transparent);
		background: linear-gradient(165deg, var(--color-ink-soft) 0%, color-mix(in srgb, var(--lane-foundation) 20%, var(--color-ink-soft)) 100%);
		box-shadow: 0 0 0 1px color-mix(in srgb, var(--lane-foundation) 25%, transparent), 0 24px 50px rgba(79, 124, 76, 0.18);
	}

	/* connector bridging the rail across each gap, with a clear directional chevron */
	.journey__connector {
		position: absolute;
		top: 2.9rem;
		right: -0.95rem;
		width: 0.95rem;
		height: 2px;
		transform: translateY(-50%);
		background: var(--journey-rail);
		z-index: 2;
	}

	.journey__connector span {
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, transparent, var(--journey-rail-accent), transparent);
		transform: translateX(-100%);
		animation: journeyFlow 2.4s linear infinite;
	}

	.journey__connector::after {
		content: '';
		position: absolute;
		right: -2px;
		top: 50%;
		width: 9px;
		height: 9px;
		border-top: 2px solid var(--journey-rail-accent);
		border-right: 2px solid var(--journey-rail-accent);
		transform: translateY(-50%) rotate(45deg);
	}

	/* the last hop lands into the Book outcome — make it read as the arrival */
	.journey__node:nth-child(5) .journey__connector,
	.journey__node:nth-child(5) .journey__connector::after {
		border-color: var(--lane-foundation);
		background-color: color-mix(in srgb, var(--lane-foundation) 60%, var(--journey-rail));
	}

	.journey__node:nth-child(2) .journey__connector span { animation-delay: 0.4s; }
	.journey__node:nth-child(3) .journey__connector span { animation-delay: 0.8s; }
	.journey__node:nth-child(4) .journey__connector span { animation-delay: 1.2s; }
	.journey__node:nth-child(5) .journey__connector span { animation-delay: 1.6s; }

	@keyframes journeyFlow {
		0% { transform: translateX(-100%); }
		60%, 100% { transform: translateX(100%); }
	}

	.journey__node:last-child .journey__connector {
		display: none;
	}

	.journey__node-top {
		position: relative;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.5rem;
	}

	.journey__step {
		position: relative;
		z-index: 1;
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-ink-accent);
	}

	.journey__step--final {
		padding: 0.2rem 0.5rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--lane-foundation) 26%, transparent);
		color: color-mix(in srgb, var(--lane-foundation) 55%, white);
	}

	.journey__icon {
		position: relative;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.1rem;
		height: 3.1rem;
		border-radius: 14px;
		background: color-mix(in srgb, var(--color-white) 7%, var(--color-ink-soft));
		border: 1px solid color-mix(in srgb, var(--journey-rail) 70%, var(--color-ink-line-strong));
		color: var(--color-white);
	}

	.journey__icon svg {
		width: 1.55rem;
		height: 1.55rem;
	}

	.journey__icon--foundation { color: color-mix(in srgb, var(--lane-foundation) 70%, white); }
	.journey__icon--custom     { color: var(--color-white); }
	.journey__icon--audit      { color: color-mix(in srgb, var(--lane-audit) 75%, white); }
	.journey__icon--growth     { color: color-mix(in srgb, var(--lane-growth) 80%, white); }

	.journey__icon--booked {
		background: var(--lane-foundation);
		border-color: var(--lane-foundation);
		color: var(--color-white);
		box-shadow: 0 0 0 6px color-mix(in srgb, var(--lane-foundation) 20%, transparent);
	}

	.journey__stage {
		margin: 0;
		color: var(--color-white);
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.journey__question {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		margin: 0;
		color: var(--color-white);
		font-size: 0.92rem;
		font-style: italic;
		font-weight: 500;
		line-height: 1.35;
	}

	.journey__question-label {
		font-size: 0.62rem;
		font-style: normal;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-ink-accent);
	}

	.journey__rf {
		display: grid;
		gap: 0.55rem;
		margin-top: auto;
		padding-top: 0.2rem;
	}

	.journey__risk,
	.journey__fix {
		display: flex;
		align-items: flex-start;
		gap: 0.5rem;
		margin: 0;
		font-size: 0.82rem;
		line-height: 1.45;
	}

	.journey__rf-tag {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		min-width: 2.4rem;
		margin-top: 0.05rem;
		padding: 0.12rem 0.4rem;
		border-radius: 5px;
		font-size: 0.58rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.journey__risk {
		color: color-mix(in srgb, #E8A593 92%, white);
	}

	.journey__risk .journey__rf-tag {
		background: color-mix(in srgb, #C2553F 22%, transparent);
		color: color-mix(in srgb, #E8A593 95%, white);
	}

	.journey__fix {
		color: var(--color-ink-text);
	}

	.journey__fix .journey__rf-tag {
		background: color-mix(in srgb, var(--lane-foundation) 26%, transparent);
		color: color-mix(in srgb, var(--lane-foundation) 62%, white);
	}

	.journey__foot {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem 2rem;
		margin-top: clamp(2.25rem, 4vw, 3rem);
		padding-top: clamp(1.75rem, 3vw, 2.25rem);
		border-top: 1px solid var(--color-ink-line);
	}

	.journey__foot-text {
		max-width: 42rem;
		margin: 0;
		color: var(--color-ink-text);
		font-size: 1.05rem;
		font-weight: 500;
		line-height: 1.5;
	}

	.journey__foot-text strong {
		color: var(--color-white);
		font-weight: 750;
	}

	.journey__cta span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.journey__cta:hover span {
		transform: translateX(3px);
	}

	/* Laptops/desktops: keep the single-row horizontal path, just tighten spacing so it never feels cramped */
	@media (max-width: 1280px) {
		.journey__track {
			gap: 0.6rem;
		}

		.journey__node {
			--node-pad: 0.85rem;
		}

		.journey__stage {
			font-size: 1.05rem;
		}

		.journey__question {
			font-size: 0.86rem;
		}

		.journey__connector {
			right: -0.65rem;
			width: 0.65rem;
		}
	}

	@media (max-width: 1100px) {
		.journey__head {
			grid-template-columns: 1fr;
			align-items: start;
		}
	}

	/* Tablet + mobile: one centered vertical timeline so the path always reads as a connected journey, never scattered cards */
	@media (max-width: 1024px) {
		.journey__track {
			grid-template-columns: 1fr;
			gap: 1.9rem;
			max-width: 40rem;
			margin-inline: auto;
		}

		.journey__node {
			--node-pad: 1.35rem;
		}

		/* horizontal node rail off; the vertical connectors carry the path */
		.journey__node-top::before {
			display: none;
		}

		/* vertical segment dropping from each node's icon into the next */
		.journey__connector {
			display: block;
			top: auto;
			right: auto;
			bottom: -1.9rem;
			left: 2.9rem;
			width: 2px;
			height: 1.9rem;
			transform: none;
			background: var(--journey-rail);
		}

		.journey__connector span {
			display: none;
		}

		.journey__connector::after {
			right: auto;
			left: 50%;
			top: auto;
			bottom: -1px;
			transform: translateX(-50%) rotate(135deg);
		}

		.journey__node:last-child .journey__connector {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.journey__connector span {
			animation: none;
			transform: translateX(0);
			opacity: 0.5;
		}
	}
</style>
