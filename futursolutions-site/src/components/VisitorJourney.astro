---
const stages = [
	{
		lane: 'foundation',
		icon: 'search',
		stage: 'Discovers you',
		text: 'Found through local search, a referral, or an ad — and your site loads fast and looks the part.',
		system: 'Local Visibility',
	},
	{
		lane: 'custom',
		icon: 'shield',
		stage: 'Trusts you',
		text: 'Premium design, clear services, and real proof earn confidence in the first few seconds.',
		system: 'Website design',
	},
	{
		lane: 'audit',
		icon: 'cursor',
		stage: 'Takes the step',
		text: 'One obvious next action — book or inquire — with no friction or dead ends.',
		system: 'Conversion paths',
	},
	{
		lane: 'growth',
		icon: 'flow',
		stage: 'Gets followed up',
		text: 'The inquiry is captured, routed, and nurtured automatically — nothing slips through.',
		system: 'Growth System',
	},
];
---

<section class="journey section-ink" aria-labelledby="journey-heading">
	<div class="dot-grid dot-grid--ink journey__dots" aria-hidden="true"></div>
	<div class="site-container site-container--wide journey__inner">
		<header class="journey__head">
			<p class="eyebrow">From visitor to booked client</p>
			<h2 id="journey-heading" class="display-lg journey__headline">
				Every visit is a path.
				<span class="journey__headline-soft">We design the whole thing.</span>
			</h2>
			<p class="lead journey__lead">
				A website isn't one moment — it's a journey from "who is this?" to "I'm booked." Here's the path we build for, end to end.
			</p>
		</header>

		<ol class="journey__track" aria-label="The path from visitor to booked client">
			{stages.map((s, i) => (
				<li class={`journey__node journey__node--${s.lane}`}>
					<div class="journey__connector" aria-hidden="true"></div>
					<div class="journey__step">Step {i + 1}</div>
					<span class={`journey__icon journey__icon--${s.lane}`} aria-hidden="true">
						{s.icon === 'search' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="11" cy="11" r="7" /><path d="M16 16l5 5" />
							</svg>
						)}
						{s.icon === 'shield' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" /><path d="M9 12l2 2 4-4" />
							</svg>
						)}
						{s.icon === 'cursor' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M5 4l6 16 2.5-6.5L20 11z" />
							</svg>
						)}
						{s.icon === 'flow' && (
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<rect x="3" y="4" width="6" height="6" rx="1.5" /><rect x="15" y="4" width="6" height="6" rx="1.5" /><rect x="9" y="14" width="6" height="6" rx="1.5" /><path d="M6 10v2h6M18 10v2h-6" />
							</svg>
						)}
					</span>
					<h3 class="journey__stage">{s.stage}</h3>
					<p class="journey__text">{s.text}</p>
					<span class={`journey__system journey__system--${s.lane}`}>{s.system}</span>
				</li>
			))}

			<li class="journey__node journey__node--booked">
				<div class="journey__connector" aria-hidden="true"></div>
				<div class="journey__step journey__step--final">Result</div>
				<span class="journey__icon journey__icon--booked" aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M4 12l5 5L20 6" />
					</svg>
				</span>
				<h3 class="journey__stage">Booked client</h3>
				<p class="journey__text">A new patient on the calendar — not a lead lost to a slow inbox.</p>
				<span class="journey__system journey__system--booked">The whole point</span>
			</li>
		</ol>

		<div class="journey__foot">
			<p class="journey__foot-text">Most studios design one screen. We design the path that turns a stranger into a booked appointment.</p>
			<a class="button button-on-ink journey__cta" href="/audit">
				See where your path breaks
				<span aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</section>

<style>
	.journey {
		position: relative;
		overflow: hidden;
		padding-block: var(--section-spacing);
	}

	.journey__dots {
		mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, #000 35%, transparent 80%);
		-webkit-mask-image: radial-gradient(ellipse 90% 70% at 50% 30%, #000 35%, transparent 80%);
	}

	.journey__inner {
		position: relative;
	}

	.journey__head {
		display: grid;
		gap: 1.1rem;
		max-width: 54rem;
		margin: 0 0 clamp(2.75rem, 5vw, 4rem);
	}

	.journey__headline {
		color: var(--color-white);
	}

	.journey__headline-soft {
		display: block;
		color: var(--color-ink-accent);
		font-weight: 650;
	}

	.journey__lead {
		max-width: 50rem;
		color: var(--color-ink-muted);
	}

	.journey__track {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
		counter-reset: journey;
	}

	.journey__node {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 1.4rem 1.2rem;
		border: 1px solid var(--color-ink-line-strong);
		border-radius: var(--radius-lg);
		background: var(--color-ink-soft);
		transition: transform 340ms var(--ease-out-quart), border-color var(--transition-base);
	}

	.journey__node:hover {
		transform: translateY(-4px);
	}

	.journey__node--foundation:hover { border-color: color-mix(in srgb, var(--lane-foundation) 55%, var(--color-ink-line-strong)); }
	.journey__node--custom:hover     { border-color: color-mix(in srgb, var(--lane-care) 55%, var(--color-ink-line-strong)); }
	.journey__node--audit:hover      { border-color: color-mix(in srgb, var(--lane-audit) 55%, var(--color-ink-line-strong)); }
	.journey__node--growth:hover     { border-color: color-mix(in srgb, var(--lane-growth) 55%, var(--color-ink-line-strong)); }
	.journey__node--booked {
		border-color: color-mix(in srgb, var(--lane-foundation) 50%, transparent);
		background: linear-gradient(160deg, var(--color-ink-soft) 0%, color-mix(in srgb, var(--lane-foundation) 16%, var(--color-ink-soft)) 100%);
	}

	/* connecting line between nodes */
	.journey__connector {
		position: absolute;
		top: 2.7rem;
		right: -1rem;
		width: 1rem;
		height: 2px;
		background: linear-gradient(90deg, var(--color-ink-accent), transparent);
		z-index: 1;
	}

	.journey__node:last-child .journey__connector {
		display: none;
	}

	.journey__step {
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-ink-accent);
	}

	.journey__step--final {
		color: var(--lane-foundation);
	}

	.journey__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.85rem;
		height: 2.85rem;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid var(--color-ink-line-strong);
		color: var(--color-white);
	}

	.journey__icon svg {
		width: 1.4rem;
		height: 1.4rem;
	}

	.journey__icon--foundation { color: color-mix(in srgb, var(--lane-foundation) 70%, white); }
	.journey__icon--custom     { color: var(--color-white); }
	.journey__icon--audit      { color: color-mix(in srgb, var(--lane-audit) 75%, white); }
	.journey__icon--growth     { color: color-mix(in srgb, var(--lane-growth) 80%, white); }

	.journey__icon--booked {
		background: var(--lane-foundation);
		border-color: var(--lane-foundation);
		color: var(--color-white);
		box-shadow: 0 0 0 6px color-mix(in srgb, var(--lane-foundation) 20%, transparent);
	}

	.journey__stage {
		margin: 0;
		color: var(--color-white);
		font-size: 1.08rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.journey__text {
		margin: 0;
		color: var(--color-ink-muted);
		font-size: 0.88rem;
		line-height: 1.55;
	}

	.journey__system {
		margin-top: auto;
		width: fit-content;
		padding: 0.28rem 0.6rem;
		border-radius: 999px;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		background: rgba(255, 255, 255, 0.06);
		color: var(--color-ink-text);
		border: 1px solid var(--color-ink-line);
	}

	.journey__system--foundation { color: color-mix(in srgb, var(--lane-foundation) 60%, white); }
	.journey__system--audit      { color: color-mix(in srgb, var(--lane-audit) 70%, white); }
	.journey__system--growth     { color: color-mix(in srgb, var(--lane-growth) 75%, white); }
	.journey__system--booked {
		background: var(--lane-foundation);
		border-color: var(--lane-foundation);
		color: var(--color-white);
	}

	.journey__foot {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem 2rem;
		margin-top: clamp(2.25rem, 4vw, 3rem);
		padding-top: clamp(1.75rem, 3vw, 2.25rem);
		border-top: 1px solid var(--color-ink-line);
	}

	.journey__foot-text {
		max-width: 40rem;
		margin: 0;
		color: var(--color-ink-text);
		font-size: 1.02rem;
		font-weight: 500;
		line-height: 1.5;
	}

	.journey__cta span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.journey__cta:hover span {
		transform: translateX(3px);
	}

	@media (max-width: 1100px) {
		.journey__track {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.2rem 2rem;
		}

		.journey__connector {
			display: none;
		}
	}

	@media (max-width: 560px) {
		.journey__track {
			grid-template-columns: 1fr;
		}
	}
</style>
