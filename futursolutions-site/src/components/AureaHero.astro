<section class="aurea-hero" aria-labelledby="aurea-hero-heading">
	<div class="aurea-container aurea-hero__inner">
		<div class="aurea-hero__content">
			<p class="aurea-eyebrow">Aur&eacute;a Skin &amp; Aesthetics &middot; Temecula, CA</p>
			<h1 id="aurea-hero-heading">Modern aesthetics, medically guided.</h1>
			<p class="aurea-lead">
				Natural-looking injectables, laser treatments, and skin care plans designed around your features, goals, and comfort.
			</p>
			<div class="aurea-btn-row">
				<a class="aurea-btn aurea-btn--primary" href="/demos/med-spa/contact">Book a Consultation</a>
				<a class="aurea-btn aurea-btn--secondary" href="/demos/med-spa/treatments">Explore Treatments</a>
			</div>
			<ul class="aurea-hero__trust" aria-label="Trust highlights">
				<li>
					<span aria-hidden="true"></span>
					Licensed providers
				</li>
				<li>
					<span aria-hidden="true"></span>
					Natural-looking results
				</li>
				<li>
					<span aria-hidden="true"></span>
					Personalized treatment plans
				</li>
			</ul>
		</div>

		<div class="aurea-hero__visual" aria-hidden="true">
			<div class="aurea-hero__panel">
				<div class="aurea-hero__panel-corner"></div>
				<div class="aurea-hero__panel-ambiance">
					<div class="aurea-hero__panel-orb aurea-hero__panel-orb--1"></div>
					<div class="aurea-hero__panel-orb aurea-hero__panel-orb--2"></div>
					<div class="aurea-hero__panel-lines">
						<div></div><div></div><div></div>
					</div>
				</div>

				<div class="aurea-hero__profile-card">
					<div class="aurea-hero__profile-accent"></div>
					<div class="aurea-hero__profile-name">Facial Balancing</div>
					<div class="aurea-hero__profile-tags">Dermal Fillers &middot; Botox</div>
				</div>
			</div>

			<div class="aurea-hero__stat-card">
				<div class="aurea-hero__stat-number">4.9</div>
				<div class="aurea-hero__stat-body">
					<div class="aurea-hero__stat-stars" aria-hidden="true">
						<svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 1.5l2.47 5.01L18 7.27l-4 3.9.94 5.5L10 14.14l-4.94 2.53.94-5.5-4-3.9 5.53-.76z"/></svg>
						<svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 1.5l2.47 5.01L18 7.27l-4 3.9.94 5.5L10 14.14l-4.94 2.53.94-5.5-4-3.9 5.53-.76z"/></svg>
						<svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 1.5l2.47 5.01L18 7.27l-4 3.9.94 5.5L10 14.14l-4.94 2.53.94-5.5-4-3.9 5.53-.76z"/></svg>
						<svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 1.5l2.47 5.01L18 7.27l-4 3.9.94 5.5L10 14.14l-4.94 2.53.94-5.5-4-3.9 5.53-.76z"/></svg>
						<svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 1.5l2.47 5.01L18 7.27l-4 3.9.94 5.5L10 14.14l-4.94 2.53.94-5.5-4-3.9 5.53-.76z"/></svg>
					</div>
					<div class="aurea-hero__stat-label">from 200+ patient reviews</div>
				</div>
			</div>

			<div class="aurea-hero__consult-badge">
				<span class="aurea-hero__consult-dot"></span>
				Consultations available
			</div>
		</div>
	</div>
</section>

<style>
	.aurea-hero {
		padding-block: clamp(6rem, 10vw, 10rem) clamp(5rem, 8vw, 8rem);
		background:
			radial-gradient(ellipse at 80% 12%, color-mix(in srgb, var(--aurea-champagne) 16%, transparent), transparent 55%),
			radial-gradient(ellipse at 15% 90%, color-mix(in srgb, var(--aurea-sage) 10%, transparent), transparent 45%),
			radial-gradient(circle at 50% 50%, color-mix(in srgb, var(--aurea-champagne) 4%, transparent), transparent 70%),
			linear-gradient(175deg, var(--aurea-white) 0%, var(--aurea-bg) 60%, var(--aurea-bg-warm) 100%);
	}

	.aurea-hero__inner {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(360px, 0.82fr);
		gap: clamp(3rem, 6vw, 6rem);
		align-items: center;
	}

	.aurea-hero__content h1 {
		max-width: 13ch;
	}

	/* ---- Trust strip ---- */

	.aurea-hero__trust {
		display: flex;
		flex-wrap: wrap;
		gap: 1.35rem;
		margin: 2.25rem 0 0;
		padding: 0;
		list-style: none;
	}

	.aurea-hero__trust li {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--aurea-muted);
	}

	.aurea-hero__trust span {
		display: block;
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: var(--aurea-champagne);
	}

	/* ---- Visual composition ---- */

	.aurea-hero__visual {
		position: relative;
		min-height: 480px;
	}

	/* -- Main panel -- */

	.aurea-hero__panel {
		position: relative;
		width: 100%;
		height: 420px;
		border-radius: var(--aurea-radius-lg);
		background:
			linear-gradient(
				155deg,
				color-mix(in srgb, var(--aurea-sage) 22%, var(--aurea-ivory)),
				color-mix(in srgb, var(--aurea-stone) 30%, var(--aurea-white)) 55%,
				color-mix(in srgb, var(--aurea-champagne) 12%, var(--aurea-ivory))
			);
		border: 1px solid var(--aurea-border);
		box-shadow:
			0 24px 64px rgba(36, 35, 33, 0.07),
			0 4px 16px rgba(36, 35, 33, 0.03);
		overflow: hidden;
	}

	.aurea-hero__panel-corner {
		position: absolute;
		top: 16px;
		right: 16px;
		width: 56px;
		height: 56px;
		border-top: 1.5px solid var(--aurea-champagne);
		border-right: 1.5px solid var(--aurea-champagne);
		border-radius: 0 12px 0 0;
		opacity: 0.5;
	}

	.aurea-hero__panel-ambiance {
		position: absolute;
		inset: 0;
		overflow: hidden;
	}

	.aurea-hero__panel-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(50px);
	}

	.aurea-hero__panel-orb--1 {
		top: 15%;
		left: 20%;
		width: 180px;
		height: 180px;
		background: color-mix(in srgb, var(--aurea-sage) 18%, transparent);
	}

	.aurea-hero__panel-orb--2 {
		bottom: 20%;
		right: 15%;
		width: 140px;
		height: 140px;
		background: color-mix(in srgb, var(--aurea-champagne) 15%, transparent);
	}

	.aurea-hero__panel-lines {
		position: absolute;
		top: 30%;
		left: 10%;
		display: flex;
		flex-direction: column;
		gap: 10px;
		opacity: 0.15;
	}

	.aurea-hero__panel-lines div {
		height: 1px;
		background: var(--aurea-charcoal);
		border-radius: 1px;
	}

	.aurea-hero__panel-lines div:nth-child(1) { width: 120px; }
	.aurea-hero__panel-lines div:nth-child(2) { width: 80px; }
	.aurea-hero__panel-lines div:nth-child(3) { width: 100px; }

	/* -- Treatment profile card -- */

	.aurea-hero__profile-card {
		position: absolute;
		bottom: 24px;
		left: 20px;
		background: var(--aurea-white);
		border: 1px solid var(--aurea-border);
		border-radius: var(--aurea-radius);
		padding: 1rem 1.2rem;
		box-shadow: 0 10px 32px rgba(36, 35, 33, 0.08);
		min-width: 180px;
	}

	.aurea-hero__profile-accent {
		width: 32px;
		height: 3px;
		border-radius: 2px;
		background: var(--aurea-champagne);
		margin-bottom: 0.65rem;
	}

	.aurea-hero__profile-name {
		font-family: var(--aurea-font-heading);
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--aurea-charcoal);
		line-height: 1.2;
		margin-bottom: 0.3rem;
	}

	.aurea-hero__profile-tags {
		font-size: 0.78rem;
		font-weight: 500;
		color: var(--aurea-muted);
		letter-spacing: 0.01em;
	}

	/* -- Stat card -- */

	.aurea-hero__stat-card {
		position: absolute;
		bottom: -12px;
		right: -8px;
		display: flex;
		align-items: center;
		gap: 0.85rem;
		padding: 1.1rem 1.35rem;
		border: 1px solid var(--aurea-border);
		border-radius: var(--aurea-radius);
		background: var(--aurea-white);
		box-shadow:
			0 16px 48px rgba(36, 35, 33, 0.08),
			0 4px 12px rgba(36, 35, 33, 0.03);
		z-index: 2;
	}

	.aurea-hero__stat-number {
		font-family: var(--aurea-font-heading);
		font-size: 2.15rem;
		font-weight: 700;
		color: var(--aurea-charcoal);
		letter-spacing: -0.03em;
		line-height: 1;
	}

	.aurea-hero__stat-body {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.aurea-hero__stat-stars {
		display: flex;
		gap: 2px;
		color: var(--aurea-champagne);
	}

	.aurea-hero__stat-stars svg {
		width: 14px;
		height: 14px;
	}

	.aurea-hero__stat-label {
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--aurea-muted);
		white-space: nowrap;
	}

	/* -- Consultation badge -- */

	.aurea-hero__consult-badge {
		position: absolute;
		top: -10px;
		right: 24px;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.55rem 1rem;
		border: 1px solid var(--aurea-border);
		border-radius: 999px;
		background: var(--aurea-white);
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--aurea-charcoal);
		box-shadow: 0 8px 24px rgba(36, 35, 33, 0.06);
		z-index: 2;
		white-space: nowrap;
	}

	.aurea-hero__consult-dot {
		display: block;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--aurea-champagne);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--aurea-champagne) 20%, transparent);
	}

	/* ---- Responsive ---- */

	@media (max-width: 960px) {
		.aurea-hero__inner {
			grid-template-columns: 1fr;
		}

		.aurea-hero__content h1 {
			max-width: none;
		}

		.aurea-hero__visual {
			min-height: 380px;
			max-width: 480px;
		}

		.aurea-hero__panel {
			height: 340px;
		}

		.aurea-hero__stat-card {
			right: 0;
			bottom: -8px;
		}
	}

	@media (max-width: 560px) {
		.aurea-hero__visual {
			min-height: 320px;
		}

		.aurea-hero__panel {
			height: 280px;
		}

		.aurea-hero__stat-card {
			padding: 0.85rem 1rem;
			gap: 0.6rem;
		}

		.aurea-hero__stat-number {
			font-size: 1.65rem;
		}

		.aurea-hero__consult-badge {
			right: 8px;
		}
	}
</style>
