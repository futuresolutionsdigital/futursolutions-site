---
---

<section class="aurea-hero" aria-labelledby="aurea-hero-heading">
	<div class="aurea-container aurea-hero__inner">
		<div class="aurea-hero__content">
			<p class="aurea-eyebrow">Aur&eacute;a Skin &amp; Aesthetics &middot; Temecula, CA</p>
			<h1 id="aurea-hero-heading">Modern aesthetics, medically guided.</h1>
			<p class="aurea-lead">
				Natural-looking injectables, laser treatments, and skin care plans designed around your features, goals, and comfort.
			</p>
			<div class="aurea-btn-row">
				<a class="aurea-btn aurea-btn--primary" href="#location">Book a Consultation</a>
				<a class="aurea-btn aurea-btn--secondary" href="#treatments">Explore Treatments</a>
			</div>
			<ul class="aurea-hero__trust" aria-label="Trust highlights">
				<li>
					<span aria-hidden="true"></span>
					Licensed providers
				</li>
				<li>
					<span aria-hidden="true"></span>
					Natural-looking results
				</li>
				<li>
					<span aria-hidden="true"></span>
					Personalized treatment plans
				</li>
			</ul>
		</div>
		<div class="aurea-hero__visual" aria-hidden="true">
			<div class="aurea-hero__card-main">
				<div class="aurea-hero__card-label">Consultation-ready</div>
				<div class="aurea-hero__card-headline">
					Your treatment plan starts with listening.
				</div>
				<div class="aurea-hero__card-tags">
					<span>Personalized</span>
					<span>Medical oversight</span>
					<span>Natural results</span>
				</div>
			</div>
			<div class="aurea-hero__card-stat">
				<div class="aurea-hero__stat-number">4.9</div>
				<div class="aurea-hero__stat-label">from 200+ patient reviews</div>
			</div>
		</div>
	</div>
</section>

<style>
	.aurea-hero {
		padding-block: clamp(5rem, 9vw, 8rem) clamp(4rem, 7vw, 7rem);
		background:
			radial-gradient(ellipse at 78% 15%, color-mix(in srgb, var(--aurea-champagne) 14%, transparent), transparent 50%),
			radial-gradient(ellipse at 20% 85%, color-mix(in srgb, var(--aurea-sage) 8%, transparent), transparent 40%),
			linear-gradient(180deg, var(--aurea-white) 0%, var(--aurea-bg) 80%);
	}

	.aurea-hero__inner {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.78fr);
		gap: clamp(3rem, 6vw, 5rem);
		align-items: center;
	}

	.aurea-hero__content h1 {
		max-width: 12ch;
	}

	.aurea-hero__trust {
		display: flex;
		flex-wrap: wrap;
		gap: 1.25rem;
		margin: 2rem 0 0;
		padding: 0;
		list-style: none;
	}

	.aurea-hero__trust li {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--aurea-muted);
	}

	.aurea-hero__trust span {
		display: block;
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: var(--aurea-champagne);
	}

	.aurea-hero__visual {
		display: grid;
		gap: 0.85rem;
	}

	.aurea-hero__card-main {
		display: flex;
		flex-direction: column;
		min-height: 340px;
		padding: 1.75rem;
		border: 1px solid var(--aurea-border);
		border-radius: var(--aurea-radius-lg);
		background:
			linear-gradient(145deg, color-mix(in srgb, var(--aurea-ivory) 88%, var(--aurea-champagne)), var(--aurea-white) 70%);
		box-shadow: 0 20px 55px rgba(36, 35, 33, 0.06);
	}

	.aurea-hero__card-label {
		color: var(--aurea-champagne);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.aurea-hero__card-headline {
		margin-top: auto;
		font-family: var(--aurea-font-heading);
		font-size: 1.65rem;
		font-weight: 600;
		line-height: 1.15;
		color: var(--aurea-charcoal);
		letter-spacing: -0.02em;
		max-width: 280px;
	}

	.aurea-hero__card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 1.25rem;
	}

	.aurea-hero__card-tags span {
		display: inline-flex;
		padding: 0.32rem 0.6rem;
		border: 1px solid var(--aurea-border);
		border-radius: 999px;
		background: var(--aurea-white);
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--aurea-muted);
	}

	.aurea-hero__card-stat {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		padding: 1.15rem 1.4rem;
		border: 1px solid var(--aurea-border);
		border-radius: var(--aurea-radius);
		background: var(--aurea-white);
		box-shadow: 0 12px 36px rgba(36, 35, 33, 0.04);
	}

	.aurea-hero__stat-number {
		font-family: var(--aurea-font-heading);
		font-size: 2rem;
		font-weight: 700;
		color: var(--aurea-charcoal);
		letter-spacing: -0.03em;
		line-height: 1;
	}

	.aurea-hero__stat-label {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--aurea-muted);
	}

	@media (max-width: 960px) {
		.aurea-hero__inner {
			grid-template-columns: 1fr;
		}

		.aurea-hero__content h1 {
			max-width: none;
		}

		.aurea-hero__card-main {
			min-height: 240px;
		}
	}
</style>
