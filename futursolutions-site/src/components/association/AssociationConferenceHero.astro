---
import { annualConferenceHero } from '../../data/association';
const h = annualConferenceHero;
---

<section class="conf-hero" aria-labelledby="conf-hero-heading">
	<div class="assoc-container conf-hero__inner">
		<div class="conf-hero__content">
			<p class="assoc-eyebrow">{h.eyebrow}</p>
			<h1 id="conf-hero-heading">{h.headline}</h1>
			<p class="conf-hero__lead">{h.lead}</p>
			<div class="conf-hero__meta">
				<span class="conf-hero__meta-item">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
					{h.date}
				</span>
				<span class="conf-hero__meta-item">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
					{h.location}
				</span>
				<span class="conf-hero__meta-chip">{h.ceHours}</span>
				<span class="conf-hero__meta-chip">{h.attendees}</span>
			</div>
			<div class="assoc-btn-row">
				<a class="assoc-btn assoc-btn--primary" href={h.primaryCta.href}>{h.primaryCta.text}</a>
				<a class="assoc-btn assoc-btn--secondary" href={h.secondaryCta.href}>{h.secondaryCta.text}</a>
			</div>
			<a class="conf-hero__tertiary" href={h.tertiaryLink.href}>{h.tertiaryLink.text}</a>
		</div>
		<div class="conf-hero__visual" aria-hidden="true">
			<div class="conf-hero__card conf-hero__card--wide">
				<div class="conf-hero__card-dot conf-hero__card-dot--teal"></div>
				<span class="conf-hero__card-label">Registration</span>
				<span class="conf-hero__card-value">Open</span>
			</div>
			<div class="conf-hero__card">
				<div class="conf-hero__card-dot conf-hero__card-dot--navy"></div>
				<span class="conf-hero__card-label">CE Hours</span>
				<span class="conf-hero__card-value">18</span>
			</div>
			<div class="conf-hero__card">
				<div class="conf-hero__card-dot conf-hero__card-dot--teal"></div>
				<span class="conf-hero__card-label">Sessions</span>
				<span class="conf-hero__card-value">42</span>
			</div>
			<div class="conf-hero__card conf-hero__card--wide">
				<div class="conf-hero__card-dot conf-hero__card-dot--coral"></div>
				<span class="conf-hero__card-label">Policy Briefing</span>
				<span class="conf-hero__card-value">Friday AM</span>
			</div>
			<div class="conf-hero__card conf-hero__card--wide conf-hero__card--deadline">
				<div class="conf-hero__card-dot conf-hero__card-dot--coral"></div>
				<span class="conf-hero__card-label">Member Rate Deadline</span>
				<span class="conf-hero__card-value">August 30</span>
			</div>
			<div class="conf-hero__badge">
				<span>3</span>
				<small>days</small>
			</div>
		</div>
	</div>
</section>

<style>
	.conf-hero {
		padding-block: clamp(3rem, 6vw, 5rem);
		background:
			radial-gradient(ellipse at 80% 25%, color-mix(in srgb, var(--assoc-teal) 6%, transparent), transparent 55%),
			linear-gradient(175deg, var(--assoc-bg) 40%, color-mix(in srgb, var(--assoc-sand) 40%, var(--assoc-bg)) 100%);
		border-bottom: 1px solid var(--assoc-border);
	}

	.conf-hero__inner {
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		align-items: center;
		gap: clamp(2rem, 5vw, 4rem);
	}

	.conf-hero__content h1 {
		max-width: 600px;
		text-wrap: balance;
	}

	.conf-hero__lead {
		max-width: 520px;
		font-size: clamp(1.02rem, 1rem + 0.15vw, 1.12rem);
		line-height: 1.6;
		color: var(--assoc-slate);
	}

	.conf-hero__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-bottom: 0.5rem;
	}

	.conf-hero__meta-item {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--assoc-slate);
	}

	.conf-hero__meta-item svg { display: inline; flex-shrink: 0; color: var(--assoc-teal); }

	.conf-hero__meta-chip {
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		background: var(--assoc-teal-light);
		color: var(--assoc-teal);
		font-size: 0.75rem;
		font-weight: 700;
	}

	.conf-hero__tertiary {
		display: inline-block;
		margin-top: 0.75rem;
		font-size: 0.88rem;
		font-weight: 700;
		color: var(--assoc-coral);
	}
	.conf-hero__tertiary:hover { color: var(--assoc-navy); }

	/* Visual cluster */
	.conf-hero__visual {
		position: relative;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.65rem;
		padding: 0.75rem;
	}

	.conf-hero__card {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0.85rem 1rem;
		border: 1px solid var(--assoc-border);
		border-radius: var(--assoc-radius);
		background: var(--assoc-white);
		box-shadow: 0 3px 14px rgba(16, 42, 67, 0.04);
	}

	.conf-hero__card--wide { grid-column: 1 / -1; flex-direction: row; align-items: center; gap: 0.6rem; }

	.conf-hero__card-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
	.conf-hero__card-dot--teal { background: var(--assoc-teal); }
	.conf-hero__card-dot--navy { background: var(--assoc-navy); }
	.conf-hero__card-dot--coral { background: var(--assoc-coral); }

	.conf-hero__card-label {
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--assoc-slate);
	}

	.conf-hero__card-value {
		font-size: 1rem;
		font-weight: 800;
		color: var(--assoc-navy);
		letter-spacing: -0.02em;
	}

	.conf-hero__card--wide .conf-hero__card-value { margin-left: auto; }

	.conf-hero__card--deadline { background: var(--assoc-coral-light); border-color: color-mix(in srgb, var(--assoc-coral) 15%, transparent); }
	.conf-hero__card--deadline .conf-hero__card-value { color: var(--assoc-coral); }

	.conf-hero__badge {
		position: absolute;
		top: -0.4rem;
		right: -0.15rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		width: 3.2rem;
		height: 3.2rem;
		border-radius: 50%;
		background: var(--assoc-navy);
		color: var(--assoc-white);
		box-shadow: 0 4px 14px rgba(16, 42, 67, 0.2);
	}
	.conf-hero__badge span { font-size: 1.05rem; font-weight: 800; line-height: 1; }
	.conf-hero__badge small { font-size: 0.5rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; opacity: 0.75; }

	@media (max-width: 900px) {
		.conf-hero__inner { grid-template-columns: 1fr; }
		.conf-hero__visual { max-width: 440px; }
	}

	@media (max-width: 480px) {
		.conf-hero__badge { width: 2.6rem; height: 2.6rem; }
		.conf-hero__badge span { font-size: 0.85rem; }
	}
</style>
