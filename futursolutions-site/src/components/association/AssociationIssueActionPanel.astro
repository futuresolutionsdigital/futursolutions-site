---
import { advocacyIssueActions, advocacyIssueDates, advocacyIssueResources } from '../../data/association';
const act = advocacyIssueActions;
---

<!-- Action panel -->
<section class="issue-action" id="take-action" aria-labelledby="issue-action-heading">
	<div class="assoc-container issue-action__inner">
		<div class="issue-action__steps">
			<p class="issue-action__eyebrow">Take Action</p>
			<h2 id="issue-action-heading">{act.headline}</h2>
			<div class="issue-action__step-list">
				{act.steps.map((s) => (
					<div class="issue-action__step">
						<span class="issue-action__step-num">{s.num}</span>
						<div>
							<h3>{s.title}</h3>
							<p>{s.description}</p>
						</div>
					</div>
				))}
			</div>
			<form class="issue-compose" data-demo-form novalidate>
				<div class="issue-compose__fields" data-demo-fields>
					<input type="text" name="company_url" tabindex="-1" autocomplete="off" aria-hidden="true" data-honeypot />
					<p class="issue-compose__to"><span>To:</span> {act.recipient}</p>
					<div class="issue-compose__row">
						<div class="issue-compose__field">
							<label for="ia-name">Your name</label>
							<input type="text" id="ia-name" placeholder="Your name" autocomplete="name" data-required />
							<span class="assoc-form-error" data-error-for="ia-name" role="alert" hidden></span>
						</div>
						<div class="issue-compose__field">
							<label for="ia-email">Your email</label>
							<input type="email" id="ia-email" placeholder="you@example.com" autocomplete="email" data-required />
							<span class="assoc-form-error" data-error-for="ia-email" role="alert" hidden></span>
						</div>
					</div>
					<div class="issue-compose__field">
						<label for="ia-message">Your message <span class="issue-compose__opt">(edit to personalize)</span></label>
						<textarea id="ia-message" rows="5" data-required>{act.messageTemplate}</textarea>
						<span class="assoc-form-error" data-error-for="ia-message" role="alert" hidden></span>
					</div>
					<div class="assoc-btn-row">
						<button type="submit" class="assoc-btn issue-action__btn-primary">{act.primaryCta.text}</button>
						<a class="assoc-btn assoc-btn--secondary" href={act.secondaryCta.href}>{act.secondaryCta.text}</a>
					</div>
					<p class="issue-compose__note">Demonstration only — no message is sent. In a live advocacy portal, this would route to the member's elected officials by district and count toward the campaign total.</p>
				</div>

				<div class="assoc-form-success" data-demo-success hidden>
					<span class="assoc-form-success__icon" aria-hidden="true">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
					</span>
					<h3>Your message is ready to make an impact.</h3>
					<p>It passed validation and would be on its way to {act.recipient}.</p>
					<p class="assoc-form-success__demo-note">In your live site, an advocacy portal like this matches each member to their elected officials by address, delivers the message, tracks how many members have taken action, and shows real-time campaign momentum — turning passive supporters into active advocates.</p>
					<button type="button" class="assoc-btn assoc-btn--secondary assoc-form-success__reset" data-demo-reset>Compose another</button>
				</div>
			</form>
		</div>
		<div class="issue-action__sidebar">
			<!-- Key dates -->
			<div class="issue-dates">
				<h3>Key Dates</h3>
				{advocacyIssueDates.map((d) => (
					<div class="issue-dates__item">
						<span class="issue-dates__date">{d.date}</span>
						<span class="issue-dates__label">{d.label}</span>
					</div>
				))}
			</div>
			<!-- Resources -->
			<div class="issue-resources" id="resources">
				<h3>Resources</h3>
				{advocacyIssueResources.map((r) => (
					<div class="issue-resource-card">
						<div class="issue-resource-card__top">
							<span class="issue-resource-card__format">{r.format}</span>
							<span class:list={['issue-resource-card__access', { 'issue-resource-card__access--member': r.access === 'Member-only' }]}>{r.access}</span>
						</div>
						<h4>{r.title}</h4>
						<p>{r.summary}</p>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.issue-action {
		padding-block: var(--assoc-section-spacing);
		background: var(--assoc-coral-light);
		border-block: 1px solid color-mix(in srgb, var(--assoc-coral) 12%, transparent);
	}
	.issue-action__inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
	.issue-action__eyebrow { font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--assoc-coral); margin-bottom: 0.5rem; }
	.issue-action h2 { font-size: clamp(1.2rem, 1.1rem + 0.5vw, 1.55rem); margin-bottom: 1.25rem; }
	.issue-action__step-list { display: grid; gap: 1rem; margin-bottom: 1.5rem; }
	.issue-action__step { display: flex; gap: 1rem; align-items: flex-start; }
	.issue-action__step-num {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 50%;
		background: var(--assoc-coral);
		color: var(--assoc-white);
		font-size: 0.88rem;
		font-weight: 800;
	}
	.issue-action__step h3 { font-size: 0.95rem; margin-bottom: 0.15rem; }
	.issue-action__step p { font-size: 0.85rem; line-height: 1.5; margin: 0; }
	.issue-action__btn-primary { background: var(--assoc-coral) !important; color: var(--assoc-white) !important; border-color: var(--assoc-coral) !important; }
	.issue-action__btn-primary:hover { background: color-mix(in srgb, var(--assoc-coral) 85%, var(--assoc-navy)) !important; }

	.issue-compose__fields { display: grid; gap: 0.85rem; padding: 1.25rem; border: 1px solid color-mix(in srgb, var(--assoc-coral) 18%, var(--assoc-border)); border-radius: var(--assoc-radius); background: var(--assoc-white); }
	.issue-compose__to { font-size: 0.85rem; font-weight: 700; color: var(--assoc-navy); margin: 0; }
	.issue-compose__to span { color: var(--assoc-slate); font-weight: 600; }
	.issue-compose__row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem; }
	.issue-compose__field label { display: block; font-size: 0.8rem; font-weight: 700; color: var(--assoc-navy); margin-bottom: 0.25rem; }
	.issue-compose__opt { font-weight: 400; color: var(--assoc-slate); }
	.issue-compose__field input,
	.issue-compose__field textarea { width: 100%; padding: 0.55rem 0.75rem; border: 1px solid var(--assoc-border); border-radius: 8px; font-size: 0.88rem; font-family: inherit; background: var(--assoc-white); color: var(--assoc-navy); }
	.issue-compose__field input:focus,
	.issue-compose__field textarea:focus { outline: 2px solid var(--assoc-coral); outline-offset: -1px; border-color: var(--assoc-coral); }
	.issue-compose__field textarea { resize: vertical; min-height: 110px; line-height: 1.55; }
	.issue-compose__note { margin: 0; font-size: 0.72rem; font-weight: 600; color: var(--assoc-coral-text); line-height: 1.45; }

	@media (max-width: 520px) { .issue-compose__row { grid-template-columns: 1fr; } }

	.issue-action__sidebar { display: grid; gap: 1.5rem; }

	.issue-dates { padding: 1.25rem; border: 1px solid var(--assoc-border); border-radius: var(--assoc-radius); background: var(--assoc-white); }
	.issue-dates h3 { font-size: 0.88rem; margin-bottom: 0.75rem; }
	.issue-dates__item { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0; border-bottom: 1px solid var(--assoc-border); }
	.issue-dates__item:last-child { border-bottom: none; }
	.issue-dates__date { flex-shrink: 0; min-width: 5.5rem; font-size: 0.82rem; font-weight: 800; color: var(--assoc-coral); }
	.issue-dates__label { font-size: 0.82rem; font-weight: 600; color: var(--assoc-navy); }

	.issue-resources h3 { font-size: 0.88rem; margin-bottom: 0.5rem; }
	.issue-resource-card {
		padding: 1rem;
		border: 1px solid var(--assoc-border);
		border-radius: var(--assoc-radius);
		background: var(--assoc-white);
		margin-bottom: 0.5rem;
	}
	.issue-resource-card:last-child { margin-bottom: 0; }
	.issue-resource-card__top { display: flex; gap: 0.4rem; margin-bottom: 0.35rem; }
	.issue-resource-card__format { padding: 0.12rem 0.4rem; border-radius: 4px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; background: var(--assoc-teal-light); color: var(--assoc-teal); }
	.issue-resource-card__access { padding: 0.12rem 0.4rem; border-radius: 4px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; background: color-mix(in srgb, var(--assoc-slate) 8%, var(--assoc-white)); color: var(--assoc-slate); }
	.issue-resource-card__access--member { background: color-mix(in srgb, var(--assoc-coral) 8%, var(--assoc-white)); color: var(--assoc-coral-text); }
	.issue-resource-card h4 { font-size: 0.88rem; margin-bottom: 0.15rem; }
	.issue-resource-card p { font-size: 0.78rem; line-height: 1.45; margin: 0; }

	@media (max-width: 768px) { .issue-action__inner { grid-template-columns: 1fr; } }
</style>
