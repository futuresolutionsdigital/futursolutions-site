---
import { aboutWhatWeDo } from '../../data/association';
---

<section class="assoc-section assoc-section--warm" aria-labelledby="about-wwd-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">What We Do</p>
		<h2 id="about-wwd-heading">Built around the work professional associations do best.</h2>
		<div class="about-wwd-grid">
			{aboutWhatWeDo.map((item) => (
				<a href={item.href} class="assoc-card about-wwd-card">
					<h3>{item.title}</h3>
					<p>{item.description}</p>
					<span class="about-wwd-card__cta">Explore →</span>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.about-wwd-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2rem; }
	.about-wwd-card { display: flex; flex-direction: column; padding: 1.35rem; transition: border-color 0.15s ease, transform 0.15s ease; }
	.about-wwd-card:hover { border-color: var(--assoc-teal); transform: translateY(-1px); }
	.about-wwd-card h3 { font-size: 1rem; margin-bottom: 0.3rem; }
	.about-wwd-card p { font-size: 0.85rem; line-height: 1.5; flex: 1; }
	.about-wwd-card__cta { margin-top: 0.65rem; font-size: 0.8rem; font-weight: 700; color: var(--assoc-teal); }
	@media (max-width: 768px) { .about-wwd-grid { grid-template-columns: 1fr 1fr; } }
	@media (max-width: 520px) { .about-wwd-grid { grid-template-columns: 1fr; } }
</style>
