---
import { resourceGuidancePaths } from '../../data/association';
const icons: Record<string, string> = {
	ce: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
	practice: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
	advocacy: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
	career: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
};
---

<section class="assoc-section" aria-labelledby="res-guidance-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Quick Start</p>
		<h2 id="res-guidance-heading">Not sure what you need?</h2>
		<div class="res-guidance-grid">
			{resourceGuidancePaths.map((p) => (
				<a href={p.href} class="res-guidance-card">
					<div class="res-guidance-card__icon" aria-hidden="true" set:html={icons[p.icon] || icons.ce} />
					<h3>{p.title}</h3>
					<p>{p.description}</p>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.res-guidance-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 2rem; }
	.res-guidance-card {
		display: flex; flex-direction: column; align-items: center; text-align: center; padding: 1.5rem 1rem;
		border: 1px solid var(--assoc-border); border-radius: var(--assoc-radius); background: var(--assoc-white);
		transition: border-color 0.15s ease, transform 0.15s ease;
	}
	.res-guidance-card:hover { border-color: var(--assoc-teal); transform: translateY(-1px); }
	.res-guidance-card__icon { display: flex; align-items: center; justify-content: center; width: 2.75rem; height: 2.75rem; border-radius: 50%; background: var(--assoc-teal-light); color: var(--assoc-teal); margin-bottom: 0.85rem; }
	:global(.res-guidance-card__icon svg) { display: inline; }
	.res-guidance-card h3 { font-size: 0.95rem; margin-bottom: 0.25rem; }
	.res-guidance-card p { font-size: 0.82rem; line-height: 1.45; margin: 0; }
	@media (max-width: 768px) { .res-guidance-grid { grid-template-columns: 1fr 1fr; } }
	@media (max-width: 520px) { .res-guidance-grid { grid-template-columns: 1fr; } }
</style>
