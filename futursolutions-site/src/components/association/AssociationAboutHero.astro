---
import { aboutHero } from '../../data/association';
const h = aboutHero;
---

<section class="about-hero" aria-labelledby="about-hero-heading">
	<div class="assoc-container">
		<div class="about-hero__content">
			<p class="assoc-eyebrow">{h.eyebrow}</p>
			<h1 id="about-hero-heading">{h.headline}</h1>
			<p class="about-hero__lead">{h.lead}</p>
			<p class="about-hero__support">{h.supportLine}</p>
			<div class="assoc-btn-row">
				<a class="assoc-btn assoc-btn--primary" href={h.primaryCta.href}>{h.primaryCta.text}</a>
				<a class="assoc-btn assoc-btn--secondary" href={h.secondaryCta.href}>{h.secondaryCta.text}</a>
			</div>
			<a class="about-hero__tertiary" href={h.tertiaryLink.href}>{h.tertiaryLink.text}</a>
		</div>
	</div>
</section>

<style is:global>
	.about-hero {
		padding-block: clamp(3rem, 6vw, 5rem);
		background: linear-gradient(175deg, var(--assoc-bg) 40%, color-mix(in srgb, var(--assoc-sand) 40%, var(--assoc-bg)) 100%);
		border-bottom: 1px solid var(--assoc-border);
	}
	.about-hero__content { width: min(100%, 820px); max-width: 820px; margin-inline: auto; text-align: center; }
	.about-hero__content h1 { text-wrap: balance; margin-inline: auto; }
	.about-hero__content p { margin-inline: auto; }
	.about-hero__lead { font-size: clamp(1rem, 0.98rem + 0.15vw, 1.1rem); line-height: 1.6; color: var(--assoc-slate); max-width: 640px; }
	.about-hero__support { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.02em; color: var(--assoc-slate); opacity: 0.6; margin-bottom: 0.25rem; }
	.about-hero__content .assoc-btn-row { justify-content: center; }
	.about-hero__tertiary { display: inline-block; margin-top: 0.75rem; font-size: 0.85rem; font-weight: 700; color: var(--assoc-teal); }
	.about-hero__tertiary:hover { color: var(--assoc-navy); }
</style>
