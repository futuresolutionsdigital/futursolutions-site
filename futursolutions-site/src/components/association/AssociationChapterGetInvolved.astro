---
import { chapterDetailInvolvement } from '../../data/association';
---

<section class="assoc-section" aria-labelledby="chd-involved-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Participate</p>
		<h2 id="chd-involved-heading">Ways to participate</h2>
		<div class="chd-involved-grid">
			{chapterDetailInvolvement.map((item, i) => (
				<a href={item.href} class="chd-involved-card">
					<span class="chd-involved-card__num" aria-hidden="true">{i + 1}</span>
					<div>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</div>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.chd-involved-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-top: 2rem; }
	.chd-involved-card {
		display: flex; gap: 1rem; align-items: flex-start; padding: 1.25rem;
		border: 1px solid var(--assoc-border); border-radius: var(--assoc-radius); background: var(--assoc-white);
		transition: border-color 0.15s ease, transform 0.15s ease;
	}
	.chd-involved-card:hover { border-color: var(--assoc-teal); transform: translateY(-1px); }
	.chd-involved-card__num {
		flex-shrink: 0; display: flex; align-items: center; justify-content: center;
		width: 2.25rem; height: 2.25rem; border-radius: 50%; background: var(--assoc-teal-light); color: var(--assoc-teal);
		font-size: 0.88rem; font-weight: 800;
	}
	.chd-involved-card h3 { font-size: 0.95rem; margin-bottom: 0.2rem; }
	.chd-involved-card p { font-size: 0.82rem; line-height: 1.45; margin: 0; }
	@media (max-width: 520px) { .chd-involved-grid { grid-template-columns: 1fr; } }
</style>
