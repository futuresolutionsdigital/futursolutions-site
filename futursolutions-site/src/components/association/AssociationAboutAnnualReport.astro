---
import { aboutAnnualReport } from '../../data/association';
---

<section class="about-report" aria-labelledby="about-report-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow about-report__eyebrow">Annual Impact</p>
		<h2 id="about-report-heading" class="about-report__heading">Annual impact, made visible.</h2>
		<div class="about-report-grid">
			{aboutAnnualReport.map((r) => (
				<div class="about-report-card">
					<h3>{r.area}</h3>
					<p class="about-report-desc">{r.description}</p>
					<span class="about-report-metric">{r.metric}</span>
				</div>
			))}
		</div>
		<div class="about-report-cta">
			<a class="assoc-btn assoc-btn--secondary" href="/demos/association/resources">View Demo Impact Report</a>
		</div>
	</div>
</section>

<style>
	.about-report { padding-block: clamp(2.5rem, 5vw, 4rem); background: var(--assoc-navy); color: var(--assoc-white); }
	.about-report__eyebrow { color: rgba(255, 255, 255, 0.4) !important; }
	.about-report__heading { color: var(--assoc-white); text-align: center; text-wrap: balance; max-width: 500px; margin-inline: auto; }
	.about-report-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-top: 2rem; }
	.about-report-card { padding: 1.5rem; background: rgba(255, 255, 255, 0.06); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: var(--assoc-radius); display: flex; flex-direction: column; gap: 0.4rem; }
	.about-report-card h3 { font-size: 0.92rem; font-weight: 800; color: var(--assoc-white); }
	.about-report-desc { font-size: 0.82rem; line-height: 1.55; color: rgba(255, 255, 255, 0.65); margin: 0; }
	.about-report-metric { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.03em; color: var(--assoc-teal); margin-top: auto; }
	.about-report-cta { text-align: center; margin-top: 1.5rem; }
	.about-report-cta .assoc-btn--secondary { border-color: rgba(255, 255, 255, 0.2); color: var(--assoc-white); }
	.about-report-cta .assoc-btn--secondary:hover { border-color: var(--assoc-teal); color: var(--assoc-teal); }
	@media (max-width: 600px) { .about-report-grid { grid-template-columns: 1fr; } }
</style>
