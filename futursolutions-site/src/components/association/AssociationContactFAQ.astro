---
import { contactFaqs } from '../../data/association';
---

<section class="assoc-section assoc-section--warm" id="faq" aria-labelledby="contact-faq-heading">
	<div class="assoc-container contact-faq-inner">
		<div class="contact-faq-intro">
			<p class="assoc-eyebrow">FAQ</p>
			<h2 id="contact-faq-heading">Contact questions, answered.</h2>
		</div>
		<div class="contact-faq-list">
			{contactFaqs.map((faq) => (
				<details class="contact-faq-item">
					<summary>
						<span>{faq.question}</span>
						<svg class="contact-faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
					</summary>
					<div class="contact-faq-answer"><p>{faq.answer}</p></div>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	.contact-faq-inner { display: grid; grid-template-columns: 0.35fr 0.65fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
	.contact-faq-list { display: grid; gap: 0; }
	.contact-faq-item { border-bottom: 1px solid var(--assoc-border); }
	.contact-faq-item summary { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 0; cursor: pointer; list-style: none; font-size: 0.95rem; font-weight: 700; color: var(--assoc-navy); line-height: 1.35; }
	.contact-faq-item summary::-webkit-details-marker { display: none; }
	.contact-faq-item summary::marker { content: ''; }
	.contact-faq-chevron { flex-shrink: 0; color: var(--assoc-slate); transition: transform 0.2s ease; }
	.contact-faq-item[open] .contact-faq-chevron { transform: rotate(180deg); }
	.contact-faq-answer { padding-bottom: 1rem; }
	.contact-faq-answer p { font-size: 0.9rem; line-height: 1.6; margin: 0; }
	@media (max-width: 768px) { .contact-faq-inner { grid-template-columns: 1fr; } }
</style>
