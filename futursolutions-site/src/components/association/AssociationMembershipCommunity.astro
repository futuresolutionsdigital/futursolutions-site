---
import { membershipCommunity } from '../../data/association';
---

<section class="assoc-section assoc-section--warm" aria-labelledby="community-heading">
	<div class="assoc-container community__inner">
		<div class="community__content">
			<p class="assoc-eyebrow">Local Community</p>
			<h2 id="community-heading">{membershipCommunity.headline}</h2>
			<p class="assoc-lead">{membershipCommunity.description}</p>
			<a class="assoc-btn assoc-btn--primary" href={membershipCommunity.cta.href}>{membershipCommunity.cta.text}</a>
		</div>
		<ul class="community__benefits">
			{membershipCommunity.benefits.map((b) => (
				<li>
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
					<span>{b}</span>
				</li>
			))}
		</ul>
	</div>
</section>

<style>
	.community__inner {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
	}

	.community__content .assoc-lead {
		margin-bottom: 2rem;
	}

	.community__benefits {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0;
	}

	.community__benefits li {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		padding: 1rem 0;
		border-bottom: 1px solid var(--assoc-border);
		font-size: 0.95rem;
		font-weight: 500;
		color: var(--assoc-navy);
		line-height: 1.4;
	}

	.community__benefits li:last-child {
		border-bottom: none;
	}

	.community__benefits li svg {
		display: inline;
		flex-shrink: 0;
		margin-top: 0.1rem;
		color: var(--assoc-teal);
	}

	@media (max-width: 768px) {
		.community__inner {
			grid-template-columns: 1fr;
		}
	}
</style>
