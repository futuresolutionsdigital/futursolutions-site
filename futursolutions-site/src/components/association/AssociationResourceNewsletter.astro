---
---

<section class="assoc-section assoc-section--warm" aria-labelledby="res-newsletter-heading">
	<div class="assoc-container res-newsletter__inner">
		<div class="res-newsletter__content">
			<p class="assoc-eyebrow">Stay Updated</p>
			<h2 id="res-newsletter-heading">Get new resources when they are published.</h2>
			<p class="assoc-lead">Receive curated resource updates, new CE course announcements, and professional development highlights directly in your inbox.</p>
		</div>
		<form class="res-newsletter__form" onsubmit="return false">
			<div class="res-newsletter__field">
				<label for="res-email">Email address</label>
				<input type="email" id="res-email" class="res-newsletter__input" placeholder="you@example.com" />
			</div>
			<div class="res-newsletter__field">
				<label for="res-interest">Primary interest</label>
				<select id="res-interest" class="res-newsletter__select">
					<option value="">Select an area</option>
					<option value="clinical">Clinical Practice</option>
					<option value="advocacy">Advocacy & Policy</option>
					<option value="career">Career Growth</option>
					<option value="leadership">Leadership</option>
					<option value="education">Education & CE</option>
				</select>
			</div>
			<button type="button" class="assoc-btn assoc-btn--primary res-newsletter__submit">Subscribe</button>
			<p class="res-newsletter__note">This demo form does not submit.</p>
		</form>
	</div>
</section>

<style>
	.res-newsletter__inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
	.res-newsletter__form { display: grid; gap: 0.75rem; }
	.res-newsletter__field label { display: block; font-size: 0.78rem; font-weight: 700; color: var(--assoc-navy); margin-bottom: 0.3rem; }
	.res-newsletter__input, .res-newsletter__select {
		width: 100%; padding: 0.6rem 0.85rem; border: 1px solid var(--assoc-border); border-radius: 8px;
		font-size: 0.88rem; font-family: inherit; background: var(--assoc-white); color: var(--assoc-navy);
	}
	.res-newsletter__input:focus, .res-newsletter__select:focus { outline: 2px solid var(--assoc-teal); outline-offset: -1px; border-color: var(--assoc-teal); }
	.res-newsletter__submit { margin-top: 0.25rem; }
	.res-newsletter__note { font-size: 0.72rem; color: var(--assoc-slate); opacity: 0.55; margin-top: 0.25rem; }
	@media (max-width: 768px) { .res-newsletter__inner { grid-template-columns: 1fr; } }
</style>
