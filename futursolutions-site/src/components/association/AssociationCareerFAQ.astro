---
import { careerFaqs } from '../../data/association';
---

<section class="assoc-section assoc-section--warm" id="faq" aria-labelledby="career-faq-heading">
	<div class="assoc-container cfaq-inner">
		<div class="cfaq-intro">
			<p class="assoc-eyebrow">FAQ</p>
			<h2 id="career-faq-heading">Career center questions, answered.</h2>
			<p class="assoc-lead">Have a question not listed here? Contact the MHPA career support team.</p>
			<a class="assoc-btn assoc-btn--secondary" href="/demos/association/contact">Contact Us</a>
		</div>
		<div class="cfaq-list">
			{careerFaqs.map((faq) => (
				<details class="cfaq-item">
					<summary>
						<span>{faq.question}</span>
						<svg class="cfaq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
					</summary>
					<div class="cfaq-answer"><p>{faq.answer}</p></div>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	.cfaq-inner { display: grid; grid-template-columns: 0.4fr 0.6fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
	.cfaq-intro .assoc-lead { margin-bottom: 1.5rem; }
	.cfaq-list { display: grid; gap: 0; }
	.cfaq-item { border-bottom: 1px solid var(--assoc-border); }
	.cfaq-item summary { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 0; cursor: pointer; list-style: none; font-size: 0.95rem; font-weight: 700; color: var(--assoc-navy); line-height: 1.35; }
	.cfaq-item summary::-webkit-details-marker { display: none; }
	.cfaq-item summary::marker { content: ''; }
	.cfaq-chevron { flex-shrink: 0; color: var(--assoc-slate); transition: transform 0.2s ease; }
	.cfaq-item[open] .cfaq-chevron { transform: rotate(180deg); }
	.cfaq-answer { padding-bottom: 1rem; }
	.cfaq-answer p { font-size: 0.9rem; line-height: 1.6; margin: 0; }
	@media (max-width: 768px) { .cfaq-inner { grid-template-columns: 1fr; } }
</style>
