---
import { careerMentorship } from '../../data/association';
const m = careerMentorship;
---

<section class="assoc-section assoc-section--warm" id="mentorship" aria-labelledby="career-mentor-heading">
	<div class="assoc-container cm-inner">
		<div class="cm-content">
			<p class="assoc-eyebrow">Mentorship</p>
			<h2 id="career-mentor-heading">{m.headline}</h2>
			<p class="cm-desc">{m.description}</p>
			<a class="assoc-btn assoc-btn--primary" href={m.cta.href}>{m.cta.text}</a>
		</div>
		<div class="cm-pathways">
			{m.pathways.map((p) => (
				<a href={p.href} class="cm-path">
					<h3>{p.title}</h3>
					<p>{p.description}</p>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.cm-inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
	.cm-desc { font-size: 0.92rem; line-height: 1.6; margin-bottom: 1.5rem; }
	.cm-pathways { display: grid; gap: 0.75rem; }
	.cm-path { display: block; padding: 1.15rem; border: 1px solid var(--assoc-border); border-radius: var(--assoc-radius); background: var(--assoc-white); transition: border-color 0.15s ease, transform 0.15s ease; }
	.cm-path:hover { border-color: var(--assoc-teal); transform: translateY(-1px); }
	.cm-path h3 { font-size: 0.95rem; margin-bottom: 0.2rem; }
	.cm-path p { font-size: 0.82rem; line-height: 1.45; margin: 0; }
	@media (max-width: 768px) { .cm-inner { grid-template-columns: 1fr; } }
</style>
