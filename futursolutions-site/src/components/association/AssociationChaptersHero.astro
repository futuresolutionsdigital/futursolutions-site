---
import { chaptersHero } from '../../data/association';
const h = chaptersHero;
---

<section class="ch-hero" aria-labelledby="ch-hero-heading">
	<div class="assoc-container">
		<div class="ch-hero__content">
			<p class="assoc-eyebrow">{h.eyebrow}</p>
			<h1 id="ch-hero-heading">{h.headline}</h1>
			<p class="ch-hero__lead">{h.lead}</p>
			<p class="ch-hero__support">{h.supportLine}</p>
			<div class="assoc-btn-row">
				<a class="assoc-btn assoc-btn--primary" href={h.primaryCta.href}>{h.primaryCta.text}</a>
				<a class="assoc-btn assoc-btn--secondary" href={h.secondaryCta.href}>{h.secondaryCta.text}</a>
			</div>
			<a class="ch-hero__tertiary" href={h.tertiaryLink.href}>{h.tertiaryLink.text}</a>
		</div>
	</div>
</section>

<style>
	.ch-hero {
		padding-block: clamp(3rem, 6vw, 5rem);
		background: linear-gradient(175deg, var(--assoc-bg) 40%, color-mix(in srgb, var(--assoc-sand) 45%, var(--assoc-bg)) 100%);
		border-bottom: 1px solid var(--assoc-border);
	}
	.ch-hero__content { width: min(100%, 760px); margin-inline: auto; text-align: center; }
	.ch-hero h1 { text-wrap: balance; }
	.ch-hero__lead { font-size: clamp(1rem, 0.98rem + 0.15vw, 1.1rem); line-height: 1.6; color: var(--assoc-slate); margin-inline: auto; max-width: 620px; }
	.ch-hero__support { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.02em; color: var(--assoc-slate); opacity: 0.6; margin-bottom: 0.25rem; }
	.ch-hero .assoc-btn-row { justify-content: center; }
	.ch-hero__tertiary { display: inline-block; margin-top: 0.75rem; font-size: 0.85rem; font-weight: 700; color: var(--assoc-teal); }
	.ch-hero__tertiary:hover { color: var(--assoc-navy); }
</style>
