---
import { annualConferenceCE } from '../../data/association';
const ce = annualConferenceCE;
---

<section class="assoc-section assoc-section--warm" id="ce" aria-labelledby="ce-heading">
	<div class="assoc-container ce__inner">
		<div class="ce__intro">
			<p class="assoc-eyebrow">Continuing Education</p>
			<h2 id="ce-heading">{ce.headline}</h2>
			<div class="ce__badge" aria-hidden="true">
				<span class="ce__badge-val">{ce.hours}</span>
				<span class="ce__badge-label">CE hours</span>
			</div>
			<p class="ce__desc">{ce.description}</p>
			<a class="assoc-btn assoc-btn--secondary" href={ce.cta.href}>{ce.cta.text}</a>
		</div>
		<div class="ce__details">
			<ul>
				{ce.details.map((d) => (
					<li>
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
						<span>{d}</span>
					</li>
				))}
			</ul>
			<p class="ce__disclaimer">{ce.disclaimer}</p>
		</div>
	</div>
</section>

<style>
	.ce__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
	}
	.ce__badge {
		display: inline-flex;
		align-items: baseline;
		gap: 0.35rem;
		margin-bottom: 1rem;
		padding: 0.5rem 1rem;
		border-radius: 10px;
		background: var(--assoc-teal);
		color: var(--assoc-white);
	}
	.ce__badge-val { font-size: 1.6rem; font-weight: 800; line-height: 1; }
	.ce__badge-label { font-size: 0.78rem; font-weight: 700; opacity: 0.85; }
	.ce__desc { font-size: 0.95rem; line-height: 1.6; margin-bottom: 1.5rem; }
	.ce__details ul {
		margin: 0; padding: 0; list-style: none;
		display: grid; gap: 0.75rem;
	}
	.ce__details li {
		display: flex;
		align-items: flex-start;
		gap: 0.6rem;
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--assoc-navy);
		line-height: 1.4;
	}
	.ce__details li svg { display: inline; flex-shrink: 0; margin-top: 0.1rem; color: var(--assoc-teal); }
	.ce__disclaimer {
		margin-top: 1.25rem;
		font-size: 0.75rem;
		color: var(--assoc-slate);
		opacity: 0.65;
		line-height: 1.5;
	}
	@media (max-width: 768px) {
		.ce__inner { grid-template-columns: 1fr; }
	}
</style>
