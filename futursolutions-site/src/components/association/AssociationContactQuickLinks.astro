---
import { contactQuickLinks } from '../../data/association';
---

<section class="assoc-section assoc-section--warm" aria-labelledby="contact-quick-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Quick Links</p>
		<h2 id="contact-quick-heading">Need something specific?</h2>
		<div class="contact-quick-grid">
			{contactQuickLinks.map((link) => (
				<a href={link.href} class="assoc-card contact-quick-card">
					<span>{link.title} →</span>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.contact-quick-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-top: 2rem; }
	.contact-quick-card { display: flex; align-items: center; justify-content: center; padding: 1rem; text-align: center; transition: border-color 0.15s ease, transform 0.15s ease; }
	.contact-quick-card:hover { border-color: var(--assoc-teal); transform: translateY(-1px); }
	.contact-quick-card span { font-size: 0.88rem; font-weight: 700; color: var(--assoc-navy); }
	.contact-quick-card:hover span { color: var(--assoc-teal); }
	@media (max-width: 600px) { .contact-quick-grid { grid-template-columns: 1fr 1fr; } }
	@media (max-width: 400px) { .contact-quick-grid { grid-template-columns: 1fr; } }
</style>
