---
import { aboutLeadership } from '../../data/association';
const bgColors = ['var(--assoc-teal)', 'var(--assoc-navy)', 'var(--assoc-coral)', 'var(--assoc-teal)', 'var(--assoc-navy)', 'var(--assoc-coral)'];
---

<section class="assoc-section assoc-section--warm" aria-labelledby="about-lead-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Leadership</p>
		<h2 id="about-lead-heading">Member-led. Profession-focused.</h2>
		<div class="about-lead-grid">
			{aboutLeadership.map((l, i) => (
				<div class="assoc-card about-lead-card">
					<div class="about-lead-card__avatar" style={`background: ${bgColors[i]}`} aria-hidden="true">
						<span>{l.initials}</span>
					</div>
					<div class="about-lead-card__body">
						<h3>{l.name}</h3>
						<p class="about-lead-card__role">{l.role}</p>
						<p>{l.bio}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.about-lead-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2rem; }
	.about-lead-card { display: flex; gap: 1rem; padding: 1.25rem; }
	.about-lead-card__avatar { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 3rem; height: 3rem; border-radius: 50%; color: var(--assoc-white); }
	.about-lead-card__avatar span { font-size: 0.82rem; font-weight: 800; letter-spacing: 0.03em; }
	.about-lead-card__body { flex: 1; }
	.about-lead-card h3 { font-size: 0.95rem; margin-bottom: 0.1rem; }
	.about-lead-card__role { font-size: 0.72rem; font-weight: 700; color: var(--assoc-teal); margin-bottom: 0.35rem; }
	.about-lead-card p:last-child { font-size: 0.82rem; line-height: 1.5; }
	@media (max-width: 768px) { .about-lead-grid { grid-template-columns: 1fr 1fr; } }
	@media (max-width: 520px) { .about-lead-grid { grid-template-columns: 1fr; } }
</style>
