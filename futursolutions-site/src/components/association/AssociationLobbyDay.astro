---
import { advocacyLobbyDay } from '../../data/association';
const ld = advocacyLobbyDay;
---

<section class="assoc-section assoc-section--warm" id="lobby-day" aria-labelledby="lobby-heading">
	<div class="assoc-container lobby__inner">
		<div class="lobby__content">
			<p class="assoc-eyebrow">Lobby Day</p>
			<h2 id="lobby-heading">Bring the profession directly to policymakers.</h2>
			<div class="lobby__event">
				<h3>{ld.title}</h3>
				<div class="lobby__meta">
					<span>
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
						{ld.date}
					</span>
					<span>
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
						{ld.location}
					</span>
				</div>
			</div>
			<p class="lobby__desc">{ld.summary}</p>
			<div class="assoc-btn-row">
				<a class="assoc-btn assoc-btn--primary" href={ld.primaryCta.href}>{ld.primaryCta.text}</a>
				<a class="assoc-btn assoc-btn--secondary" href={ld.secondaryCta.href}>{ld.secondaryCta.text}</a>
			</div>
		</div>
		<div class="lobby__schedule">
			<h3>What to expect</h3>
			<ul>
				{ld.schedule.map((item) => (
					<li>
						<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
						<span>{item}</span>
					</li>
				))}
			</ul>
		</div>
	</div>
</section>

<style>
	.lobby__inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
	.lobby__event { margin-bottom: 0.75rem; }
	.lobby__event h3 { font-size: 1.1rem; margin-bottom: 0.35rem; }
	.lobby__meta { display: flex; flex-wrap: wrap; gap: 0.85rem; }
	.lobby__meta span {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--assoc-slate);
	}
	.lobby__meta span svg { display: inline; flex-shrink: 0; color: var(--assoc-teal); }
	.lobby__desc { font-size: 0.92rem; line-height: 1.6; margin-bottom: 1.25rem; }
	.lobby__schedule h3 { font-size: 0.95rem; margin-bottom: 0.75rem; }
	.lobby__schedule ul { margin: 0; padding: 0; list-style: none; display: grid; gap: 0.6rem; }
	.lobby__schedule li { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.88rem; font-weight: 500; color: var(--assoc-navy); line-height: 1.4; }
	.lobby__schedule li svg { display: inline; flex-shrink: 0; margin-top: 0.1rem; color: var(--assoc-teal); }
	@media (max-width: 768px) { .lobby__inner { grid-template-columns: 1fr; } }
</style>
