---
import { topTasks } from '../../data/association';

const iconMap: Record<string, string> = {
	membership: 'M12 4.354a4 4 0 1 1 0 5.292M15 21H3v-1a6 6 0 0 1 12 0v1Zm0 0h6v-1a6 6 0 0 0-9-5.197',
	education: 'M12 14l9-5-9-5-9 5 9 5Zm0 0v7M21 12v7',
	event: 'M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z',
	advocacy: 'M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z',
	chapters: 'M17.657 16.657 13.414 20.9a2 2 0 0 1-2.827 0l-4.244-4.243a8 8 0 1 1 11.314 0ZM15 11a3 3 0 1 0-6 0 3 3 0 0 0 6 0Z',
	career: 'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M12 7a4 4 0 1 0-8 0 4 4 0 0 0 8 0Zm9 14v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
};
---

<section class="assoc-section" id="quick-actions" aria-labelledby="top-tasks-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Quick Actions</p>
		<h2 id="top-tasks-heading">What can MHPA help you do today?</h2>
		<div class="tasks-grid">
			{topTasks.map((task) => (
				<a href={task.href} class="assoc-card task-card">
					<div class="task-card__icon">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d={iconMap[task.icon] || iconMap.membership} />
						</svg>
					</div>
					<h3>{task.title}</h3>
					<p>{task.description}</p>
					<span class="task-card__arrow" aria-hidden="true">→</span>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.tasks-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		margin-top: 2rem;
	}

	.task-card {
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		position: relative;
	}

	.task-card:hover {
		border-color: var(--assoc-teal);
		transform: translateY(-2px);
	}

	.task-card__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 10px;
		background: var(--assoc-teal-light);
		color: var(--assoc-teal);
		margin-bottom: 1rem;
	}

	.task-card h3 {
		font-size: 1.05rem;
		margin-bottom: 0.4rem;
	}

	.task-card p {
		font-size: 0.88rem;
		line-height: 1.5;
		flex: 1;
	}

	.task-card__arrow {
		display: inline-block;
		margin-top: 0.75rem;
		font-size: 1rem;
		font-weight: 700;
		color: var(--assoc-teal);
		opacity: 0;
		transform: translateX(-4px);
		transition: opacity 0.18s ease, transform 0.18s ease;
	}

	.task-card:hover .task-card__arrow {
		opacity: 1;
		transform: translateX(0);
	}

	@media (max-width: 768px) {
		.tasks-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 520px) {
		.tasks-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
