---
import { annualConferenceSponsors } from '../../data/association';
const sp = annualConferenceSponsors;
---

<section class="assoc-section" id="sponsor" aria-labelledby="sponsor-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Sponsors & Exhibitors</p>
		<h2 id="sponsor-heading">{sp.headline}</h2>
		<p class="assoc-lead">{sp.description}</p>
		<div class="sponsor-grid">
			{sp.packages.map((pkg, i) => (
				<div class:list={['assoc-card sponsor-card', { 'sponsor-card--premier': i === 2 }]}>
					<h3>{pkg.name}</h3>
					<span class="sponsor-card__price">{pkg.price}</span>
					<ul>
						{pkg.includes.map((item) => (
							<li>
								<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
								<span>{item}</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
		<div class="sponsor__cta">
			<a class="assoc-btn assoc-btn--primary" href={sp.cta.href}>{sp.cta.text}</a>
		</div>
		<p class="sponsor__note">All sponsor and exhibitor pricing is fictional demo content.</p>
	</div>
</section>

<style>
	.sponsor-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		margin-top: 2rem;
	}
	.sponsor-card { padding: 1.5rem; display: flex; flex-direction: column; }
	.sponsor-card--premier { border-color: var(--assoc-teal); }
	.sponsor-card h3 { font-size: 1.1rem; margin-bottom: 0.3rem; }
	.sponsor-card__price {
		font-size: 1.1rem;
		font-weight: 800;
		color: var(--assoc-teal);
		margin-bottom: 1rem;
		padding-bottom: 0.85rem;
		border-bottom: 1px solid var(--assoc-border);
	}
	.sponsor-card ul {
		margin: 0; padding: 0; list-style: none;
		display: grid; gap: 0.45rem; flex: 1;
	}
	.sponsor-card li {
		display: flex;
		align-items: flex-start;
		gap: 0.45rem;
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--assoc-navy);
		line-height: 1.3;
	}
	.sponsor-card li svg { display: inline; flex-shrink: 0; margin-top: 0.1rem; color: var(--assoc-teal); }
	.sponsor__cta { margin-top: 1.5rem; }
	.sponsor__note {
		margin-top: 0.75rem;
		font-size: 0.74rem;
		color: var(--assoc-slate);
		opacity: 0.6;
	}
	@media (max-width: 700px) {
		.sponsor-grid { grid-template-columns: 1fr; }
	}
</style>
