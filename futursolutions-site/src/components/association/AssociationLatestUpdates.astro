---
import { latestUpdates } from '../../data/association';
---

<section class="assoc-section assoc-section--warm" id="updates" aria-labelledby="updates-heading">
	<div class="assoc-container">
		<div class="updates__header">
			<div>
				<p class="assoc-eyebrow">Latest Updates</p>
				<h2 id="updates-heading">What's happening at MHPA.</h2>
			</div>
		</div>
		<div class="updates-grid">
			{latestUpdates.map((item) => (
				<a href={item.href} class="update-card">
					<span class="update-card__date">{item.date}</span>
					<h3>{item.title}</h3>
					<p>{item.excerpt}</p>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.updates__header {
		margin-bottom: 2rem;
	}

	.updates-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
	}

	.update-card {
		display: flex;
		flex-direction: column;
		padding: 1.25rem;
		border: 1px solid var(--assoc-border);
		border-radius: var(--assoc-radius);
		background: var(--assoc-white);
		transition: box-shadow 0.22s ease, transform 0.22s ease, border-color 0.22s ease;
	}

	.update-card:hover {
		border-color: var(--assoc-teal);
		box-shadow: 0 6px 24px rgba(16, 42, 67, 0.06);
		transform: translateY(-1px);
	}

	.update-card__date {
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--assoc-teal);
		margin-bottom: 0.5rem;
		letter-spacing: 0.02em;
	}

	.update-card h3 {
		font-size: 0.95rem;
		line-height: 1.3;
		margin-bottom: 0.4rem;
	}

	.update-card p {
		font-size: 0.82rem;
		line-height: 1.5;
		margin: 0;
	}

	@media (max-width: 960px) {
		.updates-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 520px) {
		.updates-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
