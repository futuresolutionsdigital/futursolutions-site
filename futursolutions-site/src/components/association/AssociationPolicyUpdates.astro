---
import { advocacyPolicyUpdates } from '../../data/association';
const catColors: Record<string, string> = {
	Legislative: 'var(--assoc-coral)',
	Coalition: 'var(--assoc-teal)',
	Events: 'var(--assoc-navy)',
};
---

<section class="assoc-section assoc-section--warm" id="updates" aria-labelledby="updates-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Latest Updates</p>
		<h2 id="updates-heading">Latest advocacy updates</h2>
		<div class="updates-grid">
			{advocacyPolicyUpdates.map((u) => (
				<a href={u.href} class="assoc-card update-card" style={`--cat-color: ${catColors[u.category] || catColors.Legislative}`}>
					<div class="update-card__top">
						<span class="update-card__cat">{u.category}</span>
						<span class="update-card__date">{u.date}</span>
					</div>
					<h3>{u.title}</h3>
					<p>{u.summary}</p>
					<span class="update-card__link">Read more →</span>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.updates-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 2rem; }
	.update-card { display: flex; flex-direction: column; padding: 1.25rem; transition: border-color 0.15s ease, transform 0.15s ease; }
	.update-card:hover { border-color: var(--assoc-teal); transform: translateY(-1px); }
	.update-card__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.65rem; }
	.update-card__cat {
		padding: 0.15rem 0.45rem;
		border-radius: 4px;
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		background: color-mix(in srgb, var(--cat-color) 10%, var(--assoc-white));
		color: var(--cat-color);
	}
	.update-card__date { font-size: 0.72rem; font-weight: 600; color: var(--assoc-slate); }
	.update-card h3 { font-size: 0.95rem; margin-bottom: 0.3rem; line-height: 1.3; }
	.update-card p { font-size: 0.82rem; line-height: 1.5; flex: 1; }
	.update-card__link { margin-top: 0.65rem; font-size: 0.78rem; font-weight: 700; color: var(--assoc-teal); }
	@media (max-width: 960px) { .updates-grid { grid-template-columns: 1fr 1fr; } }
	@media (max-width: 520px) { .updates-grid { grid-template-columns: 1fr; } }
</style>
