---
import { careerJobDetailQuickFacts } from '../../data/association';
---

<section class="assoc-section" aria-label="Job quick facts">
	<div class="assoc-container">
		<div class="jqf-grid">
			{careerJobDetailQuickFacts.map((f) => (
				<div class="jqf-item">
					<span class="jqf-label">{f.label}</span>
					<span class="jqf-value">{f.value}</span>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.jqf-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0; border: 1px solid var(--assoc-border); border-radius: var(--assoc-radius); background: var(--assoc-white); overflow: hidden; }
	.jqf-item { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 1rem 0.5rem; border-right: 1px solid var(--assoc-border); }
	.jqf-item:last-child { border-right: none; }
	.jqf-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--assoc-slate); margin-bottom: 0.2rem; }
	.jqf-value { font-size: 0.92rem; font-weight: 800; color: var(--assoc-navy); }
	@media (max-width: 768px) { .jqf-grid { grid-template-columns: repeat(3, 1fr); } .jqf-item:nth-child(3) { border-right: none; } }
	@media (max-width: 480px) { .jqf-grid { grid-template-columns: repeat(2, 1fr); } .jqf-item:nth-child(even) { border-right: none; } }
</style>
