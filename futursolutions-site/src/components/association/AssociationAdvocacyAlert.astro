---
import { advocacyAlert } from '../../data/association';
---

<section class="alert" aria-labelledby="advocacy-alert-heading">
	<div class="assoc-container alert__inner">
		<div class="alert__icon" aria-hidden="true">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
		</div>
		<div class="alert__content">
			<div class="alert__header">
				<span class="alert__eyebrow">{advocacyAlert.eyebrow}</span>
				<span class="alert__urgency">{advocacyAlert.urgency}</span>
			</div>
			<h2 id="advocacy-alert-heading">{advocacyAlert.title}</h2>
			<p>{advocacyAlert.description}</p>
		</div>
		<div class="alert__actions">
			<a class="assoc-btn assoc-btn--coral" href={advocacyAlert.cta.href}>{advocacyAlert.cta.text}</a>
			<a class="alert__link" href={advocacyAlert.secondaryLink.href}>{advocacyAlert.secondaryLink.text} →</a>
		</div>
	</div>
</section>

<style>
	.alert {
		padding-block: clamp(1.5rem, 3vw, 2.5rem);
		background: var(--assoc-coral-light);
		border-block: 1px solid color-mix(in srgb, var(--assoc-coral) 15%, transparent);
	}

	.alert__inner {
		display: flex;
		align-items: center;
		gap: clamp(1rem, 3vw, 2rem);
	}

	.alert__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		background: var(--assoc-coral);
		color: var(--assoc-white);
	}

	.alert__icon svg {
		display: inline;
	}

	.alert__content {
		flex: 1;
	}

	.alert__header {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.4rem;
	}

	.alert__eyebrow {
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--assoc-coral);
	}

	.alert__urgency {
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--assoc-slate);
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--assoc-coral) 10%, var(--assoc-white));
	}

	.alert h2 {
		font-size: clamp(1.2rem, 1.1rem + 0.4vw, 1.45rem);
		margin-bottom: 0.35rem;
	}

	.alert p {
		font-size: 0.9rem;
		line-height: 1.55;
		max-width: 540px;
		margin: 0;
	}

	.alert__actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.6rem;
		flex-shrink: 0;
	}

	.alert__link {
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--assoc-coral);
		white-space: nowrap;
	}

	.alert__link:hover {
		color: var(--assoc-navy);
	}

	@media (max-width: 768px) {
		.alert__inner {
			flex-direction: column;
			align-items: flex-start;
		}

		.alert__actions {
			flex-direction: row;
			width: 100%;
		}
	}

	@media (max-width: 480px) {
		.alert__icon {
			width: 2.5rem;
			height: 2.5rem;
		}

		.alert__icon svg {
			width: 18px;
			height: 18px;
		}

		.alert__actions {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
