---
import { contactResponseProcess } from '../../data/association';
---

<section class="assoc-section" aria-labelledby="contact-process-heading">
	<div class="assoc-container contact-process-inner">
		<p class="assoc-eyebrow">How It Works</p>
		<h2 id="contact-process-heading">What happens after you reach out?</h2>
		<div class="contact-process-steps">
			{contactResponseProcess.map((s) => (
				<div class="contact-process-step">
					<span class="contact-process-step__num" aria-hidden="true">{s.step}</span>
					<div>
						<h3>{s.title}</h3>
						<p>{s.description}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.contact-process-inner { max-width: 720px; }
	.contact-process-steps { display: grid; gap: 0.75rem; margin-top: 1.5rem; }
	.contact-process-step { display: flex; gap: 1rem; align-items: flex-start; padding: 1rem; border: 1px solid var(--assoc-border); border-radius: var(--assoc-radius); background: var(--assoc-white); }
	.contact-process-step__num { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: 50%; background: var(--assoc-teal-light); color: var(--assoc-teal); font-size: 0.92rem; font-weight: 800; }
	.contact-process-step h3 { font-size: 0.92rem; margin-bottom: 0.15rem; }
	.contact-process-step p { font-size: 0.82rem; line-height: 1.45; margin: 0; }
</style>
