---
import { chapterStories } from '../../data/association';
---

<section class="assoc-section" aria-labelledby="ch-stories-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Community</p>
		<h2 id="ch-stories-heading">What local connection makes possible.</h2>
		<div class="ch-stories-grid">
			{chapterStories.map((s) => (
				<blockquote class="assoc-card ch-story-card">
					<p class="ch-story-card__quote">&ldquo;{s.quote}&rdquo;</p>
					<footer class="ch-story-card__footer">
						<span class="ch-story-card__name">{s.name}</span>
						<span class="ch-story-card__role">{s.role} · {s.chapter}</span>
					</footer>
				</blockquote>
			))}
		</div>
	</div>
</section>

<style>
	.ch-stories-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2rem; }
	.ch-story-card { display: flex; flex-direction: column; padding: 1.5rem; margin: 0; }
	.ch-story-card__quote { font-size: 0.92rem; line-height: 1.6; font-style: italic; color: var(--assoc-navy); flex: 1; }
	.ch-story-card__footer { margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--assoc-border); }
	.ch-story-card__name { display: block; font-size: 0.88rem; font-weight: 700; color: var(--assoc-navy); font-style: normal; }
	.ch-story-card__role { display: block; font-size: 0.75rem; font-weight: 600; color: var(--assoc-teal); font-style: normal; }
	@media (max-width: 768px) { .ch-stories-grid { grid-template-columns: 1fr; } }
</style>
