---
interface Props {
	faqs: { question: string; answer: string }[];
	heading?: string;
	lead?: string;
	contactHref?: string;
	id?: string;
}

const {
	faqs,
	heading = 'Frequently asked questions',
	lead,
	contactHref = '/demos/association/contact',
	id = 'faq',
} = Astro.props;
---

<section class="assoc-section assoc-section--warm" id={id} aria-labelledby={`${id}-heading`}>
	<div class="assoc-container assoc-faq__inner">
		<div class="assoc-faq__intro">
			<p class="assoc-eyebrow">FAQ</p>
			<h2 id={`${id}-heading`}>{heading}</h2>
			{lead && <p class="assoc-lead">{lead}</p>}
			{contactHref && <a class="assoc-btn assoc-btn--secondary" href={contactHref}>Contact Us</a>}
		</div>
		<div class="assoc-faq__list">
			{faqs.map((faq) => (
				<details class="assoc-faq-item">
					<summary>
						<span>{faq.question}</span>
						<svg class="assoc-faq-item__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
					</summary>
					<div class="assoc-faq-item__answer">
						<p>{faq.answer}</p>
					</div>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	.assoc-faq__inner {
		display: grid;
		grid-template-columns: 0.4fr 0.6fr;
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
	}

	.assoc-faq__intro .assoc-lead {
		margin-bottom: 1.5rem;
	}

	.assoc-faq__list {
		display: grid;
		gap: 0;
	}

	.assoc-faq-item {
		border-bottom: 1px solid var(--assoc-border);
	}

	.assoc-faq-item summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 0;
		cursor: pointer;
		list-style: none;
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--assoc-navy);
		line-height: 1.35;
	}

	.assoc-faq-item summary::-webkit-details-marker {
		display: none;
	}

	.assoc-faq-item summary::marker {
		content: '';
	}

	.assoc-faq-item__chevron {
		flex-shrink: 0;
		color: var(--assoc-slate);
		transition: transform 0.2s ease;
		display: inline;
	}

	.assoc-faq-item[open] .assoc-faq-item__chevron {
		transform: rotate(180deg);
	}

	.assoc-faq-item__answer {
		padding-bottom: 1rem;
	}

	.assoc-faq-item__answer p {
		font-size: 0.9rem;
		line-height: 1.6;
		margin: 0;
	}

	@media (max-width: 768px) {
		.assoc-faq__inner {
			grid-template-columns: 1fr;
		}
	}
</style>
