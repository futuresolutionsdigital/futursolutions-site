---
import { memberStories } from '../../data/association';
---

<section class="assoc-section" id="stories" aria-labelledby="stories-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Member Voices</p>
		<h2 id="stories-heading">What members say about being part of MHPA.</h2>
		<div class="stories-grid">
			{memberStories.map((story) => (
				<blockquote class="assoc-card story-card">
					<p class="story-card__quote">&ldquo;{story.quote}&rdquo;</p>
					<footer class="story-card__footer">
						<span class="story-card__name">{story.name}</span>
						<span class="story-card__role">{story.role}</span>
					</footer>
				</blockquote>
			))}
		</div>
	</div>
</section>

<style>
	.stories-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		margin-top: 2rem;
	}

	.story-card {
		margin: 0;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
	}

	.story-card__quote {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--assoc-navy);
		font-weight: 500;
		flex: 1;
		margin: 0;
	}

	.story-card__footer {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		margin-top: 1.25rem;
		padding-top: 1rem;
		border-top: 1px solid var(--assoc-border);
	}

	.story-card__name {
		font-size: 0.88rem;
		font-weight: 700;
		color: var(--assoc-navy);
	}

	.story-card__role {
		font-size: 0.78rem;
		color: var(--assoc-slate);
	}

	@media (max-width: 768px) {
		.stories-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
