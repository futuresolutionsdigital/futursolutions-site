---
import { contactFormSubjects, contactOffice } from '../../data/association';
---

<section class="assoc-section assoc-section--warm" id="form" aria-labelledby="contact-form-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Get in Touch</p>
		<h2 id="contact-form-heading">Send a demo request</h2>
		<div class="contact-form-grid">
			<form class="contact-form" data-demo-form novalidate>
				<div class="contact-form__fields" data-demo-fields>
					<input type="text" name="company_url" tabindex="-1" autocomplete="off" aria-hidden="true" data-honeypot />
					<div class="contact-form__field">
						<label for="cf-name">Name</label>
						<input type="text" id="cf-name" placeholder="Your name" autocomplete="name" data-required />
						<span class="assoc-form-error" data-error-for="cf-name" role="alert" hidden></span>
					</div>
					<div class="contact-form__field">
						<label for="cf-email">Email</label>
						<input type="email" id="cf-email" placeholder="you@example.com" autocomplete="email" data-required />
						<span class="assoc-form-error" data-error-for="cf-email" role="alert" hidden></span>
					</div>
					<div class="contact-form__field">
						<label for="cf-org">Organization <span class="contact-form__opt">(optional)</span></label>
						<input type="text" id="cf-org" placeholder="Your organization" autocomplete="organization" />
					</div>
					<div class="contact-form__field">
						<label for="cf-subject">Inquiry Type</label>
						<select id="cf-subject" data-required>
							<option value="">Select a topic…</option>
							{contactFormSubjects.map((s) => <option value={s}>{s}</option>)}
						</select>
						<span class="assoc-form-error" data-error-for="cf-subject" role="alert" hidden></span>
					</div>
					<div class="contact-form__field contact-form__field--full">
						<label for="cf-message">Message</label>
						<textarea id="cf-message" rows="5" placeholder="How can we help?" data-required></textarea>
						<span class="assoc-form-error" data-error-for="cf-message" role="alert" hidden></span>
					</div>
					<div class="contact-form__field contact-form__field--full">
						<label class="contact-form__check">
							<input type="checkbox" id="cf-consent" data-required />
							<span>I understand this is a fictional demo form.</span>
						</label>
						<span class="assoc-form-error" data-error-for="cf-consent" role="alert" hidden></span>
					</div>
					<div class="contact-form__field contact-form__field--full">
						<button type="submit" class="assoc-btn assoc-btn--primary contact-form__submit">Send Message</button>
					</div>
					<p class="contact-form__note">This is a demonstration form. Nothing is sent or stored. In a live association site, this submission would route to your CRM, AMS, helpdesk, or email workflow.</p>
				</div>

				<div class="assoc-form-success" data-demo-success hidden>
					<span class="assoc-form-success__icon" aria-hidden="true">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
					</span>
					<h3>Message received — this is how it would feel for your members.</h3>
					<p>Thanks for trying the demo. Your message looked great and passed validation.</p>
					<p class="assoc-form-success__demo-note">In your live site, a submission like this would instantly route to the right team, notify staff, log the contact in your CRM/AMS, and trigger an auto-reply — no inbox digging, nothing lost.</p>
					<button type="button" class="assoc-btn assoc-btn--secondary assoc-form-success__reset" data-demo-reset>Send another</button>
				</div>
			</form>

			<div class="contact-info">
				<div class="contact-info__card assoc-card">
					<h3>Office</h3>
					<p class="contact-info__name">{contactOffice.name}</p>
					<p>{contactOffice.address}</p>
					<p>{contactOffice.city}</p>
				</div>
				<div class="contact-info__card assoc-card">
					<h3>Phone & Email</h3>
					<p>{contactOffice.phone}</p>
					<p>{contactOffice.email}</p>
				</div>
				<div class="contact-info__card assoc-card">
					<h3>Support Hours</h3>
					<p>{contactOffice.hours}</p>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.contact-form-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: clamp(2rem, 4vw, 3.5rem); align-items: start; margin-top: 2rem; }
	.contact-form__fields { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
	.contact-form__field--full { grid-column: 1 / -1; }
	.contact-form label { display: block; font-size: 0.82rem; font-weight: 700; color: var(--assoc-navy); margin-bottom: 0.25rem; }
	.contact-form__opt { font-weight: 400; color: var(--assoc-slate); }
	.contact-form input[type="text"],
	.contact-form input[type="email"],
	.contact-form select,
	.contact-form textarea { width: 100%; padding: 0.6rem 0.75rem; border: 1px solid var(--assoc-border); border-radius: 8px; font-size: 0.88rem; font-family: inherit; background: var(--assoc-white); color: var(--assoc-navy); }
	.contact-form input:focus,
	.contact-form select:focus,
	.contact-form textarea:focus { outline: 2px solid var(--assoc-teal); outline-offset: -1px; border-color: var(--assoc-teal); }
	.contact-form textarea { resize: vertical; min-height: 100px; }
	.contact-form__check { display: flex; align-items: flex-start; gap: 0.5rem; font-weight: 400; font-size: 0.82rem; cursor: pointer; }
	.contact-form__check input { margin-top: 0.15rem; }
	.contact-form__submit { width: 100%; justify-content: center; }
	.contact-form__note { grid-column: 1 / -1; margin-top: 0.25rem; padding: 0.5rem 0.75rem; border-radius: 6px; background: color-mix(in srgb, var(--assoc-coral) 6%, var(--assoc-white)); font-size: 0.72rem; font-weight: 600; color: var(--assoc-coral-text); line-height: 1.45; }

	.contact-info { display: grid; gap: 0.75rem; }
	.contact-info__card { padding: 1.25rem; }
	.contact-info__card h3 { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--assoc-teal); margin-bottom: 0.5rem; }
	.contact-info__name { font-weight: 700; color: var(--assoc-navy); }
	.contact-info__card p { font-size: 0.88rem; line-height: 1.5; margin: 0 0 0.15rem; }

	@media (max-width: 768px) { .contact-form-grid { grid-template-columns: 1fr; } .contact-form__fields { grid-template-columns: 1fr; } }
</style>
