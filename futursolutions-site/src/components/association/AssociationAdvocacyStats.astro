---
import { advocacyStats } from '../../data/association';
---

<section class="adv-stats" aria-label="Advocacy impact numbers">
	<div class="assoc-container adv-stats__inner">
		{advocacyStats.map((s) => (
			<div class="adv-stats__item">
				<span class="adv-stats__value">{s.value}</span>
				<span class="adv-stats__label">{s.label}</span>
			</div>
		))}
	</div>
</section>

<style>
	.adv-stats {
		padding-block: clamp(1.25rem, 2.5vw, 2rem);
		background: var(--assoc-navy);
		color: var(--assoc-white);
	}
	.adv-stats__inner {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: clamp(1.25rem, 3.5vw, 2.75rem);
	}
	.adv-stats__item { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.1rem; }
	.adv-stats__value { font-size: clamp(1.4rem, 1.2rem + 0.7vw, 1.85rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
	.adv-stats__label { font-size: 0.72rem; font-weight: 600; color: rgba(255, 255, 255, 0.55); }
	@media (max-width: 520px) { .adv-stats__item { min-width: 70px; } }
</style>
