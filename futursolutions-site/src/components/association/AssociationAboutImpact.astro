---
import { aboutImpactStats } from '../../data/association';
---

<section class="about-impact" aria-label="Association impact statistics">
	<div class="assoc-container about-impact__inner">
		{aboutImpactStats.map((s) => (
			<div class="about-impact__item">
				<span class="about-impact__value">{s.value}</span>
				<span class="about-impact__label">{s.label}</span>
			</div>
		))}
	</div>
</section>

<style>
	.about-impact { padding-block: clamp(1.25rem, 2.5vw, 2rem); background: var(--assoc-navy); color: var(--assoc-white); }
	.about-impact__inner { display: flex; flex-wrap: wrap; justify-content: center; gap: clamp(1.25rem, 3.5vw, 2.75rem); }
	.about-impact__item { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.1rem; }
	.about-impact__value { font-size: clamp(1.4rem, 1.2rem + 0.7vw, 1.85rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
	.about-impact__label { font-size: 0.72rem; font-weight: 600; color: rgba(255, 255, 255, 0.55); }
	@media (max-width: 520px) { .about-impact__item { min-width: 70px; } }
</style>
