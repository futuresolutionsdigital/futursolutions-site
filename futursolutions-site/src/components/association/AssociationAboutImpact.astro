---
import { aboutImpactStats } from '../../data/association';
---

<section class="about-impact" aria-labelledby="about-impact-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow about-impact__eyebrow">Institutional Scale</p>
		<h2 id="about-impact-heading" class="about-impact__heading">A statewide association model built for real professional scale.</h2>
		<div class="about-impact__grid">
			{aboutImpactStats.map((s) => (
				<div class="about-impact__item">
					<span class="about-impact__value">{s.value}</span>
					<span class="about-impact__label">{s.label}</span>
				</div>
			))}
		</div>
		<p class="about-impact__note">Fictional demo metrics shown to illustrate how association scale and impact can be presented.</p>
	</div>
</section>

<style>
	.about-impact { padding-block: clamp(2rem, 4vw, 3.5rem); background: var(--assoc-navy); color: var(--assoc-white); }
	.about-impact__eyebrow { color: rgba(255, 255, 255, 0.4) !important; }
	.about-impact__heading { color: var(--assoc-white); text-align: center; text-wrap: balance; max-width: 600px; margin-inline: auto; }
	.about-impact__grid { display: flex; flex-wrap: wrap; justify-content: center; gap: clamp(1.5rem, 4vw, 3rem); margin-top: 1.5rem; }
	.about-impact__item { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.15rem; }
	.about-impact__value { font-size: clamp(1.5rem, 1.3rem + 0.8vw, 2rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
	.about-impact__label { font-size: 0.72rem; font-weight: 600; color: rgba(255, 255, 255, 0.5); }
	.about-impact__note { text-align: center; margin-top: 1.25rem; font-size: 0.68rem; font-weight: 600; color: rgba(255, 255, 255, 0.3); letter-spacing: 0.02em; }
	@media (max-width: 520px) { .about-impact__item { min-width: 80px; } }
</style>
