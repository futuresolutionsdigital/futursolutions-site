---
import { careerEmployerBlock } from '../../data/association';
const e = careerEmployerBlock;
---

<section class="ce-section" id="employers" aria-labelledby="career-employers-heading">
	<div class="assoc-container ce-inner">
		<p class="assoc-eyebrow">For Employers</p>
		<h2 id="career-employers-heading">{e.headline}</h2>
		<p class="ce-sub">{e.subheadline}</p>
		<div class="ce-grid">
			{e.values.map((v) => (
				<div class="ce-card">
					<h3>{v.title}</h3>
					<p>{v.description}</p>
				</div>
			))}
		</div>
		<div class="assoc-btn-row ce-btns">
			<a class="assoc-btn ce-btn-primary" href={e.primaryCta.href}>{e.primaryCta.text}</a>
			<a class="assoc-btn ce-btn-ghost" href={e.secondaryCta.href}>{e.secondaryCta.text}</a>
		</div>
	</div>
</section>

<style>
	.ce-section { padding-block: var(--assoc-section-spacing); background: var(--assoc-navy); color: var(--assoc-white); }
	.ce-inner { max-width: 900px; text-align: center; margin-inline: auto; }
	.ce-section h2 { color: var(--assoc-white); text-wrap: balance; }
	.ce-sub { font-size: 0.95rem; line-height: 1.6; color: rgba(255,255,255,0.6); max-width: 680px; margin-inline: auto; margin-bottom: 2rem; }
	.ce-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
	.ce-card { padding: 1.25rem; border: 1px solid rgba(255,255,255,0.1); border-radius: var(--assoc-radius); text-align: left; }
	.ce-card h3 { font-size: 0.95rem; color: var(--assoc-white); margin-bottom: 0.3rem; }
	.ce-card p { font-size: 0.82rem; line-height: 1.5; color: rgba(255,255,255,0.55); margin: 0; }
	.ce-btns { justify-content: center; }
	.ce-btn-primary { background: var(--assoc-teal) !important; color: var(--assoc-white) !important; }
	.ce-btn-primary:hover { background: color-mix(in srgb, var(--assoc-teal) 80%, var(--assoc-white)) !important; }
	.ce-btn-ghost { border-color: rgba(255,255,255,0.2) !important; background: transparent !important; color: var(--assoc-white) !important; }
	.ce-btn-ghost:hover { border-color: rgba(255,255,255,0.4) !important; background: rgba(255,255,255,0.06) !important; }
	@media (max-width: 700px) { .ce-grid { grid-template-columns: 1fr; } }
</style>
