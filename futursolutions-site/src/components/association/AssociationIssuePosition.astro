---
import { advocacyIssuePosition } from '../../data/association';
---

<section class="assoc-section" aria-labelledby="issue-pos-heading">
	<div class="assoc-container issue-pos__inner">
		<div class="issue-pos__intro">
			<p class="assoc-eyebrow">MHPA Position</p>
			<h2 id="issue-pos-heading">What MHPA supports</h2>
			<p class="assoc-lead">MHPA supports responsible scope-of-practice reform that expands access while preserving high clinical standards.</p>
		</div>
		<ul class="issue-pos__list">
			{advocacyIssuePosition.map((point) => (
				<li>
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
					<span>{point}</span>
				</li>
			))}
		</ul>
	</div>
</section>

<style>
	.issue-pos__inner { display: grid; grid-template-columns: 0.45fr 0.55fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
	.issue-pos__intro .assoc-lead { margin-bottom: 0; }
	.issue-pos__list { margin: 0; padding: 0; list-style: none; display: grid; gap: 0.75rem; }
	.issue-pos__list li {
		display: flex;
		align-items: flex-start;
		gap: 0.6rem;
		font-size: 0.92rem;
		font-weight: 600;
		color: var(--assoc-navy);
		line-height: 1.45;
	}
	.issue-pos__list li svg { display: inline; flex-shrink: 0; margin-top: 0.15rem; color: var(--assoc-teal); }
	@media (max-width: 768px) { .issue-pos__inner { grid-template-columns: 1fr; } }
</style>
