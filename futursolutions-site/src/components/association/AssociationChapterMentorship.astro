---
import { chapterMentorship } from '../../data/association';
const m = chapterMentorship;
---

<section class="assoc-section" id="mentorship" aria-labelledby="ch-mentor-heading">
	<div class="assoc-container ch-mentor__inner">
		<div class="ch-mentor__content">
			<p class="assoc-eyebrow">Mentorship & Community</p>
			<h2 id="ch-mentor-heading">{m.headline}</h2>
			<p class="ch-mentor__desc">{m.description}</p>
			<a class="assoc-btn assoc-btn--primary" href={m.cta.href}>{m.cta.text}</a>
		</div>
		<div class="ch-mentor__pathways">
			{m.pathways.map((p) => (
				<a href={p.href} class="ch-mentor__path">
					<h3>{p.title}</h3>
					<p>{p.description}</p>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.ch-mentor__inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
	.ch-mentor__desc { font-size: 0.92rem; line-height: 1.6; margin-bottom: 1.5rem; }
	.ch-mentor__pathways { display: grid; gap: 0.75rem; }
	.ch-mentor__path { display: block; padding: 1.15rem; border: 1px solid var(--assoc-border); border-radius: var(--assoc-radius); background: var(--assoc-white); transition: border-color 0.15s ease, transform 0.15s ease; }
	.ch-mentor__path:hover { border-color: var(--assoc-teal); transform: translateY(-1px); }
	.ch-mentor__path h3 { font-size: 0.95rem; margin-bottom: 0.2rem; }
	.ch-mentor__path p { font-size: 0.82rem; line-height: 1.45; margin: 0; }
	@media (max-width: 768px) { .ch-mentor__inner { grid-template-columns: 1fr; } }
</style>
