---
import { aboutPartners } from '../../data/association';
---

<section class="assoc-section" aria-labelledby="about-partners-heading">
	<div class="assoc-container about-partners-inner">
		<p class="assoc-eyebrow">Collaboration</p>
		<h2 id="about-partners-heading">Collaboration strengthens the profession.</h2>
		<div class="about-partners-grid">
			{aboutPartners.map((name) => (
				<div class="about-partner-badge">
					<span>{name}</span>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.about-partners-inner { text-align: center; }
	.about-partners-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-top: 2rem; }
	.about-partner-badge { padding: 0.65rem 1.25rem; border: 1px solid var(--assoc-border); border-radius: var(--assoc-radius); background: var(--assoc-white); }
	.about-partner-badge span { font-size: 0.82rem; font-weight: 700; color: var(--assoc-navy); letter-spacing: 0.01em; }
</style>
