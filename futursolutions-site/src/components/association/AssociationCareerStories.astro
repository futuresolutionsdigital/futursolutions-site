---
import { careerStories } from '../../data/association';
---

<section class="assoc-section" aria-labelledby="career-stories-heading">
	<div class="assoc-container">
		<p class="assoc-eyebrow">Success Stories</p>
		<h2 id="career-stories-heading">Career support that moves with members.</h2>
		<div class="cst-grid">
			{careerStories.map((s) => (
				<blockquote class="assoc-card cst-card">
					<p class="cst-card__quote">&ldquo;{s.quote}&rdquo;</p>
					<footer class="cst-card__footer">
						<span class="cst-card__name">{s.name}</span>
						<span class="cst-card__role">{s.role} · {s.region}</span>
						<span class="cst-card__outcome">{s.outcome}</span>
					</footer>
				</blockquote>
			))}
		</div>
	</div>
</section>

<style>
	.cst-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2rem; }
	.cst-card { display: flex; flex-direction: column; padding: 1.5rem; margin: 0; }
	.cst-card__quote { font-size: 0.92rem; line-height: 1.6; font-style: italic; color: var(--assoc-navy); flex: 1; }
	.cst-card__footer { margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--assoc-border); }
	.cst-card__name { display: block; font-size: 0.88rem; font-weight: 700; color: var(--assoc-navy); font-style: normal; }
	.cst-card__role { display: block; font-size: 0.75rem; font-weight: 600; color: var(--assoc-teal); font-style: normal; }
	.cst-card__outcome { display: block; margin-top: 0.35rem; font-size: 0.72rem; font-weight: 600; font-style: normal; color: var(--assoc-slate); }
	@media (max-width: 768px) { .cst-grid { grid-template-columns: 1fr; } }
</style>
