---
const nodes = [
	{
		label: 'Form submitted',
		sub: 'From your website or landing page',
		icon: 'form',
	},
	{
		label: 'Lead is captured',
		sub: 'Saved to your CRM with full context',
		icon: 'inbox',
	},
	{
		label: 'Team is notified',
		sub: 'Routed to the right person in seconds',
		icon: 'bell',
	},
	{
		label: 'Consult is booked',
		sub: 'Patient picks a time and gets confirmation',
		icon: 'calendar',
	},
	{
		label: 'Follow-up is sent',
		sub: 'Reminders, SMS, and email sequences',
		icon: 'message',
	},
	{
		label: 'Results are tracked',
		sub: 'Source, status, outcome, conversion',
		icon: 'chart',
	},
];

const principles = [
	{
		title: 'Owned data',
		text: 'Lead, source, status, and outcome live in your CRM — not a third-party plugin you cannot export.',
	},
	{
		title: 'Fast routing',
		text: 'New inquiries reach the right person in seconds, with full context, before they go cold.',
	},
	{
		title: 'No drop-off',
		text: 'Automated reminders and sequences keep prospects warm until they book a consult.',
	},
];
---

<section id="system" class="section-loose system-diagram section-ink" aria-labelledby="system-diagram-heading">
	<div class="dot-grid dot-grid--ink" aria-hidden="true"></div>

	<div class="site-container site-container--wide system-diagram__inner">
		<div class="system-diagram__head">
			<p class="eyebrow">Growth Systems</p>
			<h2 id="system-diagram-heading" class="display-lg">
				What happens after someone fills out the form on your&nbsp;site.
			</h2>
			<p class="lead system-diagram__lead">
				A Growth System is the lead capture, booking, follow-up, and reporting setup behind the website. We design and wire it so nothing drops between the click and the consult.
			</p>
		</div>

		<ol class="system-diagram__flow" aria-label="Lead system flow">
			{
				nodes.map((node, i) => (
					<li class="system-node">
						<div class="system-node__icon" aria-hidden="true">
							{node.icon === 'form' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
									<rect x="6" y="4" width="12" height="17" rx="2" />
									<path d="M9 3h6a1 1 0 0 1 1 1v2H8V4a1 1 0 0 1 1-1z" />
									<path d="M9 11h6M9 15h6M9 8h3" />
								</svg>
							)}
							{node.icon === 'inbox' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
									<path d="M3 13l3-7h12l3 7v6a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z" />
									<path d="M3 13h5l1 2h6l1-2h5" />
								</svg>
							)}
							{node.icon === 'bell' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
									<path d="M6 16h12a1 1 0 0 0 .78-1.63L17 12V9a5 5 0 0 0-10 0v3l-1.78 2.37A1 1 0 0 0 6 16z" />
									<path d="M10 19a2 2 0 0 0 4 0" />
								</svg>
							)}
							{node.icon === 'calendar' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
									<rect x="3" y="5" width="18" height="16" rx="2" />
									<path d="M3 10h18M8 3v4M16 3v4" />
								</svg>
							)}
							{node.icon === 'message' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
									<path d="M4 5h16a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H8l-4 3V6a1 1 0 0 1 1-1z" />
									<path d="M8 10h8M8 13h5" />
								</svg>
							)}
							{node.icon === 'chart' && (
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round">
									<path d="M4 20h16M6 16l4-5 4 3 4-7" />
								</svg>
							)}
						</div>
						<div class="system-node__label">
							<span class="system-node__index">{String(i + 1).padStart(2, '0')}</span>
							<p class="system-node__title">{node.label}</p>
							<p class="system-node__sub">{node.sub}</p>
						</div>
					</li>
				))
			}
		</ol>

		<div class="system-diagram__compare" aria-label="Before and after a Growth System">
			<article class="system-compare system-compare--before">
				<header class="system-compare__head">
					<span class="system-compare__indicator system-compare__indicator--before" aria-hidden="true">
						<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
							<path d="M4 4l8 8M12 4l-8 8" />
						</svg>
					</span>
					<p class="system-compare__label">Without a system</p>
				</header>
				<p class="system-compare__text">
					Leads sit in inboxes, calls get missed, and follow-up depends on whoever remembers. Inquiries go cold while your team is in clinic.
				</p>
			</article>

			<article class="system-compare system-compare--after">
				<header class="system-compare__head">
					<span class="system-compare__indicator system-compare__indicator--after" aria-hidden="true">
						<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 8.5l3.5 3.5 7-7.5" />
						</svg>
					</span>
					<p class="system-compare__label">With a Growth System</p>
				</header>
				<p class="system-compare__text">
					Every inquiry is captured, routed to the right person, followed up with automatically, and visible in one place — from first form to booked consult.
				</p>
			</article>
		</div>

		<div class="system-diagram__principles">
			{
				principles.map((p) => (
					<div class="system-principle">
						<div class="system-principle__indicator" aria-hidden="true" />
						<h3 class="system-principle__title">{p.title}</h3>
						<p class="system-principle__text">{p.text}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.system-diagram {
		position: relative;
		overflow: hidden;
		background:
			radial-gradient(ellipse 80% 60% at 80% 0%, color-mix(in srgb, var(--lane-growth-tint) 75%, transparent), transparent 70%),
			linear-gradient(180deg, var(--color-bg) 0%, color-mix(in srgb, var(--lane-growth-tint) 50%, var(--color-bg)) 100%);
		border-block: 1px solid color-mix(in srgb, var(--lane-growth) 16%, var(--color-border-soft));
	}

	.system-diagram .eyebrow {
		color: var(--lane-growth-ink);
	}

	.system-diagram__inner {
		position: relative;
	}

	.system-diagram__head {
		max-width: 64ch;
		margin-bottom: clamp(3rem, 5.5vw, 4.5rem);
	}

	.system-diagram__head h2 {
		max-width: 22ch;
		margin-bottom: 1.25rem;
	}

	.system-diagram__lead {
		max-width: 60ch;
	}

	.system-diagram__flow {
		position: relative;
		display: grid;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		gap: 1rem;
		margin: 0 0 clamp(3rem, 5vw, 4rem) 0;
		padding: 2.5rem 1.25rem;
		border: 1px solid var(--color-ink-line);
		border-radius: var(--radius-xl);
		background: var(--color-ink-soft);
		list-style: none;
	}

	.system-diagram__flow::before {
		position: absolute;
		top: 50%;
		left: 4rem;
		right: 4rem;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--color-ink-line-strong) 12%, var(--color-ink-line-strong) 88%, transparent);
		transform: translateY(-50%);
		content: '';
		z-index: 0;
		pointer-events: none;
	}

	.system-node {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.85rem;
	}

	.system-node__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.85rem;
		height: 2.85rem;
		border: 1px solid color-mix(in srgb, var(--lane-growth) 35%, var(--color-ink-line-strong));
		border-radius: 12px;
		background: var(--color-ink);
		color: color-mix(in srgb, var(--lane-growth) 60%, var(--color-ink-accent));
		box-shadow: 0 0 0 4px var(--color-ink-soft);
	}

	.system-node__icon svg {
		width: 1.25rem;
		height: 1.25rem;
	}

	.system-node__label {
		display: grid;
		gap: 0.2rem;
	}

	.system-node__index {
		color: var(--color-ink-muted);
		font-size: 0.7rem;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.16em;
	}

	.system-node__title {
		margin: 0;
		color: var(--color-white);
		font-size: 0.98rem;
		font-weight: 650;
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.system-node__sub {
		margin: 0;
		color: var(--color-ink-muted);
		font-size: 0.82rem;
		line-height: 1.45;
	}

	.system-diagram__compare {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin: 0 0 clamp(3rem, 5vw, 4rem) 0;
	}

	.system-compare {
		display: grid;
		gap: 0.75rem;
		padding: 1.5rem 1.65rem;
		border: 1px solid var(--color-ink-line-strong);
		border-radius: var(--radius-lg);
		background: var(--color-ink-soft);
	}

	.system-compare--before {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.015) 0%, transparent 60%),
			var(--color-ink-soft);
	}

	.system-compare--after {
		border-color: color-mix(in srgb, var(--lane-growth) 45%, var(--color-ink-line-strong));
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--lane-growth) 8%, transparent) 0%, transparent 75%),
			var(--color-ink-soft);
	}

	.system-compare__head {
		display: flex;
		align-items: center;
		gap: 0.65rem;
	}

	.system-compare__indicator {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		border-radius: 999px;
		flex-shrink: 0;
	}

	.system-compare__indicator svg {
		width: 0.85rem;
		height: 0.85rem;
	}

	.system-compare__indicator--before {
		background: rgba(255, 255, 255, 0.06);
		color: var(--color-ink-muted);
	}

	.system-compare__indicator--after {
		background: color-mix(in srgb, var(--lane-growth) 25%, transparent);
		color: color-mix(in srgb, var(--lane-growth) 70%, var(--color-white));
	}

	.system-compare__label {
		margin: 0;
		color: var(--color-white);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.system-compare--before .system-compare__label {
		color: var(--color-ink-muted);
	}

	.system-compare__text {
		margin: 0;
		color: var(--color-ink-text);
		font-size: 0.98rem;
		line-height: 1.6;
		font-weight: 450;
	}

	.system-compare--before .system-compare__text {
		color: var(--color-ink-muted);
	}

	.system-diagram__principles {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 2.5rem;
	}

	.system-principle {
		position: relative;
		padding-left: 1.25rem;
		border-left: 1px solid var(--color-ink-line-strong);
	}

	.system-principle__indicator {
		position: absolute;
		top: 0;
		left: -3.5px;
		width: 6px;
		height: 6px;
		border-radius: 999px;
		background: color-mix(in srgb, var(--lane-growth) 75%, var(--color-ink-accent));
	}

	.system-principle__title {
		margin: 0 0 0.5rem 0;
		color: var(--color-white);
		font-size: 1.05rem;
		font-weight: 650;
		letter-spacing: -0.02em;
	}

	.system-principle__text {
		margin: 0;
		color: var(--color-ink-muted);
		font-size: 0.93rem;
		line-height: 1.6;
	}

	@media (max-width: 1080px) {
		.system-diagram__flow {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 1.5rem 1rem;
		}

		.system-diagram__flow::before {
			display: none;
		}

		.system-diagram__principles {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.system-diagram__compare {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 620px) {
		.system-diagram__flow {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
