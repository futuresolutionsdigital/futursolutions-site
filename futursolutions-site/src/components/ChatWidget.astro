---
---

<div class="chat-widget" data-chat-widget>
	<button
		class="chat-widget__fab"
		type="button"
		aria-label="Open Fit Assistant chat"
		aria-expanded="false"
		data-chat-toggle
	>
		<svg class="chat-widget__fab-icon chat-widget__fab-icon--chat" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
		</svg>
		<svg class="chat-widget__fab-icon chat-widget__fab-icon--close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<line x1="18" y1="6" x2="6" y2="18" />
			<line x1="6" y1="6" x2="18" y2="18" />
		</svg>
	</button>

	<div class="chat-widget__panel" role="dialog" aria-label="FutureSolutions Fit Assistant" data-chat-panel>
		<header class="chat-widget__header">
			<div class="chat-widget__header-info">
				<span class="chat-widget__header-mark" aria-hidden="true">
					<span class="chat-widget__header-mark-shape"></span>
				</span>
				<div>
					<strong class="chat-widget__header-title">Fit Assistant</strong>
					<span class="chat-widget__header-sub">FutureSolutions</span>
				</div>
			</div>
			<button class="chat-widget__close" type="button" aria-label="Close chat" data-chat-close>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="18" y1="6" x2="6" y2="18" />
					<line x1="6" y1="6" x2="18" y2="18" />
				</svg>
			</button>
		</header>

		<div class="chat-widget__messages" data-chat-messages>
			<!-- Messages rendered by JS -->
		</div>

		<form class="chat-widget__form" data-chat-form>
			<input
				class="chat-widget__input"
				type="text"
				placeholder="Ask about our services..."
				autocomplete="off"
				data-chat-input
			/>
			<button class="chat-widget__send" type="submit" aria-label="Send message" data-chat-send>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="22" y1="2" x2="11" y2="13" />
					<polygon points="22 2 15 22 11 13 2 9 22 2" />
				</svg>
			</button>
		</form>
	</div>
</div>

<script>
	import '../scripts/chat-widget';
</script>

<style>
	.chat-widget {
		position: fixed;
		bottom: 1.25rem;
		right: 1.25rem;
		z-index: 50;
		font-family: var(--font-family-base);
	}

	/* ═══ FAB ═══ */
	.chat-widget__fab {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 3.25rem;
		height: 3.25rem;
		border: none;
		border-radius: 50%;
		background: var(--color-text);
		color: var(--color-white);
		cursor: pointer;
		box-shadow: 0 8px 24px rgba(15, 23, 42, 0.22);
		transition: transform 220ms var(--ease-out-quart), box-shadow var(--transition-base);
	}

	.chat-widget__fab:hover {
		transform: scale(1.06);
		box-shadow: 0 12px 32px rgba(15, 23, 42, 0.3);
	}

	.chat-widget__fab:focus-visible {
		outline: 3px solid var(--color-accent);
		outline-offset: 3px;
	}

	.chat-widget__fab-icon {
		width: 1.35rem;
		height: 1.35rem;
	}

	.chat-widget__fab-icon--close {
		display: none;
	}

	.chat-widget.is-open .chat-widget__fab-icon--chat {
		display: none;
	}

	.chat-widget.is-open .chat-widget__fab-icon--close {
		display: block;
	}

	/* ═══ Panel ═══ */
	.chat-widget__panel {
		display: none;
		flex-direction: column;
		position: absolute;
		bottom: calc(100% + 0.75rem);
		right: 0;
		width: 380px;
		max-height: 520px;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: 0 24px 64px rgba(15, 23, 42, 0.14), 0 4px 12px rgba(15, 23, 42, 0.06);
		overflow: hidden;
	}

	.chat-widget.is-open .chat-widget__panel {
		display: flex;
	}

	/* ═══ Header ═══ */
	.chat-widget__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.85rem 1rem;
		border-bottom: 1px solid var(--color-border-soft);
		background: var(--color-bg-secondary);
	}

	.chat-widget__header-info {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.chat-widget__header-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.65rem;
		height: 1.65rem;
		border-radius: 7px;
		background: var(--color-text);
		flex-shrink: 0;
	}

	.chat-widget__header-mark-shape {
		display: block;
		width: 0.5rem;
		height: 0.5rem;
		background: var(--color-white);
		transform: rotate(45deg);
	}

	.chat-widget__header-title {
		display: block;
		font-size: 0.88rem;
		font-weight: 700;
		color: var(--color-text);
		line-height: 1.2;
	}

	.chat-widget__header-sub {
		display: block;
		font-size: 0.72rem;
		color: var(--color-muted);
		font-weight: 500;
	}

	.chat-widget__close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		border: none;
		border-radius: 6px;
		background: transparent;
		color: var(--color-muted);
		cursor: pointer;
		transition: background var(--transition-base), color var(--transition-base);
	}

	.chat-widget__close:hover {
		background: var(--color-bg);
		color: var(--color-text);
	}

	.chat-widget__close:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 1px;
	}

	.chat-widget__close svg {
		width: 1rem;
		height: 1rem;
	}

	/* ═══ Messages ═══ */
	.chat-widget__messages {
		flex: 1;
		overflow-y: auto;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-height: 280px;
		max-height: 380px;
	}

	/* ═══ Form ═══ */
	.chat-widget__form {
		display: flex;
		gap: 0.5rem;
		padding: 0.75rem 1rem;
		border-top: 1px solid var(--color-border-soft);
		background: var(--color-bg-secondary);
	}

	.chat-widget__input {
		flex: 1;
		min-height: 2.35rem;
		padding: 0.55rem 0.75rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-white);
		color: var(--color-text);
		font-size: 0.875rem;
		font-family: inherit;
		outline: none;
		transition: border-color var(--transition-base);
	}

	.chat-widget__input:focus-visible {
		border-color: var(--color-accent);
		outline: 3px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
		outline-offset: 1px;
	}

	.chat-widget__input::placeholder {
		color: var(--color-muted-soft);
	}

	.chat-widget__send {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.35rem;
		height: 2.35rem;
		border: none;
		border-radius: var(--radius-sm);
		background: var(--color-text);
		color: var(--color-white);
		cursor: pointer;
		flex-shrink: 0;
		transition: background var(--transition-base), transform 160ms ease;
	}

	.chat-widget__send:hover {
		background: var(--color-ink);
	}

	.chat-widget__send:active {
		transform: scale(0.94);
	}

	.chat-widget__send svg {
		width: 1rem;
		height: 1rem;
	}

	.chat-widget__send:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.chat-widget__send:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	/* ═══ Mobile ═══ */
	@media (max-width: 560px) {
		.chat-widget {
			bottom: 0;
			right: 0;
			left: 0;
		}

		.chat-widget__fab {
			position: fixed;
			bottom: 1rem;
			right: 1rem;
		}

		.chat-widget.is-open .chat-widget__fab {
			display: none;
		}

		.chat-widget__panel {
			position: fixed;
			inset: 0;
			width: 100%;
			max-height: none;
			border: none;
			border-radius: 0;
		}

		.chat-widget__messages {
			max-height: none;
			flex: 1;
		}
	}
</style>
