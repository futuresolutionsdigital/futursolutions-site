---
import { getChatbotContext, themeToCssVars } from '../lib/chatbot-contexts';

interface Props {
	/** 'base' for the main site, or a demo key (e.g. 'med-spa'). */
	context?: string;
}

const { context = 'base' } = Astro.props;
const ctx = getChatbotContext(context);
const cssVars = themeToCssVars(ctx.theme);
const styleString = Object.entries(cssVars)
	.map(([k, v]) => `${k}: ${v}`)
	.join('; ');
const initial = ctx.brandName.trim().charAt(0).toUpperCase();
const isDemo = ctx.demoSlug !== null;
---

<div
	class="chat-widget"
	data-chat-widget
	data-context={ctx.key}
	data-scheme={ctx.theme.scheme}
	data-greeting={ctx.greeting}
	data-nudge={ctx.nudge}
	data-assistant-name={ctx.assistantName}
	data-quick-replies={JSON.stringify(ctx.quickReplies)}
	style={styleString}
>
	<!-- Proactive nudge bubble -->
	<div class="chat-widget__nudge" data-chat-nudge hidden>
		<button class="chat-widget__nudge-body" type="button" data-chat-nudge-open>
			<span class="chat-widget__nudge-mark" aria-hidden="true">{initial}</span>
			<span class="chat-widget__nudge-text" data-chat-nudge-text>{ctx.nudge}</span>
		</button>
		<button class="chat-widget__nudge-close" type="button" aria-label="Dismiss message" data-chat-nudge-close>
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
				<line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
			</svg>
		</button>
	</div>

	<button
		class="chat-widget__fab"
		type="button"
		aria-label={`Open ${ctx.assistantName} chat`}
		aria-expanded="false"
		data-chat-toggle
	>
		<span class="chat-widget__fab-dot" data-chat-unread aria-hidden="true"></span>
		<svg class="chat-widget__fab-icon chat-widget__fab-icon--chat" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
		</svg>
		<svg class="chat-widget__fab-icon chat-widget__fab-icon--close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
		</svg>
	</button>

	<div class="chat-widget__panel" role="dialog" aria-label={`${ctx.assistantName} chat`} data-chat-panel>
		<header class="chat-widget__header">
			<div class="chat-widget__header-info">
				<span class="chat-widget__header-mark" aria-hidden="true">{initial}</span>
				<div class="chat-widget__header-meta">
					<strong class="chat-widget__header-title">
						{ctx.assistantName}
						{isDemo && <span class="chat-widget__badge">Demo</span>}
					</strong>
					<span class="chat-widget__header-sub">
						<span class="chat-widget__status-dot" aria-hidden="true"></span>
						{ctx.tagline}
					</span>
				</div>
			</div>
			<div class="chat-widget__header-actions">
				<button class="chat-widget__icon-btn" type="button" aria-label="Mute notification sound" data-chat-mute>
					<svg class="chat-widget__icon--sound" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" /><path d="M15.5 8.5a5 5 0 0 1 0 7" /><path d="M18.5 5.5a9 9 0 0 1 0 13" />
					</svg>
					<svg class="chat-widget__icon--muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" /><line x1="22" y1="9" x2="16" y2="15" /><line x1="16" y1="9" x2="22" y2="15" />
					</svg>
				</button>
				<button class="chat-widget__icon-btn" type="button" aria-label="Close chat" data-chat-close>
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
					</svg>
				</button>
			</div>
		</header>

		<div class="chat-widget__messages" role="log" aria-live="polite" aria-atomic="false" data-chat-messages></div>

		<div class="chat-widget__quick" data-chat-quick hidden></div>

		<form class="chat-widget__form" data-chat-form>
			<input
				class="chat-widget__input"
				type="text"
				placeholder="Type a message…"
				autocomplete="off"
				aria-label="Type your message"
				data-chat-input
			/>
			<button class="chat-widget__send" type="submit" aria-label="Send message" data-chat-send>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" />
				</svg>
			</button>
		</form>

		{isDemo && (
			<a class="chat-widget__footer" href="/" data-chat-footer>
				<span class="chat-widget__footer-dot" aria-hidden="true"></span>
				Demo by FutureSolutions
			</a>
		)}
	</div>
</div>

<script>
	import '../scripts/chat-widget';
</script>

<style is:global>
	.chat-widget {
		position: fixed;
		bottom: 1.25rem;
		right: 1.25rem;
		z-index: 60;
		font-family: var(--chat-font);
	}

	/* ═══ FAB ═══ */
	.chat-widget__fab {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 3.5rem;
		height: 3.5rem;
		border: none;
		border-radius: 50%;
		background: var(--chat-fab);
		color: var(--chat-fab-ink);
		cursor: pointer;
		box-shadow: 0 10px 30px rgba(15, 23, 42, 0.26);
		transition: transform 220ms cubic-bezier(0.25, 1, 0.5, 1), box-shadow 220ms ease;
	}

	.chat-widget__fab:hover {
		transform: scale(1.06);
		box-shadow: 0 14px 38px rgba(15, 23, 42, 0.32);
	}

	.chat-widget__fab:focus-visible {
		outline: 3px solid var(--chat-accent);
		outline-offset: 3px;
	}

	.chat-widget__fab-icon {
		width: 1.4rem;
		height: 1.4rem;
		transition: opacity 160ms ease, transform 160ms ease;
	}

	.chat-widget__fab-icon--close {
		display: none;
	}

	.chat-widget.is-open .chat-widget__fab-icon--chat {
		display: none;
	}

	.chat-widget.is-open .chat-widget__fab-icon--close {
		display: block;
	}

	.chat-widget__fab-dot {
		position: absolute;
		top: 0.15rem;
		right: 0.15rem;
		width: 0.85rem;
		height: 0.85rem;
		border-radius: 50%;
		background: var(--chat-accent);
		border: 2px solid var(--chat-surface);
		opacity: 0;
		transform: scale(0.4);
		transition: opacity 200ms ease, transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.chat-widget.has-unread .chat-widget__fab-dot {
		opacity: 1;
		transform: scale(1);
	}

	.chat-widget.is-open .chat-widget__fab-dot {
		opacity: 0;
	}

	/* ═══ Nudge bubble ═══ */
	.chat-widget__nudge {
		position: absolute;
		bottom: calc(100% + 0.85rem);
		right: 0;
		display: flex;
		align-items: stretch;
		width: max-content;
		max-width: 17rem;
		border-radius: 16px;
		background: var(--chat-surface);
		border: 1px solid var(--chat-border);
		box-shadow: 0 16px 40px rgba(15, 23, 42, 0.16);
		overflow: hidden;
		transform: translateY(8px) scale(0.96);
		opacity: 0;
		transition: opacity 260ms ease, transform 260ms cubic-bezier(0.34, 1.56, 0.64, 1);
		transform-origin: bottom right;
		pointer-events: none;
	}

	.chat-widget__nudge.is-visible {
		opacity: 1;
		transform: translateY(0) scale(1);
		pointer-events: auto;
	}

	.chat-widget__nudge-body {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.75rem 0.4rem 0.75rem 0.85rem;
		border: none;
		background: transparent;
		color: var(--chat-text);
		font-family: inherit;
		font-size: 0.83rem;
		line-height: 1.4;
		text-align: left;
		cursor: pointer;
	}

	.chat-widget__nudge-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 1.85rem;
		height: 1.85rem;
		border-radius: 50%;
		background: var(--chat-accent);
		color: var(--chat-accent-ink);
		font-weight: 700;
		font-size: 0.85rem;
		font-family: var(--chat-font-display);
	}

	.chat-widget__nudge-text {
		color: var(--chat-text);
	}

	.chat-widget__nudge-close {
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding: 0.45rem 0.5rem 0 0;
		border: none;
		background: transparent;
		color: var(--chat-muted);
		cursor: pointer;
	}

	.chat-widget__nudge-close svg {
		width: 0.85rem;
		height: 0.85rem;
	}

	.chat-widget__nudge-close:hover {
		color: var(--chat-text);
	}

	/* ═══ Panel ═══ */
	.chat-widget__panel {
		display: none;
		flex-direction: column;
		position: absolute;
		bottom: calc(100% + 0.85rem);
		right: 0;
		width: 384px;
		max-height: min(560px, calc(100vh - 3rem));
		border: 1px solid var(--chat-border);
		border-radius: var(--chat-radius);
		background: var(--chat-surface);
		color: var(--chat-text);
		box-shadow: 0 28px 70px rgba(15, 23, 42, 0.22), 0 6px 16px rgba(15, 23, 42, 0.08);
		overflow: hidden;
	}

	.chat-widget.is-open .chat-widget__panel {
		display: flex;
		animation: chatPanelIn 280ms cubic-bezier(0.25, 1, 0.5, 1) both;
	}

	@keyframes chatPanelIn {
		from { opacity: 0; transform: translateY(14px) scale(0.98); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}

	/* ═══ Header ═══ */
	.chat-widget__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.85rem 0.85rem 0.85rem 1rem;
		border-bottom: 1px solid var(--chat-border);
		background: var(--chat-surface-2);
	}

	.chat-widget__header-info {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		min-width: 0;
	}

	.chat-widget__header-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.1rem;
		height: 2.1rem;
		border-radius: 50%;
		background: var(--chat-accent);
		color: var(--chat-accent-ink);
		font-family: var(--chat-font-display);
		font-weight: 700;
		font-size: 0.95rem;
		flex-shrink: 0;
	}

	.chat-widget__header-meta {
		min-width: 0;
	}

	.chat-widget__header-title {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.92rem;
		font-weight: 700;
		color: var(--chat-text);
		line-height: 1.2;
	}

	.chat-widget__badge {
		flex-shrink: 0;
		padding: 0.1rem 0.4rem;
		border-radius: 5px;
		background: color-mix(in srgb, var(--chat-accent) 16%, transparent);
		color: var(--chat-link);
		font-size: 0.58rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.chat-widget__header-sub {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.72rem;
		color: var(--chat-muted);
		font-weight: 500;
	}

	.chat-widget__status-dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: #36c98a;
		box-shadow: 0 0 0 3px color-mix(in srgb, #36c98a 22%, transparent);
	}

	.chat-widget__header-actions {
		display: flex;
		align-items: center;
		gap: 0.15rem;
		flex-shrink: 0;
	}

	.chat-widget__icon-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.9rem;
		height: 1.9rem;
		border: none;
		border-radius: 8px;
		background: transparent;
		color: var(--chat-muted);
		cursor: pointer;
		transition: background 160ms ease, color 160ms ease;
	}

	.chat-widget__icon-btn:hover {
		background: color-mix(in srgb, var(--chat-text) 8%, transparent);
		color: var(--chat-text);
	}

	.chat-widget__icon-btn:focus-visible {
		outline: 2px solid var(--chat-accent);
		outline-offset: 1px;
	}

	.chat-widget__icon-btn svg {
		width: 1.05rem;
		height: 1.05rem;
	}

	.chat-widget__icon--muted {
		display: none;
	}

	.chat-widget.is-muted .chat-widget__icon--sound {
		display: none;
	}

	.chat-widget.is-muted .chat-widget__icon--muted {
		display: block;
	}

	/* ═══ Messages ═══ */
	.chat-widget__messages {
		flex: 1;
		overflow-y: auto;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		min-height: 260px;
		scrollbar-width: thin;
		scrollbar-color: var(--chat-border) transparent;
	}

	.chat-widget__messages::-webkit-scrollbar {
		width: 8px;
	}

	.chat-widget__messages::-webkit-scrollbar-thumb {
		background: var(--chat-border);
		border-radius: 999px;
	}

	.chat-msg {
		display: flex;
		max-width: 90%;
		animation: chatMsgIn 240ms ease-out both;
	}

	@media (prefers-reduced-motion: reduce) {
		.chat-msg,
		.chat-widget.is-open .chat-widget__panel,
		.chat-widget__nudge {
			animation: none;
		}
	}

	.chat-msg--user {
		align-self: flex-end;
	}

	.chat-msg--assistant {
		align-self: flex-start;
	}

	.chat-msg__body {
		padding: 0.6rem 0.85rem;
		border-radius: 16px;
		font-size: 0.875rem;
		line-height: 1.55;
		word-break: break-word;
	}

	.chat-msg--user .chat-msg__body {
		background: var(--chat-accent);
		color: var(--chat-accent-ink);
		border-bottom-right-radius: 5px;
	}

	.chat-msg--assistant .chat-msg__body {
		background: var(--chat-bubble);
		color: var(--chat-bubble-ink);
		border-bottom-left-radius: 5px;
	}

	.chat-msg__body p {
		margin: 0 0 0.45rem;
	}

	.chat-msg__body p:last-child {
		margin-bottom: 0;
	}

	.chat-msg__body ul {
		margin: 0.35rem 0;
		padding-left: 1.1rem;
	}

	.chat-msg__body li {
		margin-bottom: 0.2rem;
	}

	.chat-msg__body strong {
		font-weight: 700;
	}

	/* Inline link pill */
	.chat-msg__link {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.12rem 0.5rem;
		margin: 0.05rem 0;
		border-radius: 999px;
		background: color-mix(in srgb, var(--chat-accent) 12%, transparent);
		color: var(--chat-link);
		font-weight: 600;
		text-decoration: none;
		line-height: 1.4;
		transition: background 160ms ease, color 160ms ease;
	}

	.chat-msg__link::after {
		content: '→';
		font-size: 0.85em;
		opacity: 0.7;
	}

	.chat-msg__link:hover {
		background: color-mix(in srgb, var(--chat-accent) 22%, transparent);
		color: var(--chat-link);
	}

	.chat-msg--user .chat-msg__link {
		background: color-mix(in srgb, #ffffff 22%, transparent);
		color: var(--chat-accent-ink);
	}

	/* Rich action card for standalone links */
	.chat-msg__card {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		margin: 0.45rem 0 0.1rem;
		padding: 0.65rem 0.75rem;
		border: 1px solid color-mix(in srgb, var(--chat-accent) 30%, var(--chat-border));
		border-radius: 12px;
		background: color-mix(in srgb, var(--chat-accent) 8%, var(--chat-surface));
		text-decoration: none;
		transition: background 160ms ease, border-color 160ms ease, transform 140ms ease;
	}

	.chat-msg__card:hover {
		background: color-mix(in srgb, var(--chat-accent) 14%, var(--chat-surface));
		border-color: color-mix(in srgb, var(--chat-accent) 48%, var(--chat-border));
		transform: translateY(-1px);
	}

	.chat-msg__card-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 2rem;
		height: 2rem;
		border-radius: 8px;
		background: var(--chat-accent);
		color: var(--chat-accent-ink);
	}

	.chat-msg__card-icon svg {
		width: 1.05rem;
		height: 1.05rem;
	}

	.chat-msg__card-text {
		display: flex;
		flex-direction: column;
		gap: 0.05rem;
		min-width: 0;
		flex: 1;
	}

	.chat-msg__card-title {
		color: var(--chat-text);
		font-size: 0.85rem;
		font-weight: 700;
		line-height: 1.25;
	}

	.chat-msg__card-sub {
		color: var(--chat-muted);
		font-size: 0.74rem;
		line-height: 1.3;
	}

	.chat-msg__card-arrow {
		flex-shrink: 0;
		color: var(--chat-link);
		font-size: 1rem;
		transition: transform 160ms ease;
	}

	.chat-msg__card:hover .chat-msg__card-arrow {
		transform: translateX(3px);
	}

	.chat-msg__typing {
		display: inline-flex;
		gap: 0.22rem;
		padding: 0.15rem 0;
	}

	.chat-msg__typing span {
		width: 0.42rem;
		height: 0.42rem;
		border-radius: 50%;
		background: var(--chat-muted);
		animation: chatTyping 1.2s ease-in-out infinite;
	}

	.chat-msg__typing span:nth-child(2) { animation-delay: 0.15s; }
	.chat-msg__typing span:nth-child(3) { animation-delay: 0.3s; }

	@keyframes chatTyping {
		0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
		30% { opacity: 1; transform: translateY(-3px); }
	}

	@keyframes chatMsgIn {
		from { opacity: 0; transform: translateY(6px); }
		to { opacity: 1; transform: translateY(0); }
	}

	/* ═══ Quick replies ═══ */
	.chat-widget__quick {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		padding: 0 1rem 0.5rem;
	}

	.chat-widget__quick-chip {
		padding: 0.4rem 0.75rem;
		border: 1px solid var(--chat-border);
		border-radius: 999px;
		background: var(--chat-surface);
		color: var(--chat-link);
		font-family: inherit;
		font-size: 0.8rem;
		font-weight: 600;
		line-height: 1.2;
		cursor: pointer;
		transition: background 160ms ease, border-color 160ms ease, transform 120ms ease;
	}

	.chat-widget__quick-chip:hover {
		background: color-mix(in srgb, var(--chat-accent) 10%, var(--chat-surface));
		border-color: color-mix(in srgb, var(--chat-accent) 40%, var(--chat-border));
	}

	.chat-widget__quick-chip:active {
		transform: scale(0.96);
	}

	.chat-widget__quick-chip:focus-visible {
		outline: 2px solid var(--chat-accent);
		outline-offset: 1px;
	}

	/* ═══ Composer ═══ */
	.chat-widget__form {
		display: flex;
		gap: 0.5rem;
		padding: 0.75rem 1rem;
		border-top: 1px solid var(--chat-border);
		background: var(--chat-surface-2);
	}

	.chat-widget__input {
		flex: 1;
		min-width: 0;
		min-height: 2.5rem;
		padding: 0.55rem 0.85rem;
		border: 1px solid var(--chat-border);
		border-radius: 999px;
		background: var(--chat-surface);
		color: var(--chat-text);
		font-size: 0.875rem;
		font-family: inherit;
		outline: none;
		transition: border-color 160ms ease, box-shadow 160ms ease;
	}

	.chat-widget__input:focus-visible {
		border-color: var(--chat-accent);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--chat-accent) 22%, transparent);
	}

	.chat-widget__input::placeholder {
		color: var(--chat-muted);
		opacity: 0.8;
	}

	.chat-widget__send {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border: none;
		border-radius: 50%;
		background: var(--chat-accent);
		color: var(--chat-accent-ink);
		cursor: pointer;
		flex-shrink: 0;
