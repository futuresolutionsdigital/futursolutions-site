---
import { templateSystems, foundationPalette } from '../data/templates';

const featuredDemos = templateSystems;
const newDemoSlugs = new Set(['premium-wellness-clinic', 'hormone-trt']);
---

<section id="demos" class="section section-tight demo-library" aria-labelledby="demo-library-heading">
	<div class="site-container site-container--wide">
		<header class="demo-library__head">
			<div class="demo-library__head-left">
				<p class="eyebrow">Website Foundations · Live demos</p>
				<h2 id="demo-library-heading" class="display-lg">
					Walk through live website Foundations built for real healthcare business&nbsp;models.
				</h2>
			</div>
			<div class="demo-library__head-right">
				<p>
					Each Foundation is a real, clickable website — not a screenshot or Figma file. Use one as a strategic starting point, or treat it as proof of the system quality behind a Signature Custom build.
				</p>
				<a class="demo-library__head-cta" href="/templates">
					Browse all Foundations
					<span aria-hidden="true">&rarr;</span>
				</a>
			</div>
		</header>

		<ul class="demo-library__signals" aria-label="What each Foundation is">
			<li>
				<span class="demo-library__signals-dot demo-library__signals-dot--live" aria-hidden="true"></span>
				<span><strong>Live and clickable.</strong> Real working sites, not mockups.</span>
			</li>
			<li>
				<span class="demo-library__signals-dot demo-library__signals-dot--strategic" aria-hidden="true"></span>
				<span><strong>Strategic, not generic.</strong> Built around a specific business model.</span>
			</li>
			<li>
				<span class="demo-library__signals-dot demo-library__signals-dot--custom" aria-hidden="true"></span>
				<span><strong>Customizable for your brand.</strong> Services, content, booking, branding.</span>
			</li>
		</ul>

		<div class="demo-library__grid">
			{
				featuredDemos.map((template, index) => {
					const palette = foundationPalette[template.slug];
					const styleVars = palette
						? `--demo-accent:${palette.accent};--demo-tint:${palette.tint};--demo-ink:${palette.ink};`
						: undefined;
					return (
						<article
							class:list={[
								'demo-card',
								{
									'demo-card--vt': template.slug === 'hormone-trt',
								},
							]}
							style={styleVars}
						>
							<a class="demo-card__link" href={template.detailUrl} aria-label={`View details for the ${template.name} Foundation`} />

							<div class="demo-card__media" aria-hidden="true">
								{template.slug === 'hormone-trt' ? (
									<div class="vt-prev">
										<div class="vt-prev__chrome">
											<span class="vt-prev__dot" />
											<span class="vt-prev__dot" />
											<span class="vt-prev__dot" />
											<span class="vt-prev__live">
												<span class="vt-prev__live-dot"></span>
												LIVE
											</span>
											<span class="vt-prev__label">VANTAGE</span>
										</div>
										<div class="vt-prev__screen">
											<div class="vt-prev__rule" />
											<div class="vt-prev__hero-block">
												<span class="vt-prev__tag">MEN'S HEALTH / TRT</span>
												<span class="vt-prev__headline" />
												<span class="vt-prev__headline vt-prev__headline--short" />
												<span class="vt-prev__cta">START ASSESSMENT</span>
											</div>
											<div class="vt-prev__stats">
												<div style="height:55%" />
												<div style="height:80%" />
												<div style="height:40%" />
												<div style="height:65%" />
											</div>
											<div class="vt-prev__diagonal" />
										</div>
									</div>
								) : (
									<div class="demo-card__mockup">
										<div class="demo-card__topbar">
											<span />
											<span />
											<span />
											<span class="demo-card__topbar-live" aria-hidden="true">
												<span class="demo-card__topbar-live-dot"></span>
												LIVE
											</span>
											<span class="demo-card__topbar-label">{template.category}</span>
										</div>
										<div class="demo-card__screen">
											<div class="demo-card__lines">
												<span class="demo-card__tag" />
												<span class="demo-card__headline" />
												<span class="demo-card__sub" />
												<span class="demo-card__cta-pill" />
											</div>
											<div class={`demo-card__panel demo-card__panel--${index + 1}`}>
												<span class="demo-card__panel-bar demo-card__panel-bar--a" />
												<span class="demo-card__panel-bar demo-card__panel-bar--b" />
												<span class="demo-card__panel-bar demo-card__panel-bar--c" />
											</div>
											<div class="demo-card__tiles">
												<span />
												<span />
												<span />
											</div>
										</div>
									</div>
								)}
							</div>

							<div class="demo-card__body">
								<div class="demo-card__meta">
									<span class="lane-chip lane-chip--foundation">Foundation</span>
									<span class="demo-card__category">{template.category}</span>
									{newDemoSlugs.has(template.slug) && (
										<span class="demo-card__badge">New</span>
									)}
								</div>
								<h3 class="demo-card__title">{template.name}</h3>
								<p class="demo-card__desc">{template.shortDescription}</p>
								<ul class="demo-card__tags" aria-label={`${template.name} feature tags`}>
									{template.features.slice(0, 3).map((feature) => (
										<li>{feature}</li>
									))}
								</ul>
								<div class="demo-card__actions">
									{template.demoUrl ? (
										<a class="demo-card__primary" href={template.demoUrl}>
											View Live Demo
											<span aria-hidden="true">&rarr;</span>
										</a>
									) : (
										<span class="demo-card__pending">Demo coming soon</span>
									)}
									<a class="demo-card__secondary" href={template.detailUrl}>See Foundation Details</a>
									<a class="demo-card__tertiary" href={template.auditUrl}>
										Get This Foundation Customized
										<span aria-hidden="true">&rarr;</span>
									</a>
								</div>
							</div>
						</article>
					);
				})
			}
		</div>
	</div>
</section>

<style>
	.demo-library {
		background: var(--color-bg-secondary);
		border-block: 1px solid var(--color-border-soft);
	}

	.demo-library__head {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: end;
		margin-bottom: clamp(2.5rem, 4vw, 3.5rem);
	}

	.demo-library__head h2 {
		max-width: 18ch;
		margin-bottom: 0;
	}

	.demo-library__head-right {
		display: grid;
		gap: 1rem;
		justify-items: start;
	}

	.demo-library__head-right p {
		max-width: 36ch;
		margin: 0;
		color: var(--color-muted);
		font-size: 1rem;
		line-height: 1.6;
	}

	.demo-library__head-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 650;
		transition: gap var(--transition-base);
	}

	.demo-library__head-cta:hover {
		gap: 0.55rem;
	}

	.demo-library__head-cta span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.demo-library__head-cta:hover span {
		transform: translateX(2px);
	}

	.demo-library__signals {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.5rem;
		margin: 0 0 clamp(2rem, 3.5vw, 2.5rem) 0;
		padding: 0.85rem 1rem;
		border: 1px solid var(--color-border-soft);
		border-radius: var(--radius-md);
		background: var(--color-white);
		list-style: none;
	}

	.demo-library__signals li {
		display: flex;
		align-items: flex-start;
		gap: 0.6rem;
		padding: 0.35rem 0.5rem;
		color: var(--color-muted);
		font-size: 0.88rem;
		line-height: 1.5;
	}

	.demo-library__signals strong {
		display: block;
		color: var(--color-text);
		font-weight: 700;
		letter-spacing: -0.005em;
	}

	.demo-library__signals-dot {
		flex-shrink: 0;
		display: inline-block;
		width: 0.55rem;
		height: 0.55rem;
		margin-top: 0.45rem;
		border-radius: 999px;
	}

	.demo-library__signals-dot--live {
		background: var(--lane-foundation);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--lane-foundation) 24%, transparent);
	}

	.demo-library__signals-dot--strategic {
		background: var(--lane-custom);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--lane-custom) 18%, transparent);
	}

	.demo-library__signals-dot--custom {
		background: var(--lane-audit);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--lane-audit) 24%, transparent);
	}

	.demo-library__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.demo-card {
		position: relative;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: var(--shadow-card);
		transition: transform 320ms var(--ease-out-quart),
			border-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.demo-card:hover {
		transform: translateY(-3px);
		border-color: color-mix(in srgb, var(--color-text) 22%, var(--color-border));
		box-shadow: var(--shadow-card-hover);
	}

	.demo-card__link {
		position: absolute;
		inset: 0;
		z-index: 1;
		content: '';
	}

	.demo-card__media {
		position: relative;
		z-index: 0;
		padding: 0.85rem 0.85rem 0;
		border-bottom: 1px solid var(--color-border);
	}

	.demo-card__mockup {
		overflow: hidden;
		border: 1px solid var(--color-border);
		border-radius: 12px 12px 0 0;
		background: var(--color-bg);
	}

	.demo-card__topbar {
		display: flex;
		gap: 0.34rem;
		align-items: center;
		padding: 0.55rem 0.7rem;
		background: var(--color-white);
		border-bottom: 1px solid var(--color-border-soft);
	}

	.demo-card__topbar span:not(.demo-card__topbar-label) {
		width: 0.4rem;
		height: 0.4rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-muted) 30%, var(--color-white));
	}

	.demo-card__topbar-label {
		margin-left: 0.4rem;
		font-size: 0.52rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		color: var(--demo-ink, var(--color-muted));
		text-transform: uppercase;
		opacity: 0.6;
	}

	.demo-card__topbar-live {
		margin-left: auto;
		display: inline-flex;
		align-items: center;
		gap: 0.28rem;
		padding: 0.18rem 0.42rem;
		border: 1px solid color-mix(in srgb, var(--lane-foundation) 32%, var(--color-border-soft));
		border-radius: 999px;
		background: color-mix(in srgb, var(--lane-foundation-tint) 80%, var(--color-white));
		color: var(--lane-foundation-ink);
		font-size: 0.5rem;
		font-weight: 800;
		letter-spacing: 0.16em;
	}

	.demo-card__topbar-live-dot {
		display: inline-block;
		width: 5px;
		height: 5px;
		border-radius: 999px;
		background: var(--lane-foundation);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--lane-foundation) 22%, transparent);
		animation: demo-live-pulse 2.4s ease-in-out infinite;
	}

	@keyframes demo-live-pulse {
		0%, 100% { opacity: 1; box-shadow: 0 0 0 3px color-mix(in srgb, var(--lane-foundation) 22%, transparent); }
		50%      { opacity: 0.78; box-shadow: 0 0 0 5px color-mix(in srgb, var(--lane-foundation) 8%, transparent); }
	}

	@media (prefers-reduced-motion: reduce) {
		.demo-card__topbar-live-dot { animation: none; }
	}

	.demo-card__screen {
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		gap: 0.75rem;
		min-height: 180px;
		padding: 1rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.7), transparent 65%),
			var(--demo-tint, var(--color-bg));
	}

	.demo-card__lines {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		justify-content: center;
	}

	.demo-card__tag {
		display: block;
		width: 32%;
		height: 0.5rem;
		border-radius: 2px;
		background: var(--demo-accent, var(--color-accent));
		opacity: 0.7;
	}

	.demo-card__headline {
		display: block;
		width: 86%;
		height: 0.85rem;
		border-radius: 3px;
		background: color-mix(in srgb, var(--color-text) 75%, transparent);
	}

	.demo-card__sub {
		display: block;
		width: 64%;
		height: 0.55rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-text) 28%, var(--color-border));
	}

	.demo-card__cta-pill {
		display: block;
		width: 44%;
		height: 0.8rem;
		margin-top: 0.15rem;
		border-radius: 4px;
		background: var(--demo-accent, var(--color-accent));
	}

	.demo-card__panel {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		gap: 0.32rem;
		min-height: 108px;
		padding: 0.6rem;
		border: 1px solid color-mix(in srgb, var(--demo-accent, var(--color-accent)) 35%, var(--color-border));
		border-radius: 12px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0)),
			color-mix(in srgb, var(--demo-tint, var(--color-accent-light)) 80%, var(--color-white));
	}

	.demo-card__panel-bar {
		display: block;
		height: 0.4rem;
		border-radius: 999px;
		background: var(--demo-accent, var(--color-accent));
	}

	.demo-card__panel-bar--a { width: 80%; opacity: 0.85; }
	.demo-card__panel-bar--b { width: 60%; opacity: 0.6; }
	.demo-card__panel-bar--c { width: 45%; opacity: 0.35; }

	/* Subtle per-template panel layout signatures so each preview reads
	   differently at a glance, even though the structure is shared. */
	.demo-card__panel--1 { justify-content: space-between; }
	.demo-card__panel--2 { justify-content: center; align-items: flex-start; }
	.demo-card__panel--3 { align-items: center; }
	.demo-card__panel--4 { justify-content: flex-end; }

	.demo-card__tiles {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.5rem;
	}

	.demo-card__tiles span {
		min-height: 2.1rem;
		border: 1px solid color-mix(in srgb, var(--demo-accent, var(--color-accent)) 18%, var(--color-border-soft));
		border-radius: 10px;
		background: var(--color-white);
	}

	.demo-card__tiles span:first-child {
		background: color-mix(in srgb, var(--demo-tint, var(--color-accent-light)) 70%, var(--color-white));
	}

	.demo-card__body {
		position: relative;
		z-index: 2;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 1.35rem;
	}

	.demo-card__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
	}

	.demo-card__category {
		color: var(--color-muted);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.demo-card__badge {
		margin-left: auto;
		padding: 0.18rem 0.5rem;
		border-radius: 999px;
		background: var(--color-text);
		color: var(--color-white);
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.demo-card__title {
		margin: 0;
		font-size: 1.25rem;
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.2;
	}

	.demo-card__desc {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.93rem;
		line-height: 1.55;
	}

	.demo-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin: 0.4rem 0 0 0;
		padding: 0;
		list-style: none;
	}

	.demo-card__tags li {
		padding: 0.3rem 0.55rem;
		border: 1px solid var(--color-border-soft);
		border-radius: 999px;
		background: var(--color-bg-secondary);
		color: var(--color-muted);
		font-size: 0.74rem;
		font-weight: 500;
		line-height: 1;
	}

	.demo-card__actions {
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-areas:
			'primary primary'
			'secondary tertiary';
		gap: 0.85rem 0.9rem;
		align-items: center;
		margin-top: 1rem;
		padding-top: 1.05rem;
		border-top: 1px solid var(--color-border-soft);
	}

	.demo-card__primary {
		grid-area: primary;
		position: relative;
		z-index: 2;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		width: 100%;
		min-height: 2.65rem;
		padding: 0.7rem 1.1rem;
		border: 1px solid var(--color-text);
		border-radius: var(--radius-sm);
		background: var(--color-text);
		color: var(--color-white);
		font-size: 0.93rem;
		font-weight: 700;
		letter-spacing: -0.005em;
		transition: gap var(--transition-base),
			background var(--transition-base),
			border-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.demo-card__primary:hover {
		gap: 0.7rem;
		background: var(--color-ink);
		border-color: var(--color-ink);
		box-shadow: 0 6px 18px color-mix(in srgb, var(--color-ink) 24%, transparent);
	}

	.demo-card__primary span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.demo-card__primary:hover span {
		transform: translateX(3px);
	}

	.demo-card__secondary {
		grid-area: secondary;
		position: relative;
		z-index: 2;
		color: var(--color-muted);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: -0.005em;
		transition: color var(--transition-base);
	}

	.demo-card__secondary:hover {
		color: var(--demo-ink, var(--color-text));
	}

	.demo-card__tertiary {
		grid-area: tertiary;
		position: relative;
		z-index: 2;
		justify-self: end;
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		color: var(--lane-audit-ink);
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: -0.005em;
		transition: color var(--transition-base), gap var(--transition-base);
	}

	.demo-card__tertiary:hover {
		color: var(--color-text);
		gap: 0.45rem;
	}

	.demo-card__tertiary span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.demo-card__tertiary:hover span {
		transform: translateX(2px);
	}

	.demo-card__pending {
		grid-area: primary;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: 2.65rem;
		padding: 0.7rem 1.1rem;
		border: 1px dashed var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
		color: var(--color-muted);
		font-size: 0.85rem;
		font-style: italic;
	}

	/* VANTAGE preview variant — inherited from the previous template preview */
	.demo-card--vt {
		border-color: rgba(200, 30, 30, 0.22);
	}

	.demo-card--vt .demo-card__media {
		padding: 0;
		border-bottom: none;
	}

	.vt-prev {
		background: #111;
		border-radius: 0;
	}

	.vt-prev__chrome {
		display: flex;
		gap: 0.35rem;
		align-items: center;
		padding: 0.6rem 0.8rem;
		background: #0a0a0a;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.vt-prev__dot {
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: #c81e1e;
		opacity: 0.6;
	}

	.vt-prev__label {
		margin-left: 0.4rem;
		font-size: 0.48rem;
		font-weight: 800;
		letter-spacing: 0.18em;
		color: rgba(244, 239, 231, 0.2);
		text-transform: uppercase;
	}

	.vt-prev__live {
		margin-left: auto;
		display: inline-flex;
		align-items: center;
		gap: 0.28rem;
		padding: 0.18rem 0.42rem;
		border: 1px solid rgba(200, 30, 30, 0.4);
		border-radius: 999px;
		background: rgba(200, 30, 30, 0.12);
		color: #f4efe7;
		font-size: 0.46rem;
		font-weight: 800;
		letter-spacing: 0.16em;
	}

	.vt-prev__live-dot {
