---
import type { TemplateSystem } from '../data/templates';

interface Props {
	template: TemplateSystem;
}

const { template } = Astro.props;

const glance = template.atAGlance;
const isVantage = template.slug === 'hormone-trt';

const items = glance
	? [
			{ label: 'Best for', value: glance.bestFor, icon: 'audience' },
			{ label: 'Primary goal', value: glance.primaryGoal, icon: 'target' },
			{ label: 'Includes', value: glance.includes, icon: 'pages' },
			{ label: 'Typical path', value: glance.typicalPath, icon: 'path' },
		]
	: [];
---

{
	glance && (
		<section class:list={['section', 'foundation-glance', { 'foundation-glance--vantage': isVantage }]} aria-labelledby="foundation-glance-heading">
			<div class="site-container">
				<div class="foundation-glance__panel">
					<div class="foundation-glance__left">
						<header class="foundation-glance__head">
							<p class="eyebrow">At a glance</p>
							<h2 id="foundation-glance-heading" class="foundation-glance__heading">
								This Foundation in 30&nbsp;seconds.
							</h2>
						</header>

						<dl class="foundation-glance__grid">
							{items.map((item) => (
								<div class="foundation-glance__item">
									<dt class="foundation-glance__label">
										<span class="foundation-glance__icon" aria-hidden="true">
											{item.icon === 'audience' && (
												<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
													<circle cx="7.5" cy="7.5" r="3" />
													<path d="M2.5 16c.6-2.5 2.7-4 5-4s4.4 1.5 5 4" />
													<circle cx="14.5" cy="6" r="2.2" />
													<path d="M12.8 11.5c1.6.4 2.9 1.7 3.7 3.6" />
												</svg>
											)}
											{item.icon === 'target' && (
												<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
													<circle cx="10" cy="10" r="7" />
													<circle cx="10" cy="10" r="3.5" />
													<circle cx="10" cy="10" r="1" fill="currentColor" stroke="none" />
												</svg>
											)}
											{item.icon === 'pages' && (
												<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
													<rect x="3.5" y="2.5" width="10" height="13" rx="1.5" />
													<rect x="6.5" y="5.5" width="10" height="13" rx="1.5" />
												</svg>
											)}
											{item.icon === 'path' && (
												<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
													<circle cx="4" cy="4" r="1.5" />
													<circle cx="16" cy="10" r="1.5" />
													<circle cx="4" cy="16" r="1.5" />
													<path d="M5.4 4.5h6.4a2 2 0 0 1 2 2v2.4" />
													<path d="M14.6 11.5H8.2a2 2 0 0 0-2 2V16" />
												</svg>
											)}
										</span>
										{item.label}
									</dt>
									<dd class="foundation-glance__value">{item.value}</dd>
								</div>
							))}
						</dl>
					</div>

					<div class="foundation-glance__right">
						<div class="foundation-glance__signals" aria-label="Foundation guarantees">
							<span class="foundation-glance__signal">
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M3 8.5l3 3 7-7" />
								</svg>
								Live and clickable
							</span>
							<span class="foundation-glance__signal">
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M3 8.5l3 3 7-7" />
								</svg>
								Fully customizable
							</span>
							<span class="foundation-glance__signal">
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M3 8.5l3 3 7-7" />
								</svg>
								Growth System ready
							</span>
						</div>

						<div class="foundation-glance__actions">
							{template.demoUrl ? (
								<a class="button button-primary foundation-glance__btn-primary" href={template.demoUrl}>
									View Live Demo
									<span aria-hidden="true">&rarr;</span>
								</a>
							) : (
								<span class="foundation-glance__pending">Demo coming soon</span>
							)}
							<a class="button button-secondary" href={template.auditUrl}>
								Get This Customized
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>
	)
}

<style>
	.foundation-glance {
		position: relative;
		background:
			linear-gradient(180deg, var(--color-white) 0%, color-mix(in srgb, var(--foundation-tint, var(--lane-foundation-tint)) 70%, var(--color-white)) 100%);
		border-block: 1px solid color-mix(in srgb, var(--foundation-accent, var(--lane-foundation)) 16%, var(--color-border-soft));
	}

	.foundation-glance__panel {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: clamp(2rem, 4vw, 3.5rem);
		padding: clamp(2rem, 4vw, 2.75rem);
		border: 1px solid color-mix(in srgb, var(--foundation-accent, var(--lane-foundation)) 18%, var(--color-border));
		border-radius: var(--radius-xl);
		background: var(--color-white);
		box-shadow: 0 16px 48px rgba(15, 23, 42, 0.05);
	}

	.foundation-glance__head {
		margin: 0 0 clamp(1.25rem, 2.5vw, 1.75rem) 0;
	}

	.foundation-glance__head .eyebrow {
		color: var(--foundation-ink, var(--lane-foundation-ink));
	}

	.foundation-glance__heading {
		margin: 0;
		font-size: clamp(1.55rem, 1.15rem + 1.2vw, 2.1rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.2;
	}

	.foundation-glance__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
		margin: 0;
	}

	.foundation-glance__item {
		display: grid;
		gap: 0.45rem;
		padding: 1.15rem 1.2rem;
		border: 1px solid color-mix(in srgb, var(--foundation-accent, var(--lane-foundation)) 14%, var(--color-border-soft));
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--foundation-tint, var(--lane-foundation-tint)) 40%, var(--color-white));
	}

	.foundation-glance__label {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		margin: 0;
		color: var(--foundation-ink, var(--lane-foundation-ink));
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.foundation-glance__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		border: 1px solid color-mix(in srgb, var(--foundation-accent, var(--lane-foundation)) 26%, var(--color-border-soft));
		border-radius: 10px;
		background: color-mix(in srgb, var(--foundation-tint, var(--lane-foundation-tint)) 85%, var(--color-white));
		color: var(--foundation-ink, var(--lane-foundation-ink));
	}

	.foundation-glance__icon svg {
		width: 1.1rem;
		height: 1.1rem;
	}

	.foundation-glance__value {
		margin: 0;
		color: var(--color-text);
		font-size: 0.93rem;
		font-weight: 500;
		line-height: 1.5;
	}

	.foundation-glance__right {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1.75rem;
	}

	.foundation-glance__signals {
		display: grid;
		gap: 0.7rem;
	}

	.foundation-glance__signal {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		color: var(--color-text);
		font-size: 0.92rem;
		font-weight: 650;
	}

	.foundation-glance__signal svg {
		flex-shrink: 0;
		width: 1.1rem;
		height: 1.1rem;
		color: var(--foundation-accent, var(--lane-foundation));
	}

	.foundation-glance__actions {
		display: grid;
		gap: 0.65rem;
	}

	.foundation-glance__btn-primary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
	}

	.foundation-glance__btn-primary span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.foundation-glance__btn-primary:hover span {
		transform: translateX(2px);
	}

	.foundation-glance__pending {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.6rem 0.9rem;
		border: 1px dashed var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
		color: var(--color-muted);
		font-size: 0.88rem;
		font-style: italic;
	}

	/* ═══ VANTAGE (dark) overrides ═══ */
	.foundation-glance--vantage {
		background: #111;
		border-color: rgba(200, 30, 30, 0.12);
	}

	.foundation-glance--vantage .foundation-glance__panel {
		background: #141414;
		border-color: rgba(200, 30, 30, 0.14);
		box-shadow: 0 16px 48px rgba(0, 0, 0, 0.35);
	}

	.foundation-glance--vantage .foundation-glance__head .eyebrow {
		color: #B82020;
	}

	.foundation-glance--vantage .foundation-glance__heading {
		color: #f4efe7;
	}

	.foundation-glance--vantage .foundation-glance__item {
		background: rgba(255, 255, 255, 0.03);
		border-color: rgba(255, 255, 255, 0.06);
	}

	.foundation-glance--vantage .foundation-glance__label {
		color: #B82020;
	}

	.foundation-glance--vantage .foundation-glance__icon {
		background: rgba(200, 30, 30, 0.08);
		border-color: rgba(200, 30, 30, 0.16);
		color: #C81E1E;
	}

	.foundation-glance--vantage .foundation-glance__value {
		color: rgba(244, 239, 231, 0.78);
	}

	.foundation-glance--vantage .foundation-glance__signal {
		color: rgba(244, 239, 231, 0.82);
	}

	.foundation-glance--vantage .foundation-glance__signal svg {
		color: #C81E1E;
	}

	.foundation-glance--vantage .button-primary {
		background: #C81E1E;
		border-color: #C81E1E;
		color: #f4efe7;
	}

	.foundation-glance--vantage .button-primary:hover {
		background: #a81a1a;
		border-color: #a81a1a;
	}

	.foundation-glance--vantage .button-secondary {
		background: transparent;
		border-color: rgba(244, 239, 231, 0.16);
		color: #f4efe7;
	}

	.foundation-glance--vantage .button-secondary:hover {
		background: rgba(244, 239, 231, 0.05);
		border-color: rgba(244, 239, 231, 0.3);
	}

	@media (max-width: 900px) {
		.foundation-glance__panel {
			grid-template-columns: 1fr;
		}

		.foundation-glance__right {
			gap: 1.25rem;
		}
	}

	@media (max-width: 560px) {
		.foundation-glance__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
