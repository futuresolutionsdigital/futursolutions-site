---
const filters = ['All', 'Med Spa', 'Solo Practice', 'Association', 'Booking', 'Local SEO', 'Backend Ready'];
---

<div class="template-filter-bar" aria-label="Template filters">
	{filters.map((filter, index) => (
		<span class={index === 0 ? 'is-active' : undefined}>
			{filter}
		</span>
	))}
</div>

<style>
	.template-filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 2rem;
	}

	.template-filter-bar span {
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-white);
		color: var(--color-muted);
		font-size: 0.875rem;
		font-weight: 700;
		line-height: 1;
	}

	.template-filter-bar .is-active {
		border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border));
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
	}
</style>
