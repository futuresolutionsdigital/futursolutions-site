---
// "What we check before recommending anything" — a diagnostic checklist
// grouped into three buckets (Clarity / Conversion / Systems). No fake scores
// or percentages; it reads like the report a visitor will actually receive.
const buckets = [
	{
		lane: 'foundation',
		name: 'Clarity',
		items: [
			{ title: 'Positioning', text: 'Can visitors quickly understand who you help and what you offer?' },
			{ title: 'Service structure', text: 'Are services organized around visitor intent, not internal categories?' },
			{ title: 'Messaging', text: 'Does the copy explain benefits, objections, and next steps clearly?' },
		],
	},
	{
		lane: 'growth',
		name: 'Conversion',
		items: [
			{ title: 'CTA path', text: 'Are calls-to-action visible, consistent, and easy to act on?' },
			{ title: 'Trust signals', text: 'Are reviews, credentials, FAQs, and proof placed near decisions?' },
			{ title: 'Mobile experience', text: 'Is the experience fast, readable, and easy to use on mobile?' },
		],
	},
	{
		lane: 'audit',
		name: 'Systems',
		items: [
			{ title: 'Local visibility', text: 'Does the site support service-area search and relevant local discovery?' },
			{ title: 'Forms & CRM', text: 'Do inquiries route into a clear lead-handling process?' },
			{ title: 'Tracking & reporting', text: 'Can the business see what is working?' },
		],
	},
];
---

<section class="section audit-scope" aria-labelledby="audit-scope-heading">
	<div class="site-container site-container--wide">
		<header class="audit-scope__head">
			<div class="audit-scope__head-left">
				<p class="eyebrow">The audit</p>
				<h2 id="audit-scope-heading" class="display-lg">What we check before recommending anything.</h2>
			</div>
			<p class="audit-scope__head-copy">
				The audit reviews the parts of your website that most directly affect clarity, trust, conversion, local visibility, and follow-up — then shows you what to fix first.
			</p>
		</header>

		<div class="audit-scope__buckets" aria-label="What the audit reviews, grouped into three areas">
			{
				buckets.map((bucket) => (
					<div class={`audit-scope__bucket lane-accent-top lane-accent-top--${bucket.lane}`}>
						<div class="audit-scope__bucket-head">
							<span class={`lane-tag lane-tag--${bucket.lane}`}>{bucket.name}</span>
						</div>
						<ul class="audit-scope__list">
							{bucket.items.map((item) => (
								<li class="audit-scope__item">
									<span class="audit-scope__check" aria-hidden="true">
										<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="3,8.5 6.5,12 13,4" />
										</svg>
									</span>
									<div class="audit-scope__item-body">
										<span class="audit-scope__item-title">{item.title}</span>
										<span class="audit-scope__item-text">{item.text}</span>
									</div>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>

		<div class="audit-scope__cta">
			<p class="audit-scope__cta-text">
				Every audit is reviewed by hand — no automated score, just a written breakdown of where the most value is.
			</p>
			<a class="button button-primary audit-scope__cta-button" href="/audit">
				Request My Website Audit
				<span aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</section>

<style>
	.audit-scope {
		background:
			radial-gradient(ellipse 70% 60% at 100% 0%, color-mix(in srgb, var(--lane-audit-tint) 55%, transparent), transparent 72%),
			var(--color-bg);
		border-block: 1px solid var(--color-border-soft);
	}

	.audit-scope__head {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: end;
		margin-bottom: clamp(2.5rem, 4vw, 3.25rem);
	}

	.audit-scope__head .eyebrow {
		color: var(--lane-audit-ink);
	}

	.audit-scope__head h2 {
		max-width: 18ch;
		margin-bottom: 0;
	}

	.audit-scope__head-copy {
		max-width: 38ch;
		margin: 0;
		color: var(--color-muted);
		font-size: 1rem;
		line-height: 1.6;
	}

	.audit-scope__buckets {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.1rem;
		margin-bottom: clamp(2rem, 4vw, 2.75rem);
	}

	.audit-scope__bucket {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		padding: 1.6rem 1.5rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: var(--shadow-card);
	}

	.audit-scope__bucket.lane-accent-top::before {
		height: 4px;
	}

	.audit-scope__bucket-head {
		display: flex;
		align-items: center;
	}

	.audit-scope__list {
		display: grid;
		gap: 1.1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.audit-scope__item {
		display: flex;
		gap: 0.75rem;
	}

	.audit-scope__check {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 1.6rem;
		height: 1.6rem;
		border-radius: 999px;
		background: var(--lane-audit-tint);
		color: var(--lane-audit-ink);
	}

	.audit-scope__check svg {
		width: 0.9rem;
		height: 0.9rem;
	}

	.audit-scope__item-body {
		display: grid;
		gap: 0.2rem;
		min-width: 0;
	}

	.audit-scope__item-title {
		color: var(--color-text);
		font-size: 0.98rem;
		font-weight: 700;
		letter-spacing: -0.015em;
		line-height: 1.2;
	}

	.audit-scope__item-text {
		color: var(--color-muted);
		font-size: 0.86rem;
		line-height: 1.45;
	}

	.audit-scope__cta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1.25rem 2rem;
		padding: clamp(1.5rem, 3vw, 2rem);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: linear-gradient(135deg, var(--color-white) 0%, var(--lane-audit-tint) 130%);
		box-shadow: var(--shadow-card);
	}

	.audit-scope__cta-text {
		max-width: 44ch;
		margin: 0;
		color: var(--color-text);
		font-size: 1rem;
		font-weight: 500;
		line-height: 1.55;
	}

	.audit-scope__cta-button span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.audit-scope__cta-button:hover span {
		transform: translateX(2px);
	}

	@media (max-width: 1080px) {
		.audit-scope__head {
			grid-template-columns: 1fr;
			align-items: start;
		}

		.audit-scope__buckets {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 560px) {
		.audit-scope__cta-button {
			width: 100%;
		}
	}
</style>
