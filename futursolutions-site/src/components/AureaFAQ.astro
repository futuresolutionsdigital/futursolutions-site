---
import { faqs } from '../data/aurea';
---

<section id="faq" class="aurea-section" aria-labelledby="faq-heading">
	<div class="aurea-container">
		<div class="faq__layout">
			<div class="faq__intro">
				<p class="aurea-eyebrow">FAQ</p>
				<h2 id="faq-heading">Questions we hear most.</h2>
				<p class="aurea-lead">
					If your question isn't answered here, we're happy to discuss it during your consultation.
				</p>
			</div>

			<div class="faq__content">
				<div class="faq__list">
					{faqs.map((faq) => (
						<details class="faq__item">
							<summary>
								<span class="faq__question">{faq.question}</span>
								<span class="faq__icon" aria-hidden="true"></span>
							</summary>
							<div class="faq__answer">
								<p>{faq.answer}</p>
							</div>
						</details>
					))}
				</div>

				<div class="faq__cta">
					<p>Still have questions?</p>
					<a class="aurea-btn aurea-btn--primary" href="/demos/med-spa/contact">Book a Consultation</a>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.faq__layout {
		display: grid;
		grid-template-columns: minmax(0, 0.4fr) minmax(0, 1fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
	}

	.faq__intro {
		position: sticky;
		top: 6rem;
	}

	.faq__list {
		max-width: 640px;
	}

	.faq__item {
		border-bottom: 1px solid var(--aurea-border);
	}

	.faq__item:first-child {
		border-top: 1px solid var(--aurea-border);
	}

	.faq__item summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.35rem 0;
		cursor: pointer;
		list-style: none;
	}

	.faq__item summary::-webkit-details-marker {
		display: none;
	}

	.faq__question {
		font-family: var(--aurea-font-heading);
		font-size: 1.12rem;
		font-weight: 600;
		color: var(--aurea-charcoal);
		line-height: 1.35;
	}

	.faq__icon {
		position: relative;
		flex-shrink: 0;
		width: 1.25rem;
		height: 1.25rem;
	}

	.faq__icon::before,
	.faq__icon::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		background: var(--aurea-champagne);
		border-radius: 2px;
	}

	.faq__icon::before {
		width: 12px;
		height: 2px;
		transform: translate(-50%, -50%);
	}

	.faq__icon::after {
		width: 2px;
		height: 12px;
		transform: translate(-50%, -50%);
		transition: transform 0.2s ease, opacity 0.2s ease;
	}

	.faq__item[open] .faq__icon::after {
		transform: translate(-50%, -50%) rotate(90deg);
		opacity: 0;
	}

	.faq__answer {
		padding-bottom: 1.35rem;
	}

	.faq__answer p {
		max-width: 600px;
		font-size: 0.92rem;
		line-height: 1.65;
		color: var(--aurea-muted);
	}

	.faq__item summary:hover .faq__question {
		color: var(--aurea-champagne);
	}

	.faq__item summary:focus-visible {
		outline: 2px solid var(--aurea-champagne);
		outline-offset: 2px;
		border-radius: 4px;
	}

	.faq__cta {
		margin-top: 2.5rem;
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.faq__cta p {
		font-size: 0.92rem;
		font-weight: 600;
		color: var(--aurea-muted);
		margin: 0;
	}

	@media (max-width: 860px) {
		.faq__layout {
			grid-template-columns: 1fr;
		}

		.faq__intro {
			position: static;
		}
	}
</style>
