---
import DemoBanner from '../components/DemoBanner.astro';
import { brand, announcement, navItems, footerNav, footerServices } from '../data/aster';
import '../styles/global.css';

interface Props { title: string; description: string; canonicalUrl?: string; }
const { title, description, canonicalUrl } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="icon" href="/favicon.ico" />
	<meta name="viewport" content="width=device-width" />
	<meta name="generator" content={Astro.generator} />
	<meta name="description" content={description} />
	{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:type" content="website" />
	{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />
	<title>{title}</title>
</head>
<body class="aster-site">
	<DemoBanner customizeHref="/audit?template=solo-practice" />

	<div class="aster-announce">
		<div class="aster-container aster-announce__inner">
			<p>{announcement}</p>
		</div>
	</div>

	<header class="aster-header" id="aster-header">
		<div class="aster-container aster-header__inner">
			<a class="aster-header__brand" href={brand.homeHref} aria-label="Aster Private Health home">
				<span class="aster-header__wordmark">Aster</span>
				<span class="aster-header__sub">Private Health</span>
			</a>
			<nav class="aster-header__nav" aria-label="Main navigation">
				{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
			</nav>
			<div class="aster-header__actions">
				<a class="aster-header__util" href="#faq">Patient Portal</a>
				<a class="aster-header__cta" href="#pricing">Book Consultation</a>
			</div>
			<button class="aster-header__menu-btn" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="aster-mobile-menu">
				<span></span><span></span><span></span>
			</button>
		</div>
		<nav class="aster-mobile-menu" id="aster-mobile-menu" aria-label="Mobile navigation" hidden>
			<div class="aster-container aster-mobile-menu__inner">
				{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
				<a class="aster-mobile-menu__cta" href="#pricing">Book Consultation</a>
			</div>
		</nav>
	</header>

	<main><slot /></main>

	<footer class="aster-footer">
		<div class="aster-container aster-footer__grid">
			<div class="aster-footer__brand-col">
				<a class="aster-footer__brand" href={brand.homeHref}>Aster Private Health</a>
				<p class="aster-footer__tagline">{brand.tagline}</p>
				<p class="aster-footer__location">{brand.locationLine}<br/>{brand.availability}</p>
			</div>
			<nav class="aster-footer__col" aria-label="Navigation footer links">
				<h2>Navigate</h2>
				<ul>{footerNav.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
			</nav>
			<nav class="aster-footer__col" aria-label="Services footer links">
				<h2>Services</h2>
				<ul>{footerServices.map((s) => <li><a href="#services">{s}</a></li>)}</ul>
			</nav>
			<div class="aster-footer__col">
				<h2>Contact</h2>
				<ul>
					<li><a href="#pricing">Book a Consultation</a></li>
					<li><a href="#faq">Patient Portal</a></li>
					<li>{brand.location}</li>
				</ul>
				<div class="aster-footer__legal">
					<a href="#">Privacy Policy</a>
					<a href="#">Terms</a>
					<a href="#">Accessibility</a>
				</div>
			</div>
		</div>
		<div class="aster-container aster-footer__bottom">
			<p>&copy; {new Date().getFullYear()} {brand.name}. All rights reserved.</p>
			<p class="aster-footer__disclaimer">{brand.disclaimer} Built by <a href="/">FutureSolutions</a>.</p>
		</div>
	</footer>

	<script is:inline>
	(function(){
		var btn=document.querySelector('.aster-header__menu-btn');
		var menu=document.getElementById('aster-mobile-menu');
		if(!btn||!menu)return;
		btn.addEventListener('click',function(){
			var open=menu.hidden;
			menu.hidden=!open;
			btn.setAttribute('aria-expanded',open?'true':'false');
			btn.classList.toggle('is-open',open);
		});
		menu.querySelectorAll('a').forEach(function(a){
			a.addEventListener('click',function(){
				menu.hidden=true;
				btn.setAttribute('aria-expanded','false');
				btn.classList.remove('is-open');
			});
		});
	})();
	</script>
</body>
</html>

<style is:global>
.aster-site {
	--aster-ivory: #fbf7ef;
	--aster-paper: #f4ecdf;
	--aster-ink: #20201d;
	--aster-text: #4a4640;
	--aster-heading: #20201d;
	--aster-muted: #746f66;
	--aster-clay: #a7684d;
	--aster-clay-dark: #8b5239;
	--aster-clay-light: #f3e8e0;
	--aster-aubergine: #4b3346;
	--aster-eucalyptus: #879782;
	--aster-eucalyptus-light: #eef0eb;
	--aster-border: #ded3c4;
	--aster-white: #FFFFFF;
	--aster-radius: 10px;
	--aster-radius-lg: 18px;
	--aster-serif: 'Lora', Georgia, 'Times New Roman', serif;
	--aster-sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	--aster-max-width: 1120px;
	--aster-transition: 0.2s ease;

	margin: 0; min-width: 320px;
	background: var(--aster-ivory); color: var(--aster-text);
	font-family: var(--aster-sans);
	font-size: clamp(1rem, 0.95rem + 0.25vw, 1.0625rem); line-height: 1.7;
	text-rendering: optimizeLegibility;
	-webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
}
.aster-site *, .aster-site *::before, .aster-site *::after { box-sizing: border-box; }
.aster-site img, .aster-site svg { display: block; max-width: 100%; }
.aster-site a { color: inherit; text-decoration: none; transition: color var(--aster-transition), background var(--aster-transition), border-color var(--aster-transition); }

.aster-site h1, .aster-site h2, .aster-site h3 { margin-top: 0; color: var(--aster-heading); letter-spacing: -0.015em; line-height: 1.2; }
.aster-site h1, .aster-site h2 { font-family: var(--aster-serif); font-weight: 500; }
.aster-site h3 { font-family: var(--aster-sans); font-weight: 700; }
.aster-site h1 { font-size: clamp(2.2rem, 1.6rem + 2.5vw, 3.4rem); line-height: 1.12; margin-bottom: 1.25rem; }
.aster-site h2 { font-size: clamp(1.6rem, 1.35rem + 1vw, 2.2rem); margin-bottom: 1rem; }
.aster-site h3 { font-size: clamp(1.05rem, 1rem + 0.25vw, 1.2rem); margin-bottom: 0.5rem; letter-spacing: -0.01em; }
.aster-site p { margin-top: 0; margin-bottom: 1rem; color: var(--aster-text); }
.aster-site p:last-child { margin-bottom: 0; }
.aster-site button, .aster-site input, .aster-site select, .aster-site textarea { font: inherit; }
.aster-site button { cursor: pointer; }
.aster-site :focus-visible { outline: 2px solid var(--aster-clay); outline-offset: 3px; border-radius: 4px; }
.aster-site ::selection { background: var(--aster-clay-light); color: var(--aster-heading); }

.aster-container { width: min(100% - 2rem, var(--aster-max-width)); margin-inline: auto; }
.aster-section { padding-block: clamp(4.5rem, 8vw, 7rem); }
.aster-section--paper { background: var(--aster-paper); border-block: 1px solid var(--aster-border); }
.aster-section--sand { background: var(--aster-paper); border-block: 1px solid var(--aster-border); }
.aster-section--sage-light { background: var(--aster-eucalyptus-light); border-block: 1px solid color-mix(in srgb, var(--aster-eucalyptus) 15%, var(--aster-border)); }
.aster-eyebrow { margin-bottom: 0.6rem; color: var(--aster-clay); font-family: var(--aster-sans); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
.aster-lead { max-width: 600px; color: var(--aster-muted); font-size: clamp(1rem, 0.96rem + 0.2vw, 1.12rem); line-height: 1.7; }

.aster-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 2.85rem; padding: 0.7rem 1.25rem; border: 1px solid transparent; border-radius: 8px; font-size: 0.875rem; font-weight: 600; line-height: 1; white-space: nowrap; transition: background var(--aster-transition), color var(--aster-transition), border-color var(--aster-transition); }
.aster-site .aster-btn--primary { background: var(--aster-clay); color: var(--aster-white); }
.aster-site .aster-btn--primary:hover { background: var(--aster-clay-dark); color: var(--aster-white); }
.aster-site .aster-btn--secondary { border-color: var(--aster-border); background: var(--aster-white); color: var(--aster-heading); }
.aster-site .aster-btn--secondary:hover { border-color: var(--aster-clay); color: var(--aster-clay-dark); }
.aster-btn-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
.aster-card { border: 1px solid var(--aster-border); border-radius: var(--aster-radius); background: var(--aster-white); }

@media (prefers-reduced-motion: reduce) {
	.aster-site *, .aster-site *::before, .aster-site *::after { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
}
</style>

<style>
.aster-announce { background: var(--aster-aubergine); color: rgba(255,255,255,0.85); font-size: 0.75rem; font-weight: 500; letter-spacing: 0.02em; }
.aster-announce__inner { display: flex; align-items: center; justify-content: center; padding-block: 0.5rem; text-align: center; }
.aster-announce p { margin: 0; color: rgba(255,255,255,0.85); }

.aster-header { position: sticky; top: 3.6rem; z-index: 12; border-bottom: 1px solid var(--aster-border); background: color-mix(in srgb, var(--aster-ivory) 92%, transparent); backdrop-filter: blur(16px); }
.aster-header__inner { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; min-height: 4.25rem; }
.aster-header__brand { display: flex; align-items: baseline; gap: 0.4rem; flex-shrink: 0; }
.aster-header__wordmark { font-family: var(--aster-serif); font-size: 1.2rem; font-weight: 600; color: var(--aster-heading); letter-spacing: -0.02em; }
.aster-header__sub { font-size: 0.68rem; font-weight: 600; color: var(--aster-muted); letter-spacing: 0.06em; text-transform: uppercase; }
.aster-header__nav { display: flex; align-items: center; gap: 1.25rem; font-size: 0.82rem; font-weight: 500; color: var(--aster-muted); }
.aster-header__nav a:hover { color: var(--aster-heading); }
.aster-header__actions { display: flex; align-items: center; gap: 0.75rem; }
.aster-header__util { font-size: 0.78rem; font-weight: 600; color: var(--aster-muted); }
.aster-header__util:hover { color: var(--aster-heading); }
.aster-header__cta { display: inline-flex; align-items: center; min-height: 2.1rem; padding: 0.45rem 0.9rem; border-radius: 6px; background: var(--aster-clay); color: var(--aster-white); font-size: 0.78rem; font-weight: 600; line-height: 1; white-space: nowrap; }
.aster-header__cta:hover { background: var(--aster-clay-dark); color: var(--aster-white); }
.aster-header__menu-btn { display: none; flex-direction: column; justify-content: center; gap: 4px; width: 2.5rem; height: 2.5rem; padding: 0.55rem; border: 1px solid var(--aster-border); border-radius: 8px; background: var(--aster-white); }
.aster-header__menu-btn span { display: block; width: 100%; height: 2px; border-radius: 2px; background: var(--aster-heading); transition: transform 0.2s ease, opacity 0.2s ease; }
.aster-header__menu-btn.is-open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
.aster-header__menu-btn.is-open span:nth-child(2) { opacity: 0; }
.aster-header__menu-btn.is-open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

.aster-mobile-menu { border-top: 1px solid var(--aster-border); background: var(--aster-white); }
.aster-mobile-menu__inner { display: grid; gap: 0; padding-block: 0.5rem; }
.aster-mobile-menu__inner a { display: block; padding: 0.75rem 0; font-size: 0.95rem; font-weight: 600; color: var(--aster-heading); border-bottom: 1px solid var(--aster-border); }
.aster-mobile-menu__cta { margin-top: 0.75rem; text-align: center; padding: 0.8rem !important; border: none !important; border-radius: 8px; background: var(--aster-clay); color: var(--aster-white) !important; }

.aster-footer { border-top: 1px solid var(--aster-border); background: var(--aster-aubergine); color: rgba(255,255,255,0.55); }
.aster-footer__grid { display: grid; grid-template-columns: minmax(200px, 1.6fr) repeat(3, minmax(0, 1fr)); gap: clamp(1.5rem, 4vw, 3rem); padding-block: clamp(2.5rem, 5vw, 4rem); }
.aster-footer__brand { display: block; margin-bottom: 0.6rem; font-family: var(--aster-serif); font-size: 1rem; font-weight: 600; color: rgba(255,255,255,0.9); }
.aster-footer__tagline { font-size: 0.82rem; line-height: 1.55; color: rgba(255,255,255,0.4); }
.aster-footer__location { margin-top: 0.5rem; font-size: 0.78rem; line-height: 1.5; color: rgba(255,255,255,0.3); }
.aster-footer__col h2 { margin-bottom: 0.75rem; font-family: var(--aster-sans); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.3); }
.aster-footer__col ul { display: grid; gap: 0.35rem; margin: 0; padding: 0; list-style: none; }
.aster-footer__col a, .aster-footer__col li { font-size: 0.82rem; font-weight: 500; color: rgba(255,255,255,0.5); }
.aster-footer__col a:hover { color: var(--aster-white); }
.aster-footer__legal { display: flex; gap: 0.75rem; margin-top: 0.75rem; }
.aster-footer__legal a { font-size: 0.72rem; color: rgba(255,255,255,0.3); }
.aster-footer__legal a:hover { color: rgba(255,255,255,0.55); }
.aster-footer__bottom { padding-block: 1.15rem; border-top: 1px solid rgba(255,255,255,0.06); }
.aster-footer__bottom p { margin-bottom: 0.35rem; font-size: 0.72rem; color: rgba(255,255,255,0.25); }
.aster-footer__disclaimer { max-width: 640px; font-size: 0.68rem !important; line-height: 1.55; }
.aster-footer__disclaimer a { color: rgba(255,255,255,0.45); text-decoration: underline; text-underline-offset: 2px; }
.aster-footer__disclaimer a:hover { color: var(--aster-white); }

@media (max-width: 960px) {
	.aster-header__nav { display: none; }
	.aster-header__menu-btn { display: flex; }
	.aster-header__util { display: none; }
	.aster-footer__grid { grid-template-columns: 1fr 1fr; }
	.aster-footer__brand-col { grid-column: 1 / -1; }
}
@media (max-width: 520px) {
	.aster-header__actions { display: none; }
	.aster-header__menu-btn { display: flex; }
	.aster-footer__grid { grid-template-columns: 1fr; }
}
</style>
