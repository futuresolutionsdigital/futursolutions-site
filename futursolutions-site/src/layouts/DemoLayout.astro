---
import DemoBanner from '../components/DemoBanner.astro';
import '../styles/global.css';

interface NavItem {
	label: string;
	href: string;
}

interface Props {
	title: string;
	description: string;
	canonicalUrl?: string;
	variant?: 'med-spa' | 'solo-practice';
	/** First line of header brand (e.g. Luma, Meridian). */
	brandLine1?: string;
	brandLine2?: string;
	brandHomeHref?: string;
	brandAriaLabel?: string;
	navLabel?: string;
	navItems?: NavItem[];
	primaryCtaLabel?: string;
	primaryCtaHref?: string;
	footerBrandHref?: string;
	footerBrandText?: string;
	footerNote?: string;
	footerLinks?: NavItem[];
}

const medSpaConfig = {
	variantClass: 'demo-site--med-spa',
	brandLine1: 'Luma',
	brandLine2: 'Aesthetics',
	brandHomeHref: '/demos/med-spa',
	brandAriaLabel: 'Luma Aesthetics demo home',
	navLabel: 'Luma Aesthetics demo navigation',
	navItems: [
		{ label: 'Treatments', href: '/demos/med-spa/treatments' },
		{ label: 'About', href: '/demos/med-spa/#about' },
		{ label: 'Contact', href: '/demos/med-spa/contact' },
	],
	primaryCtaLabel: 'Book Consultation',
	primaryCtaHref: '/demos/med-spa/contact',
	footerBrandHref: '/demos/med-spa',
	footerBrandText: 'Luma Aesthetics',
	footerNote: 'Demonstration practice site showcasing a Future Solutions website template.',
	footerLinks: [
		{ label: 'Treatments', href: '/demos/med-spa/treatments' },
		{ label: 'Consultation', href: '/demos/med-spa/contact' },
		{ label: 'Template Details', href: '/templates/med-spa' },
	],
} as const;

const props = Astro.props;
const demoVariant = props.variant ?? 'med-spa';

const activeConfig =
	demoVariant === 'solo-practice'
		? {
				variantClass: 'demo-site--solo-practice',
				brandLine1: props.brandLine1!,
				brandLine2: props.brandLine2!,
				brandHomeHref: props.brandHomeHref!,
				brandAriaLabel: props.brandAriaLabel!,
				navLabel: props.navLabel!,
				navItems: props.navItems!,
				primaryCtaLabel: props.primaryCtaLabel!,
				primaryCtaHref: props.primaryCtaHref!,
				footerBrandHref: props.footerBrandHref!,
				footerBrandText: props.footerBrandText!,
				footerNote: props.footerNote ?? 'Demonstration solo practice site showcasing a Future Solutions website template.',
				footerLinks: props.footerLinks!,
		  }
		: medSpaConfig;

const { title, description, canonicalUrl } = props;

const demoBannerCustomizeHref =
	demoVariant === 'solo-practice' ? '/audit?template=solo-practice' : '/audit?template=med-spa';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body class:list={['demo-site', activeConfig.variantClass]}>
		<DemoBanner customizeHref={demoBannerCustomizeHref} />
		<header class="demo-header">
			<div class="site-container demo-header__inner">
				<a class="demo-header__brand" href={activeConfig.brandHomeHref} aria-label={activeConfig.brandAriaLabel}>
					<span>{activeConfig.brandLine1}</span>
					<span>{activeConfig.brandLine2}</span>
				</a>
				<nav class="demo-header__nav" aria-label={activeConfig.navLabel}>
					{activeConfig.navItems.map((item) => (
						<a href={item.href}>{item.label}</a>
					))}
				</nav>
				<a class="demo-header__cta" href={activeConfig.primaryCtaHref}>{activeConfig.primaryCtaLabel}</a>
			</div>
		</header>
		<main>
			<slot />
		</main>
		<footer class="demo-footer">
			<div class="site-container demo-footer__inner">
				<div>
					<a class="demo-footer__brand" href={activeConfig.footerBrandHref}>{activeConfig.footerBrandText}</a>
					<p>{activeConfig.footerNote}</p>
				</div>
				<div class="demo-footer__links" aria-label={`${activeConfig.footerBrandText} demo footer links`}>
					{activeConfig.footerLinks.map((link) => (
						<a href={link.href}>{link.label}</a>
					))}
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
	.demo-site.demo-site--med-spa {
		background: #fbfaf7;
		color: #17202a;
	}

	.demo-site.demo-site--solo-practice {
		background: #f9faf8;
		color: #1a2330;
	}

	.demo-header {
		position: sticky;
		top: 3.6rem;
		z-index: 12;
		border-bottom: 1px solid rgba(42, 54, 65, 0.1);
		backdrop-filter: blur(16px);
	}

	.demo-site--med-spa .demo-header {
		background: rgba(251, 250, 247, 0.92);
	}

	.demo-site--solo-practice .demo-header {
		background: rgba(249, 250, 248, 0.94);
	}

	.demo-header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		min-height: 5rem;
	}

	.demo-header__brand {
		display: inline-grid;
		gap: 0.05rem;
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1;
	}

	.demo-site--med-spa .demo-header__brand {
		color: #17202a;
	}

	.demo-site--solo-practice .demo-header__brand {
		color: #1a2330;
	}

	.demo-site--med-spa .demo-header__brand span:last-child {
		color: #8f6f63;
		font-size: 0.88rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.demo-site--solo-practice .demo-header__brand span:last-child {
		color: #4d7a71;
		font-size: 0.88rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.demo-header__nav {
		display: flex;
		align-items: center;
		gap: 1.2rem;
		font-size: 0.92rem;
		font-weight: 700;
	}

	.demo-site--med-spa .demo-header__nav {
		color: #64706f;
	}

	.demo-site--solo-practice .demo-header__nav {
		color: #5c6b6a;
	}

	.demo-header__nav a:hover {
		color: #17202a;
	}

	.demo-site--solo-practice .demo-header__nav a:hover {
		color: #1a2330;
	}

	.demo-site--med-spa .demo-header__brand:focus-visible,
	.demo-site--med-spa .demo-header__nav a:focus-visible,
	.demo-site--med-spa .demo-header__cta:focus-visible,
	.demo-site--med-spa .demo-footer__brand:focus-visible,
	.demo-site--med-spa .demo-footer__links a:focus-visible {
		outline: 2px solid #8f6f63;
		outline-offset: 3px;
		border-radius: 6px;
	}

	.demo-site--solo-practice .demo-header__brand:focus-visible,
	.demo-site--solo-practice .demo-header__nav a:focus-visible,
	.demo-site--solo-practice .demo-header__cta:focus-visible,
	.demo-site--solo-practice .demo-footer__brand:focus-visible,
	.demo-site--solo-practice .demo-footer__links a:focus-visible {
		outline: 2px solid #4d7a71;
		outline-offset: 3px;
		border-radius: 6px;
	}

	.demo-site--med-spa :global(main a:focus-visible),
	.demo-site--med-spa :global(main button:focus-visible) {
		outline: 2px solid #8f6f63;
		outline-offset: 3px;
	}

	.demo-site--solo-practice :global(main a:focus-visible),
	.demo-site--solo-practice :global(main button:focus-visible) {
		outline: 2px solid #4d7a71;
		outline-offset: 3px;
	}

	.demo-header__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.45rem;
		padding: 0.7rem 0.9rem;
		border-radius: 999px;
		background: #ffffff;
		font-size: 0.875rem;
		font-weight: 800;
		line-height: 1;
		white-space: nowrap;
	}

	.demo-site--med-spa .demo-header__cta {
		border: 1px solid rgba(143, 111, 99, 0.26);
		color: #17202a;
	}

	.demo-site--solo-practice .demo-header__cta {
		border: 1px solid rgba(77, 122, 113, 0.35);
		color: #1a2330;
	}

	.demo-site--med-spa .demo-header__cta:hover {
		background: #efe7e1;
		color: #6f554b;
	}

	.demo-site--solo-practice .demo-header__cta:hover {
		background: #e8f0ee;
		color: #3d5f57;
	}

	.demo-footer {
		border-top: 1px solid rgba(42, 54, 65, 0.1);
	}

	.demo-site--med-spa .demo-footer {
		background: #f5f0eb;
	}

	.demo-site--solo-practice .demo-footer {
		background: #eef2f1;
	}

	.demo-footer__inner {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		padding-block: 2.5rem;
	}

	.demo-footer__brand {
		display: inline-flex;
		margin-bottom: 0.5rem;
		font-weight: 800;
		letter-spacing: -0.035em;
	}

	.demo-site--med-spa .demo-footer__brand {
		color: #17202a;
	}

	.demo-site--solo-practice .demo-footer__brand {
		color: #1a2330;
	}

	.demo-footer p {
		font-size: 0.9375rem;
	}

	.demo-site--solo-practice .demo-footer p {
		color: #5c6b6a;
	}

	.demo-footer__links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		align-items: flex-start;
		justify-content: flex-end;
		font-size: 0.9375rem;
		font-weight: 700;
	}

	.demo-site--med-spa .demo-footer__links {
		color: #64706f;
	}

	.demo-site--solo-practice .demo-footer__links {
		color: #5c6b6a;
	}

	.demo-site--med-spa .demo-footer__links a:hover {
		color: #6f554b;
	}

	.demo-site--solo-practice .demo-footer__links a:hover {
		color: #3d5f57;
	}

	@media (max-width: 860px) {
		.demo-header {
			top: 6.9rem;
		}

		.demo-header__nav {
			display: none;
		}
	}

	@media (max-width: 700px) {
		.demo-footer__inner {
			flex-direction: column;
		}

		.demo-footer__links {
			justify-content: flex-start;
		}
	}

	@media (max-width: 420px) {
		.demo-header__cta {
			display: none;
		}
	}
</style>
