---
import DemoBanner from '../components/DemoBanner.astro';
import { brand, navItems, footerTreatments, footerConditions, footerCompany } from '../data/vantage';
import '../styles/global.css';

interface Props { title: string; description: string; canonicalUrl?: string; }
const { title, description, canonicalUrl } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string) {
	const clean = href.replace(/\/$/, '').split('#')[0];
	if (clean === currentPath) return true;
	if (clean && currentPath.startsWith(clean + '/')) return true;
	return false;
}
---

<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="icon" href="/favicon.ico" />
	<meta name="viewport" content="width=device-width" />
	<meta name="generator" content={Astro.generator} />
	<meta name="description" content={description} />
	{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:type" content="website" />
	{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
	<title>{title}</title>
</head>
<body class="vt">
	<DemoBanner customizeHref="/audit?template=hormone-trt" />

	<!-- ═══ SPORTS-CLUB HEADER ═══ -->
	<div class="vt-rule" aria-hidden="true"></div>
	<header class="vt-hdr" id="vt-header">
		<div class="vt-w vt-hdr__bar">
			<a class="vt-hdr__brand" href={brand.homeHref} aria-label="VANTAGE Men's Health home">VANTAGE</a>
			<nav class="vt-hdr__nav" aria-label="Main navigation">
				{navItems.map((item) => <a href={item.href} class:list={[{ 'is-active': isActive(item.href) }]}>{item.label}</a>)}
			</nav>
			<div class="vt-hdr__right">
				<span class="vt-hdr__micro">Private Consults &middot; Labs &middot; Provider-Led</span>
				<a class="vt-hdr__cta" href="/demos/hormone-trt/assessment">Start Assessment</a>
			</div>
			<button class="vt-hdr__menu" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="vt-mob">
				<span></span><span></span>
			</button>
		</div>
		<nav class="vt-mob" id="vt-mob" aria-label="Mobile navigation" hidden>
			<div class="vt-w vt-mob__inner">
				{navItems.map((item) => <a href={item.href}>{item.label}</a>)}
				<a href="/demos/hormone-trt#providers">Providers</a>
				<a href="/demos/hormone-trt#faq">FAQ</a>
				<div class="vt-mob__actions">
					<a class="vt-mob__primary" href="/demos/hormone-trt/assessment">Start My Assessment &rarr;</a>
					<a class="vt-mob__secondary" href="/demos/hormone-trt/book-consultation">Book Consult</a>
				</div>
			</div>
		</nav>
	</header>

	<main><slot /></main>

	<!-- ═══ FOOTER ═══ -->
	<footer class="vt-ft">
		<div class="vt-w vt-ft__grid">
			<div class="vt-ft__brand">
				<span class="vt-ft__logo">VANTAGE</span>
				<p>{brand.tagline}</p>
				<p class="vt-ft__contact">{brand.phone} &middot; {brand.email}</p>
			</div>
			<nav class="vt-ft__col" aria-label="Footer treatments">
				<h2>Treatments</h2>
				{footerTreatments.map((t) => <a href="/demos/hormone-trt#treatments">{t}</a>)}
			</nav>
			<nav class="vt-ft__col" aria-label="Footer conditions">
				<h2>Conditions</h2>
				{footerConditions.map((c) => <a href="/demos/hormone-trt#problems">{c}</a>)}
			</nav>
			<nav class="vt-ft__col" aria-label="Footer company">
				<h2>Company</h2>
				{footerCompany.map((l) => <a href={l.href}>{l.label}</a>)}
			</nav>
		</div>
		<div class="vt-w vt-ft__bottom">
			<span>&copy; {new Date().getFullYear()} {brand.name}</span>
			<span class="vt-ft__disc">{brand.disclaimer} Built by <a href="/">Future Solutions</a>.</span>
		</div>
	</footer>

	<a class="vt-sticky" href="/demos/hormone-trt/assessment">Start My Assessment &rarr;</a>

	<script is:inline>
	(function(){
		var banner=document.querySelector('.demo-banner');
		function sync(){var h=banner?banner.offsetHeight:0;document.documentElement.style.setProperty('--vt-banner-h',h+'px');}
		if(banner){sync();window.addEventListener('resize',sync);}
		var btn=document.querySelector('.vt-hdr__menu');
		var menu=document.getElementById('vt-mob');
		if(!btn||!menu)return;
		btn.addEventListener('click',function(){
			var open=menu.hidden;
			menu.hidden=!open;
			btn.setAttribute('aria-expanded',open?'true':'false');
			btn.classList.toggle('is-open',open);
		});
		menu.querySelectorAll('a').forEach(function(a){
			a.addEventListener('click',function(){menu.hidden=true;btn.setAttribute('aria-expanded','false');btn.classList.remove('is-open');});
		});
	})();
	</script>
</body>
</html>

<style is:global>
/* ═══════════════════════════════════════════════════════
   VANTAGE — Elite Sports Performance Medicine
   Red/Black Athletic Health System
   ═══════════════════════════════════════════════════════ */
.vt {
	--vt-black: #050505;
	--vt-charcoal: #111111;
	--vt-carbon: #1A1A1A;
	--vt-bone: #F4EFE7;
	--vt-white: #FFFFFF;
	--vt-red: #D71920;
	--vt-crimson: #8F1117;
	--vt-muted-red: #B4232A;
	--vt-steel: #7C858C;
	--vt-silver: #C7CED3;
	--vt-warm-gray: #D8D0C5;
	--vt-border: rgba(255,255,255,0.08);
	--vt-border-light: rgba(0,0,0,0.08);
	--vt-border-red: rgba(215,25,32,0.2);
	--vt-r: 3px;
	--vt-font: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	--vt-max: 1080px;
	--vt-ease: 0.15s ease;

	margin: 0; min-width: 320px;
	background: var(--vt-black); color: var(--vt-bone);
	font-family: var(--vt-font);
	font-size: 0.9375rem; line-height: 1.6;
	-webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
}
.vt *, .vt *::before, .vt *::after { box-sizing: border-box; }
.vt img, .vt svg { display: block; max-width: 100%; }
.vt a { color: inherit; text-decoration: none; transition: color var(--vt-ease), opacity var(--vt-ease); }

/* Typography — sharp, athletic, high contrast */
.vt h1, .vt h2, .vt h3 { margin-top: 0; font-weight: 800; }
.vt h1 { font-size: clamp(2.4rem, 1.6rem + 3.5vw, 3.8rem); line-height: 1.02; letter-spacing: -0.045em; margin-bottom: 1.25rem; color: var(--vt-white); }
.vt h2 { font-size: clamp(1.3rem, 0.9rem + 1.5vw, 1.85rem); line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 0.75rem; color: var(--vt-white); }
.vt h3 { font-size: 0.92rem; line-height: 1.3; letter-spacing: -0.01em; margin-bottom: 0.3rem; font-weight: 700; color: var(--vt-white); }
.vt p { margin-top: 0; margin-bottom: 0.75rem; }
.vt p:last-child { margin-bottom: 0; }
.vt button, .vt input, .vt select, .vt textarea { font: inherit; }
.vt button { cursor: pointer; }
.vt :focus-visible { outline: 2px solid var(--vt-red); outline-offset: 2px; border-radius: 2px; }
.vt ::selection { background: rgba(215,25,32,0.2); color: var(--vt-white); }

/* Containers */
.vt-w { width: min(100% - 2rem, var(--vt-max)); margin-inline: auto; }
.vt-w--wide { width: min(100% - 2rem, 1200px); margin-inline: auto; }

/* Sections — break from wellness patterns */
.vt-s { padding: clamp(3rem, 6vw, 5rem) 0; }
.vt-s--black { background: var(--vt-black); color: var(--vt-bone); }
.vt-s--charcoal { background: var(--vt-charcoal); color: var(--vt-bone); }
.vt-s--carbon { background: var(--vt-carbon); color: var(--vt-bone); }
.vt-s--bone { background: var(--vt-bone); color: var(--vt-charcoal); }
.vt-s--bone h1, .vt-s--bone h2, .vt-s--bone h3 { color: var(--vt-black); }
.vt-s--white { background: var(--vt-white); color: var(--vt-charcoal); }
.vt-s--white h1, .vt-s--white h2, .vt-s--white h3 { color: var(--vt-black); }

/* Eyebrow — sport style */
.vt-e { display: block; font-size: 0.6rem; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; color: var(--vt-red); margin-bottom: 0.5rem; }
.vt-s--bone .vt-e, .vt-s--white .vt-e { color: var(--vt-muted-red); }

/* Subtitle */
.vt-sub { font-size: 0.88rem; line-height: 1.55; color: rgba(244,239,231,0.6); max-width: 500px; }
.vt-s--bone .vt-sub, .vt-s--white .vt-sub { color: var(--vt-steel); }

/* Muted body */
.vt-muted { color: rgba(244,239,231,0.5); }
.vt-s--bone .vt-muted, .vt-s--white .vt-muted { color: var(--vt-steel); }

/* Buttons — sharp, athletic */
.vt-btn { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.7rem 1.5rem; font-size: 0.75rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; border-radius: var(--vt-r); border: 2px solid transparent; transition: all var(--vt-ease); white-space: nowrap; }
.vt-btn--red { background: var(--vt-red); color: var(--vt-white); border-color: var(--vt-red); }
.vt-btn--red:hover { background: var(--vt-muted-red); border-color: var(--vt-muted-red); }
.vt-btn--dark { background: var(--vt-charcoal); color: var(--vt-white); border-color: var(--vt-border); }
.vt-btn--dark:hover { border-color: var(--vt-red); color: var(--vt-red); }
.vt-btn--white { background: var(--vt-white); color: var(--vt-black); border-color: var(--vt-white); }
.vt-btn--white:hover { background: var(--vt-bone); }
.vt-s--bone .vt-btn--dark, .vt-s--white .vt-btn--dark { background: var(--vt-white); color: var(--vt-black); border-color: var(--vt-border-light); }
.vt-s--bone .vt-btn--dark:hover, .vt-s--white .vt-btn--dark:hover { border-color: var(--vt-red); color: var(--vt-muted-red); }
.vt-btn-row { display: flex; flex-wrap: wrap; gap: 0.6rem; }

/* Red accent line — used as decorative element */
.vt-redline { display: block; width: 40px; height: 3px; background: var(--vt-red); border-radius: 1px; }

/* Text link */
.vt-link { font-size: 0.72rem; font-weight: 700; color: var(--vt-red); letter-spacing: 0.04em; text-transform: uppercase; }
.vt-link:hover { color: var(--vt-muted-red); }

/* ═══ BRANDED IMAGE PLACEHOLDER ═══ */
.vt-img { position: relative; background: var(--vt-carbon); border-radius: var(--vt-r); overflow: hidden; display: flex; align-items: center; justify-content: center; min-height: 180px; }
.vt-img::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(135deg, transparent, transparent 24px, rgba(255,255,255,0.015) 24px, rgba(255,255,255,0.015) 25px); pointer-events: none; }
.vt-img::after { content: ''; position: absolute; top: 0; left: 0; width: 28px; height: 28px; border-top: 2px solid var(--vt-red); border-left: 2px solid var(--vt-red); border-radius: var(--vt-r) 0 0 0; }
.vt-img__label { font-size: 0.55rem; font-weight: 900; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(244,239,231,0.15); position: relative; z-index: 1; }
.vt-img--br::after { top: auto; left: auto; bottom: 0; right: 0; border-top: none; border-left: none; border-bottom: 2px solid var(--vt-red); border-right: 2px solid var(--vt-red); border-radius: 0 0 var(--vt-r) 0; }

/* ═══ OVERSIZED SECTION NUMBER ═══ */
.vt-bignum { font-size: clamp(3rem, 6vw, 5rem); font-weight: 900; color: rgba(215,25,32,0.08); line-height: 1; letter-spacing: -0.04em; user-select: none; }
.vt-s--bone .vt-bignum, .vt-s--white .vt-bignum { color: rgba(215,25,32,0.06); }

/* ═══ THIN RED DIVIDER ═══ */
.vt-hr { border: none; height: 1px; background: var(--vt-border-red); margin: 0; }

/* ═══ RED TOP RULE ═══ */
.vt-rule { height: 3px; background: var(--vt-red); position: relative; z-index: 20; }

/* ═══ SPORTS-CLUB HEADER ═══ */
.vt-hdr { position: sticky; top: var(--vt-banner-h, 3.55rem); z-index: 15; background: rgba(5,5,5,0.97); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.04); }
.vt-hdr__bar { display: flex; align-items: center; gap: 1.25rem; height: 3.5rem; }
.vt-hdr__brand { font-size: 0.9rem; font-weight: 900; letter-spacing: 0.25em; text-transform: uppercase; color: var(--vt-white); text-decoration: none; }
.vt-hdr__nav { display: flex; gap: 1.5rem; margin-left: auto; }
.vt-hdr__nav a { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(244,239,231,0.4); transition: color var(--vt-ease); }
.vt-hdr__nav a:hover { color: var(--vt-white); }
.vt-hdr__nav a.is-active { color: var(--vt-red); }
.vt-hdr__right { display: flex; align-items: center; gap: 1rem; margin-left: 1.5rem; }
.vt-hdr__micro { font-size: 0.52rem; font-weight: 500; letter-spacing: 0.06em; color: rgba(244,239,231,0.2); white-space: nowrap; }
.vt-hdr__cta { padding: 0.35rem 0.9rem; font-size: 0.6rem; font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; background: var(--vt-red); color: var(--vt-white); border-radius: var(--vt-r); transition: background var(--vt-ease); }
.vt-hdr__cta:hover { background: var(--vt-muted-red); }

/* Hamburger */
.vt-hdr__menu { display: none; background: none; border: none; padding: 0.5rem; flex-direction: column; gap: 5px; margin-left: auto; }
.vt-hdr__menu span { display: block; width: 18px; height: 2px; background: var(--vt-white); transition: transform var(--vt-ease), opacity var(--vt-ease); }
.vt-hdr__menu.is-open span:first-child { transform: translateY(3.5px) rotate(45deg); }
.vt-hdr__menu.is-open span:last-child { transform: translateY(-3.5px) rotate(-45deg); }

/* Mobile menu */
.vt-mob { background: var(--vt-black); border-top: 1px solid rgba(255,255,255,0.04); }
.vt-mob__inner { display: flex; flex-direction: column; padding: 1rem 0; gap: 0.5rem; }
.vt-mob__inner > a { font-size: 0.82rem; font-weight: 700; color: rgba(244,239,231,0.5); padding: 0.35rem 0; }
.vt-mob__inner > a:hover { color: var(--vt-white); }
.vt-mob__actions { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
.vt-mob__primary { flex: 1; text-align: center; padding: 0.7rem; font-size: 0.72rem; font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase; background: var(--vt-red); color: var(--vt-white); border-radius: var(--vt-r); }
.vt-mob__secondary { flex: 1; text-align: center; padding: 0.7rem; font-size: 0.72rem; font-weight: 700; border: 1px solid var(--vt-border); color: var(--vt-bone); border-radius: var(--vt-r); }

/* ═══ FOOTER ═══ */
.vt-ft { background: var(--vt-charcoal); border-top: 3px solid var(--vt-red); padding: clamp(2.5rem, 5vw, 3.5rem) 0 1.25rem; }
.vt-ft__grid { display: grid; grid-template-columns: 1.5fr repeat(3, 1fr); gap: 2rem; padding-bottom: 2rem; border-bottom: 1px solid var(--vt-border); }
.vt-ft__logo { font-size: 0.8rem; font-weight: 900; letter-spacing: 0.25em; text-transform: uppercase; color: var(--vt-white); display: block; margin-bottom: 0.5rem; }
.vt-ft__brand p { font-size: 0.72rem; color: rgba(244,239,231,0.4); max-width: 260px; line-height: 1.5; }
.vt-ft__contact { font-size: 0.65rem !important; color: rgba(244,239,231,0.25) !important; margin-top: 0.5rem; }
.vt-ft__col { display: flex; flex-direction: column; gap: 0.25rem; }
.vt-ft__col h2 { font-size: 0.55rem; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase; color: var(--vt-red); margin-bottom: 0.4rem; }
.vt-ft__col a { font-size: 0.72rem; color: rgba(244,239,231,0.4); }
.vt-ft__col a:hover { color: var(--vt-white); }
.vt-ft__bottom { display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; padding-top: 1rem; align-items: baseline; }
.vt-ft__bottom span { font-size: 0.6rem; color: rgba(244,239,231,0.2); }
.vt-ft__disc { font-size: 0.52rem !important; color: rgba(244,239,231,0.12) !important; font-style: italic; max-width: 560px; }
.vt-ft__disc a { color: var(--vt-red); }

/* ═══ STICKY MOBILE CTA ═══ */
.vt-sticky { display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 14; padding: 0.75rem; text-align: center; font-size: 0.72rem; font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase; background: var(--vt-red); color: var(--vt-white); }

/* ═══ RESPONSIVE ═══ */
@media (prefers-reduced-motion: reduce) {
	.vt, .vt * { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
}
@media (max-width: 900px) {
	.vt-hdr__nav, .vt-hdr__right { display: none; }
	.vt-hdr__menu { display: flex; }
	.vt-ft__grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
	.vt-ft__grid { grid-template-columns: 1fr; }
	.vt-ft__bottom { flex-direction: column; }
	.vt-sticky { display: block; }
	body.vt { padding-bottom: 3rem; }
}
</style>
