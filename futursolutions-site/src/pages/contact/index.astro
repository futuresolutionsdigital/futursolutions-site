---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../../data/schema';

const pageTitle = 'Contact | FutureSolutions';
const pageDescription =
	'Get in touch with FutureSolutions. Email us directly, request a free Website and Systems Audit, or learn how we work with healthcare and high-trust businesses.';
const canonicalUrl = 'https://futuresolutions.io/contact/';

const contactEmail = 'admin@futuresolutions.io';

const facts = [
	{ label: 'Based in', value: 'California, USA' },
	{ label: 'Working with', value: 'Clients across the United States' },
	{ label: 'Typical reply', value: 'Within 2 business days' },
	{ label: 'Best for', value: 'Healthcare & high-trust service businesses' },
];

const pageSchema = [
	breadcrumbSchema([
		{ name: 'Home', path: '/' },
		{ name: 'Contact', path: '/contact' },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
	schema={pageSchema}
>
	<section class="section contact-hero" aria-labelledby="contact-heading">
		<div class="site-container contact-hero__inner">
			<p class="eyebrow">Contact</p>
			<h1 id="contact-heading">Let's talk about your website.</h1>
			<p class="lead">
				Whether you have a specific project in mind or just want a clear read on your current site,
				we'd be glad to hear from you. There's no pressure and no obligation — just a straight answer.
			</p>
		</div>
	</section>

	<section class="section contact-main" aria-labelledby="contact-main-heading">
		<div class="site-container contact-main__inner">
			<div class="contact-form-col">
				<h2 id="contact-main-heading" class="contact-form-col__heading">Send us a message</h2>
				<p class="contact-form-col__intro">
					Tell us a little about your practice and what you're hoping to improve. For a full
					structured review, the <a href="/audit">free Website &amp; Systems Audit</a> is the better starting point.
				</p>

				<form class="card contact-form" id="contact-form" novalidate>
					<div class="contact-form__grid">
						<div class="contact-field">
							<label for="contact-name">Name <span aria-hidden="true">*</span></label>
							<input type="text" id="contact-name" name="name" autocomplete="name" required />
							<p class="contact-field__error" data-error-for="name" hidden></p>
						</div>
						<div class="contact-field">
							<label for="contact-email">Email <span aria-hidden="true">*</span></label>
							<input type="email" id="contact-email" name="email" autocomplete="email" required />
							<p class="contact-field__error" data-error-for="email" hidden></p>
						</div>
						<div class="contact-field">
							<label for="contact-business">Business name</label>
							<input type="text" id="contact-business" name="business-name" autocomplete="organization" />
						</div>
						<div class="contact-field">
							<label for="contact-website">Current website</label>
							<input type="url" id="contact-website" name="website-url" inputmode="url" placeholder="https://" />
						</div>
						<div class="contact-field contact-field--full">
							<label for="contact-message">How can we help? <span aria-hidden="true">*</span></label>
							<textarea id="contact-message" name="message" rows="5" required></textarea>
							<p class="contact-field__error" data-error-for="message" hidden></p>
						</div>
					</div>

					<!-- Honeypot: hidden from real users, catches bots. -->
					<div class="contact-form__hp" aria-hidden="true">
						<label for="company_website">Company website</label>
						<input type="text" id="company_website" name="company_website" tabindex="-1" autocomplete="off" />
					</div>

					<div class="contact-form__footer">
						<button type="submit" class="button button-primary" id="contact-submit">Send message</button>
						<p class="contact-form__status" id="contact-status" role="status" aria-live="polite" hidden></p>
					</div>
				</form>
			</div>

			<aside class="contact-facts" aria-label="Other ways to reach us">
				<a class="card contact-direct" href={`mailto:${contactEmail}`}>
					<span class="contact-direct__label">Prefer email?</span>
					<span class="contact-direct__value">{contactEmail}</span>
					<span class="contact-direct__note">A real person reads every message.</span>
				</a>

				<p class="contact-facts__label">At a glance</p>
				<dl class="contact-facts__list">
					{facts.map((fact) => (
						<div class="contact-facts__row">
							<dt>{fact.label}</dt>
							<dd>{fact.value}</dd>
						</div>
					))}
				</dl>
				<a class="button button-secondary contact-facts__cta" href="/audit">Get a Website Audit</a>
				<p class="contact-facts__demo">
					Prefer to see the work first? Every site in our <a href="/templates">live demo library</a> is a real, clickable build.
				</p>
			</aside>
		</div>
	</section>
</BaseLayout>

<script>
	(() => {
		const form = document.getElementById('contact-form');
		if (!(form instanceof HTMLFormElement)) return;
		const submitBtn = document.getElementById('contact-submit');
		const status = document.getElementById('contact-status');

		const clearErrors = () => {
			form.querySelectorAll('[data-error-for]').forEach((el) => {
				el.textContent = '';
				el.setAttribute('hidden', '');
			});
		};

		const showError = (field, message) => {
			const el = form.querySelector(`[data-error-for="${field}"]`);
			if (el) {
				el.textContent = message;
				el.removeAttribute('hidden');
			}
		};

		const setStatus = (message, kind) => {
			if (!status) return;
			status.textContent = message;
			status.dataset.kind = kind;
			status.removeAttribute('hidden');
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			clearErrors();
			if (status) status.setAttribute('hidden', '');

			const data = Object.fromEntries(new FormData(form).entries());

			if (submitBtn instanceof HTMLButtonElement) {
				submitBtn.disabled = true;
				submitBtn.textContent = 'Sending…';
			}

			try {
				const res = await fetch('/api/contact', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(data),
				});
				const result = await res.json().catch(() => ({}));

				if (res.ok && result.ok) {
					form.reset();
					setStatus("Thanks — your message is on its way. We'll reply within two business days.", 'success');
					if (submitBtn instanceof HTMLButtonElement) {
						submitBtn.textContent = 'Message sent';
					}
					return;
				}

				if (res.status === 422 && result.errors) {
					Object.entries(result.errors).forEach(([field, message]) => showError(field, String(message)));
					setStatus('Please fix the highlighted fields and try again.', 'error');
				} else {
					setStatus(result.message || 'Something went wrong. Please email us directly.', 'error');
				}
			} catch {
				setStatus('Network error. Please try again or email us directly.', 'error');
			}

			if (submitBtn instanceof HTMLButtonElement) {
				submitBtn.disabled = false;
				submitBtn.textContent = 'Send message';
			}
		});
	})();
</script>

<style>
	.contact-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(4.5rem, 8vw, 7rem) clamp(2rem, 4vw, 3rem);
	}
	.contact-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		content: '';
		background:
			radial-gradient(circle at 80% 14%, color-mix(in srgb, var(--color-accent) 14%, transparent), transparent 32%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
	}
	.contact-hero__inner {
		max-width: 720px;
	}
	.contact-hero h1 {
		margin-block: 0.4rem 1rem;
	}
	.contact-hero .lead {
		max-width: 58ch;
	}

	.contact-main__inner {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.8fr);
		gap: clamp(2rem, 5vw, 3.5rem);
		align-items: start;
	}

	.contact-form-col__heading {
		font-size: 1.05rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-muted);
		margin-bottom: 0.6rem;
	}
	.contact-form-col__intro {
		margin: 0 0 1.5rem 0;
		max-width: 52ch;
		color: var(--color-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}
	.contact-form-col__intro a {
		color: var(--color-accent-dark);
		font-weight: 700;
	}

	.contact-form {
		padding: clamp(1.5rem, 3vw, 2rem);
	}
	.contact-form__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.1rem;
	}
	.contact-field {
		display: grid;
		gap: 0.4rem;
	}
	.contact-field--full {
		grid-column: 1 / -1;
	}
	.contact-field label {
		color: var(--color-text);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.01em;
	}
	.contact-field label span {
		color: var(--color-accent-dark);
	}
	.contact-field input,
	.contact-field textarea {
		width: 100%;
		padding: 0.7rem 0.8rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: var(--color-white);
		color: var(--color-text);
		font: inherit;
		font-size: 0.95rem;
		transition: border-color var(--transition-base), box-shadow var(--transition-base);
	}
	.contact-field textarea {
		resize: vertical;
		min-height: 7rem;
	}
	.contact-field input:focus-visible,
	.contact-field textarea:focus-visible {
		outline: none;
		border-color: color-mix(in srgb, var(--color-accent) 55%, var(--color-border));
		box-shadow: 0 0 0 3px var(--color-accent-light);
	}
	.contact-field__error {
		margin: 0;
		color: #b42318;
		font-size: 0.8rem;
		font-weight: 600;
	}

	.contact-form__hp {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.contact-form__footer {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1rem;
		margin-top: 1.5rem;
	}
	.contact-form__status {
		margin: 0;
		font-size: 0.9rem;
		font-weight: 600;
		line-height: 1.5;
	}
	.contact-form__status[data-kind='success'] {
		color: var(--color-accent-dark);
	}
	.contact-form__status[data-kind='error'] {
		color: #b42318;
	}

	.contact-direct {
		display: grid;
		gap: 0.3rem;
		padding: 1.25rem 1.5rem;
		margin-bottom: 1.5rem;
		transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
	}
	.contact-direct:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-accent) 32%, var(--color-border));
		box-shadow: 0 20px 48px rgba(15, 23, 42, 0.06);
	}
	.contact-direct__label {
		color: var(--color-accent-dark);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}
	.contact-direct__value {
		color: var(--color-text);
		font-size: 1.05rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		word-break: break-word;
	}
	.contact-direct__note {
		color: var(--color-muted);
		font-size: 0.88rem;
		line-height: 1.5;
	}
	.contact-facts__demo {
		margin: 1rem 0 0 0;
		color: var(--color-muted);
		font-size: 0.88rem;
		line-height: 1.6;
	}
	.contact-facts__demo a {
		color: var(--color-accent-dark);
		font-weight: 700;
	}

	.contact-facts {
		padding: 1.75rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-bg-secondary);
	}
	.contact-facts__label {
		margin: 0 0 1.1rem 0;
		color: var(--color-accent-dark);
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}
	.contact-facts__list {
		display: grid;
		gap: 1rem;
		margin: 0 0 1.5rem 0;
	}
	.contact-facts__row {
		display: grid;
		gap: 0.15rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--color-border-soft);
	}
	.contact-facts__row:last-child {
		padding-bottom: 0;
		border-bottom: none;
	}
	.contact-facts__row dt {
		color: var(--color-muted-soft);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}
	.contact-facts__row dd {
		margin: 0;
		color: var(--color-text);
		font-size: 0.96rem;
		font-weight: 600;
	}
	.contact-facts__cta {
		width: 100%;
		justify-content: center;
	}

	@media (max-width: 860px) {
		.contact-main__inner {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 540px) {
		.contact-form__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
