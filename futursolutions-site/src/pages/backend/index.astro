---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'Backend Lead Systems | Future Solutions';
const pageDescription =
	'Future Solutions helps health and wellness businesses connect website inquiries to lead capture, booking, follow-up, and pipeline systems.';
const canonicalUrl = 'https://futursolutions.vercel.app/backend/';

const problems = [
	{
		title: 'Inbox-only inquiries',
		text: 'Form submissions are easy to miss when they only arrive by email.',
	},
	{
		title: 'No clear lead status',
		text: 'Without a pipeline, it is hard to know who needs follow-up.',
	},
	{
		title: 'Manual follow-up gaps',
		text: 'People drop off when reminders and next steps are inconsistent.',
	},
	{
		title: 'Disconnected booking flow',
		text: 'The website, calendar, and CRM should work together.',
	},
];

const flowSteps = [
	{
		title: 'Website Visit',
		text: 'Visitor lands on a service or landing page.',
	},
	{
		title: 'Form Submission',
		text: 'Inquiry is captured from the website.',
	},
	{
		title: 'CRM Contact',
		text: 'Contact record is created or updated.',
	},
	{
		title: 'Booking Request',
		text: 'Visitor is routed toward a consultation or appointment.',
	},
	{
		title: 'Follow-Up',
		text: 'Emails, reminders, or tasks help prevent drop-off.',
	},
	{
		title: 'Pipeline',
		text: 'Each lead has a status and next step.',
	},
];

const supportedItems = [
	'Website forms',
	'Booking calendars',
	'CRM contact records',
	'Intake questions',
	'Follow-up emails',
	'Reminder sequences',
	'Lead tags',
	'Sales pipeline stages',
	'Template interest tracking',
	'Audit request tracking',
];

const useCases = [
	{
		title: 'Med spas',
		text: 'Capture treatment interest, route people toward consultations, and follow up with non-booked leads.',
	},
	{
		title: 'Solo practices',
		text: 'Organize new patient inquiries, preferred services, and next steps.',
	},
	{
		title: 'Associations',
		text: 'Support event inquiries, membership interest, resource requests, and contact follow-up.',
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section backend-hero" aria-labelledby="backend-heading">
		<div class="site-container backend-hero__inner">
			<p class="eyebrow">Backend Systems</p>
			<h1 id="backend-heading">A conversion does not end when someone fills out your form.</h1>
			<p class="lead">
				Future Solutions can help connect your website to a backend system for lead capture, booking, CRM organization, follow-up, and pipeline visibility.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
				<a class="button button-secondary" href="/services">View Services</a>
			</div>
		</div>
	</section>

	<section class="section section-muted backend-problem" aria-labelledby="backend-problem-heading">
		<div class="site-container">
			<div class="backend-intro">
				<p class="eyebrow">Operational gap</p>
				<h2 id="backend-problem-heading">Most websites collect leads. A real system manages them.</h2>
				<p class="lead">
					When website inquiries land in an inbox without a clear process, leads can get missed, delayed, or forgotten.
				</p>
			</div>
			<div class="backend-grid backend-grid--4">
				{problems.map((problem) => (
					<article class="card backend-card">
						<h3>{problem.title}</h3>
						<p>{problem.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section backend-flow" aria-labelledby="backend-flow-heading">
		<div class="site-container">
			<div class="backend-intro">
				<p class="eyebrow">Lead path</p>
				<h2 id="backend-flow-heading">A clearer path from inquiry to next step.</h2>
			</div>
			<div class="backend-flow__grid" aria-label="Backend lead system flow">
				{flowSteps.map((step, index) => (
					<article class="card backend-flow__step">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section section-muted backend-support" aria-labelledby="backend-support-heading">
		<div class="site-container">
			<div class="backend-intro">
				<p class="eyebrow">Connected system</p>
				<h2 id="backend-support-heading">What the backend system can support.</h2>
				<p class="lead">
					GoHighLevel can be used as the backend engine for forms, booking, CRM, follow-up, and pipeline management once the account is ready.
				</p>
			</div>
			<div class="backend-grid backend-grid--2">
				{supportedItems.map((item) => (
					<article class="card backend-check">
						<span aria-hidden="true">✓</span>
						<p>{item}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section backend-use-cases" aria-labelledby="backend-use-cases-heading">
		<div class="site-container">
			<div class="backend-intro">
				<p class="eyebrow">Use cases</p>
				<h2 id="backend-use-cases-heading">Useful for more than one kind of business.</h2>
			</div>
			<div class="backend-grid backend-grid--3">
				{useCases.map((useCase) => (
					<article class="card backend-card">
						<h3>{useCase.title}</h3>
						<p>{useCase.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section backend-final" aria-labelledby="backend-final-heading">
		<div class="site-container">
			<div class="backend-final__card">
				<div>
					<p class="eyebrow">Website audit</p>
					<h2 id="backend-final-heading">Want a website that does more after the form?</h2>
					<p class="lead">
						Request a website audit and get a recommendation for how your site could connect trust, lead capture, booking, and follow-up.
					</p>
				</div>
				<div class="button-row">
					<a class="button button-primary" href="/audit">Get a Website Audit</a>
					<a class="button button-secondary" href="/services">View Services</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.backend-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.backend-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 76% 14%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.backend-hero__inner,
	.backend-intro {
		max-width: 820px;
	}

	.backend-hero h1 {
		max-width: 900px;
	}

	.backend-grid,
	.backend-flow__grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.backend-grid--2 {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.backend-grid--3 {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.backend-grid--4 {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.backend-flow__grid {
		grid-template-columns: repeat(6, minmax(0, 1fr));
	}

	.backend-card,
	.backend-flow__step,
	.backend-check {
		padding: 1.25rem;
	}

	.backend-card h3,
	.backend-flow__step h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	.backend-card p,
	.backend-flow__step p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.backend-flow__step span {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 1.25rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}

	.backend-check {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.8rem;
		align-items: start;
	}

	.backend-check span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.35rem;
		height: 1.35rem;
		margin-top: 0.1rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}

	.backend-check p {
		margin: 0;
		font-size: 0.9375rem;
		font-weight: 700;
		line-height: 1.5;
	}

	.backend-final {
		background: var(--color-accent-light);
	}

	.backend-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
		border-radius: 20px;
		background: var(--color-text);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.backend-final .eyebrow {
		color: color-mix(in srgb, var(--color-accent-light) 84%, var(--color-white));
	}

	.backend-final h2,
	.backend-final .lead {
		color: var(--color-white);
	}

	.backend-final .lead {
		opacity: 0.78;
	}

	.backend-final .button-row {
		justify-content: flex-end;
		margin-top: 0;
	}

	.backend-final .button-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.22);
		color: var(--color-white);
	}

	.backend-final .button-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.38);
		color: var(--color-white);
	}

	@media (max-width: 1120px) {
		.backend-flow__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.backend-grid--4 {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 860px) {
		.backend-grid--3 {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.backend-grid--2,
		.backend-grid--4,
		.backend-flow__grid,
		.backend-final__card {
			grid-template-columns: 1fr;
		}

		.backend-final .button-row {
			justify-content: flex-start;
		}
	}
</style>
