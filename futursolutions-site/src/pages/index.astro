---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuditScope from '../components/AuditScope.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import DemoLibraryPreview from '../components/DemoLibraryPreview.astro';
import FinalCTA from '../components/FinalCTA.astro';
import HomeHero from '../components/HomeHero.astro';
import MarketingSystems from '../components/MarketingSystems.astro';
import OfferOverview from '../components/OfferOverview.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ProofStrip from '../components/ProofStrip.astro';
import SectionBridge from '../components/SectionBridge.astro';
import SelectedWork from '../components/SelectedWork.astro';
import ServiceFAQSection from '../components/ServiceFAQSection.astro';
import Testimonials from '../components/Testimonials.astro';
import VisitorJourney from '../components/VisitorJourney.astro';
import { organizationSchema, websiteSchema, faqSchema } from '../data/schema';

const pageTitle = 'FutureSolutions — Premium healthcare websites and Growth Systems';
const pageDescription =
	'Premium websites, customizable Website Foundations, and CRM-connected Growth Systems for clinics, wellness brands, associations, and high-trust service businesses.';
const canonicalUrl = 'https://futuresolutions.io/';

const faqs = [
	{
		question: 'What does FutureSolutions actually do?',
		answer:
			'We design and build premium websites for healthcare and high-trust service businesses, and connect them to the systems behind the scenes — lead capture, booking, and follow-up. You can start with a customizable Website Foundation, a fully custom build, or add a Growth System to a site you already have.',
	},
	{
		question: 'Do I need a custom website or a website foundation?',
		answer:
			'It depends on your stage. A Website Foundation is the fastest, more affordable path to a credible, converting site and fits most clinics and wellness brands. A Signature Custom build makes sense when you have unique positioning, complex content, or a larger team. The free audit makes a clear recommendation either way — no pressure toward the larger option.',
	},
	{
		question: 'Can you work with my existing website?',
		answer:
			'Often, yes. If your current site has a solid foundation, we can restructure key pages, fix the conversion path, and connect follow-up systems without a full rebuild. If it is holding you back, the audit will say so plainly — and a Website Foundation or custom build may be the better investment.',
	},
	{
		question: 'Can you connect my website to GoHighLevel or another CRM?',
		answer:
			'Yes. Forms, calendars, and lead routing connect into GoHighLevel (or a similar CRM), with automated follow-up, review requests, and basic reporting. This can be wired in at launch or added to a site you already have.',
	},
	{
		question: 'Do you write the copy and structure the service pages?',
		answer:
			'Yes. Conversion-focused copy and service-page structure are part of the build — pages are organized around how your visitors actually decide, not filled with placeholder text. You stay involved so every detail is accurate to your practice.',
	},
	{
		question: 'Do you only work with healthcare businesses?',
		answer:
			'We focus on healthcare, wellness, and high-trust, appointment-based businesses — clinics, med spas, private practices, hormone and TRT clinics, wellness brands, and associations. If trust and booked appointments drive your business, you are a good fit, even just outside strict clinical care.',
	},
	{
		question: 'Can you help with SEO or paid ads after launch?',
		answer:
			'Sites are built SEO-aware and campaign-ready, and our Care & Optimization plans support ongoing SEO structure and landing pages for paid traffic. We focus on the website and system side, and we are clear about what we do and do not run so nothing falls through the cracks.',
	},
	{
		question: 'What happens after I request an audit?',
		answer:
			'We review your site, visibility, and follow-up by hand, then send a structured written breakdown of what is working and what to fix first — with a recommendation. No obligation and no sales pitch.',
	},
	{
		question: 'How is this different from hiring a normal web designer?',
		answer:
			'Most designers stop at how the pages look. We plan around your offer, the visitor journey, and the system behind the form — service clarity, conversion path, CRM, follow-up, and tracking — so the site actually generates and handles leads instead of just looking nice.',
	},
	{
		question: 'How long does a build usually take?',
		answer:
			'A Website Foundation is the fastest path to launch; custom builds take longer because of the added strategy and design. We map a realistic timeline during the strategy step so you know what to expect before any work begins.',
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
	schema={[organizationSchema, websiteSchema, faqSchema(faqs)]}
>
	<HomeHero />
	<ProblemSection />
	<SectionBridge label="Next: rebuild the path" text="You've seen where visitors quietly slip away — here's the path we rebuild so more of them actually book." />
	<BeforeAfter />
	<OfferOverview />
	<SectionBridge label="Next: the visitor's journey" text="Whatever starting point you choose, the goal stays the same — guide every visitor along a clear path from first click to booked." />
	<VisitorJourney />
	<SectionBridge label="Next: see it live" text="You've seen how the path should work — now click through a real, live Foundation and see it in action." />
	<DemoLibraryPreview />
	<SelectedWork />
	<ProofStrip />
	<MarketingSystems />
	<SectionBridge label="Next: the free snapshot" text="Before recommending a build, we look for the gaps that are costing clarity, trust, and follow-up." />
	<AuditScope />
	<Testimonials variant="muted" />
	<ServiceFAQSection faqs={faqs} />
	<FinalCTA />
</BaseLayout>

