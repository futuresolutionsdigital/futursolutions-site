---
import BaseLayout from '../layouts/BaseLayout.astro';
import AudienceStrip from '../components/AudienceStrip.astro';
import BackendFlowSection from '../components/BackendFlowSection.astro';
import DemoLibraryPreview from '../components/DemoLibraryPreview.astro';
import FinalCTA from '../components/FinalCTA.astro';
import HomeHero from '../components/HomeHero.astro';
import LaneCards from '../components/LaneCards.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import SeoVisibilitySection from '../components/SeoVisibilitySection.astro';

const pageTitle = 'FutureSolutions — Healthcare websites built like operational systems';
const pageDescription =
	'Premium web design and growth systems for clinics, associations, and high-trust service businesses. Foundations, custom builds, and backend lead systems.';
const canonicalUrl = 'https://futursolutions.vercel.app/';
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<HomeHero />

	<AudienceStrip />
	<ProblemSection />
	<LaneCards />
	<DemoLibraryPreview />
	<SeoVisibilitySection />
	<BackendFlowSection />
	<ProcessSection />
	<FinalCTA />
</BaseLayout>

