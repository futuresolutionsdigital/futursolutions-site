---
import BaseLayout from '../layouts/BaseLayout.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import DemoLibraryPreview from '../components/DemoLibraryPreview.astro';
import FinalCTA from '../components/FinalCTA.astro';
import HomeHero from '../components/HomeHero.astro';
import OfferOverview from '../components/OfferOverview.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ProofStrip from '../components/ProofStrip.astro';
import ServiceFAQSection from '../components/ServiceFAQSection.astro';
import Testimonials from '../components/Testimonials.astro';
import VisitorJourney from '../components/VisitorJourney.astro';
import { organizationSchema, websiteSchema, faqSchema } from '../data/schema';

const pageTitle = 'FutureSolutions — Premium healthcare websites and Growth Systems';
const pageDescription =
	'Premium websites, customizable Website Foundations, and CRM-connected Growth Systems for clinics, wellness brands, associations, and high-trust service businesses.';
const canonicalUrl = 'https://futuresolutions.io/';

const faqs = [
	{
		question: 'What does FutureSolutions actually do?',
		answer:
			'We design and build premium websites for healthcare and high-trust service businesses, and connect them to the systems behind the scenes — lead capture, booking, and follow-up. You can start with a customizable Website Foundation, a fully custom build, or add a Growth System to a site you already have.',
	},
	{
		question: 'Who do you work with?',
		answer:
			'Clinics, med spas, solo and private practices, wellness and functional medicine, hormone and TRT clinics, and healthcare associations — businesses where trust is the product. We work with clients across the United States.',
	},
	{
		question: 'Where do I start?',
		answer:
			'A free Website and Systems Audit. We review your current site, visibility, and follow-up, then send a structured recommendation — with no obligation. It tells us both whether a Foundation, a custom build, or a Growth System is the right next step.',
	},
	{
		question: 'How much does it cost?',
		answer:
			'It depends on the level of system you need. A Website Foundation is a smaller, faster investment than a fully custom build, and a Growth System is scoped to your lead volume. After the audit, you get a fixed, written proposal grounded in your actual scope — no hourly surprises.',
	},
	{
		question: 'How long does it take?',
		answer:
			'A Website Foundation is the fastest path to a credible, converting site; custom builds take longer because of the added strategy and design. We map a realistic timeline during the strategy step so you know what to expect before any work begins.',
	},
	{
		question: 'Can I see examples of your work?',
		answer:
			'Yes — our demo library is full of real, clickable websites built for each industry we serve. Rather than static screenshots, you can explore complete, functioning sites end to end before you ever reach out.',
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
	schema={[organizationSchema, websiteSchema, faqSchema(faqs)]}
>
	<HomeHero />
	<ProblemSection />
	<BeforeAfter />
	<OfferOverview />
	<VisitorJourney />
	<DemoLibraryPreview />
	<ProofStrip />
	<Testimonials variant="muted" />
	<ServiceFAQSection faqs={faqs} />
	<FinalCTA />
</BaseLayout>

