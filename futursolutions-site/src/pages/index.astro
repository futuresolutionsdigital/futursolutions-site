---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClientProof from '../components/ClientProof.astro';
import DemoLibraryPreview from '../components/DemoLibraryPreview.astro';
import FinalCTA from '../components/FinalCTA.astro';
import HomeHero from '../components/HomeHero.astro';
import OfferOverview from '../components/OfferOverview.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import ProofStrip from '../components/ProofStrip.astro';
import SeoVisibilitySection from '../components/SeoVisibilitySection.astro';
import SystemDiagram from '../components/SystemDiagram.astro';
import { organizationSchema, websiteSchema } from '../data/schema';

const pageTitle = 'FutureSolutions — Premium healthcare websites and Growth Systems';
const pageDescription =
	'Premium websites, customizable Website Foundations, and CRM-connected Growth Systems for clinics, wellness brands, associations, and high-trust service businesses.';
const canonicalUrl = 'https://futursolutions.io/';
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
	schema={[organizationSchema, websiteSchema]}
>
	<HomeHero />
	<OfferOverview />
	<ProblemSection />
	<DemoLibraryPreview />
	<SystemDiagram />
	<SeoVisibilitySection />
	<ProcessSection />
	<ProofStrip />
	<ClientProof />
	<FinalCTA />
</BaseLayout>

