---
import { sanityClient } from '../lib/sanity';

const homepageQuery = `*[_type == "homepage"][0]{
  title,
  heroHeading,
  heroSubheading
}`;

const homepage = await sanityClient.fetch<{
  title?: string | null;
  heroHeading?: string | null;
  heroSubheading?: string | null;
} | null>(homepageQuery);

const pageTitle = homepage?.title?.trim() || 'Future Solutions';
const heroHeading = homepage?.heroHeading?.trim() || 'Future Solutions';
const heroSubheading =
  homepage?.heroSubheading?.trim() ||
  'Content will appear here when connected to Sanity.';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<h1>{heroHeading}</h1>
		<p>{heroSubheading}</p>
	</body>
</html>
