---
import BaseLayout from '../layouts/BaseLayout.astro';
import AudienceStrip from '../components/AudienceStrip.astro';
import BackendFlowSection from '../components/BackendFlowSection.astro';
import FinalCTA from '../components/FinalCTA.astro';
import HeroSystemPreview from '../components/HeroSystemPreview.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import ServicesSnapshotSection from '../components/ServicesSnapshotSection.astro';
import SeoVisibilitySection from '../components/SeoVisibilitySection.astro';
import SystemSection from '../components/SystemSection.astro';
import TemplatePreviewSection from '../components/TemplatePreviewSection.astro';

const pageTitle = 'FutureSolutions — Healthcare websites built like operational systems';
const pageDescription =
	'Premium web design and growth systems for clinics, associations, and high-trust service businesses. Foundations, custom builds, and backend lead systems.';
const canonicalUrl = 'https://futursolutions.vercel.app/';
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section homepage-hero" aria-labelledby="homepage-heading">
		<div class="site-container homepage-hero__inner">
			<div class="homepage-hero__content">
				<p class="homepage-hero__eyebrow">Premium web design + growth systems for healthcare</p>
				<h1 id="homepage-heading">Healthcare websites built like operational systems, not brochures.</h1>
				<p class="lead">
					FutureSolutions builds industry-specific website Foundations, signature Custom websites, and the Growth Systems behind them — for clinics, associations, and high-trust service businesses.
				</p>
				<div class="button-row">
					<a class="button button-primary" href="/templates">Explore Live Demos</a>
					<a class="button button-secondary" href="/audit">Get a Website and Systems Audit</a>
				</div>
				<p class="homepage-hero__trust">Built for med spas, solo practices, hormone/TRT clinics, wellness clinics, and professional associations.</p>
			</div>

			<HeroSystemPreview />
		</div>
	</section>

	<AudienceStrip />
	<ProblemSection />
	<SystemSection />
	<TemplatePreviewSection />
	<ServicesSnapshotSection />
	<SeoVisibilitySection />
	<BackendFlowSection />
	<ProcessSection />
	<FinalCTA />
</BaseLayout>

<style>
	.homepage-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8.5vw, 8.25rem);
	}

	.homepage-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 78% 18%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.homepage-hero__inner {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(420px, 0.95fr);
		gap: clamp(3rem, 6vw, 5.5rem);
		align-items: center;
	}

	.homepage-hero__content {
		max-width: 740px;
	}

	.homepage-hero__content h1 {
		max-width: 13.5ch;
		font-size: clamp(3.25rem, 2.55rem + 2.9vw, 4.5rem);
		line-height: 1.04;
	}

	.homepage-hero__eyebrow {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 1.25rem;
		padding: 0.45rem 0.7rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.8125rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		line-height: 1.2;
	}

	.homepage-hero__trust {
		margin-top: 1.25rem;
		color: var(--color-muted);
		font-size: 0.9375rem;
	}

	@media (max-width: 980px) {
		.homepage-hero__inner {
			grid-template-columns: 1fr;
		}

		.homepage-hero__content h1 {
			max-width: 820px;
		}
	}

	@media (max-width: 620px) {
		.homepage-hero {
			padding-block: 3.75rem;
		}

		.homepage-hero__eyebrow {
			font-size: 0.75rem;
		}
	}
</style>
