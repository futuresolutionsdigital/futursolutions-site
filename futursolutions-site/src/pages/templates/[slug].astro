---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FoundationAtAGlance from '../../components/FoundationAtAGlance.astro';
import TemplateDetailHero from '../../components/TemplateDetailHero.astro';
import TemplateDetailSection from '../../components/TemplateDetailSection.astro';
import TemplateFinalCTA from '../../components/TemplateFinalCTA.astro';
import { templateSystems, foundationPalette, type TemplateSystem } from '../../data/templates';

export function getStaticPaths() {
	return templateSystems.map((template) => ({
		params: { slug: template.slug },
		props: { template },
	}));
}

interface Props {
	template: TemplateSystem;
}

const { template } = Astro.props;
const pageTitle = `${template.name} | FutureSolutions`;
const pageDescription = template.shortDescription;
const canonicalUrl = `https://futursolutions.vercel.app${template.detailUrl}`;
const backendFlow = ['Form Submission', 'CRM Contact', 'Booking Request', 'Follow-Up', 'Pipeline'];
const processSteps = [
	'Choose the Foundation',
	'Customize brand, content, and services',
	'Connect SEO and Growth Systems',
	'Launch and optimize',
];

const palette = foundationPalette[template.slug];
const paletteVars = palette
	? `--foundation-accent:${palette.accent};--foundation-tint:${palette.tint};--foundation-ink:${palette.ink};`
	: undefined;
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<div class="foundation-page" style={paletteVars} data-foundation-slug={template.slug}>
	<TemplateDetailHero template={template} />

	<FoundationAtAGlance template={template} />

	{template.audienceDetails && template.audienceDetails.length > 0 ? (
		<section class="section detail-audience-rich" aria-labelledby="detail-audience-heading">
			<div class="site-container">
				<div class="detail-audience-rich__intro">
					<p class="eyebrow">Audience</p>
					<h2 id="detail-audience-heading">Who this Foundation is for</h2>
					<p class="lead">{template.audience}</p>
				</div>
				<div class="detail-audience-rich__grid">
					{template.audienceDetails.map((item) => (
						<article class="card detail-audience-rich__card">
							<h3>{item.label}</h3>
							<p>{item.desc}</p>
						</article>
					))}
				</div>
			</div>
		</section>
	) : (
		<TemplateDetailSection
			eyebrow="Audience"
			heading="Who it's for"
			description={template.audience}
			items={template.businessTypes}
			columns={3}
		/>
	)}

	<TemplateDetailSection
		variant="muted"
		eyebrow="Problems solved"
		heading="What this system helps fix"
		description={template.slug === 'hormone-trt'
			? "Men's health sites face unique trust and conversion challenges. This Foundation addresses the gaps that keep TRT and hormone clinics from converting qualified patients."
			: 'The structure is designed to address common gaps that keep healthcare websites from earning trust, being found, and converting qualified visitors.'
		}
		items={template.problemsSolved}
		columns={2}
	/>

	{template.pageDetails && template.pageDetails.length > 0 ? (
		<section class="section detail-pages" aria-labelledby="detail-pages-heading">
			<div class="site-container">
				<div class="detail-pages__intro">
					<p class="eyebrow">Included pages</p>
					<h2 id="detail-pages-heading">A complete page system, already mapped out.</h2>
					<p class="lead">{template.pageDetails.length} pages, each planned as part of a practical website system — not a disconnected design mockup.</p>
				</div>
				<ol class="detail-pages__list">
					{template.pageDetails.map((page, i) => (
						<li class="detail-pages__item">
							<span class="detail-pages__num">{String(i + 1).padStart(2, '0')}</span>
							<div>
								<h3>{page.name}</h3>
								<p>{page.purpose}</p>
							</div>
						</li>
					))}
				</ol>
			</div>
		</section>
	) : (
		<TemplateDetailSection
			eyebrow="Included pages"
			heading="Core pages included"
			description="Each page is planned as part of a practical website system, not as a disconnected design mockup."
			items={template.includedPages}
			variant="checklist"
			columns={3}
		/>
	)}

	{template.strategicFeatures && template.strategicFeatures.length > 0 && (
		<section class="section section-muted detail-strategic" aria-labelledby="detail-strategic-heading">
			<div class="site-container">
				<div class="detail-strategic__intro">
					<p class="eyebrow">Strategic features</p>
					<h2 id="detail-strategic-heading">Built for the way these visitors actually make decisions.</h2>
					<p class="lead">Every structural decision in this Foundation exists to move a visitor from curiosity to a confident next step.</p>
				</div>
				<div class="detail-strategic__grid">
					{template.strategicFeatures.map((f) => (
						<article class="card detail-strategic__card">
							<h3>{f.title}</h3>
							<p>{f.desc}</p>
						</article>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- Mid-page CTA break -->
	<div class="detail-mid-cta" aria-label="Call to action">
		<div class="site-container detail-mid-cta__inner">
			<p class="detail-mid-cta__text">Ready to see it live?</p>
			<div class="detail-mid-cta__actions">
				{template.demoUrl ? (
					<a class="button button-primary detail-mid-cta__primary" href={template.demoUrl}>
						View Live Demo
						<span aria-hidden="true">&rarr;</span>
					</a>
				) : (
					<a class="button button-primary detail-mid-cta__primary" href="/templates">
						Browse Foundations
					</a>
				)}
				<a class="detail-mid-cta__link" href={template.auditUrl}>Get This Foundation Customized</a>
			</div>
		</div>
	</div>

	<!-- Conversion features — compact checklist strip -->
	<section class="section section-muted detail-conversion-strip" aria-labelledby="detail-conversion-heading">
		<div class="site-container">
			<div class="detail-conversion-strip__intro">
				<p class="eyebrow">Conversion</p>
				<h2 id="detail-conversion-heading">Conversion features built into every page.</h2>
			</div>
			<ul class="detail-conversion-strip__list">
				{template.conversionFeatures.map((f) => {
					const item = typeof f === 'string' ? { text: f } : f;
					return (
						<li class="detail-conversion-strip__item">
							<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M3.5 8 6 10.5l6.5-7" />
							</svg>
							<span>{item.title ? `${item.title} — ${item.text}` : item.text}</span>
						</li>
					);
				})}
			</ul>
		</div>
	</section>

	<TemplateDetailSection
		eyebrow="Local visibility"
		heading="SEO and local visibility features"
		items={template.seoFeatures}
		variant="checklist"
		columns={2}
	/>

	{template.whyDifferent && template.whyDifferent.length > 0 && (
		<section class="section detail-why-different" aria-labelledby="detail-why-different-heading">
			<div class="site-container">
				<div class="detail-why-different__intro">
					<p class="eyebrow">Differentiation</p>
					<h2 id="detail-why-different-heading">Why this Foundation is different</h2>
				</div>
				<div class="detail-why-different__grid">
					{template.whyDifferent.map((item, index) => (
						<article class="card detail-why-different__card">
							<span class="detail-why-different__num">{String(index + 1).padStart(2, '0')}</span>
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>
	)}

	<section class="section section-ink detail-backend" aria-labelledby="detail-backend-heading">
		<div class="site-container">
			<div class="detail-backend__intro">
				<p class="eyebrow detail-backend__eyebrow">Growth System ready</p>
				<h2 id="detail-backend-heading">Built to connect to a real Growth System when you're ready.</h2>
				<p class="lead">
					This Foundation can later connect to GoHighLevel for lead capture, booking, CRM follow-up, and pipeline tracking.
				</p>
			</div>
			<div class="detail-backend__pipeline" aria-label="Growth System pipeline">
				{backendFlow.map((step, index) => (
					<>
						<div class="detail-backend__node">
							<span class="detail-backend__node-num">{String(index + 1).padStart(2, '0')}</span>
							<p class="detail-backend__node-label">{step}</p>
						</div>
						{index < backendFlow.length - 1 && (
							<span class="detail-backend__connector" aria-hidden="true">
								<svg viewBox="0 0 20 8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
									<path d="M0 4h16M14 1l3 3-3 3" />
								</svg>
							</span>
						)}
					</>
				))}
			</div>
			<div class="detail-backend__features">
				{template.backendFeatures.map((feature) => <span>{feature}</span>)}
			</div>
		</div>
	</section>

	<section class="section detail-process" aria-labelledby="detail-process-heading">
		<div class="site-container">
			<div class="detail-process__intro">
				<p class="eyebrow">Customization process</p>
				<h2 id="detail-process-heading">How a {template.category} Foundation becomes a launch-ready system.</h2>
			</div>
			<div class="detail-process__grid">
				{processSteps.map((step, index) => (
					<article class="card detail-process__card">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<h3>{step}</h3>
					</article>
				))}
			</div>
		</div>
	</section>

	{template.customizationOptions && template.customizationOptions.length > 0 && (
		<section class="section section-muted detail-customize" aria-labelledby="detail-customize-heading">
			<div class="site-container">
				<div class="detail-customize__intro">
					<p class="eyebrow">Customization</p>
					<h2 id="detail-customize-heading">Adapt this Foundation to a real {template.category.toLowerCase()} brand.</h2>
					<p class="lead">Everything in the demo is designed to be replaced with your real details, services, photography, and booking workflow.</p>
				</div>
				<ul class="detail-customize__list">
					{template.customizationOptions.map((opt) => (
						<li class="detail-customize__item">
							<svg aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M3.5 8 6 10.5l6.5-7" />
							</svg>
							<span>{opt}</span>
						</li>
					))}
				</ul>
			</div>
		</section>
	)}

	{template.salesFaqs && template.salesFaqs.length > 0 && (
		<section class="section detail-faq" aria-labelledby="detail-faq-heading">
			<div class="site-container">
				<div class="detail-faq__intro">
					<p class="eyebrow">Common questions</p>
					<h2 id="detail-faq-heading">Frequently asked about this Foundation.</h2>
				</div>
				<div class="detail-faq__list">
					{template.salesFaqs.map((faq) => (
						<details class="detail-faq__item">
							<summary class="detail-faq__q">
								{faq.q}
								<svg aria-hidden="true" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4.5 7 9 11.5 13.5 7" />
								</svg>
							</summary>
							<div class="detail-faq__a"><p>{faq.a}</p></div>
						</details>
					))}
				</div>
			</div>
		</section>
	)}

	<TemplateFinalCTA demoUrl={template.demoUrl} auditUrl={template.auditUrl} />
	</div>
</BaseLayout>

<style>
	.detail-why-different__intro {
		max-width: 780px;
	}

	.detail-why-different__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.detail-why-different__card {
		padding: 1.4rem;
	}

	.detail-why-different__num {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 1rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--foundation-accent, var(--color-accent)) 35%, var(--color-border));
		border-radius: 999px;
		background: color-mix(in srgb, var(--foundation-accent, var(--color-accent)) 12%, var(--color-white));
		color: var(--foundation-ink, var(--color-accent-dark));
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}

	.detail-why-different__card h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	.detail-why-different__card p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	/* ═══ Mid-page CTA divider ═══ */
	.detail-mid-cta {
		padding: clamp(1.5rem, 3vw, 2rem) 0;
		background: color-mix(in srgb, var(--foundation-tint, var(--lane-foundation-tint)) 50%, var(--color-white));
		border-block: 1px solid color-mix(in srgb, var(--foundation-accent, var(--lane-foundation)) 12%, var(--color-border-soft));
	}

	.detail-mid-cta__inner {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.detail-mid-cta__text {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--color-text);
	}

	.detail-mid-cta__actions {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.detail-mid-cta__primary {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}

	.detail-mid-cta__primary span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.detail-mid-cta__primary:hover span {
		transform: translateX(2px);
	}

	.detail-mid-cta__link {
		color: var(--foundation-ink, var(--color-text));
		font-size: 0.88rem;
		font-weight: 650;
		text-decoration: underline;
		text-underline-offset: 3px;
		transition: color var(--transition-base);
	}

	.detail-mid-cta__link:hover {
		color: var(--color-text);
	}

	/* ═══ Conversion checklist strip ═══ */
	.detail-conversion-strip__intro {
		max-width: 780px;
	}

	.detail-conversion-strip__list {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		max-width: 720px;
		margin: clamp(1.5rem, 3vw, 2rem) 0 0;
		padding: 0;
		list-style: none;
	}

	.detail-conversion-strip__item {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		padding: 0.7rem 0.85rem;
		border-bottom: 1px solid var(--color-border-soft);
	}

	.detail-conversion-strip__item:first-child {
		border-top: 1px solid var(--color-border-soft);
	}

	.detail-conversion-strip__item:nth-child(even) {
		background: color-mix(in srgb, var(--foundation-tint, var(--lane-foundation-tint)) 30%, var(--color-white));
	}

	.detail-conversion-strip__item svg {
		flex-shrink: 0;
		width: 0.95rem;
		height: 0.95rem;
		color: var(--foundation-accent, var(--lane-foundation));
	}

	.detail-conversion-strip__item span {
		font-size: 0.92rem;
		font-weight: 550;
		color: var(--color-text);
		line-height: 1.45;
	}

	/* ═══ Dark pipeline — Growth System ═══ */
	.detail-backend {
		background: var(--color-ink);
		color: var(--color-white);
	}

	.detail-backend__intro {
		max-width: 780px;
	}

	.detail-backend__eyebrow {
		color: var(--lane-growth) !important;
	}

	.detail-backend__intro h2 {
		color: var(--color-white);
	}

	.detail-backend__intro .lead {
		color: rgba(255, 255, 255, 0.75);
	}

	.detail-backend__pipeline {
		display: flex;
		align-items: center;
		gap: 0;
		margin-top: clamp(2rem, 4vw, 3rem);
		overflow-x: auto;
		padding-bottom: 0.5rem;
	}

	.detail-backend__node {
		flex-shrink: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.55rem;
		padding: 1.2rem 1rem;
		min-width: 120px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: var(--radius-md);
		background: rgba(255, 255, 255, 0.04);
	}

	.detail-backend__node-num {
		display: inline-flex;
		padding: 0.3rem 0.5rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--lane-growth) 22%, transparent);
		color: var(--lane-growth);
		font-size: 0.68rem;
		font-weight: 800;
		line-height: 1;
	}

	.detail-backend__node-label {
		margin: 0;
		font-size: 0.88rem;
		font-weight: 700;
		text-align: center;
		color: rgba(255, 255, 255, 0.85);
	}

	.detail-backend__connector {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		padding: 0 0.25rem;
	}

	.detail-backend__connector svg {
		width: 1.2rem;
		height: 0.5rem;
		color: rgba(255, 255, 255, 0.28);
	}

	.detail-backend__features {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: 1.5rem;
	}

	.detail-backend__features span {
		display: inline-flex;
		padding: 0.42rem 0.65rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.04);
		color: rgba(255, 255, 255, 0.65);
		font-size: 0.8125rem;
		font-weight: 700;
	}

	.detail-process__intro {
		max-width: 780px;
	}

	.detail-process__grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.detail-process__card {
		padding: 1.25rem;
	}

	.detail-process__card span {
		display: inline-flex;
		margin-bottom: 1.25rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--foundation-accent, var(--color-accent)) 35%, var(--color-border));
		border-radius: 999px;
		background: color-mix(in srgb, var(--foundation-accent, var(--color-accent)) 12%, var(--color-white));
		color: var(--foundation-ink, var(--color-accent-dark));
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}

	.detail-process__card h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	/* Rich audience (per-template detail) */
	.detail-audience-rich__intro,
	.detail-pages__intro,
	.detail-strategic__intro,
	.detail-customize__intro,
	.detail-faq__intro {
		max-width: 780px;
	}

	.detail-audience-rich__grid,
	.detail-strategic__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.detail-audience-rich__card,
	.detail-strategic__card {
		padding: 1.25rem;
	}

	.detail-audience-rich__card h3,
	.detail-strategic__card h3 {
		font-size: 1rem;
		margin-bottom: 0.3rem;
		letter-spacing: -0.02em;
	}

	.detail-audience-rich__card p,
	.detail-strategic__card p {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.55;
	}

	/* Page list */
	.detail-pages__list {
		display: grid;
		gap: 0;
		max-width: 820px;
		margin: clamp(2rem, 4vw, 3rem) 0 0;
		padding: 0;
		list-style: none;
	}

	.detail-pages__item {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		padding-block: clamp(1rem, 2vw, 1.35rem);
		border-bottom: 1px solid var(--color-border);
	}

	.detail-pages__item:first-child {
		border-top: 1px solid var(--color-border);
	}

	.detail-pages__item:nth-child(even) {
		background: color-mix(in srgb, var(--foundation-tint, var(--lane-foundation-tint)) 35%, var(--color-white));
		padding-inline: 1rem;
		margin-inline: -1rem;
		border-radius: var(--radius-sm);
	}

	.detail-pages__num {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.8rem;
		padding: 0.3rem 0.45rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--foundation-accent, var(--lane-foundation)) 14%, var(--color-white));
		color: var(--foundation-ink, var(--lane-foundation-ink));
		font-size: 0.68rem;
		font-weight: 800;
		line-height: 1;
		margin-top: 0.15rem;
	}

	.detail-pages__item h3 {
		font-size: 1.05rem;
		margin-bottom: 0.15rem;
		letter-spacing: -0.02em;
	}

	.detail-pages__item p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.55;
	}

	/* Customization list */
	.detail-customize__list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.5rem 2rem;
		max-width: 820px;
		margin: clamp(2rem, 4vw, 3rem) 0 0;
		padding: 0;
		list-style: none;
	}

	.detail-customize__item {
		display: flex;
		align-items: flex-start;
		gap: 0.6rem;
		padding-block: 0.55rem;
	}

	.detail-customize__item svg {
		flex-shrink: 0;
		width: 1rem;
		height: 1rem;
		margin-top: 0.2rem;
		color: var(--foundation-accent, var(--lane-foundation));
	}

	.detail-customize__item span {
		font-size: 0.92rem;
		font-weight: 500;
		color: var(--color-text);
		line-height: 1.5;
	}

	/* FAQ accordion */
