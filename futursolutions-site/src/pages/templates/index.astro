---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TemplateCard from '../../components/TemplateCard.astro';
import ServiceFAQSection from '../../components/ServiceFAQSection.astro';
import { templateSystems, templateBrowseFilterDefs } from '../../data/templates';

const pageTitle = 'Website Foundations | FutureSolutions';
const pageDescription =
	'A premium website foundation, customized around your business. Start from a proven FutureSolutions framework and shape it around your brand, services, and lead path — the smart middle path between cheap templates and fully custom.';
const canonicalUrl = 'https://futuresolutions.io/templates/';

const heroChips = [
	'From $3,500',
	'Customized framework',
	'Faster than fully custom',
	'Growth-system ready',
];

// "What is a Website Foundation" — a not-this / this contrast keeps the offer
// from reading like a cheap template.
const notThis = [
	'A generic theme reskin',
	'Placeholder page structure',
	'A pretty design with no lead path',
	'Content locked away from you',
];
const insteadThis = [
	'A proven structure customized to your business',
	'Service pages built around visitor intent',
	'A clear call-to-action and booking path',
	'Editable content where it matters',
];

const bestForCards = [
	'Outdated sites that need a professional rebuild',
	'Wellness clinics and med spas',
	'Solo practices and consultants',
	'Hormone / TRT and high-trust health brands',
	'Local and appointment-based service businesses',
	'Teams that need a clearer path from visitor to inquiry',
];

const includeCategories = [
	{
		title: 'Strategy & structure',
		items: ['Offer clarity', 'Page map', 'Visitor journey', 'Service-page planning'],
	},
	{
		title: 'Design customization',
		items: ['Brand adaptation', 'Section styling', 'Imagery direction', 'Mobile-first layout'],
	},
	{
		title: 'Core pages',
		items: ['Homepage', 'Service pages', 'About', 'Contact / booking', 'FAQs & trust sections', 'Optional resources structure'],
	},
	{
		title: 'Lead path',
		items: ['CTA hierarchy', 'Inquiry / booking path', 'Form placement', 'Follow-up readiness'],
	},
	{
		title: 'SEO & tracking foundation',
		items: ['SEO-aware structure', 'Metadata basics', 'Local visibility', 'GA4 / GSC / GTM readiness'],
	},
	{
		title: 'Editable content',
		items: ['Sanity CMS where useful', 'Key content stays manageable after launch'],
	},
	{
		title: 'Launch support',
		items: ['Responsive QA', 'Form testing', 'Deployment', 'Post-launch walkthrough'],
	},
];

const processSteps = [
	{ step: '01', title: 'Free Snapshot & discovery', text: 'We review your current site, lead path, and goals — and confirm a Foundation is the right fit.' },
	{ step: '02', title: 'Foundation direction', text: 'We choose the strongest starting framework for your business, audience, and service model.' },
	{ step: '03', title: 'Structure & content', text: 'We map the pages, service structure, and conversion path, then shape the copy around how visitors decide.' },
	{ step: '04', title: 'Design customization', text: 'We adapt the look, sections, imagery, and messaging to your brand so it feels genuinely custom.' },
	{ step: '05', title: 'Build & connect', text: 'We build the site, connect forms and tracking, and prepare the lead and booking path.' },
	{ step: '06', title: 'Launch & improve', text: 'We test, launch, and recommend next improvements or ongoing management support.' },
];

const comparison = [
	{
		lane: 'foundation',
		name: 'Website Foundation',
		tag: 'Core offer',
		points: [
			'Faster path to launch',
			'Starts from a proven framework',
			'Customized around your brand and services',
			'Best for common high-trust service-business needs',
			'Lower starting investment',
			'Ideal when you need a professional site without a full custom process',
		],
	},
	{
		lane: 'custom',
		name: 'Signature Custom Website',
		tag: 'Premium path',
		points: [
			'Deeper strategy and design',
			'Custom page architecture',
			'Custom content model',
			'Best for complex organizations or unique positioning',
			'Higher investment',
			'Ideal when a framework approach would be too limiting',
		],
	},
];

const growthAddItems = [
	'CRM pipeline',
	'Booking / calendar routing',
	'Form notifications',
	'Email / SMS follow-up',
	'Review request flow',
	'Reporting and lead visibility',
];

const pricingTiers = [
	{
		name: 'Foundation Starter',
		price: 'From $3,500',
		text: 'A focused site foundation for a clean, professional launch.',
		featured: false,
	},
	{
		name: 'Foundation Plus',
		price: 'Typically $5,000–$6,500',
		text: 'More pages, deeper service structure, stronger content support, and added launch preparation.',
		featured: true,
	},
	{
		name: 'Foundation + Growth System',
		price: 'Quoted after your Snapshot',
		text: 'Your Website Foundation plus CRM, booking, follow-up, and reporting setup.',
		featured: false,
	},
];

const foundationFaqs = [
	{
		question: 'Is this just a template?',
		answer:
			'No. A Website Foundation starts from a proven framework, then we customize the structure, content, and design around your business. The result is a real, conversion-ready site — not a prebuilt theme you have to force your business into.',
	},
	{
		question: 'What can be customized?',
		answer:
			'Your brand, colors, imagery, services, page structure, copy, and lead path. The strategic structure stays intact while everything that makes the site yours is tailored.',
	},
	{
		question: 'Can I edit the site myself?',
		answer:
			'Yes, where it matters. Key content areas are set up in an editable CMS (such as Sanity) so you can update text and content after launch without breaking the design.',
	},
	{
		question: 'What pages are included?',
		answer:
			'Typically a homepage, a services overview and individual service pages, an about page, and a contact or booking page, plus trust and FAQ sections. Final page count depends on your business and is confirmed during the Snapshot.',
	},
	{
		question: 'Do you write the copy?',
		answer:
			'Yes. Conversion-focused copy and service-page structure are part of the build, organized around how your visitors actually decide. You stay involved so everything is accurate to your business.',
	},
	{
		question: 'Can you connect it to GoHighLevel or another CRM?',
		answer:
			'Yes. Forms, booking, and lead routing can connect to GoHighLevel or a similar CRM as a Growth System — at launch or later.',
	},
	{
		question: 'What if I need something fully custom?',
		answer:
			'Then a Signature Custom Website is the better path. If a Foundation would be too limiting, we will say so in your Snapshot and recommend the custom route.',
	},
	{
		question: 'How long does it take?',
		answer:
			'Because the structure is already proven, Foundations typically launch in weeks rather than months. We map a realistic timeline during the Snapshot before any work begins.',
	},
	{
		question: 'What happens after launch?',
		answer:
			'You can manage editable content yourself, or add an ongoing management plan for updates, content, SEO structure, reporting, and continued optimization.',
	},
	{
		question: 'Do I need a Free Snapshot first?',
		answer:
			'It is the best starting point. The free Website & Lead Flow Snapshot reviews your situation and recommends whether a Foundation, a custom build, or something simpler fits — with no pressure.',
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<!-- SECTION 1 — HERO -->
	<section class="section templates-hero" aria-labelledby="templates-heading">
		<div class="site-container templates-hero__inner">
			<p class="eyebrow">Website Foundations</p>
			<h1 id="templates-heading">A premium website foundation, customized around your business.</h1>
			<p class="lead">
				Start with a proven FutureSolutions framework, then shape it around your brand, services, audience, and lead path — so you can launch faster without settling for a generic template.
			</p>
			<ul class="templates-hero__chips" aria-label="Website Foundation highlights">
				{heroChips.map((chip, i) => (
					<li class:list={[{ 'is-accent': i === 0 }]}>{chip}</li>
				))}
			</ul>
			<div class="button-row">
				<a class="button button-primary" href="/audit">Get My Free Snapshot</a>
				<a class="button button-secondary" href="#foundation-examples">Explore Foundation Examples</a>
			</div>
			<p class="templates-hero__micro">Free Loom review · Clear recommendation · No pressure</p>
		</div>
	</section>

	<!-- SECTION 2 — WHAT A WEBSITE FOUNDATION IS -->
	<section class="section templates-define" aria-labelledby="templates-define-heading">
		<div class="site-container templates-define__inner">
			<div class="templates-define__copy">
				<p class="eyebrow">The middle path</p>
				<h2 id="templates-define-heading">What is a Website Foundation?</h2>
				<p class="lead">
					A Website Foundation is a premium, customizable website built from a proven FutureSolutions framework — then tailored around your brand, services, service pages, content needs, and lead path.
				</p>
				<p>
					It is not a theme reskin or a generic template swap. The structure is planned around the pieces most high-trust service businesses actually need: clarity, trust, mobile experience, service-page strategy, lead capture, and editable content.
				</p>
			</div>
			<div class="templates-define__compare" role="group" aria-label="What a Website Foundation is not, versus what it is">
				<div class="templates-define__col templates-define__col--not">
					<p class="templates-define__col-label">Not this</p>
					<ul>
						{notThis.map((item) => (
							<li>
								<span class="templates-define__icon templates-define__icon--x" aria-hidden="true">
									<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="4" x2="12" y2="12" /><line x1="12" y1="4" x2="4" y2="12" /></svg>
								</span>
								{item}
							</li>
						))}
					</ul>
				</div>
				<div class="templates-define__col templates-define__col--yes">
					<p class="templates-define__col-label">Instead</p>
					<ul>
						{insteadThis.map((item) => (
							<li>
								<span class="templates-define__icon templates-define__icon--check" aria-hidden="true">
									<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3,8.5 6.5,12 13,4" /></svg>
								</span>
								{item}
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- SECTION 3 — BEST FOR -->
	<section class="section section-muted templates-bestfor" aria-labelledby="templates-bestfor-heading">
		<div class="site-container">
			<div class="templates-bestfor__intro">
				<p class="eyebrow">Best fit</p>
				<h2 id="templates-bestfor-heading">Built for businesses that need a stronger site without a fully custom process.</h2>
			</div>
			<ul class="templates-bestfor__grid">
				{bestForCards.map((item) => (
					<li class="card templates-bestfor__card">
						<span class="templates-bestfor__check" aria-hidden="true">
							<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3,8.5 6.5,12 13,4" /></svg>
						</span>
						<span>{item}</span>
					</li>
				))}
			</ul>
			<div class="templates-bestfor__note">
				<p class="templates-bestfor__note-label">Better fit for a custom build</p>
				<p>
					A Foundation may not be the right fit for complex membership portals, large associations with legacy AMS/CMS constraints, heavy custom integrations, large content libraries, or deeply custom brand systems. When that is the case, we will point you toward a
					<a href="/services/custom-healthcare-websites">Signature Custom Website</a>
					<!-- TODO: link "Web & Business Systems Consulting" once a dedicated /services/web-business-systems-consulting page exists -->
					or business systems consulting instead.
				</p>
			</div>
		</div>
	</section>

	<!-- SECTION 4 — WHAT IS INCLUDED -->
	<section class="section templates-include" aria-labelledby="templates-include-heading">
		<div class="site-container">
			<div class="templates-include__intro">
				<p class="eyebrow">What you get</p>
				<h2 id="templates-include-heading">What your Foundation can include.</h2>
				<p class="lead">You are not handed a theme to figure out. You get a complete, launch-ready website with your content in place and a clear path for visitors to take the next step.</p>
			</div>
			<div class="templates-include__grid">
				{includeCategories.map((cat) => (
					<article class="card templates-include__card">
						<h3>{cat.title}</h3>
						<ul>
							{cat.items.map((item) => (
								<li>
									<span class="templates-include__check" aria-hidden="true">
										<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3,8.5 6.5,12 13,4" /></svg>
									</span>
									{item}
								</li>
							))}
						</ul>
					</article>
				))}
			</div>
			<p class="templates-include__note">Final scope depends on page count, content needs, integrations, and whether a Growth System is included.</p>
		</div>
	</section>

	<!-- SECTION 5 — HOW IT WORKS -->
	<section class="section section-muted templates-process" aria-labelledby="templates-process-heading">
		<div class="site-container">
			<div class="templates-process__intro">
				<p class="eyebrow">How it works</p>
				<h2 id="templates-process-heading">How a Website Foundation comes together.</h2>
				<p class="lead">A clear, low-pressure path from first conversation to a launched site you can keep improving.</p>
			</div>
			<ol class="templates-process__grid">
				{processSteps.map((step) => (
					<li class="card templates-process__card">
						<span class="templates-process__step">{step.step}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</li>
				))}
			</ol>
		</div>
	</section>

	<!-- SECTION 6 — FOUNDATION EXAMPLES / DEMOS -->
	<section id="foundation-examples" class="section templates-examples" aria-labelledby="templates-examples-heading">
		<div class="site-container">
			<div class="templates-examples__intro">
				<p class="eyebrow">Foundation examples</p>
				<h2 id="templates-examples-heading">Explore foundation starting points.</h2>
				<p class="lead">
					These examples are not one-size-fits-all templates. They are real, clickable starting points — structured around the pages, trust signals, and conversion paths an industry needs — that we customize around your brand, services, content, and lead path.
				</p>
			</div>
			<div
				id="template-browse-toolbar"
				class="template-browse-filters"
				role="toolbar"
				aria-label="Filter Foundations"
			>
				<button type="button" class="template-browse-filters__chip is-active" data-template-filter="all" aria-pressed="true">
					All
				</button>
				{templateBrowseFilterDefs.map((chip) => (
					<button
						type="button"
						class="template-browse-filters__chip"
						data-template-filter={chip.id}
						aria-pressed="false"
					>
						{chip.label}
					</button>
				))}
			</div>
			<div id="featured-templates-grid" class="templates-examples__grid">
				{templateSystems.map((template, index) => <TemplateCard template={template} priority={index + 1} />)}
			</div>
		</div>
	</section>

	<script is:inline>
		(() => {
			const grid = document.getElementById('featured-templates-grid');
			const toolbar = document.getElementById('template-browse-toolbar');
			if (!grid || !toolbar) return;
			const chips = toolbar.querySelectorAll('[data-template-filter]');
			const cards = grid.querySelectorAll('[data-template-card]');

			function apply(filterId) {
				chips.forEach((chip) => {
					const id = chip.getAttribute('data-template-filter') || 'all';
					const active = id === filterId;
					chip.setAttribute('aria-pressed', active ? 'true' : 'false');
					chip.classList.toggle('is-active', active);
				});

				cards.forEach((card) => {
					const raw = card.getAttribute('data-template-filters') || '';
					const tokens = raw.split(/\s+/).filter(Boolean);
					const show = filterId === 'all' || tokens.includes(filterId);
					card.hidden = !show;
				});
			}

			toolbar.addEventListener('click', (event) => {
				const chip = event.target && event.target.closest('[data-template-filter]');
				if (!chip || !toolbar.contains(chip)) return;
				apply(chip.getAttribute('data-template-filter') || 'all');
			});
		})();
	</script>

	<!-- SECTION 7 — FOUNDATION VS CUSTOM -->
	<section class="section section-muted templates-vs" aria-labelledby="templates-vs-heading">
		<div class="site-container">
			<div class="templates-vs__intro">
				<p class="eyebrow">Foundation or fully custom?</p>
				<h2 id="templates-vs-heading">Which path fits your business?</h2>
				<p class="lead">Most businesses are well served by a Foundation. A Signature Custom Website makes sense when the framework approach would be too limiting.</p>
			</div>
			<div class="templates-vs__grid">
				{comparison.map((col) => (
					<article class={`card templates-vs__card lane-accent-top lane-accent-top--${col.lane}`}>
						<span class={`lane-tag lane-tag--${col.lane}`}>{col.tag}</span>
						<h3>{col.name}</h3>
						<ul>
							{col.points.map((point) => (
								<li>
									<span class="templates-vs__check" aria-hidden="true">
										<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3,8.5 6.5,12 13,4" /></svg>
									</span>
									{point}
								</li>
							))}
						</ul>
					</article>
				))}
			</div>
			<div class="templates-vs__cta">
				<a class="button button-primary" href="/audit">Get My Free Snapshot</a>
				<p class="templates-vs__cta-note">Not sure which path fits? The free snapshot makes a clear recommendation.</p>
			</div>
		</div>
	</section>

	<!-- SECTION 8 — OPTIONAL GROWTH SYSTEM ADD-ON -->
	<section class="section templates-growth" aria-labelledby="templates-growth-heading">
		<div class="site-container">
			<div class="templates-growth__card">
				<div class="templates-growth__copy">
					<p class="eyebrow">Optional add-on</p>
					<h2 id="templates-growth-heading">Add a Growth System when your site needs more than a form.</h2>
					<p class="lead">
						If your website also needs to connect to CRM, booking, automated follow-up, review requests, and reporting, a Growth System can be added to your Website Foundation — at launch or after it is live.
					</p>
					<a class="button button-primary templates-growth__btn" href="/services/growth-systems">Add a Growth System</a>
				</div>
				<ul class="templates-growth__list">
					{growthAddItems.map((item) => (
						<li>
							<span class="templates-growth__check" aria-hidden="true">
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3,8.5 6.5,12 13,4" /></svg>
							</span>
							{item}
						</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<!-- SECTION 9 — PRICING / STARTING POINT -->
	<section class="section section-muted templates-pricing" aria-labelledby="templates-pricing-heading">
		<div class="site-container">
			<div class="templates-pricing__intro">
				<p class="eyebrow">Starting point</p>
				<h2 id="templates-pricing-heading">Website Foundations start at $3,500.</h2>
				<p class="lead">Final scope depends on page count, content needs, integrations, and whether a Growth System or ongoing management plan is included.</p>
			</div>
			<div class="templates-pricing__grid">
				{pricingTiers.map((tier) => (
					<article class:list={['card', 'templates-pricing__card', { 'is-featured': tier.featured }]}>
						{tier.featured && <span class="templates-pricing__badge">Most popular</span>}
						<h3>{tier.name}</h3>
						<p class="templates-pricing__price">{tier.price}</p>
						<p class="templates-pricing__text">{tier.text}</p>
					</article>
				))}
			</div>
			<div class="templates-pricing__cta">
				<a class="button button-primary" href="/audit">Get My Free Snapshot</a>
				<p class="templates-pricing__cta-note">Your Snapshot includes a clear recommendation and starting point — no pressure.</p>
			</div>
		</div>
	</section>

	<!-- SECTION 10 — FAQ -->
	<ServiceFAQSection faqs={foundationFaqs} />

	<!-- SECTION 11 — FINAL CTA -->
	<section class="section templates-final" aria-labelledby="templates-final-heading">
		<div class="site-container">
			<div class="templates-final__card">
				<div class="templates-final__copy">
					<p class="eyebrow">Start with a free snapshot</p>
					<h2 id="templates-final-heading">Not sure if a Website Foundation fits?</h2>
					<p class="lead">
						I'll review your site, lead path, and follow-up flow, then send a short Loom with the clearest opportunities and the best starting point.
					</p>
					<p class="templates-final__micro">Free Loom review · Clear recommendation · No pressure</p>
				</div>
				<div class="button-row">
					<a class="button button-primary" href="/audit">Get My Free Snapshot</a>
					<a class="button button-secondary" href="#foundation-examples">Explore Foundation Examples</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ═══ Hero ═══ */
	.templates-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.templates-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 76% 14%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.templates-hero__inner,
	.templates-bestfor__intro,
	.templates-include__intro,
	.templates-process__intro,
	.templates-examples__intro,
	.templates-vs__intro,
	.templates-pricing__intro {
		max-width: 820px;
	}

	.templates-hero h1 {
		max-width: 940px;
		font-size: clamp(2.4rem, 4.6vw, 3.5rem);
		letter-spacing: -0.03em;
		line-height: 1.04;
	}

	.templates-hero .lead {
		max-width: 660px;
		margin-top: 1.4rem;
	}

	.templates-hero__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin: 1.75rem 0 0;
		padding: 0;
		list-style: none;
	}

	.templates-hero__chips li {
		display: inline-flex;
		align-items: center;
		padding: 0.42rem 0.85rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 26%, var(--color-border));
		border-radius: 999px;
		background: var(--color-white);
		color: var(--color-accent-dark);
		font-size: 0.84rem;
		font-weight: 700;
		line-height: 1;
	}

	.templates-hero__chips li.is-accent {
		border-color: transparent;
		background: var(--color-accent-dark);
		color: var(--color-white);
	}

	.templates-hero .button-row {
		margin-top: 2rem;
	}

	.templates-hero__micro {
		margin: 1.05rem 0 0;
		color: var(--color-muted);
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: 0.01em;
	}

	/* ═══ Define / not-this-this ═══ */
	.templates-define__inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: center;
	}

	.templates-define__copy p:not(.eyebrow):not(.lead) {
		margin-top: 1rem;
		color: var(--color-muted);
		font-size: 1rem;
		line-height: 1.6;
	}

	.templates-define__compare {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
