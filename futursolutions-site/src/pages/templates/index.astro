---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TemplateCard from '../../components/TemplateCard.astro';
import { templateSystems, templateBrowseFilterDefs } from '../../data/templates';

const pageTitle = 'Website Foundations | FutureSolutions';
const pageDescription =
	'A library of launch-ready website Foundations for healthcare and wellness brands — customizable, industry-specific, and built like the start of a real operational system.';
const canonicalUrl = 'https://futursolutions.io/templates/';

const explainerItems = [
	{
		lane: 'foundation',
		label: 'Live demo',
		text: 'A real, clickable website you can walk through. Same pages, same flow, same system a launched project would use.',
	},
	{
		lane: 'custom',
		label: 'Website Foundation',
		text: 'The underlying structure behind that demo — page architecture, content patterns, forms, and conversion paths — customizable around your brand, services, and booking flow.',
	},
	{
		lane: 'growth',
		label: 'Customized project',
		text: 'What you actually get: your brand applied, your services written in, your booking path wired up. Not a template install.',
	},
];

const differenceCards = [
	{
		title: 'Healthcare-specific structure',
		text: 'Page layouts and content patterns are shaped around trust, services, patient questions, and healthcare decision-making.',
	},
	{
		title: 'Conversion-focused sections',
		text: 'Each Foundation includes clear calls-to-action, service paths, and lead capture areas that support booking conversations.',
	},
	{
		title: 'SEO/local visibility foundation',
		text: 'Foundations are organized around service clarity, metadata readiness, internal links, and location-aware content structure.',
	},
	{
		title: 'Growth System ready',
		text: 'Forms and conversion paths are prepared for future CRM, booking, follow-up, and reporting workflows.',
	},
];

const offerComparison = [
	{
		lane: 'foundation',
		name: 'Website Foundation',
		bestFor: 'You want a premium healthcare site fast, based on a proven structure',
		notFor: 'Highly unique positioning or complex content models',
		outcome: 'A customized launch built on a real demo Foundation',
		complexity: 'Starter · Growth',
	},
	{
		lane: 'custom',
		name: 'Signature Custom Website',
		bestFor: 'Unique brand, complex services, or larger organization',
		notFor: 'Practices who would benefit from a faster Foundation launch',
		outcome: 'A fully bespoke design system and page architecture',
		complexity: 'Advanced',
	},
	{
		lane: 'growth',
		name: 'Growth System',
		bestFor: 'Your site is fine but leads disappear after the form',
		notFor: 'Pre-launch businesses without a site yet',
		outcome: 'Lead capture, booking, follow-up, and reporting wired end-to-end',
		complexity: 'Add-on · Standalone',
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section templates-hero" aria-labelledby="templates-heading">
		<div class="site-container templates-hero__inner">
			<p class="eyebrow">Website Foundations · Live demos</p>
			<h1 id="templates-heading">Industry website Foundations for healthcare and wellness brands.</h1>
			<p class="lead">
				Each Foundation is a live demo website built around a real business model. If one fits, we customize the brand, pages, services, content, booking path, and backend setup around your business.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
				<a class="button button-secondary" href="#featured-templates">Explore Live Demos</a>
			</div>
		</div>
	</section>

	<section class="section section-tight templates-explainer" aria-labelledby="templates-explainer-heading">
		<div class="site-container">
			<div class="templates-explainer__head">
				<p class="eyebrow">Am I buying a template?</p>
				<h2 id="templates-explainer-heading">No. You are starting from a strategic Foundation and adapting it into a real business website.</h2>
				<p class="lead">Three terms get used together — here's the difference.</p>
			</div>
			<ul class="templates-explainer__grid">
				{explainerItems.map((item) => (
					<li class={`templates-explainer__card lane-accent-top lane-accent-top--${item.lane}`}>
						<span class={`lane-tag lane-tag--${item.lane}`}>{item.label}</span>
						<p>{item.text}</p>
					</li>
				))}
			</ul>
		</div>
	</section>

	<section id="featured-templates" class="section section-muted featured-templates" aria-labelledby="featured-templates-heading">
		<div class="site-container">
			<div class="featured-templates__intro">
				<p class="eyebrow">Featured Foundations</p>
				<h2 id="featured-templates-heading">Choose the Foundation that matches your practice.</h2>
				<p class="lead">
					Each FutureSolutions Foundation is structured around the pages, trust signals, local visibility, and conversion paths health and wellness businesses actually need.
				</p>
			</div>
			<div
				id="template-browse-toolbar"
				class="template-browse-filters"
				role="toolbar"
				aria-label="Filter Foundations"
			>
				<button type="button" class="template-browse-filters__chip is-active" data-template-filter="all" aria-pressed="true">
					All
				</button>
				{templateBrowseFilterDefs.map((chip) => (
					<button
						type="button"
						class="template-browse-filters__chip"
						data-template-filter={chip.id}
						aria-pressed="false"
					>
						{chip.label}
					</button>
				))}
			</div>
			<div id="featured-templates-grid" class="featured-templates__grid">
				{templateSystems.map((template, index) => <TemplateCard template={template} priority={index + 1} />)}
			</div>
		</div>
	</section>

	<script is:inline>
		(() => {
			const grid = document.getElementById('featured-templates-grid');
			const toolbar = document.getElementById('template-browse-toolbar');
			if (!grid || !toolbar) return;
			const chips = toolbar.querySelectorAll('[data-template-filter]');
			const cards = grid.querySelectorAll('[data-template-card]');

			function apply(filterId) {
				chips.forEach((chip) => {
					const id = chip.getAttribute('data-template-filter') || 'all';
					const active = id === filterId;
					chip.setAttribute('aria-pressed', active ? 'true' : 'false');
					chip.classList.toggle('is-active', active);
				});

				cards.forEach((card) => {
					const raw = card.getAttribute('data-template-filters') || '';
					const tokens = raw.split(/\s+/).filter(Boolean);
					const show = filterId === 'all' || tokens.includes(filterId);
					card.hidden = !show;
				});
			}

			toolbar.addEventListener('click', (event) => {
				const chip = event.target && event.target.closest('[data-template-filter]');
				if (!chip || !toolbar.contains(chip)) return;
				apply(chip.getAttribute('data-template-filter') || 'all');
			});
		})();
	</script>

	<section class="section template-difference" aria-labelledby="template-difference-heading">
		<div class="site-container">
			<div class="template-difference__intro">
				<p class="eyebrow">Strategic Foundations</p>
				<h2 id="template-difference-heading">These are not generic website themes.</h2>
				<p class="lead">
					Each FutureSolutions Foundation is structured around the needs of health and wellness businesses: clear services, trust-building sections, local visibility, lead capture, and Growth System compatibility.
				</p>
			</div>
			<div class="template-difference__grid">
				{differenceCards.map((card) => (
					<article class="card template-difference__card">
						<h3>{card.title}</h3>
						<p>{card.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section section-muted template-comparison" aria-labelledby="template-comparison-heading">
		<div class="site-container">
			<div class="template-comparison__intro">
				<p class="eyebrow">Foundation · Custom · Growth System</p>
				<h2 id="template-comparison-heading">Which level of system fits your business?</h2>
				<p class="lead">A Foundation is the fastest path to a launched site. A Signature Custom build fits larger or uniquely positioned organizations. A Growth System is the lead and booking workflow behind either one.</p>
			</div>
			<div class="template-comparison__grid">
				{offerComparison.map((item) => (
					<article class={`card template-comparison__card lane-accent-top lane-accent-top--${item.lane}`}>
						<span class={`lane-tag lane-tag--${item.lane}`}>{item.complexity}</span>
						<h3>{item.name}</h3>
						<dl>
							<div>
								<dt>Best for</dt>
								<dd>{item.bestFor}</dd>
							</div>
							<div>
								<dt>Not the right fit if</dt>
								<dd>{item.notFor}</dd>
							</div>
							<div>
								<dt>What you get</dt>
								<dd>{item.outcome}</dd>
							</div>
						</dl>
					</article>
				))}
			</div>
			<div class="template-comparison__cta">
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
				<p class="template-comparison__cta-note">Not sure which one? The audit recommends the right path.</p>
			</div>
		</div>
	</section>

	<section class="section templates-final" aria-labelledby="templates-final-heading">
		<div class="site-container">
			<div class="templates-final__card">
				<div>
					<p class="eyebrow">Guidance</p>
					<h2 id="templates-final-heading">Want help choosing the right Foundation?</h2>
					<p class="lead">
						Request a website and systems audit and get a clear recommendation based on your business, services, current site, and conversion goals.
					</p>
				</div>
				<div class="button-row">
					<a class="button button-primary" href="/audit">Get a Website Audit</a>
					<a class="button button-secondary" href="/services">View Solutions</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.templates-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.templates-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 76% 14%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.templates-hero__inner,
	.featured-templates__intro,
	.template-difference__intro,
	.template-comparison__intro {
		max-width: 820px;
	}

	.templates-hero h1 {
		max-width: 820px;
	}

	.featured-templates__grid,
	.template-difference__grid,
	.template-comparison__grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.featured-templates__grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.template-browse-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 1.75rem;
	}

	.template-browse-filters__chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.25rem;
		padding: 0.42rem 0.82rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-white);
		color: var(--color-muted);
		font-family: inherit;
		font-size: 0.8125rem;
		font-weight: 700;
		line-height: 1;
		cursor: pointer;
		transition:
			border-color 0.12s ease,
			background-color 0.12s ease,
			color 0.12s ease;
	}

	.template-browse-filters__chip:hover {
		border-color: color-mix(in srgb, var(--color-accent) 38%, var(--color-border));
		color: var(--color-accent-dark);
		background: color-mix(in srgb, var(--color-accent-light) 76%, var(--color-white));
	}

	.template-browse-filters__chip:focus-visible {
		outline: 2px solid var(--color-accent-dark);
		outline-offset: 2px;
	}

	.template-browse-filters__chip.is-active {
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		background: color-mix(in srgb, var(--color-accent-light) 88%, var(--color-white));
		color: var(--color-accent-dark);
		box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-accent) 22%, transparent);
	}

	.template-difference__grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.template-comparison__grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.template-difference__card,
	.template-comparison__card {
		padding: 1.25rem;
	}

	.template-comparison__card {
		display: grid;
		gap: 0.85rem;
		align-content: start;
		padding: 1.5rem;
	}

	.template-comparison__intro {
		max-width: 760px;
	}

	.templates-explainer {
		background: var(--color-white);
	}

	.templates-explainer__head {
		max-width: 760px;
		margin-bottom: clamp(2rem, 4vw, 2.75rem);
	}

	.templates-explainer__head h2 {
		max-width: 36ch;
		margin-bottom: 0.85rem;
	}

	.templates-explainer__head .lead {
		color: var(--color-muted);
	}

	.templates-explainer__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.templates-explainer__card {
		display: grid;
		gap: 0.85rem;
		padding: 1.5rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: var(--shadow-card);
	}

	.templates-explainer__card p {
		margin: 0;
		color: var(--color-text);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.template-difference__card h3,
	.template-comparison__card h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	.template-difference__card p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.template-comparison__card dl {
		display: grid;
		gap: 1rem;
		margin: 1rem 0 0;
	}

	.template-comparison__card div {
		display: grid;
		gap: 0.25rem;
	}

	.template-comparison__card dt {
		color: var(--color-accent-dark);
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.template-comparison__card dd {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.9375rem;
		line-height: 1.5;
	}

	.template-comparison__cta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1.25rem;
		margin-top: 2rem;
	}

	.template-comparison__cta-note {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.9rem;
		font-weight: 500;
	}

	.templates-final {
		background: var(--color-accent-light);
	}

	.templates-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
		border-radius: 20px;
		background: var(--color-text);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.templates-final .eyebrow {
		color: color-mix(in srgb, var(--color-accent-light) 84%, var(--color-white));
	}

	.templates-final h2,
	.templates-final .lead {
		color: var(--color-white);
	}

	.templates-final .lead {
		opacity: 0.78;
	}

	.templates-final .button-row {
		justify-content: flex-end;
		margin-top: 0;
	}

	.templates-final .button-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.22);
		color: var(--color-white);
	}

	.templates-final .button-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.38);
		color: var(--color-white);
	}

	@media (max-width: 1040px) {
		.featured-templates__grid,
		.template-difference__grid,
		.template-comparison__grid,
		.templates-explainer__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.featured-templates__grid,
		.template-difference__grid,
		.template-comparison__grid,
		.templates-explainer__grid,
		.templates-final__card {
			grid-template-columns: 1fr;
		}

		.templates-final .button-row {
			justify-content: flex-start;
		}
	}
</style>
