---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TemplateCard from '../../components/TemplateCard.astro';
import TemplateQuickView from '../../components/TemplateQuickView.astro';
import { templateSystems, templateBrowseFilterDefs } from '../../data/templates';

const pageTitle = 'Website Template Systems | Future Solutions';
const pageDescription =
	'Explore launch-ready healthcare website systems built around trust, service clarity, local visibility, lead capture, and booking conversion.';
const canonicalUrl = 'https://futursolutions.vercel.app/templates/';

const differenceCards = [
	{
		title: 'Healthcare-specific structure',
		text: 'Page layouts and content patterns are shaped around trust, services, patient questions, and healthcare decision-making.',
	},
	{
		title: 'Conversion-focused sections',
		text: 'Each system includes clear calls-to-action, service paths, and lead capture areas that support booking conversations.',
	},
	{
		title: 'SEO/local visibility foundation',
		text: 'Templates are organized around service clarity, metadata readiness, internal links, and location-aware content structure.',
	},
	{
		title: 'Backend system ready',
		text: 'Forms and conversion paths are prepared for future CRM, booking, follow-up, and pipeline workflows.',
	},
];

const comparisons = [
	{
		name: 'Med Spa Website System',
		bestFor: 'Treatment-based practices',
		goal: 'Book consultations',
		complexity: 'Growth',
	},
	{
		name: 'Solo Practice Website System',
		bestFor: 'Independent providers',
		goal: 'Build trust',
		complexity: 'Starter / Growth',
	},
	{
		name: 'Medical Association Website System',
		bestFor: 'Member organizations',
		goal: 'Organize resources and events',
		complexity: 'Advanced',
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section templates-hero" aria-labelledby="templates-heading">
		<div class="site-container templates-hero__inner">
			<p class="eyebrow">Template Systems</p>
			<h1 id="templates-heading">Launch-ready website systems for health and wellness brands.</h1>
			<p class="lead">
				Explore healthcare-focused website templates built around trust, service clarity, local visibility, lead capture, and booking conversion.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
				<a class="button button-secondary" href="#featured-templates">View Featured Templates</a>
			</div>
		</div>
	</section>

	<section id="featured-templates" class="section section-muted featured-templates" aria-labelledby="featured-templates-heading">
		<div class="site-container">
			<div class="featured-templates__intro">
				<p class="eyebrow">Featured systems</p>
				<h2 id="featured-templates-heading">Choose the digital system that matches your practice.</h2>
				<p class="lead">
					Each Future Solutions template is structured around the pages, trust signals, local visibility, and conversion paths health and wellness businesses need.
				</p>
			</div>
			<div
				id="template-browse-toolbar"
				class="template-browse-filters"
				role="toolbar"
				aria-label="Filter template systems"
			>
				<button type="button" class="template-browse-filters__chip is-active" data-template-filter="all" aria-pressed="true">
					All
				</button>
				{templateBrowseFilterDefs.map((chip) => (
					<button
						type="button"
						class="template-browse-filters__chip"
						data-template-filter={chip.id}
						aria-pressed="false"
					>
						{chip.label}
					</button>
				))}
			</div>
			<div id="featured-templates-grid" class="featured-templates__grid">
				{templateSystems.map((template, index) => <TemplateCard template={template} priority={index + 1} />)}
			</div>
			<TemplateQuickView templates={templateSystems} />
		</div>
	</section>

	<script is:inline>
		(() => {
			const grid = document.getElementById('featured-templates-grid');
			const toolbar = document.getElementById('template-browse-toolbar');
			if (!grid || !toolbar) return;
			const chips = toolbar.querySelectorAll('[data-template-filter]');
			const cards = grid.querySelectorAll('[data-template-card]');

			function apply(filterId) {
				chips.forEach((chip) => {
					const id = chip.getAttribute('data-template-filter') || 'all';
					const active = id === filterId;
					chip.setAttribute('aria-pressed', active ? 'true' : 'false');
					chip.classList.toggle('is-active', active);
				});

				cards.forEach((card) => {
					const raw = card.getAttribute('data-template-filters') || '';
					const tokens = raw.split(/\s+/).filter(Boolean);
					const show = filterId === 'all' || tokens.includes(filterId);
					card.hidden = !show;
				});
			}

			toolbar.addEventListener('click', (event) => {
				const chip = event.target && event.target.closest('[data-template-filter]');
				if (!chip || !toolbar.contains(chip)) return;
				apply(chip.getAttribute('data-template-filter') || 'all');
			});
		})();
	</script>

	<section class="section template-difference" aria-labelledby="template-difference-heading">
		<div class="site-container">
			<div class="template-difference__intro">
				<p class="eyebrow">Strategic systems</p>
				<h2 id="template-difference-heading">These are not generic website themes.</h2>
				<p class="lead">
					Each Future Solutions template is structured around the needs of health and wellness businesses: clear services, trust-building sections, local visibility, lead capture, and backend system compatibility.
				</p>
			</div>
			<div class="template-difference__grid">
				{differenceCards.map((card) => (
					<article class="card template-difference__card">
						<h3>{card.title}</h3>
						<p>{card.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section section-muted template-comparison" aria-labelledby="template-comparison-heading">
		<div class="site-container">
			<div class="template-comparison__intro">
				<p class="eyebrow">Comparison</p>
				<h2 id="template-comparison-heading">Not sure which template fits?</h2>
			</div>
			<div class="template-comparison__grid">
				{comparisons.map((comparison) => (
					<article class="card template-comparison__card">
						<h3>{comparison.name}</h3>
						<dl>
							<div>
								<dt>Best for</dt>
								<dd>{comparison.bestFor}</dd>
							</div>
							<div>
								<dt>Primary goal</dt>
								<dd>{comparison.goal}</dd>
							</div>
							<div>
								<dt>Complexity</dt>
								<dd>{comparison.complexity}</dd>
							</div>
						</dl>
					</article>
				))}
			</div>
			<div class="template-comparison__cta">
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
			</div>
		</div>
	</section>

	<section class="section templates-final" aria-labelledby="templates-final-heading">
		<div class="site-container">
			<div class="templates-final__card">
				<div>
					<p class="eyebrow">Guidance</p>
					<h2 id="templates-final-heading">Want help choosing the right system?</h2>
					<p class="lead">
						Request a website audit and get a clear recommendation based on your business, services, current site, and conversion goals.
					</p>
				</div>
				<div class="button-row">
					<a class="button button-primary" href="/audit">Get a Website Audit</a>
					<a class="button button-secondary" href="/services">View Services</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.templates-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.templates-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 76% 14%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.templates-hero__inner,
	.featured-templates__intro,
	.template-difference__intro,
	.template-comparison__intro {
		max-width: 820px;
	}

	.templates-hero h1 {
		max-width: 820px;
	}

	.featured-templates__grid,
	.template-difference__grid,
	.template-comparison__grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.featured-templates__grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.template-browse-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 1.75rem;
	}

	.template-browse-filters__chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.25rem;
		padding: 0.42rem 0.82rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-white);
		color: var(--color-muted);
		font-family: inherit;
		font-size: 0.8125rem;
		font-weight: 700;
		line-height: 1;
		cursor: pointer;
		transition:
			border-color 0.12s ease,
			background-color 0.12s ease,
			color 0.12s ease;
	}

	.template-browse-filters__chip:hover {
		border-color: color-mix(in srgb, var(--color-accent) 38%, var(--color-border));
		color: var(--color-accent-dark);
		background: color-mix(in srgb, var(--color-accent-light) 76%, var(--color-white));
	}

	.template-browse-filters__chip:focus-visible {
		outline: 2px solid var(--color-accent-dark);
		outline-offset: 2px;
	}

	.template-browse-filters__chip.is-active {
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		background: color-mix(in srgb, var(--color-accent-light) 88%, var(--color-white));
		color: var(--color-accent-dark);
		box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-accent) 22%, transparent);
	}

	.template-difference__grid,
	.template-comparison__grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.template-difference__card,
	.template-comparison__card {
		padding: 1.25rem;
	}

	.template-difference__card h3,
	.template-comparison__card h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	.template-difference__card p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.template-comparison__card dl {
		display: grid;
		gap: 1rem;
		margin: 1rem 0 0;
	}

	.template-comparison__card div {
		display: grid;
		gap: 0.25rem;
	}

	.template-comparison__card dt {
		color: var(--color-accent-dark);
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.template-comparison__card dd {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.9375rem;
		line-height: 1.5;
	}

	.template-comparison__cta {
		margin-top: 2rem;
	}

	.templates-final {
		background: var(--color-accent-light);
	}

	.templates-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
		border-radius: 20px;
		background: var(--color-text);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.templates-final .eyebrow {
		color: color-mix(in srgb, var(--color-accent-light) 84%, var(--color-white));
	}

	.templates-final h2,
	.templates-final .lead {
		color: var(--color-white);
	}

	.templates-final .lead {
		opacity: 0.78;
	}

	.templates-final .button-row {
		justify-content: flex-end;
		margin-top: 0;
	}

	.templates-final .button-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.22);
		color: var(--color-white);
	}

	.templates-final .button-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.38);
		color: var(--color-white);
	}

	@media (max-width: 1040px) {
		.featured-templates__grid,
		.template-difference__grid,
		.template-comparison__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.featured-templates__grid,
		.template-difference__grid,
		.template-comparison__grid,
		.templates-final__card {
			grid-template-columns: 1fr;
		}

		.templates-final .button-row {
			justify-content: flex-start;
		}
	}
</style>
