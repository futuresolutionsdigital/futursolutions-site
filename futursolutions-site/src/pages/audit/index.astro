---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuditFormShell from '../../components/AuditFormShell.astro';

const pageTitle = 'Website and Systems Audit | FutureSolutions';
const pageDescription =
	'Request a Website and Systems Audit for your healthcare or high-trust service business — site, content, conversion, lead capture, and visibility, reviewed and reported.';
const canonicalUrl = 'https://futursolutions.vercel.app/audit/';

const expectations = [
	'First-impression trust review',
	'Service clarity review',
	'Booking and conversion path review',
	'Local visibility review',
	'Follow-up system review',
	'Recommended next step',
];

const reviewCards = [
	{
		title: 'First impression',
		text: 'Does the site feel credible, modern, and trustworthy within seconds?',
	},
	{
		title: 'Service clarity',
		text: 'Can visitors quickly understand what you offer and who it is for?',
	},
	{
		title: 'Conversion path',
		text: 'Are the next steps, forms, booking links, and CTAs obvious?',
	},
	{
		title: 'Local visibility',
		text: 'Are service pages and metadata structured for local discovery?',
	},
	{
		title: 'Mobile experience',
		text: 'Does the site feel clean and usable on smaller screens?',
	},
	{
		title: 'Follow-up system',
		text: 'Is there a clear process after someone fills out a form?',
	},
];

const audiences = ['Med Spas', 'Solo Practices', 'Wellness Clinics', 'Functional Medicine', 'Healthcare Associations', 'Treatment-Based Clinics'];

const processSteps = [
	{
		step: '01',
		title: 'Submit your practice details',
		text: 'Share your current website, business type, services, and main goal.',
	},
	{
		step: '02',
		title: 'We review your site and template fit',
		text: 'We look at trust, service clarity, local visibility, conversion paths, and follow-up.',
	},
	{
		step: '03',
		title: 'You receive audit notes or a Loom walkthrough',
		text: 'A practical next-step recommendation: Industry Website Foundation, Signature Custom build, SEO foundation, Growth System, or Care and Optimization.',
	},
	{
		step: '04',
		title: 'If it is a fit, we map the build scope',
		text: 'We outline scope, timeline, and launch path around your business.',
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section audit-hero" aria-labelledby="audit-heading">
		<div class="site-container audit-hero__inner">
			<div class="audit-hero__content">
				<p class="eyebrow">Website and Systems Audit</p>
				<h1 id="audit-heading">Find the gaps between your website and your booked&nbsp;consults.</h1>
				<p class="lead">
					A practical review of your site, services, booking path, and follow-up workflow. We send back written notes or a Loom walkthrough with a recommended next step — Foundation, Custom, Growth System, Care plan, or none of the above.
				</p>

				<div class="audit-hero__youll-get lane-accent-top lane-accent-top--audit">
					<p class="audit-hero__youll-get-label">
						<span class="lane-tag lane-tag--audit">You'll get</span>
						<span class="audit-hero__youll-get-meta">Free · 5 business days · No sales pitch</span>
					</p>
					<ul class="audit-hero__expectations" aria-label="Audit deliverables">
						{expectations.map((expectation) => (
							<li>
								<svg aria-hidden="true" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 10.5l4 4 8-9" />
								</svg>
								<span>{expectation}</span>
							</li>
						))}
					</ul>
				</div>

				<p class="audit-hero__reassurance">
					<strong>No pressure.</strong> The audit is meant to clarify whether you need a Foundation, Custom Website, Growth System, Care plan, or nothing urgent. We'll tell you if it's the last one.
				</p>

				<p class="audit-hero__helper">
					Built for med spas, solo practices, wellness clinics, hormone clinics, functional medicine providers, and healthcare associations.
				</p>
			</div>

			<AuditFormShell />
		</div>
	</section>

	<section class="section section-muted audit-review" aria-labelledby="audit-review-heading">
		<div class="site-container">
			<div class="audit-review__intro">
				<p class="eyebrow">Review areas</p>
				<h2 id="audit-review-heading">What we look for.</h2>
			</div>
			<div class="audit-review__grid">
				{reviewCards.map((card) => (
					<article class="card audit-review__card">
						<h3>{card.title}</h3>
						<p>{card.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section audit-audience" aria-labelledby="audit-audience-heading">
		<div class="site-container">
			<div class="audit-audience__intro">
				<p class="eyebrow">Best fit</p>
				<h2 id="audit-audience-heading">Built for health and wellness businesses where trust matters.</h2>
			</div>
			<div class="audit-audience__chips" aria-label="Best-fit audiences">
				{audiences.map((audience) => <span>{audience}</span>)}
			</div>
		</div>
	</section>

	<section class="section section-muted audit-process" aria-labelledby="audit-process-heading">
		<div class="site-container">
			<div class="audit-process__intro">
				<p class="eyebrow">Process</p>
				<h2 id="audit-process-heading">What happens next?</h2>
			</div>
			<div class="audit-process__grid">
				{processSteps.map((process) => (
					<article class="card audit-process__card">
						<span>{process.step}</span>
						<h3>{process.title}</h3>
						<p>{process.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section audit-final" aria-labelledby="audit-final-heading">
		<div class="site-container">
			<div class="audit-final__card">
				<div>
					<p class="eyebrow">Next step</p>
					<h2 id="audit-final-heading">Want a clearer picture of what your site actually&nbsp;needs?</h2>
					<p class="lead">
						Start with an audit and get a practical recommendation before committing to a Website Foundation, Signature Custom build, Growth System, or Care plan.
					</p>
				</div>
				<div class="button-row">
					<a class="button button-primary" href="#audit-form">Back to the form</a>
					<a class="button button-secondary" href="/templates">Explore Live Demos</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	(() => {
		const params = new URLSearchParams(window.location.search);
		const slug = params.get('template');
		if (!slug) return;

		const categoryMap: Record<string, string> = {
			'med-spa': 'med spa',
			'solo-practice': 'solo practice',
			'association': 'professional association',
			'premium-wellness-clinic': 'wellness clinic',
		};
		const category = categoryMap[slug];
		if (!category) return;

		const heading = document.getElementById('audit-heading');
		const lead = heading?.nextElementSibling;
		const eyebrow = heading?.previousElementSibling;

		if (heading) heading.textContent = `Customize this ${category} Website Foundation.`;
		if (eyebrow && eyebrow.classList.contains('eyebrow')) eyebrow.textContent = 'Foundation Customization';
		if (lead && lead.classList.contains('lead')) {
			lead.textContent = 'Tell us about your practice, services, current website, and goals. We\u2019ll recommend how to adapt this Website Foundation around your provider story, services, pricing model, and patient onboarding process.';
		}
	})();
</script>

<style>
	.audit-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.audit-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 78% 18%, color-mix(in srgb, var(--lane-audit) 22%, transparent), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, color-mix(in srgb, var(--lane-audit-tint) 60%, var(--color-bg)) 72%);
		content: '';
	}

	.audit-hero .eyebrow {
		color: var(--lane-audit-ink);
	}

	.audit-hero__inner {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(420px, 0.8fr);
		gap: clamp(3rem, 6vw, 5rem);
		align-items: start;
	}

	.audit-hero__content {
		max-width: 760px;
		padding-top: 1rem;
	}

	.audit-hero h1 {
		max-width: 760px;
	}

	.audit-hero__helper {
		max-width: 620px;
		margin-top: 1.25rem;
		font-size: 0.95rem;
		line-height: 1.65;
	}

	.audit-hero__youll-get {
		margin-top: 1.75rem;
		padding: 1.4rem 1.5rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: linear-gradient(135deg, var(--color-white) 0%, var(--lane-audit-tint) 100%);
		box-shadow: var(--shadow-card);
	}

	.audit-hero__youll-get-label {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.65rem;
		margin: 0 0 1rem 0;
	}

	.audit-hero__youll-get-meta {
		color: var(--lane-audit-ink);
		font-size: 0.8rem;
		font-weight: 600;
	}

	.audit-hero__expectations {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.6rem 1.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.audit-hero__expectations li {
		display: grid;
		grid-template-columns: 1rem 1fr;
		gap: 0.55rem;
		align-items: start;
		color: var(--color-text);
		font-size: 0.92rem;
		font-weight: 600;
		line-height: 1.45;
	}

	.audit-hero__expectations svg {
		width: 1rem;
		height: 1rem;
		margin-top: 0.18rem;
		color: var(--lane-audit-ink);
	}

	.audit-hero__reassurance {
		margin: 1.5rem 0 0 0;
		padding: 1rem 1.1rem;
		border-left: 3px solid var(--lane-audit);
		background: var(--color-bg);
		color: var(--color-text);
		font-size: 0.93rem;
		line-height: 1.55;
	}

	.audit-hero__reassurance strong {
		color: var(--lane-audit-ink);
		font-weight: 700;
	}

	.audit-review__intro,
	.audit-audience__intro,
	.audit-process__intro {
		max-width: 780px;
	}

	.audit-review__grid,
	.audit-process__grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.audit-review__grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.audit-process__grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.audit-review__card,
	.audit-process__card {
		padding: 1.25rem;
	}

	.audit-review__card h3,
	.audit-process__card h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	.audit-review__card p,
	.audit-process__card p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.audit-audience__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 2rem;
	}

	.audit-audience__chips span {
		display: inline-flex;
		padding: 0.55rem 0.75rem;
		border: 1px solid color-mix(in srgb, var(--lane-audit) 28%, var(--color-border));
		border-radius: 999px;
		background: var(--color-white);
		color: var(--lane-audit-ink);
		font-size: 0.875rem;
		font-weight: 700;
		line-height: 1;
	}

	.audit-process__card span {
		display: inline-flex;
		margin-bottom: 1.25rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--lane-audit) 30%, var(--color-border));
		border-radius: 999px;
		background: var(--lane-audit-tint);
		color: var(--lane-audit-ink);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}

	.audit-final {
		background: var(--color-accent-light);
	}

	.audit-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
		border-radius: 20px;
		background: var(--color-text);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.audit-final .eyebrow {
		color: color-mix(in srgb, var(--color-accent-light) 84%, var(--color-white));
	}

	.audit-final h2,
	.audit-final .lead {
		color: var(--color-white);
	}

	.audit-final .lead {
		opacity: 0.78;
	}

	.audit-final .button-row {
		justify-content: flex-end;
		margin-top: 0;
	}

	.audit-final .button-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.22);
		color: var(--color-white);
	}

	.audit-final .button-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.38);
		color: var(--color-white);
	}

	@media (max-width: 1040px) {
		.audit-hero__inner,
		.audit-review__grid,
		.audit-process__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 800px) {
		.audit-hero__inner,
		.audit-review__grid,
		.audit-process__grid,
		.audit-final__card,
		.audit-hero__expectations {
			grid-template-columns: 1fr;
		}

		.audit-final .button-row {
			justify-content: flex-start;
		}
	}
</style>
