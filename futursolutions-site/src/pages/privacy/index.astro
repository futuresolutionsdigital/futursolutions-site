---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'Privacy Policy | FutureSolutions';
const pageDescription =
	'How FutureSolutions collects, uses, stores, and protects the information you share through our website and audit request form.';
const canonicalUrl = 'https://futursolutions.io/privacy/';

// [PLACEHOLDER] Replace with your registered legal entity name and governing jurisdiction.
const legalEntity = 'FutureSolutions';
const jurisdiction = '[your state/country]';
const contactEmail = 'privacy@futursolutions.io';
const effectiveDate = 'June 9, 2026';
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section legal-hero" aria-labelledby="legal-heading">
		<div class="site-container legal__inner">
			<p class="eyebrow">Privacy</p>
			<h1 id="legal-heading">Privacy Policy</h1>
			<p class="lead">
				This policy explains what information {legalEntity} collects through this website, how
				we use it, and the choices you have. We aim to collect only what we need to respond to you.
			</p>
			<p class="legal__meta">Effective {effectiveDate}</p>
		</div>
	</section>

	<section class="section legal-body">
		<div class="site-container legal__inner legal__prose">
			<h2>Information we collect</h2>
			<p>
				When you submit the website audit request form or otherwise contact us, we collect the
				information you choose to provide — typically your name, email address, business name,
				current website URL, business type, location, goals, and notes about your needs. We also
				collect limited technical information automatically (such as IP address and basic analytics)
				to operate and secure the site.
			</p>

			<h2>How we use your information</h2>
			<ul>
				<li>To respond to your audit request or inquiry and prepare recommendations.</li>
				<li>To follow up with you about our services and next steps.</li>
				<li>To operate, secure, and improve our website.</li>
				<li>To comply with legal obligations.</li>
			</ul>
			<p>We do not sell your personal information.</p>

			<h2>How we store and share information</h2>
			<p>
				Form submissions are routed to our team and to our customer relationship management (CRM)
				system so we can follow up with you. We use reputable third-party providers for hosting,
				form delivery, CRM, and analytics. These providers process information on our behalf and are
				expected to protect it. We share information only as needed to provide our services, to
				comply with the law, or to protect our rights.
			</p>

			<h2>Healthcare data handling</h2>
			<p>
				We work with healthcare and wellness businesses. We structure forms, CRM workflows, and
				hosting configurations with healthcare data privacy in mind. When protected health
				information (PHI) is involved in a client engagement, we support Business Associate Agreement
				(BAA) requirements and appropriate safeguards as part of that engagement. This website's
				public forms are not intended for submitting protected health information — please do not
				include patient details or sensitive health information in the audit form.
			</p>

			<h2>Cookies and analytics</h2>
			<p>
				We may use cookies and similar technologies, along with privacy-conscious analytics, to
				understand how the site is used and to improve performance. You can control cookies through
				your browser settings.
			</p>

			<h2>Your choices</h2>
			<p>
				You may request access to, correction of, or deletion of the personal information you have
				shared with us by contacting us at the address below. You can also opt out of follow-up
				communications at any time.
			</p>

			<h2>Data retention</h2>
			<p>
				We retain the information you submit for as long as needed to respond to you, provide our
				services, and meet legal or business requirements, after which it is deleted or anonymized.
			</p>

			<h2>Children's privacy</h2>
			<p>This site is intended for businesses and is not directed to children under 16.</p>

			<h2>Changes to this policy</h2>
			<p>
				We may update this policy from time to time. The effective date above reflects the most
				recent revision.
			</p>

			<h2>Contact</h2>
			<p>
				Questions about this policy or your information? Email us at
				<a href={`mailto:${contactEmail}`}>{contactEmail}</a>. This policy is governed by the laws of
				{' '}{jurisdiction}.
			</p>

			<p class="legal__disclaimer">
				This page is provided for general information and does not constitute legal advice. Please
				have counsel review it for your specific business and jurisdiction before launch.
			</p>
		</div>
	</section>
</BaseLayout>

<style>
	.legal-hero {
		padding-block: clamp(4rem, 7vw, 6rem) clamp(1.5rem, 3vw, 2.5rem);
		background: linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 100%);
	}
	.legal__inner { max-width: 760px; }
	.legal-hero h1 { margin-block: 0.4rem 0.9rem; }
	.legal__meta {
		margin-top: 1rem;
		font-size: 0.85rem;
		font-weight: 700;
		color: color-mix(in srgb, var(--color-text) 55%, transparent);
	}
	.legal-body { padding-top: clamp(1rem, 2vw, 1.5rem); }
	.legal__prose h2 {
		margin-top: 2.25rem;
		margin-bottom: 0.6rem;
		font-size: 1.2rem;
		letter-spacing: -0.01em;
	}
	.legal__prose p,
	.legal__prose li {
		font-size: 0.95rem;
		line-height: 1.7;
		color: color-mix(in srgb, var(--color-text) 82%, transparent);
	}
	.legal__prose ul { margin: 0.5rem 0; padding-left: 1.2rem; display: grid; gap: 0.35rem; }
	.legal__prose a { color: var(--color-accent-dark); font-weight: 700; }
	.legal__disclaimer {
		margin-top: 2.5rem;
		padding: 0.9rem 1.1rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: color-mix(in srgb, var(--color-white) 70%, transparent);
		font-size: 0.85rem !important;
		line-height: 1.6 !important;
	}
</style>
