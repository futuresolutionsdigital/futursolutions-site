---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import Testimonials from '../../components/Testimonials.astro';
import { breadcrumbSchema } from '../../data/schema';

const pageTitle = 'About | FutureSolutions';
const pageDescription =
	'FutureSolutions builds premium websites and connected Growth Systems for healthcare and high-trust service businesses — combining trust-first design with operational follow-through.';
const canonicalUrl = 'https://futuresolutions.io/about/';

const principles = [
	{
		title: 'Trust before traffic',
		text: 'For healthcare and high-trust businesses, credibility is the conversion. We design for the first ten seconds — clarity, proof, and a calm, confident experience — before chasing volume.',
	},
	{
		title: 'A website is a system, not a brochure',
		text: 'A page that looks good but loses the lead has failed. We connect design to capture, booking, and follow-up so the work continues after someone clicks.',
	},
	{
		title: 'Strategy over decoration',
		text: 'Every section earns its place. We start from your services, audience, and goals, then build structure that helps patients act and search engines understand.',
	},
	{
		title: 'Honest scope, honest timelines',
		text: 'We tell you what you need — and what you don\u2019t. If a Foundation is the right call instead of a custom build, we\u2019ll say so. The audit comes first for a reason.',
	},
];

const approach = [
	{
		step: '01',
		title: 'We specialize',
		text: 'Focusing on healthcare and high-trust service businesses means our defaults — compliance-aware forms, trust signals, service clarity — are already right for you.',
	},
	{
		step: '02',
		title: 'We connect the system',
		text: 'Website, local visibility, lead capture, and CRM follow-up are designed to work together, not as disconnected projects.',
	},
	{
		step: '03',
		title: 'We stay practical',
		text: 'Live demos, fixed scopes, and plain-language recommendations. You can see and understand the work before you commit.',
	},
];

const audiences = [
	{ label: 'Med spas & aesthetics', href: '/industries/med-spas' },
	{ label: 'Solo & private practices', href: '/industries/solo-practices' },
	{ label: 'Wellness & functional medicine', href: '/industries/wellness-functional-medicine' },
	{ label: 'Hormone & TRT clinics', href: '/industries/hormone-trt-clinics' },
	{ label: 'Healthcare associations', href: '/industries/healthcare-associations' },
	{ label: 'Treatment-based clinics', href: '/industries' },
];

const pageSchema = [
	breadcrumbSchema([
		{ name: 'Home', path: '/' },
		{ name: 'About', path: '/about' },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
	schema={pageSchema}
>
	<section class="section about-hero" aria-labelledby="about-heading">
		<div class="site-container about-hero__inner">
			<p class="eyebrow">About FutureSolutions</p>
			<h1 id="about-heading">We build websites that earn trust — and systems that act on it.</h1>
			<p class="lead">
				FutureSolutions is a studio for healthcare and high-trust service businesses. We pair premium,
				trust-first websites with the lead capture, booking, and follow-up systems behind them — so a
				great first impression actually turns into booked consults.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
				<a class="button button-secondary" href="/templates">Explore Live Demos</a>
			</div>
		</div>
	</section>

	<section class="section section-muted about-story" aria-labelledby="about-story-heading">
		<div class="site-container about-story__inner">
			<div class="about-story__intro">
				<p class="eyebrow">Why we exist</p>
				<h2 id="about-story-heading">Most practice websites look fine and still lose the patient.</h2>
			</div>
			<div class="about-story__body">
				<p>
					Health and wellness businesses live or die on trust. Yet most of their websites are either
					generic templates that miss healthcare-specific trust signals, or beautiful designs that
					quietly leak leads — buried calls-to-action, no clear next step, and nothing happening after
					the contact form is submitted.
				</p>
				<p>
					We started FutureSolutions to close that gap. Not just prettier websites, but connected
					systems: a site that explains your services clearly, builds credibility fast, ranks for the
					patients near you, and routes every inquiry into a follow-up process that doesn’t drop
					anyone.
				</p>
				<p>
					That’s why every engagement starts with an audit, not a sales pitch — and why we publish
					live, working demos instead of static portfolio screenshots. You should be able to see how the
					work behaves before you trust us with yours.
				</p>
			</div>
		</div>
	</section>

	<section class="section about-principles" aria-labelledby="about-principles-heading">
		<div class="site-container">
			<div class="about-principles__intro">
				<p class="eyebrow">What we believe</p>
				<h2 id="about-principles-heading">The principles behind the work.</h2>
			</div>
			<div class="about-principles__grid">
				{principles.map((item) => (
					<article class="card about-principle">
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section section-muted about-approach" aria-labelledby="about-approach-heading">
		<div class="site-container">
			<div class="about-approach__intro">
				<p class="eyebrow">How we’re different</p>
				<h2 id="about-approach-heading">A focused studio, not a generalist agency.</h2>
			</div>
			<div class="about-approach__grid">
				{approach.map((item) => (
					<article class="card about-approach__card">
						<span>{item.step}</span>
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section about-team" aria-labelledby="about-team-heading">
		<div class="site-container about-team__inner">
			<div class="about-team__intro">
				<p class="eyebrow">Who you work with</p>
				<h2 id="about-team-heading">A focused studio that stays close to the work.</h2>
			</div>
			<div class="about-team__card card">
				<div class="about-team__avatar" aria-hidden="true">FS</div>
				<div class="about-team__body">
					<p class="about-team__name">FutureSolutions</p>
					<p class="about-team__role">An independent studio · Future Solutions Digital LLC · California, USA</p>
					<p class="about-team__bio">
						FutureSolutions is a small, independent studio built around a simple idea: healthcare and
						high-trust businesses deserve websites that are as careful and credible as the care they
						provide. We keep the team deliberately lean so the people who plan your site are the same
						people who build it.
					</p>
					<p class="about-team__note">
						When you work with FutureSolutions, you work directly with the people building your site —
						not a rotating cast of account managers.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section section-muted about-audience" aria-labelledby="about-audience-heading">
		<div class="site-container">
			<div class="about-audience__intro">
				<p class="eyebrow">Who we work with</p>
				<h2 id="about-audience-heading">Built for businesses where trust is the product.</h2>
			</div>
			<div class="about-audience__chips" aria-label="Industries we serve">
				{audiences.map((audience) => <a href={audience.href}>{audience.label}</a>)}
			</div>
		</div>
	</section>

	<Testimonials />

	<FinalCTA />
</BaseLayout>

<style>
	.about-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}
	.about-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 80% 16%, color-mix(in srgb, var(--color-accent) 16%, transparent), transparent 32%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 70%);
		content: '';
	}
	.about-hero__inner {
		max-width: 880px;
	}
	.about-hero h1 {
		max-width: 18ch;
		margin-block: 0.4rem 1rem;
	}
	.about-hero .lead {
		max-width: 62ch;
	}

	.about-story__inner {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
	}
	.about-story__intro {
		max-width: 30ch;
	}
	.about-story__body p {
		margin: 0 0 1.1rem 0;
		color: var(--color-muted);
		font-size: 1.02rem;
		line-height: 1.7;
	}
	.about-story__body p:last-child {
		margin-bottom: 0;
	}

	.about-principles__intro,
	.about-approach__intro,
	.about-audience__intro,
	.about-team__intro {
		max-width: 780px;
	}
	.about-principles__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}
	.about-principle {
		padding: 1.5rem;
	}
	.about-principle h3 {
		font-size: 1.15rem;
		letter-spacing: -0.02em;
		margin-bottom: 0.45rem;
	}
	.about-principle p {
		font-size: 0.9375rem;
		line-height: 1.65;
		color: var(--color-muted);
	}

	.about-approach__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}
	.about-approach__card {
		padding: 1.5rem;
	}
	.about-approach__card span {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 1rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}
	.about-approach__card h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}
	.about-approach__card p {
		font-size: 0.9375rem;
		line-height: 1.6;
		color: var(--color-muted);
	}

	.about-team__inner {
		display: grid;
		gap: clamp(1.75rem, 4vw, 2.5rem);
	}
	.about-team__card {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: clamp(1.25rem, 3vw, 2rem);
		align-items: start;
		padding: clamp(1.5rem, 3vw, 2.25rem);
	}
	.about-team__avatar {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 4.5rem;
		height: 4.5rem;
		border-radius: var(--radius-lg);
		background: var(--color-text);
		color: var(--color-white);
		font-size: 1.4rem;
		font-weight: 800;
		letter-spacing: -0.03em;
	}
	.about-team__name {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.about-team__role {
		margin: 0.2rem 0 1rem 0;
		color: var(--color-accent-dark);
		font-size: 0.875rem;
		font-weight: 700;
	}
	.about-team__bio {
		margin: 0 0 0.9rem 0;
		color: var(--color-muted);
		line-height: 1.65;
	}
	.about-team__note {
		margin: 0;
		padding-top: 0.9rem;
		border-top: 1px solid var(--color-border-soft);
		color: var(--color-text);
		font-size: 0.9375rem;
		font-weight: 600;
		line-height: 1.55;
	}

	.about-audience__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 2rem;
	}
	.about-audience__chips a {
		display: inline-flex;
		padding: 0.55rem 0.85rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
		border-radius: 999px;
		background: var(--color-white);
		color: var(--color-accent-dark);
		font-size: 0.875rem;
		font-weight: 700;
		line-height: 1;
		transition: transform var(--transition-base), border-color var(--transition-base), background var(--transition-base);
	}
	.about-audience__chips a:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		background: var(--color-accent-light);
	}

	@media (max-width: 860px) {
		.about-story__inner,
		.about-principles__grid,
		.about-approach__grid {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 540px) {
		.about-team__card {
			grid-template-columns: 1fr;
		}
	}
</style>
