---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import Testimonials from '../../components/Testimonials.astro';
import { breadcrumbSchema } from '../../data/schema';

const pageTitle = 'About | FutureSolutions';
const pageDescription =
	'FutureSolutions is a founder-led website and growth systems studio for health, wellness, and high-trust service businesses — pairing trust-first websites with the lead capture, booking, and follow-up systems behind them.';
const canonicalUrl = 'https://futuresolutions.io/about/';

const principles = [
	{
		title: 'Trust before traffic',
		text: 'Before more traffic or ad spend, the site has to earn confidence. Clarity, proof, and a calm conversion path come first.',
	},
	{
		title: 'A website is a system, not a brochure',
		text: 'A page that looks good but loses the lead has failed. We connect design to capture, booking, follow-up, and reporting so the work continues after someone clicks.',
	},
	{
		title: 'Strategy over decoration',
		text: 'Every section needs a job: explain the offer, answer objections, build trust, or move the visitor toward the next step.',
	},
	{
		title: 'Honest scope, honest timelines',
		text: 'If a Website Foundation is the right fit, we\u2019ll say so. If the project needs custom strategy or systems work, we\u2019ll say that too.',
	},
];

const approach = [
	{
		step: '01',
		title: 'Focused on high-trust service businesses',
		text: 'We understand the decisions visitors make before they book a consult, appointment, or inquiry — and structure the site around that trust gap.',
	},
	{
		step: '02',
		title: 'Website and system thinking',
		text: 'The site is planned with the backend in mind: forms, booking, CRM, follow-up, tracking, and reporting where they matter.',
	},
	{
		step: '03',
		title: 'Practical recommendations',
		text: 'Not every business needs a full custom build. We recommend the clearest next step — Foundation, Signature Custom, Growth System, or ongoing management.',
	},
];

const audiences = [
	{ label: 'Med spas & aesthetics', href: '/industries/med-spas' },
	{ label: 'Solo & private practices', href: '/industries/solo-practices' },
	{ label: 'Wellness & functional medicine', href: '/industries/wellness-functional-medicine' },
	{ label: 'Hormone & TRT clinics', href: '/industries/hormone-trt-clinics' },
	{ label: 'Healthcare associations', href: '/industries/healthcare-associations' },
	{ label: 'Treatment-based clinics', href: '/industries' },
];

const pageSchema = [
	breadcrumbSchema([
		{ name: 'Home', path: '/' },
		{ name: 'About', path: '/about' },
	]),
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
	schema={pageSchema}
>
	<section class="section about-hero" aria-labelledby="about-heading">
		<div class="site-container about-hero__inner">
			<p class="eyebrow">About FutureSolutions</p>
			<h1 id="about-heading">We build websites that earn trust — and systems that act on it.</h1>
			<p class="lead">
				FutureSolutions is a founder-led website and growth systems studio for health, wellness, and
				high-trust service businesses. We build premium, trust-first websites and connect them to the
				lead capture, booking, follow-up, and reporting systems that help interest turn into booked
				consults.
			</p>
			<p class="about-hero__support">
				Founder-led strategy, build, and systems support — without the black-box handoff.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/audit">
					Get My Free Snapshot
					<span aria-hidden="true">&rarr;</span>
				</a>
				<a class="button button-secondary" href="/templates">Explore Website Foundations</a>
			</div>
		</div>
	</section>

	<section class="section section-muted about-story" aria-labelledby="about-story-heading">
		<div class="site-container about-story__inner">
			<div class="about-story__intro">
				<p class="eyebrow">Why we exist</p>
				<h2 id="about-story-heading">Most high-trust websites look fine and still lose the lead.</h2>
			</div>
			<div class="about-story__body">
				<p>
					Health, wellness, and service businesses often don’t need a louder website. They need a
					clearer one — a site that explains the offer, earns trust, makes the next step obvious, and
					connects every inquiry to a follow-up process.
				</p>
				<p>
					Plenty of sites look polished but fail where it matters: unclear services, weak trust
					placement, buried calls-to-action, no obvious next step, and forms that disappear into an
					inbox with no follow-up and no visibility into what’s working.
				</p>
				<p>
					That’s why FutureSolutions starts with the full path from first impression to booked
					consult: website structure, service clarity, lead capture, follow-up, and reporting.
				</p>
			</div>
		</div>
	</section>

	<section class="section about-team" aria-labelledby="about-team-heading">
		<div class="site-container about-team__inner">
			<div class="about-team__intro">
				<p class="eyebrow">Who you work with</p>
				<h2 id="about-team-heading">Founder-led, strategy-first, and close to the work.</h2>
				<p class="about-team__lead">
					FutureSolutions is led by Hayden Wagner, a website and growth systems strategist focused on
					health, wellness, and high-trust service businesses. You work directly with the person
					thinking through your site structure, lead path, content flow, and system connections — not a
					rotating account team.
				</p>
				<p class="about-team__lead">
					The studio stays intentionally focused: fewer moving parts, clearer scope, direct
					communication, and practical recommendations based on what your business actually needs next.
				</p>
			</div>
			<div class="about-team__card card">
				<div class="about-team__avatar" aria-hidden="true">FS</div>
				<div class="about-team__body">
					<p class="about-team__name">FutureSolutions</p>
					<p class="about-team__role">Founder-led website &amp; growth systems studio · California, USA</p>
					<p class="about-team__bio">
						A small independent studio built around a simple idea: high-trust businesses deserve
						websites that are as careful and credible as the care or service they provide. The person
						who helps plan the site stays close to the work that gets built.
					</p>
					<p class="about-team__note">
						When you work with FutureSolutions, you work close to the strategy, structure, and build —
						not through layers of account handoff.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section section-muted about-principles" aria-labelledby="about-principles-heading">
		<div class="site-container">
			<div class="about-principles__intro">
				<p class="eyebrow">What we believe</p>
				<h2 id="about-principles-heading">The principles behind the work.</h2>
			</div>
			<div class="about-principles__grid">
				{principles.map((item) => (
					<article class="card about-principle">
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section about-approach" aria-labelledby="about-approach-heading">
		<div class="site-container">
			<div class="about-approach__intro">
				<p class="eyebrow">How we’re different</p>
				<h2 id="about-approach-heading">A focused studio, not a generalist agency.</h2>
			</div>
			<div class="about-approach__grid">
				{approach.map((item) => (
					<article class="card about-approach__card">
						<span>{item.step}</span>
						<h3>{item.title}</h3>
						<p>{item.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section section-muted about-audience" aria-labelledby="about-audience-heading">
		<div class="site-container">
			<div class="about-audience__intro">
				<p class="eyebrow">Who we work with</p>
				<h2 id="about-audience-heading">Built for businesses where trust is the product.</h2>
				<p class="about-audience__lead">
					If your business depends on trust, clear service explanation, and booked inquiries, you’re
					likely in the right place.
				</p>
			</div>
			<div class="about-audience__chips" aria-label="Industries we serve">
				{audiences.map((audience) => <a href={audience.href}>{audience.label}</a>)}
			</div>
		</div>
	</section>

	<Testimonials />

	<FinalCTA />
</BaseLayout>

<style>
	.about-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}
	.about-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 80% 16%, color-mix(in srgb, var(--color-accent) 16%, transparent), transparent 32%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 70%);
		content: '';
	}
	.about-hero__inner {
		max-width: 880px;
	}
	.about-hero h1 {
		max-width: 18ch;
		margin-block: 0.4rem 1rem;
	}
	.about-hero .lead {
		max-width: 62ch;
	}
	.about-hero__support {
		max-width: 56ch;
		margin: 1rem 0 1.75rem 0;
		color: var(--color-accent-dark);
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1.5;
	}

	.about-story__inner {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
	}
	.about-story__intro {
		max-width: 30ch;
	}
	.about-story__body p {
		margin: 0 0 1.1rem 0;
		color: var(--color-muted);
		font-size: 1.02rem;
		line-height: 1.7;
	}
	.about-story__body p:last-child {
		margin-bottom: 0;
	}

	.about-principles__intro,
	.about-approach__intro,
	.about-audience__intro,
	.about-team__intro {
		max-width: 780px;
	}
	.about-principles__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}
	.about-principle {
		padding: 1.5rem;
	}
	.about-principle h3 {
		font-size: 1.15rem;
		letter-spacing: -0.02em;
		margin-bottom: 0.45rem;
	}
	.about-principle p {
		font-size: 0.9375rem;
		line-height: 1.65;
		color: var(--color-muted);
	}

	.about-approach__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}
	.about-approach__card {
		padding: 1.5rem;
	}
	.about-approach__card span {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 1rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}
	.about-approach__card h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}
	.about-approach__card p {
		font-size: 0.9375rem;
		line-height: 1.6;
		color: var(--color-muted);
	}

	.about-team__inner {
		display: grid;
		gap: clamp(1.75rem, 4vw, 2.5rem);
	}
	.about-team__lead {
		max-width: 70ch;
		margin: 1rem 0 0 0;
		color: var(--color-muted);
		font-size: 1.02rem;
		line-height: 1.7;
	}
	.about-team__lead + .about-team__lead {
		margin-top: 0.9rem;
	}
	.about-team__card {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: clamp(1.25rem, 3vw, 2rem);
		align-items: start;
		padding: clamp(1.5rem, 3vw, 2.25rem);
	}
	.about-team__avatar {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 4.5rem;
		height: 4.5rem;
		border-radius: var(--radius-lg);
		background: var(--color-text);
		color: var(--color-white);
		font-size: 1.4rem;
		font-weight: 800;
		letter-spacing: -0.03em;
	}
	.about-team__name {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.about-team__role {
		margin: 0.2rem 0 1rem 0;
		color: var(--color-accent-dark);
		font-size: 0.875rem;
		font-weight: 700;
	}
	.about-team__bio {
		margin: 0 0 0.9rem 0;
		color: var(--color-muted);
		line-height: 1.65;
	}
	.about-team__note {
		margin: 0;
		padding-top: 0.9rem;
		border-top: 1px solid var(--color-border-soft);
		color: var(--color-text);
		font-size: 0.9375rem;
		font-weight: 600;
		line-height: 1.55;
	}

	.about-audience__lead {
		max-width: 60ch;
		margin: 1rem 0 0 0;
		color: var(--color-muted);
		font-size: 1.02rem;
		line-height: 1.7;
	}
	.about-audience__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 2rem;
	}
	.about-audience__chips a {
		display: inline-flex;
		padding: 0.55rem 0.85rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
		border-radius: 999px;
		background: var(--color-white);
		color: var(--color-accent-dark);
		font-size: 0.875rem;
		font-weight: 700;
		line-height: 1;
		transition: transform var(--transition-base), border-color var(--transition-base), background var(--transition-base);
	}
	.about-audience__chips a:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-accent) 48%, var(--color-border));
		background: var(--color-accent-light);
	}

	@media (max-width: 860px) {
		.about-story__inner,
		.about-principles__grid,
		.about-approach__grid {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 540px) {
		.about-team__card {
			grid-template-columns: 1fr;
		}
	}
</style>
