---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { serviceOfferings } from '../../data/services';

const pageTitle = 'Services | Future Solutions';
const pageDescription =
	'Future Solutions builds healthcare websites, template systems, SEO foundations, backend lead systems, and ongoing optimization for health and wellness businesses.';
const canonicalUrl = 'https://futursolutions.vercel.app/services/';

const principles = [
	{
		title: 'Trust',
		text: 'Healthcare visitors need to feel confident before they ever book.',
	},
	{
		title: 'Clarity',
		text: 'Your site should make services, audiences, and next steps obvious.',
	},
	{
		title: 'Visibility',
		text: 'Search engines need clear structure to understand what you offer.',
	},
	{
		title: 'Follow-Up',
		text: 'A lead is only useful if it is captured, organized, and followed up with.',
	},
];

const flowSteps = ['Website Visit', 'Form Submission', 'CRM Contact', 'Follow-Up', 'Next Step'];

const processSteps = [
	{
		step: '01',
		title: 'Audit',
		text: 'We review your current site, offer, visibility, and conversion path.',
	},
	{
		step: '02',
		title: 'Strategy',
		text: 'We map the pages, content, backend system, and launch priorities.',
	},
	{
		step: '03',
		title: 'Build',
		text: 'We design and develop the site with clean structure and conversion paths.',
	},
	{
		step: '04',
		title: 'Optimize',
		text: 'We refine the site after launch with content, SEO, and conversion improvements.',
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section services-hero" aria-labelledby="services-heading">
		<div class="site-container services-hero__inner">
			<p class="eyebrow">Services</p>
			<h1 id="services-heading">Website systems for health and wellness businesses that need more than a polished homepage.</h1>
			<p class="lead">
				Future Solutions combines modern website structure, healthcare-specific templates, local visibility, and backend lead systems into one practical digital foundation.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/#audit">Get a Website Audit</a>
				<a class="button button-secondary" href="/templates">View Templates</a>
			</div>
		</div>
	</section>

	<section class="section services-principles" aria-labelledby="services-principles-heading">
		<div class="site-container">
			<div class="services-principles__intro">
				<p class="eyebrow">System first</p>
				<h2 id="services-principles-heading">A better website starts with a better system.</h2>
				<p class="lead">
					Most health and wellness businesses do not need more random marketing tactics. They need a clear website structure, stronger service pages, better local visibility, and a follow-up system that keeps leads from getting lost.
				</p>
			</div>
			<div class="services-principles__grid">
				{principles.map((principle) => (
					<article class="card services-principles__card">
						<h3>{principle.title}</h3>
						<p>{principle.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section section-muted services-grid-section" aria-labelledby="services-grid-heading">
		<div class="site-container">
			<div class="services-grid-section__intro">
				<p class="eyebrow">Service ecosystem</p>
				<h2 id="services-grid-heading">Build the level of system your business needs.</h2>
			</div>
			<div class="services-grid">
				{serviceOfferings.map((service) => (
					<article class="card service-offering" id={service.slug}>
						<div class="service-offering__header">
							<span aria-hidden="true"></span>
							<h3>{service.name}</h3>
							<p>{service.shortDescription}</p>
						</div>
						<div class="service-offering__meta">
							<p>
								<strong>Best for</strong>
								<span>{service.bestFor}</span>
							</p>
							<div>
								<strong>Includes</strong>
								<ul>
									{service.includes.map((item) => <li>{item}</li>)}
								</ul>
							</div>
							<p>
								<strong>Why it matters</strong>
								<span>{service.whyItMatters}</span>
							</p>
						</div>
						<a class="service-offering__link" href={service.ctaHref}>{service.ctaLabel}</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section services-operations" aria-labelledby="services-operations-heading">
		<div class="site-container">
			<div class="services-operations__intro">
				<p class="eyebrow">Operations</p>
				<h2 id="services-operations-heading">The website is only the front door.</h2>
				<p class="lead">
					Future Solutions can also help connect the site to the systems behind it: lead capture, booking, CRM organization, follow-up, and pipeline visibility.
				</p>
			</div>
			<div class="services-operations__flow" aria-label="Lead system flow">
				{flowSteps.map((step, index) => (
					<div class="card services-operations__step">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<p>{step}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="section section-muted services-process" aria-labelledby="services-process-heading">
		<div class="site-container">
			<div class="services-process__intro">
				<p class="eyebrow">Process preview</p>
				<h2 id="services-process-heading">How the work comes together.</h2>
			</div>
			<div class="services-process__grid">
				{processSteps.map((process) => (
					<article class="card services-process__card">
						<span>{process.step}</span>
						<h3>{process.title}</h3>
						<p>{process.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section services-final" aria-labelledby="services-final-heading">
		<div class="site-container">
			<div class="services-final__card">
				<div>
					<p class="eyebrow">Guidance</p>
					<h2 id="services-final-heading">Not sure which service fits?</h2>
					<p class="lead">
						Request a website audit and get a clear recommendation based on your business, current site, goals, and next best step.
					</p>
				</div>
				<div class="button-row">
					<a class="button button-primary" href="/#audit">Get a Website Audit</a>
					<a class="button button-secondary" href="/templates">View Templates</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.services-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.services-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 76% 14%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.services-hero__inner,
	.services-principles__intro,
	.services-grid-section__intro,
	.services-operations__intro,
	.services-process__intro {
		max-width: 820px;
	}

	.services-hero h1 {
		max-width: 900px;
	}

	.services-principles__grid,
	.services-grid,
	.services-operations__flow,
	.services-process__grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.services-principles__grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.services-principles__card,
	.service-offering,
	.services-operations__step,
	.services-process__card {
		padding: 1.25rem;
	}

	.services-principles__card h3,
	.service-offering h3,
	.services-process__card h3 {
		font-size: 1.15rem;
		letter-spacing: -0.02em;
	}

	.services-principles__card p,
	.service-offering p,
	.services-process__card p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.services-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.service-offering {
		display: flex;
		flex-direction: column;
		min-height: 100%;
	}

	.service-offering__header > span {
		display: block;
		width: 2.4rem;
		height: 0.25rem;
		margin-bottom: 1.5rem;
		border-radius: 999px;
		background: var(--color-accent);
	}

	.service-offering__meta {
		display: grid;
		gap: 1rem;
		margin-top: 1.4rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--color-border);
	}

	.service-offering__meta p,
	.service-offering__meta ul {
		margin: 0;
	}

	.service-offering__meta p,
	.service-offering__meta div {
		display: grid;
		gap: 0.4rem;
	}

	.service-offering__meta strong {
		color: var(--color-accent-dark);
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.service-offering__meta span,
	.service-offering__meta li {
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.55;
	}

	.service-offering__meta ul {
		display: grid;
		gap: 0.35rem;
		padding-left: 1.1rem;
	}

	.service-offering__link {
		display: inline-flex;
		width: fit-content;
		margin-top: auto;
		padding-top: 1.35rem;
		color: var(--color-text);
		font-size: 0.9375rem;
		font-weight: 700;
	}

	.service-offering__link:hover {
		color: var(--color-accent-dark);
	}

	.services-operations__flow {
		grid-template-columns: repeat(5, minmax(0, 1fr));
	}

	.services-operations__step span,
	.services-process__card span {
		display: inline-flex;
		margin-bottom: 1.25rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}

	.services-operations__step p {
		margin: 0;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 700;
	}

	.services-process__grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.services-final {
		background: var(--color-accent-light);
	}

	.services-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
		border-radius: 20px;
		background: var(--color-text);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.services-final .eyebrow {
		color: color-mix(in srgb, var(--color-accent-light) 84%, var(--color-white));
	}

	.services-final h2,
	.services-final .lead {
		color: var(--color-white);
	}

	.services-final .lead {
		opacity: 0.78;
	}

	.services-final .button-row {
		justify-content: flex-end;
		margin-top: 0;
	}

	.services-final .button-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.22);
		color: var(--color-white);
	}

	.services-final .button-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.38);
		color: var(--color-white);
	}

	@media (max-width: 1040px) {
		.services-principles__grid,
		.services-operations__flow,
		.services-process__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 760px) {
		.services-principles__grid,
		.services-grid,
		.services-operations__flow,
		.services-process__grid,
		.services-final__card {
			grid-template-columns: 1fr;
		}

		.services-final .button-row {
			justify-content: flex-start;
		}
	}
</style>
