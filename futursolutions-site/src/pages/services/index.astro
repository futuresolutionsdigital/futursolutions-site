---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { serviceOfferings } from '../../data/services';

const pageTitle = 'Services | FutureSolutions';
const pageDescription =
	'Choose the level of system your business needs — Website Foundations, Signature Custom Websites, Growth Systems, Local Visibility, and Care and Optimization for healthcare and high-trust service businesses.';
const canonicalUrl = 'https://futursolutions.vercel.app/services/';

/**
 * Maps each service slug to a lane category, the decision-tree section label,
 * and an outcome-oriented "what changes after this" sentence. Keeps the data
 * file lean while letting the page render decision-first.
 */
const servicePresentation: Record<string, {
	lane: 'foundation' | 'custom' | 'growth' | 'audit' | 'care' | 'visibility';
	section: string;
	outcome: string;
}> = {
	'template-setup': {
		lane: 'foundation',
		section: 'Start with a Foundation',
		outcome: 'A polished, healthcare-specific site launched faster than a fully custom build — without looking templated.',
	},
	'custom-website-system': {
		lane: 'custom',
		section: 'Build Custom',
		outcome: 'A bespoke website system shaped around your brand, services, content model, and operational workflow.',
	},
	'backend-system-setup': {
		lane: 'growth',
		section: 'Add a Growth System',
		outcome: 'Forms, booking, CRM routing, follow-up, and reporting wired end-to-end — so leads stop disappearing after submit.',
	},
	'seo-local-visibility-foundation': {
		lane: 'visibility',
		section: 'Improve Visibility',
		outcome: 'Clearer service structure, metadata, and local content paths so patients and search engines understand what you offer.',
	},
	'ongoing-optimization': {
		lane: 'care',
		section: 'Keep Optimizing',
		outcome: 'A site that keeps evolving with your services, audience, and content — instead of going stale six months after launch.',
	},
};

const decisionRows = [
	{
		ask: 'I need to launch a credible website fast.',
		answer: 'Start with a Website Foundation.',
		lane: 'foundation',
	},
	{
		ask: 'My brand and services are unusual or complex.',
		answer: 'Build a Signature Custom Website.',
		lane: 'custom',
	},
	{
		ask: 'My site is fine, but leads disappear after the form.',
		answer: 'Add a Growth System.',
		lane: 'growth',
	},
	{
		ask: "Patients can't find us locally or our pages don't rank.",
		answer: 'Improve Visibility.',
		lane: 'visibility',
	},
	{
		ask: 'We launched — now I want it to keep getting better.',
		answer: 'Add Care and Optimization.',
		lane: 'care',
	},
];

const processSteps = [
	{
		step: '01',
		title: 'Audit',
		text: 'We review your current site, offer, visibility, and conversion path.',
	},
	{
		step: '02',
		title: 'Strategy',
		text: 'We map the pages, content, Growth System, and launch priorities.',
	},
	{
		step: '03',
		title: 'Build',
		text: 'We design and develop the site with clean structure and conversion paths.',
	},
	{
		step: '04',
		title: 'Optimize',
		text: 'We refine the site after launch with content, SEO, and conversion improvements.',
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section services-hero" aria-labelledby="services-heading">
		<div class="site-container services-hero__inner">
			<p class="eyebrow">Services</p>
			<h1 id="services-heading">Choose the level of system your business&nbsp;needs.</h1>
			<p class="lead">
				Five services that build on each other — from a fast Foundation launch to a fully custom site, the Growth System behind both, and ongoing optimization. Start anywhere; expand when ready.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
				<a class="button button-secondary" href="/templates">Explore Live Demos</a>
			</div>
		</div>
	</section>

	<section class="section services-decision" aria-labelledby="services-decision-heading">
		<div class="site-container">
			<div class="services-decision__intro">
				<p class="eyebrow">Quick decision matrix</p>
				<h2 id="services-decision-heading">Which one fits your situation?</h2>
				<p class="lead">If something below sounds like you, jump straight to that section.</p>
			</div>
			<ul class="services-decision__list">
				{decisionRows.map((row) => (
					<li class={`services-decision__row services-decision__row--${row.lane}`}>
						<span class="services-decision__ask">"{row.ask}"</span>
						<span class="services-decision__arrow" aria-hidden="true">&rarr;</span>
						<span class={`services-decision__answer services-decision__answer--${row.lane}`}>{row.answer}</span>
					</li>
				))}
			</ul>
		</div>
	</section>

	<section class="section section-muted services-grid-section" aria-labelledby="services-grid-heading">
		<div class="site-container">
			<div class="services-grid-section__intro">
				<p class="eyebrow">Five services. One system.</p>
				<h2 id="services-grid-heading">Build the level of system your business needs.</h2>
				<p class="services-grid-section__sub">
					<strong>Three primary offers</strong> — Foundation, Custom, Growth System — plus <strong>two supporting layers</strong> for Local Visibility and Care.
				</p>
			</div>

			{(() => {
				const primarySlugs = new Set(['template-setup', 'custom-website-system', 'backend-system-setup']);
				const primary = serviceOfferings.filter((s) => primarySlugs.has(s.slug));
				const supporting = serviceOfferings.filter((s) => !primarySlugs.has(s.slug));
				return (
					<>
						<div class="services-grid services-grid--primary">
							{primary.map((service) => {
								const present = servicePresentation[service.slug];
								const laneKey = present?.lane === 'visibility' ? 'foundation' : present?.lane;
								return (
									<article
										class:list={[
											'card service-offering service-offering--primary',
											present && `lane-accent-top lane-accent-top--${laneKey}`,
											present && `service-offering--${laneKey}`,
										]}
										id={service.slug}
									>
										{present && (
											<header class="service-offering__head">
												<span class="service-offering__section-label">{present.section}</span>
												{present.lane !== 'visibility' ? (
													<span class={`lane-tag lane-tag--${present.lane}`}>{present.lane}</span>
												) : (
													<span class="service-offering__visibility-tag">Visibility</span>
												)}
											</header>
										)}
										<h3>{service.name}</h3>
										<p class="service-offering__summary">{service.shortDescription}</p>

										<div class="service-offering__outcomes">
											<div>
												<strong>What changes</strong>
												<span>{present?.outcome ?? service.whyItMatters}</span>
											</div>
											<div>
												<strong>Best for</strong>
												<span>{service.bestFor}</span>
											</div>
										</div>

										<details class="service-offering__details">
											<summary>What's included</summary>
											<ul>
												{service.includes.map((item) => <li>{item}</li>)}
											</ul>
										</details>

										<a class="service-offering__link" href={service.ctaHref}>
											{service.ctaLabel}
											<span aria-hidden="true">&rarr;</span>
										</a>
									</article>
								);
							})}
						</div>

						<div class="services-supporting-head">
							<span class="services-supporting-head__label">Supporting layers</span>
							<span class="services-supporting-head__rule" aria-hidden="true"></span>
							<span class="services-supporting-head__note">Add to any primary offer</span>
						</div>

						<div class="services-grid services-grid--supporting">
							{supporting.map((service) => {
								const present = servicePresentation[service.slug];
								const laneKey = present?.lane === 'visibility' ? 'foundation' : present?.lane;
								return (
									<article
										class:list={[
											'card service-offering service-offering--supporting',
											present && `lane-accent-top lane-accent-top--${laneKey}`,
											present && `service-offering--${laneKey}`,
										]}
										id={service.slug}
									>
										{present && (
											<header class="service-offering__head">
												<span class="service-offering__section-label">{present.section}</span>
												{present.lane !== 'visibility' ? (
													<span class={`lane-tag lane-tag--${present.lane}`}>{present.lane}</span>
												) : (
													<span class="service-offering__visibility-tag">Visibility</span>
												)}
											</header>
										)}
										<h3>{service.name}</h3>
										<p class="service-offering__summary">{service.shortDescription}</p>

										<div class="service-offering__compact-outcome">
											<strong>Best for</strong>
											<span>{service.bestFor}</span>
										</div>

										<a class="service-offering__link" href={service.ctaHref}>
											{service.ctaLabel}
											<span aria-hidden="true">&rarr;</span>
										</a>
									</article>
								);
							})}
						</div>
					</>
				);
			})()}
		</div>
	</section>

	<section class="section section-muted services-process" aria-labelledby="services-process-heading">
		<div class="site-container">
			<div class="services-process__intro">
				<p class="eyebrow">Process preview</p>
				<h2 id="services-process-heading">How the work comes together.</h2>
			</div>
			<div class="services-process__grid">
				{processSteps.map((process) => (
					<article class="card services-process__card">
						<span>{process.step}</span>
						<h3>{process.title}</h3>
						<p>{process.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section services-final" aria-labelledby="services-final-heading">
		<div class="site-container">
			<div class="services-final__card">
				<div>
					<p class="eyebrow">Guidance</p>
					<h2 id="services-final-heading">Not sure which service fits?</h2>
					<p class="lead">
						Request a Website and Systems Audit and get a clear recommendation based on your business, current site, goals, and next best step.
					</p>
				</div>
				<div class="button-row">
					<a class="button button-primary" href="/audit">Get a Website Audit</a>
					<a class="button button-secondary" href="/templates">Explore Live Demos</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.services-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.services-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 76% 14%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.services-hero__inner,
	.services-decision__intro,
	.services-grid-section__intro,
	.services-process__intro {
		max-width: 820px;
	}

	.services-hero h1 {
		max-width: 900px;
	}

	.services-grid,
	.services-process__grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.services-decision__list {
		display: grid;
		gap: 0.65rem;
		margin: clamp(2rem, 4vw, 2.5rem) 0 0;
		padding: 0;
		list-style: none;
	}

	.services-decision__row {
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) auto minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
		padding: 1rem 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-white);
		transition: border-color var(--transition-base), background var(--transition-base);
	}

	.services-decision__row:hover {
		border-color: color-mix(in srgb, var(--color-text) 18%, var(--color-border));
	}

	.services-decision__row--foundation:hover { background: color-mix(in srgb, var(--lane-foundation-tint) 35%, var(--color-white)); }
	.services-decision__row--custom:hover     { background: color-mix(in srgb, var(--lane-custom-tint) 35%, var(--color-white)); }
	.services-decision__row--growth:hover     { background: color-mix(in srgb, var(--lane-growth-tint) 35%, var(--color-white)); }
	.services-decision__row--visibility:hover { background: color-mix(in srgb, var(--lane-foundation-tint) 22%, var(--color-white)); }
	.services-decision__row--care:hover       { background: color-mix(in srgb, var(--lane-care-tint) 35%, var(--color-white)); }

	.services-decision__ask {
		color: var(--color-text);
		font-size: 0.98rem;
		font-style: italic;
		line-height: 1.45;
	}

	.services-decision__arrow {
		color: var(--color-muted);
		font-weight: 700;
	}

	.services-decision__answer {
		font-size: 0.95rem;
		font-weight: 650;
		letter-spacing: -0.01em;
	}

	.services-decision__answer--foundation { color: var(--lane-foundation-ink); }
	.services-decision__answer--custom     { color: var(--lane-custom-ink); }
	.services-decision__answer--growth     { color: var(--lane-growth-ink); }
	.services-decision__answer--visibility { color: var(--lane-foundation-ink); }
	.services-decision__answer--care       { color: var(--lane-care-ink); }

	.service-offering,
	.services-process__card {
		padding: 1.5rem;
	}

	.service-offering h3,
	.services-process__card h3 {
		font-size: 1.15rem;
		letter-spacing: -0.02em;
	}

	.services-process__card p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.services-grid--primary {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.services-grid--supporting {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		max-width: 56rem;
	}

	.services-grid-section__sub {
		margin: 0.5rem 0 0;
		color: var(--color-muted);
		font-size: 0.96rem;
		line-height: 1.55;
	}

	.services-grid-section__sub strong {
		color: var(--color-text);
		font-weight: 700;
	}

	.services-supporting-head {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin: clamp(2.25rem, 4vw, 3rem) 0 0.85rem;
	}

	.services-supporting-head__label {
		color: var(--color-text);
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.services-supporting-head__rule {
		flex: 1;
		height: 1px;
		background: linear-gradient(90deg, var(--color-border), transparent);
	}

	.services-supporting-head__note {
		color: var(--color-muted);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.service-offering {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		min-height: 100%;
	}

	.service-offering--supporting {
		padding: 1.25rem;
		gap: 0.7rem;
	}

	.service-offering--supporting h3 {
		font-size: 1.05rem;
	}

	.service-offering--supporting .service-offering__summary {
		font-size: 0.9rem;
	}

	.service-offering__compact-outcome {
		display: grid;
		gap: 0.25rem;
		padding: 0.75rem 0.9rem;
		border: 1px solid var(--color-border-soft);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
	}

	.service-offering--foundation.service-offering--supporting .service-offering__compact-outcome { background: color-mix(in srgb, var(--lane-foundation-tint) 60%, var(--color-bg)); border-color: color-mix(in srgb, var(--lane-foundation) 16%, var(--color-border-soft)); }
	.service-offering--care.service-offering--supporting .service-offering__compact-outcome       { background: color-mix(in srgb, var(--lane-care-tint) 65%, var(--color-bg));       border-color: color-mix(in srgb, var(--lane-care) 16%, var(--color-border-soft)); }

	.service-offering--foundation.service-offering--supporting .service-offering__compact-outcome strong { color: var(--lane-foundation-ink); }
	.service-offering--care.service-offering--supporting .service-offering__compact-outcome strong       { color: var(--lane-care-ink); }

	.service-offering__compact-outcome strong {
		color: var(--color-text);
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.service-offering__compact-outcome span {
		color: var(--color-text);
		font-size: 0.88rem;
		line-height: 1.5;
	}

	.service-offering__head {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		margin-bottom: 0.25rem;
	}

	.service-offering__section-label {
		color: var(--color-muted);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.service-offering__visibility-tag {
		display: inline-flex;
		align-items: center;
		padding: 0.22rem 0.55rem;
		border-radius: 999px;
		background: var(--lane-foundation-tint);
		color: var(--lane-foundation-ink);
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		line-height: 1;
		text-transform: uppercase;
	}

	.service-offering__summary {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.service-offering__outcomes {
		display: grid;
		gap: 0.85rem;
		padding: 1rem 1.1rem;
		border: 1px solid var(--color-border-soft);
		border-radius: var(--radius-sm);
		background: var(--color-bg);
	}

	.service-offering--foundation .service-offering__outcomes { background: color-mix(in srgb, var(--lane-foundation-tint) 65%, var(--color-bg)); border-color: color-mix(in srgb, var(--lane-foundation) 18%, var(--color-border-soft)); }
	.service-offering--custom     .service-offering__outcomes { background: color-mix(in srgb, var(--lane-custom-tint) 70%, var(--color-bg));     border-color: color-mix(in srgb, var(--lane-custom) 16%, var(--color-border-soft)); }
	.service-offering--growth     .service-offering__outcomes { background: color-mix(in srgb, var(--lane-growth-tint) 65%, var(--color-bg));     border-color: color-mix(in srgb, var(--lane-growth) 18%, var(--color-border-soft)); }
	.service-offering--care       .service-offering__outcomes { background: color-mix(in srgb, var(--lane-care-tint) 70%, var(--color-bg));       border-color: color-mix(in srgb, var(--lane-care) 18%, var(--color-border-soft)); }

	.service-offering--foundation .service-offering__outcomes strong { color: var(--lane-foundation-ink); }
	.service-offering--custom     .service-offering__outcomes strong { color: var(--lane-custom-ink); }
	.service-offering--growth     .service-offering__outcomes strong { color: var(--lane-growth-ink); }
	.service-offering--care       .service-offering__outcomes strong { color: var(--lane-care-ink); }

	.service-offering__outcomes div {
		display: grid;
		gap: 0.25rem;
	}

	.service-offering__outcomes strong {
		color: var(--color-text);
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.service-offering__outcomes span {
		color: var(--color-text);
		font-size: 0.92rem;
		line-height: 1.55;
	}

	.service-offering__details {
		border-top: 1px solid var(--color-border-soft);
		padding-top: 0.85rem;
	}

	.service-offering__details summary {
		color: var(--color-muted);
		font-size: 0.85rem;
		font-weight: 600;
		cursor: pointer;
		list-style: none;
		border-radius: 4px;
	}

	.service-offering__details summary:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--color-accent) 42%, transparent);
		outline-offset: 2px;
	}

	.service-offering__details summary::after {
		content: ' ▾';
		font-size: 0.7em;
	}

	.service-offering__details[open] summary::after {
		content: ' ▴';
	}

	.service-offering__details ul {
		display: grid;
		gap: 0.3rem;
		margin: 0.6rem 0 0;
		padding-left: 1.1rem;
		color: var(--color-muted);
		font-size: 0.875rem;
		line-height: 1.5;
	}

	.service-offering__link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		width: fit-content;
		margin-top: auto;
		padding-top: 0.5rem;
		color: var(--color-text);
		font-size: 0.92rem;
		font-weight: 650;
		transition: gap var(--transition-base);
	}

	.service-offering__link:hover {
		gap: 0.55rem;
	}

	.services-process__card span {
		display: inline-flex;
		margin-bottom: 1.25rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--lane-care) 28%, var(--color-border));
		border-radius: 999px;
		background: var(--lane-care-tint);
		color: var(--lane-care-ink);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}

	.services-process__grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.services-final {
		background: var(--color-accent-light);
	}

	.services-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
		border-radius: 20px;
		background: var(--color-text);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.services-final .eyebrow {
		color: color-mix(in srgb, var(--color-accent-light) 84%, var(--color-white));
	}

	.services-final h2,
	.services-final .lead {
		color: var(--color-white);
	}

	.services-final .lead {
		opacity: 0.78;
	}

	.services-final .button-row {
		justify-content: flex-end;
		margin-top: 0;
	}

	.services-final .button-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.22);
		color: var(--color-white);
	}

