---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import RelatedServicesSection from '../../components/RelatedServicesSection.astro';
import ServiceDetailHero from '../../components/ServiceDetailHero.astro';
import ServiceFAQSection from '../../components/ServiceFAQSection.astro';
import ServiceIncludedSection from '../../components/ServiceIncludedSection.astro';
import { serviceDetails } from '../../data/serviceDetails';
import { serviceSchema, faqSchema, breadcrumbSchema } from '../../data/schema';

const service = serviceDetails['ongoing-optimization'];
const canonicalUrl = `https://futursolutions.io${service.canonicalPath}`;
const pageSchema = [
	serviceSchema({ name: service.eyebrow, description: service.description, path: service.canonicalPath }),
	faqSchema(service.faqs),
	breadcrumbSchema([
		{ name: 'Home', path: '/' },
		{ name: 'Services', path: '/services' },
		{ name: service.eyebrow, path: service.canonicalPath },
	]),
];
const processSteps = [
	{ step: '01', title: 'Review', text: 'Identify the updates, content, SEO, and conversion improvements that matter most next.' },
	{ step: '02', title: 'Prioritize', text: 'Organize improvements around business goals, seasonal needs, new services, and site performance.' },
	{ step: '03', title: 'Improve', text: 'Publish updates, refine pages, add content, adjust CTAs, and maintain technical quality.' },
	{ step: '04', title: 'Refine', text: 'Keep strengthening the site as the business, audience, and service mix evolve.' },
];
---

<BaseLayout title={service.title} description={service.description} canonicalUrl={canonicalUrl} ogTitle={service.title} ogDescription={service.description} ogUrl={canonicalUrl} schema={pageSchema}>
	<ServiceDetailHero
		eyebrow={service.eyebrow}
		heading={service.heading}
		supportingCopy={service.supportingCopy}
		primaryCta={service.primaryCta}
		secondaryCta={service.secondaryCta}
	/>

	<section class="section section-muted service-detail-section" aria-labelledby="service-problem-heading">
		<div class="site-container">
			<div class="service-detail-section__intro">
				<p class="eyebrow">Problem</p>
				<h2 id="service-problem-heading">{service.problemHeading}</h2>
			</div>
			<div class="service-detail-grid service-detail-grid--3">
				{service.problems.map((problem) => (
					<article class="card service-detail-card">
						<p>{problem}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section service-detail-section" aria-labelledby="service-solution-heading">
		<div class="site-container">
			<div class="service-detail-section__intro">
				<p class="eyebrow">Approach</p>
				<h2 id="service-solution-heading">{service.solutionHeading}</h2>
				<p class="lead">{service.solutionCopy}</p>
			</div>
		</div>
	</section>

	<ServiceIncludedSection heading="What’s included in ongoing optimization." items={service.included} variant="muted" />

	<section class="section service-detail-section" aria-labelledby="service-audience-heading">
		<div class="site-container">
			<div class="service-detail-section__intro">
				<p class="eyebrow">Best fit</p>
				<h2 id="service-audience-heading">Who it’s for.</h2>
			</div>
			<div class="service-detail-chips">
				{service.whoItsFor.map((item) => <span>{item}</span>)}
			</div>
		</div>
	</section>

	<section class="section section-muted service-detail-section" aria-labelledby="service-process-heading">
		<div class="site-container">
			<div class="service-detail-section__intro">
				<p class="eyebrow">Process</p>
				<h2 id="service-process-heading">How the work comes together.</h2>
			</div>
			<div class="service-detail-grid service-detail-grid--4">
				{processSteps.map((step) => (
					<article class="card service-process-card">
						<span>{step.step}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<RelatedServicesSection services={service.relatedServices} />
	<ServiceFAQSection faqs={service.faqs} />
	<FinalCTA />
</BaseLayout>

<style>
	.service-detail-section__intro {
		max-width: 780px;
	}

	.service-detail-grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.service-detail-grid--3 {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.service-detail-grid--4 {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.service-detail-card,
	.service-process-card {
		padding: 1.25rem;
	}

	.service-detail-card p {
		color: var(--color-text);
		font-size: 0.9375rem;
		font-weight: 700;
		line-height: 1.55;
	}

	.service-process-card span {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 1.25rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}

	.service-process-card h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	.service-process-card p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.service-detail-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 2rem;
	}

	.service-detail-chips span {
		display: inline-flex;
		padding: 0.55rem 0.75rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
		border-radius: 999px;
		background: var(--color-white);
		color: var(--color-accent-dark);
		font-size: 0.875rem;
		font-weight: 700;
		line-height: 1;
	}

	@media (max-width: 1040px) {
		.service-detail-grid--3,
		.service-detail-grid--4 {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.service-detail-grid--3,
		.service-detail-grid--4 {
			grid-template-columns: 1fr;
		}
	}
</style>
