---
import AsterLayout from '../../../layouts/AsterLayout.astro';
import { provider, brand } from '../../../data/aster';

const philosophy = [
	{ title: 'Time to listen', description: 'Every visit starts with enough time to hear the full story — not a 7-minute window before the next patient.' },
	{ title: 'Evidence-informed care', description: 'Clinical decisions grounded in current research, thorough evaluation, and your individual health context.' },
	{ title: 'Prevention and continuity', description: 'A proactive approach that addresses concerns before they escalate and maintains a long-term care relationship.' },
	{ title: 'Practical plans for real life', description: 'Recommendations you can actually follow — not a 20-item supplement list or a plan that ignores your schedule and budget.' },
];

const clinicalInterests = [
	'Primary and preventive care',
	'Women\'s health and perimenopause',
	'Metabolic health and weight management',
	'Thyroid and hormonal concerns',
	'Lifestyle medicine and stress management',
	'Functional wellness and root-cause investigation',
	'Telehealth and virtual care',
];

const expectations = [
	{ title: 'Longer visits', description: 'Your initial consultation is 60–75 minutes. Follow-ups are 30–45 minutes. Every visit is designed to be thorough, not rushed.' },
	{ title: 'A provider who knows your story', description: 'You see the same provider every time. No rotating doors, no re-explaining your history at every visit.' },
	{ title: 'Clear communication', description: 'Labs, plans, and recommendations are explained in plain language. You leave every visit understanding what comes next.' },
	{ title: 'Accessible support', description: 'Members have access to secure messaging between visits for questions, care coordination, and follow-up guidance.' },
];
---

<AsterLayout
	title="About the Provider | Aster Private Health Demo"
	description="Meet the fictional provider behind Aster Private Health and explore a premium provider-led private practice website experience."
	canonicalUrl="https://futursolutions.vercel.app/demos/solo-practice/about/"
>
	<section class="ab-hero" aria-labelledby="ab-heading">
		<div class="aster-container">
			<a class="ab-back" href="/demos/solo-practice">← Back to Aster Home</a>
			<p class="aster-eyebrow">About the Provider</p>
			<h1 id="ab-heading">A more personal approach to modern healthcare.</h1>
			<p class="aster-lead">Meet the provider behind Aster Private Health and learn why this practice was built around time, clarity, and continuity.</p>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="ab-provider-heading">
		<div class="aster-container ab-profile">
			<div class="ab-portrait" aria-hidden="true">
				<div class="ab-portrait__img">
					<div class="ab-avatar"><span>{provider.initials}</span></div>
					<span class="ab-portrait__label">Provider portrait</span>
				</div>
			</div>
			<div class="ab-profile__body">
				<p class="aster-eyebrow">Your provider</p>
				<h2 id="ab-provider-heading">{provider.name}</h2>
				<p class="ab-profile__title">{provider.title}</p>
				<p class="ab-profile__bio">{provider.bio}</p>
				<ul class="ab-creds">
					{provider.credentials.map((c) => <li>{c}</li>)}
				</ul>
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="ab-snap-heading">
		<div class="aster-container ab-snap-layout">
			<div class="ab-snap-img" aria-hidden="true">
				<div class="ab-snap-img__inner">
					<div class="ab-avatar ab-avatar--lg"><span>{provider.initials}</span></div>
					<span class="ab-snap-img__label">Provider portrait</span>
				</div>
			</div>
			<div class="ab-snap-body">
				<p class="aster-eyebrow">Provider Snapshot</p>
				<h2 id="ab-snap-heading">Dr. Elena Marrow, FNP-C</h2>
				<dl class="ab-snap-stats">
					<div><dt>Certification</dt><dd>Board-Certified FNP-C</dd></div>
					<div><dt>Experience</dt><dd>12+ years in primary &amp; preventive care</dd></div>
					<div><dt>Focus areas</dt><dd>Women's health · metabolic health · lifestyle medicine</dd></div>
					<div><dt>Visit format</dt><dd>In-person &amp; telehealth · Temecula, CA</dd></div>
					<div><dt>First visits</dt><dd>60–75 minutes · direct-pay</dd></div>
				</dl>
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="ab-why-heading">
		<div class="aster-container ab-letter-wrap">
			<div class="ab-letter">
				<p class="ab-letter__label">Why I started Aster Private Health</p>
				<p>I spent years working in traditional healthcare systems — places where the care was good, but the time was never enough. I watched patients leave appointments still confused about their labs, unsure of their plan, and feeling like they had been processed rather than heard.</p>
				<p>I started Aster Private Health because I wanted to build the kind of practice I would want to visit as a patient. One where the first visit is 60 minutes, not 12. Where the provider actually knows your name, your history, and your goals. Where you leave with a plan that makes sense for your actual life.</p>
				<p>This is not a concierge luxury brand. It is simply healthcare the way it should work — with enough time to do it well.</p>
				<p class="ab-letter__sig">— Dr. Elena Marrow, FNP-C</p>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="ab-phil-heading">
		<div class="aster-container">
			<div class="ab-intro">
				<p class="aster-eyebrow">Care Philosophy</p>
				<h2 id="ab-phil-heading">What guides every decision at Aster Private Health.</h2>
			</div>
			<div class="ab-phil-list">
				{philosophy.map((p, i) => (
					<div class="ab-phil-item">
						<span class="ab-phil-num">{String(i + 1).padStart(2, '0')}</span>
						<div>
							<h3>{p.title}</h3>
							<p>{p.description}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="ab-interest-heading">
		<div class="aster-container ab-interest-layout">
			<div>
				<p class="aster-eyebrow">Clinical Interests</p>
				<h2 id="ab-interest-heading">Areas of clinical focus and expertise.</h2>
				<p class="aster-lead">Dr. Marrow brings over a decade of clinical experience across multiple care areas, with a particular focus on whole-person primary care and preventive health.</p>
			</div>
			<div class="ab-interest-list">
				{clinicalInterests.map((item) => (
					<div class="ab-interest-item">
						<span class="ab-interest-dot" aria-hidden="true"></span>
						<span>{item}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="ab-expect-heading">
		<div class="aster-container">
			<div class="ab-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">The Patient Experience</p>
				<h2 id="ab-expect-heading">What patients can expect at Aster Private Health.</h2>
			</div>
			<div class="ab-expect-grid">
				{expectations.map((e) => (
					<div class="ab-expect-card">
						<h3>{e.title}</h3>
						<p>{e.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section ab-final" aria-labelledby="ab-final-heading">
		<div class="aster-container">
			<div class="ab-final-card">
				<p class="aster-eyebrow ab-final-ey">Get started</p>
				<h2 id="ab-final-heading">Ready to meet your provider?</h2>
				<p class="ab-final-lead">Book a New Patient Consultation and experience healthcare designed around you.</p>
				<div class="aster-btn-row" style="justify-content:center;">
					<a class="aster-btn ab-cta-p" href="/demos/solo-practice/new-patients">Book a Consultation</a>
					<a class="aster-btn ab-cta-s" href="/demos/solo-practice/services">View Services</a>
				</div>
			</div>
		</div>
	</section>
</AsterLayout>

<style>
.ab-hero { padding-block: clamp(4.5rem, 8vw, 7rem) clamp(3rem, 5vw, 4rem); }
.ab-back { display: inline-flex; margin-bottom: 1.5rem; font-size: 0.82rem; font-weight: 600; color: var(--aster-clay); }
.ab-back:hover { color: var(--aster-clay-dark); }
.ab-intro { max-width: 560px; margin-bottom: clamp(2rem, 4vw, 3rem); }

.ab-profile { display: grid; grid-template-columns: 0.38fr 1fr; gap: clamp(2rem, 4vw, 3.5rem); align-items: start; }
.ab-portrait__img { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: clamp(2.5rem, 5vw, 4rem) 1.5rem; background: linear-gradient(170deg, var(--aster-eucalyptus-light) 0%, var(--aster-paper) 60%); border: 1px solid var(--aster-border); border-radius: var(--aster-radius-lg); min-height: 220px; }
.ab-avatar { display: flex; align-items: center; justify-content: center; width: clamp(5rem, 7vw, 6.5rem); height: clamp(5rem, 7vw, 6.5rem); border-radius: 50%; background: var(--aster-white); border: 2px solid var(--aster-border); }
.ab-avatar span { font-family: var(--aster-serif); font-size: clamp(1.3rem, 1.8vw, 1.6rem); font-weight: 600; color: var(--aster-clay); }
.ab-portrait__label { margin-top: 0.75rem; font-size: 0.62rem; font-weight: 600; color: var(--aster-muted); letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.5; }
.ab-profile__title { color: var(--aster-clay); font-weight: 600; font-size: 0.88rem; margin-bottom: 1rem; }
.ab-profile__bio { max-width: 520px; font-size: 1rem; line-height: 1.75; }
.ab-creds { display: grid; gap: 0.4rem; padding: 0; margin: 1.25rem 0 0; list-style: none; }
.ab-creds li { position: relative; padding-left: 0.85rem; font-size: 0.82rem; font-weight: 500; color: var(--aster-muted); }
.ab-creds li::before { content: ''; position: absolute; left: 0; top: 0.5rem; width: 4px; height: 4px; border-radius: 50%; background: var(--aster-clay); }

.ab-letter-wrap { max-width: 680px; margin-inline: auto; }
.ab-letter { padding: clamp(2rem, 4vw, 3rem); background: var(--aster-paper); border: 1px solid var(--aster-border); border-radius: var(--aster-radius-lg); }
.ab-letter__label { margin-bottom: 1rem; font-size: 0.68rem; font-weight: 700; color: var(--aster-clay); letter-spacing: 0.1em; text-transform: uppercase; }
.ab-letter p { font-size: 0.95rem; line-height: 1.75; }
.ab-letter__sig { margin-top: 1.5rem; font-family: var(--aster-serif); font-style: italic; font-weight: 500; color: var(--aster-heading); }

.ab-phil-list { display: grid; gap: 0; max-width: 680px; }
.ab-phil-item { display: flex; align-items: flex-start; gap: 1rem; padding-block: clamp(1.25rem, 2.5vw, 1.75rem); border-bottom: 1px solid var(--aster-border); }
.ab-phil-item:first-child { border-top: 1px solid var(--aster-border); }
.ab-phil-num { flex-shrink: 0; font-family: var(--aster-serif); font-size: 0.82rem; font-weight: 500; color: var(--aster-clay); opacity: 0.7; line-height: 1.65; }
.ab-phil-item h3 { margin-bottom: 0.25rem; }
.ab-phil-item p { margin: 0; color: var(--aster-text); font-size: 0.88rem; line-height: 1.65; }

.ab-interest-layout { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(3rem, 6vw, 5rem); align-items: start; }
.ab-interest-list { display: grid; gap: 0; }
.ab-interest-item { display: flex; align-items: center; gap: 0.65rem; padding-block: 0.75rem; border-bottom: 1px solid var(--aster-border); font-size: 0.9rem; font-weight: 500; color: var(--aster-heading); }
.ab-interest-item:first-child { border-top: 1px solid var(--aster-border); }
.ab-interest-dot { flex-shrink: 0; width: 5px; height: 5px; border-radius: 50%; background: var(--aster-clay); }

.ab-expect-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; max-width: 800px; margin-inline: auto; }
.ab-expect-card { padding: 1.5rem; background: var(--aster-white); border: 1px solid var(--aster-border); border-radius: var(--aster-radius); }
.ab-expect-card h3 { margin-bottom: 0.35rem; }
.ab-expect-card p { margin: 0; color: var(--aster-text); font-size: 0.85rem; line-height: 1.6; }

.ab-final { padding-block: clamp(2.5rem, 5vw, 4rem); }
.ab-final-card { max-width: 680px; margin-inline: auto; padding: clamp(2.5rem, 5vw, 4rem); border-radius: var(--aster-radius-lg); background: var(--aster-aubergine); text-align: center; }
.ab-final-ey { color: rgba(255,255,255,0.45) !important; }
.ab-final-card h2 { color: var(--aster-white); font-family: var(--aster-serif); font-weight: 500; max-width: 500px; margin-inline: auto; }
.ab-final-lead { max-width: 460px; margin-inline: auto; color: rgba(255,255,255,0.5); font-size: 0.92rem; line-height: 1.65; }
.ab-cta-p { background: var(--aster-clay); color: var(--aster-white); }
.ab-cta-p:hover { background: var(--aster-clay-dark); color: var(--aster-white); }
.ab-cta-s { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.75); }
.ab-cta-s:hover { background: rgba(255,255,255,0.07); color: var(--aster-white); }

.ab-snap-layout { display: grid; grid-template-columns: 0.4fr 1fr; gap: clamp(2rem, 4vw, 3.5rem); align-items: start; }
.ab-snap-img__inner { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: clamp(3rem, 6vw, 5rem) 2rem; background: linear-gradient(170deg, var(--aster-clay-light) 0%, var(--aster-paper) 70%); border: 1px solid var(--aster-border); border-radius: var(--aster-radius-lg); min-height: 280px; }
.ab-avatar--lg { width: clamp(5.5rem, 8vw, 7rem); height: clamp(5.5rem, 8vw, 7rem); }
.ab-snap-img__label { margin-top: 0.75rem; font-size: 0.62rem; font-weight: 600; color: var(--aster-muted); letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.5; }
.ab-snap-stats { display: grid; gap: 0; margin: 1.25rem 0 0; }
.ab-snap-stats > div { display: flex; gap: 1rem; padding-block: 0.7rem; border-bottom: 1px solid var(--aster-border); }
.ab-snap-stats > div:first-child { border-top: 1px solid var(--aster-border); }
.ab-snap-stats dt { flex-shrink: 0; width: 100px; font-size: 0.72rem; font-weight: 700; color: var(--aster-clay); letter-spacing: 0.06em; text-transform: uppercase; padding-top: 0.1rem; }
.ab-snap-stats dd { margin: 0; font-size: 0.88rem; font-weight: 500; color: var(--aster-heading); }

@media (max-width: 768px) {
	.ab-profile { grid-template-columns: 1fr; }
	.ab-interest-layout { grid-template-columns: 1fr; }
	.ab-expect-grid { grid-template-columns: 1fr; }
	.ab-snap-layout { grid-template-columns: 1fr; }
	.ab-snap-img__inner { min-height: 200px; }
}
</style>
