---
import AsterLayout from '../../../layouts/AsterLayout.astro';
import { brand, provider, faqs } from '../../../data/aster';

const contactMethods = [
	{ iconId: 'location', title: 'Visit In-Person', detail: 'Aster Private Health\nTemecula, CA', note: 'By appointment only' },
	{ iconId: 'telehealth', title: 'Telehealth', detail: 'Virtual appointments available', note: 'Follow-up and care coordination' },
	{ iconId: 'message', title: 'Secure Messaging', detail: 'Available to members', note: 'Response within 1 business day' },
];

const hours = [
	{ day: 'Monday – Thursday', time: '9:00 AM – 5:00 PM' },
	{ day: 'Friday', time: '9:00 AM – 3:00 PM' },
	{ day: 'Saturday – Sunday', time: 'Closed' },
];
---

<AsterLayout
	title="Contact | Aster Private Health Demo"
	description="Contact and location page for a fictional solo private healthcare practice demo."
	canonicalUrl="https://futuresolutions.io/demos/solo-practice/contact/"
>
	<section class="ct-hero" aria-labelledby="ct-heading">
		<div class="aster-container">
			<a class="ct-back" href="/demos/solo-practice">← Back to Aster Home</a>
			<p class="aster-eyebrow">Contact &amp; Location</p>
			<h1 id="ct-heading">Questions? Reach out. We will point you in the right direction.</h1>
			<p class="aster-lead">Whether you are a new patient, an existing patient, or just exploring — use this page to get in touch. This form is not for urgent medical concerns.</p>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="methods-heading">
		<div class="aster-container">
			<div class="ct-intro">
				<p class="aster-eyebrow">Reach us</p>
				<h2 id="methods-heading">How to reach the practice.</h2>
			</div>
			<div class="ct-methods-list">
				{contactMethods.map((m) => (
					<div class="ct-method">
						<span class="ct-method-icon" aria-hidden="true">
							{m.iconId === 'location' && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 20 20"><path d="M10 2C6.69 2 4 4.69 4 8c0 4.5 6 10 6 10s6-5.5 6-10c0-3.31-2.69-6-6-6Zm0 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z" fill="currentColor"/></svg>}
							{m.iconId === 'telehealth' && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 20 20"><rect x="2" y="4" width="16" height="11" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M6 18h8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M10 15v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>}
							{m.iconId === 'message' && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 20 20"><rect x="2" y="3" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M2 5l8 5 8-5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>}
						</span>
						<div>
							<h3>{m.title}</h3>
							<p class="ct-method-detail">{m.detail}</p>
							<p class="ct-method-note">{m.note}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="ct-resp-heading">
		<div class="aster-container">
			<div class="ct-intro">
				<p class="aster-eyebrow">Response Expectations</p>
				<h2 id="ct-resp-heading">What to expect after you reach out.</h2>
			</div>
			<div class="ct-resp-panel">
				<div class="ct-resp-row">
					<div class="ct-resp-type">New patient inquiries</div>
					<div class="ct-resp-detail">Within 1 business day via email or phone</div>
				</div>
				<div class="ct-resp-row">
					<div class="ct-resp-type">Existing patient messages</div>
					<div class="ct-resp-detail">Through the secure patient portal</div>
				</div>
				<div class="ct-resp-row">
					<div class="ct-resp-type">Urgent or emergency concerns</div>
					<div class="ct-resp-detail">Call 911 or visit your nearest emergency room. This form is not monitored for urgent issues.</div>
				</div>
				<div class="ct-resp-row">
					<div class="ct-resp-type">Appointment changes</div>
					<div class="ct-resp-detail">Use the patient portal or contact form</div>
				</div>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="form-heading">
		<div class="aster-container ct-form-grid">
			<div>
				<p class="aster-eyebrow">Get in touch</p>
				<h2 id="form-heading">Send a message.</h2>
				<p class="aster-lead">Use this form for scheduling questions, general inquiries, or billing questions. Existing patients should use the patient portal for clinical messages. We aim to respond within 1 business day.</p>
				<div class="ct-info-block">
					<h3>Office Hours</h3>
					<dl class="ct-hours">
						{hours.map((h) => (
							<div class="ct-hours__row"><dt>{h.day}</dt><dd>{h.time}</dd></div>
						))}
					</dl>
				</div>
				<div class="ct-info-block">
					<h3>Location</h3>
					<p>{brand.locationLine}</p>
					<p class="ct-info-note">{brand.availability}</p>
				</div>
			</div>
			<div class="ct-form-card aster-card">
				<form novalidate onsubmit="return false" aria-label="Aster Private Health contact form">
					<label><span>Full name</span><input type="text" name="name" autocomplete="name" placeholder="Your full name" /></label>
					<label><span>Email</span><input type="email" name="email" autocomplete="email" placeholder="you@email.com" /></label>
					<label><span>Phone (optional)</span><input type="tel" name="phone" autocomplete="tel" placeholder="(555) 555-5555" /></label>
					<label><span>I am a…</span>
						<select name="patient-status"><option value="">Select one</option><option value="new">New patient</option><option value="existing">Existing patient</option><option value="other">Other inquiry</option></select>
					</label>
					<label><span>Subject</span>
						<select name="subject"><option value="">Select a subject</option><option value="schedule">Schedule an appointment</option><option value="question">General question</option><option value="records">Records request</option><option value="billing">Billing or pricing question</option><option value="other">Something else</option></select>
					</label>
					<label><span>Message</span><textarea name="message" rows="4" placeholder="How can we help?"></textarea></label>
					<input type="hidden" name="source" value="Contact Page" />
					<input type="hidden" name="leadType" value="Contact Inquiry" />
					<div class="ct-form-footer">
						<button class="aster-btn aster-btn--primary" type="button" style="width:100%;">Send Message</button>
						<p>This is a demo form — no data is submitted. In a live build, this connects to scheduling, CRM, and follow-up systems.</p>
					</div>
				</form>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="map-heading">
		<div class="aster-container">
			<div class="ct-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">Location</p>
				<h2 id="map-heading">Conveniently located in Temecula, CA.</h2>
				<p class="aster-lead" style="margin-inline:auto;">Serving patients in Temecula, Murrieta, Fallbrook, and surrounding communities. Telehealth appointments available statewide.</p>
			</div>
			<div class="ct-map-placeholder" aria-label="Practice location">
				<img src="/images/aster/location-card.svg" alt="" width="600" height="300" loading="lazy" decoding="async" class="ct-map-img" />
				<p class="ct-map-note">Map integration available in live builds</p>
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="ct-faq-heading">
		<div class="aster-container">
			<div class="ct-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">FAQ</p>
				<h2 id="ct-faq-heading">Before you reach out.</h2>
			</div>
			<div class="ct-faq-list">
				{[faqs[3], faqs[2], faqs[7], faqs[6]].map((faq) => (
					<details class="ct-faq-item">
						<summary class="ct-faq-q"><span>{faq.question}</span><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 18 18" aria-hidden="true"><path stroke="currentColor" stroke-width="1.3" stroke-linecap="round" d="M4.5 7l4.5 4.5L13.5 7"/></svg></summary>
						<div class="ct-faq-a"><p>{faq.answer}</p></div>
					</details>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section ct-final" aria-labelledby="final-heading">
		<div class="aster-container">
			<div class="ct-final-card">
				<p class="aster-eyebrow ct-final-ey">New patients</p>
				<h2 id="final-heading">New to Aster? Start with a consultation.</h2>
				<p class="ct-final-lead">Your first visit is 60–75 minutes. Come with your questions — your provider will handle the rest.</p>
				<div class="aster-btn-row" style="justify-content:center;">
					<a class="aster-btn ct-cta-p" href="/demos/solo-practice/new-patients">Book a Consultation</a>
					<a class="aster-btn ct-cta-s" href="/demos/solo-practice/services">Explore Services</a>
				</div>
			</div>
		</div>
	</section>
</AsterLayout>

<style>
.ct-hero { padding-block: clamp(4.5rem, 8vw, 7rem) clamp(3rem, 5vw, 4rem); }
.ct-back { display: inline-flex; margin-bottom: 1.5rem; font-size: 0.82rem; font-weight: 600; color: var(--aster-clay); }
.ct-back:hover { color: var(--aster-clay-dark); }
.ct-intro { max-width: 560px; margin-bottom: clamp(2rem, 4vw, 3rem); }

.ct-methods-list { display: grid; gap: 0; max-width: 600px; }
.ct-method { display: flex; align-items: flex-start; gap: 1rem; padding-block: 1.25rem; border-bottom: 1px solid var(--aster-border); }
.ct-method:first-child { border-top: 1px solid var(--aster-border); }
.ct-method-icon { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 2.25rem; height: 2.25rem; border-radius: 8px; background: var(--aster-clay-light); color: var(--aster-clay); margin-top: 0.1rem; }
.ct-method h3 { margin-bottom: 0.15rem; }
.ct-method-detail { color: var(--aster-heading); font-weight: 500; font-size: 0.88rem; white-space: pre-line; margin-bottom: 0.15rem; }
.ct-method-note { color: var(--aster-muted); font-size: 0.78rem; }

.ct-resp-panel { max-width: 560px; border: 1px solid var(--aster-border); border-radius: var(--aster-radius-lg); background: var(--aster-paper); overflow: hidden; }
.ct-resp-row { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.85rem 1.5rem; border-bottom: 1px solid var(--aster-border); }
.ct-resp-row:last-child { border-bottom: none; }
.ct-resp-type { font-size: 0.88rem; font-weight: 600; color: var(--aster-heading); }
.ct-resp-detail { font-size: 0.85rem; color: var(--aster-muted); text-align: right; }

.ct-form-grid { display: grid; grid-template-columns: 0.85fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
.ct-info-block { margin-top: 1.75rem; padding-top: 1.25rem; border-top: 1px solid var(--aster-border); }
.ct-info-block h3 { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--aster-clay); margin-bottom: 0.6rem; }
.ct-hours { margin: 0; display: grid; gap: 0.35rem; }
.ct-hours__row { display: flex; justify-content: space-between; gap: 1rem; }
.ct-hours dt { font-weight: 600; font-size: 0.88rem; color: var(--aster-heading); }
.ct-hours dd { margin: 0; font-size: 0.88rem; color: var(--aster-muted); }
.ct-info-note { color: var(--aster-muted); font-size: 0.82rem; margin-top: 0.25rem; }

.ct-form-card { padding: clamp(1.35rem, 3vw, 2rem); }
.ct-form-card form, .ct-form-card label { display: grid; gap: 1rem; }
.ct-form-card label { gap: 0.4rem; }
.ct-form-card label span { color: var(--aster-heading); font-size: 0.85rem; font-weight: 600; }
.ct-form-card input, .ct-form-card select, .ct-form-card textarea { width: 100%; border: 1px solid var(--aster-border); border-radius: 8px; background: var(--aster-ivory); color: var(--aster-heading); font-size: 0.92rem; }
.ct-form-card input, .ct-form-card select { min-height: 2.75rem; padding: 0.65rem 0.8rem; }
.ct-form-card textarea { resize: vertical; min-height: 5.5rem; padding: 0.75rem 0.8rem; }
.ct-form-card input:focus, .ct-form-card select:focus, .ct-form-card textarea:focus { border-color: var(--aster-clay); outline: none; background: var(--aster-white); }
.ct-form-card input::placeholder, .ct-form-card textarea::placeholder { color: var(--aster-muted); }
.ct-form-footer { display: grid; gap: 0.75rem; }
.ct-form-footer p { margin: 0; color: var(--aster-muted); font-size: 0.78rem; line-height: 1.55; text-align: center; }

.ct-map-placeholder { border-radius: var(--aster-radius-lg); overflow: hidden; border: 1px solid var(--aster-border); background: var(--aster-white); text-align: center; }
.ct-map-img { display: block; width: 100%; height: auto; }
.ct-map-note { padding: 0.75rem; margin: 0; color: var(--aster-muted); font-size: 0.72rem; font-style: italic; border-top: 1px solid var(--aster-border); }

.ct-faq-list { max-width: 680px; margin-inline: auto; }
.ct-faq-item { border-bottom: 1px solid var(--aster-border); }
.ct-faq-item:first-child { border-top: 1px solid var(--aster-border); }
.ct-faq-q { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.1rem 0; cursor: pointer; list-style: none; font-weight: 600; font-size: 0.92rem; color: var(--aster-heading); }
.ct-faq-q::-webkit-details-marker { display: none; }
.ct-faq-q::marker { display: none; content: ''; }
.ct-faq-q svg { flex-shrink: 0; color: var(--aster-muted); transition: transform 0.2s ease; }
.ct-faq-item[open] .ct-faq-q svg { transform: rotate(180deg); }
.ct-faq-a { padding-bottom: 1.25rem; }
.ct-faq-a p { margin: 0; color: var(--aster-text); font-size: 0.88rem; line-height: 1.7; }

.ct-final { padding-block: clamp(2.5rem, 5vw, 4rem); }
.ct-final-card { max-width: 680px; margin-inline: auto; padding: clamp(2.5rem, 5vw, 4rem); border-radius: var(--aster-radius-lg); background: var(--aster-aubergine); text-align: center; }
.ct-final-ey { color: var(--aster-clay) !important; opacity: 0.9; }
.ct-final-card h2 { color: var(--aster-white); font-family: var(--aster-serif); font-weight: 500; max-width: 500px; margin-inline: auto; }
.ct-final-lead { max-width: 460px; margin-inline: auto; color: rgba(255,255,255,0.55); font-size: 0.92rem; line-height: 1.65; }
.ct-cta-p { background: var(--aster-clay); color: var(--aster-white); }
.ct-cta-p:hover { background: var(--aster-clay-dark); color: var(--aster-white); }
.ct-cta-s { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.75); }
.ct-cta-s:hover { background: rgba(255,255,255,0.07); color: var(--aster-white); }

@media (max-width: 860px) { .ct-form-grid { grid-template-columns: 1fr; } }
@media (max-width: 520px) { .ct-resp-row { flex-direction: column; gap: 0.2rem; } .ct-resp-detail { text-align: left; } }
</style>
