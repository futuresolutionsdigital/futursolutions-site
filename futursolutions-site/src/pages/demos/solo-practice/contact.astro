---
import DemoLayout from '../../../layouts/DemoLayout.astro';
import { meridianDemoLayoutDefaults } from '../../../data/demoMeridianLayout';

const serviceInterest = [
	'Functional Wellness',
	'Hormone & Metabolic Support',
	'Preventive Health Planning',
	'Lifestyle & Nutrition Support',
	'Patient Education Visit',
	'Not sure yet',
];

const preferredNext = ['Ask a question', 'Request appointment', 'Learn about services', 'Not sure yet'];

const flowSteps = ['Inquiry received', 'Contact created', 'Service interest noted', 'Follow-up', 'Appointment path'];
---

<DemoLayout
	variant="solo-practice"
	{...meridianDemoLayoutDefaults}
	title="Contact | Meridian Wellness Practice Demo"
	description="A solo practice demo contact page showing how independent providers can capture inquiries and guide visitors toward the right next step."
	canonicalUrl="https://futursolutions.vercel.app/demos/solo-practice/contact/"
>
	<section class="mw-page-hero" aria-labelledby="contact-heading">
		<div class="site-container">
			<p class="mw-eyebrow">Contact</p>
			<h1 id="contact-heading">A simple inquiry path for new patients.</h1>
			<p class="mw-lead">
				Share what you are looking for and the practice can guide you toward the right next step.
			</p>
		</div>
	</section>

	<section class="mw-section mw-section--muted" aria-labelledby="form-heading">
		<div class="site-container mw-contact-grid">
			<div>
				<p class="mw-eyebrow">Inquiry</p>
				<h2 id="form-heading">Start an inquiry.</h2>
				<p class="mw-lead">
					This form structure keeps the first step simple while collecting enough information to route the inquiry.
				</p>
			</div>
			<div class="mw-form-card">
				<form novalidate onsubmit="return false" aria-label="Meridian Wellness Practice demo inquiry form">
					<label>
						<span>Name</span>
						<input type="text" name="name" autocomplete="name" />
					</label>
					<label>
						<span>Email</span>
						<input type="email" name="email" autocomplete="email" />
					</label>
					<label>
						<span>Service interest</span>
						<select name="service-interest">
							<option value="">Select service interest</option>
							{serviceInterest.map((opt) => (
								<option value={opt}>{opt}</option>
							))}
						</select>
					</label>
					<label>
						<span>Preferred next step</span>
						<select name="preferred-next-step">
							<option value="">Select preferred next step</option>
							{preferredNext.map((opt) => (
								<option value={opt}>{opt}</option>
							))}
						</select>
					</label>
					<label>
						<span>Message</span>
						<textarea name="message" rows="4"></textarea>
					</label>
					<div class="mw-form-card__footer">
						<button class="mw-button mw-button--primary" type="button">Send Inquiry</button>
						<p>
							This is a demo form. In a real build, this could connect to GoHighLevel for lead capture, appointment requests, CRM follow-up, and pipeline tracking.
						</p>
					</div>
				</form>
			</div>
		</div>
	</section>

	<section class="mw-section" aria-labelledby="follow-heading">
		<div class="site-container">
			<div class="mw-section__intro">
				<p class="mw-eyebrow">Operations</p>
				<h2 id="follow-heading">This is where the system continues after the inquiry.</h2>
				<p class="mw-lead">
					In a full Future Solutions build, this inquiry could create a contact, apply service interest tags, trigger follow-up, and organize the lead in a pipeline.
				</p>
			</div>
			<div class="mw-flow" aria-label="Behind-the-scenes inquiry flow">
				{flowSteps.map((step, index) => (
					<div class="mw-flow__step">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<p>{step}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="mw-section mw-final" aria-labelledby="final-heading">
		<div class="site-container mw-final__card">
			<div>
				<p class="mw-eyebrow mw-eyebrow--invert">Future Solutions template</p>
				<h2 id="final-heading">Want this inquiry flow customized for your practice?</h2>
			</div>
			<div class="mw-button-row">
				<a class="mw-button mw-button--primary" href="/audit?template=solo-practice">Get This Template Customized</a>
				<a class="mw-button mw-button--secondary mw-button--invert" href="/templates">Back to Templates</a>
			</div>
		</div>
	</section>
</DemoLayout>

<style>
	.mw-page-hero,
	.mw-section {
		padding-block: clamp(4.5rem, 8vw, 7rem);
	}

	.mw-page-hero {
		background:
			radial-gradient(circle at 78% 8%, rgba(77, 122, 113, 0.12), transparent 32%),
			linear-gradient(180deg, #ffffff 0%, #f9faf8 80%);
	}

	.mw-eyebrow {
		margin-bottom: 1rem;
		color: #4d7a71;
		font-size: 0.8125rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.mw-eyebrow--invert {
		color: #b8d4cc;
	}

	.mw-page-hero h1,
	.mw-section h2 {
		max-width: 900px;
		color: #1a2330;
	}

	.mw-section__intro {
		max-width: 760px;
	}

	.mw-lead {
		max-width: 720px;
		color: #5c6b6a;
		font-size: clamp(1.05rem, 1rem + 0.28vw, 1.22rem);
		line-height: 1.66;
	}

	.mw-section--muted {
		border-block: 1px solid rgba(26, 35, 48, 0.07);
		background: #eef2f1;
	}

	.mw-contact-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(360px, 0.75fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
	}

	.mw-form-card {
		padding: clamp(1.35rem, 3vw, 2rem);
		border: 1px solid rgba(26, 35, 48, 0.09);
		border-radius: 22px;
		background: #ffffff;
		box-shadow: 0 18px 48px rgba(26, 35, 48, 0.06);
	}

	.mw-form-card form,
	.mw-form-card label {
		display: grid;
		gap: 1rem;
	}

	.mw-form-card label {
		gap: 0.45rem;
	}

	.mw-form-card label span {
		color: #1a2330;
		font-size: 0.875rem;
		font-weight: 800;
	}

	.mw-form-card input,
	.mw-form-card select,
	.mw-form-card textarea {
		width: 100%;
		border: 1px solid rgba(26, 35, 48, 0.14);
		border-radius: 12px;
		background: #f9faf8;
		color: #1a2330;
		font-size: 0.95rem;
	}

	.mw-form-card input,
	.mw-form-card select {
		min-height: 2.85rem;
		padding: 0.7rem 0.8rem;
	}

	.mw-form-card textarea {
		resize: vertical;
		min-height: 7rem;
		padding: 0.8rem;
	}

	.mw-form-card input:focus,
	.mw-form-card select:focus,
	.mw-form-card textarea:focus {
		border-color: rgba(77, 122, 113, 0.55);
		outline: none;
		background: #ffffff;
	}

	.mw-form-card__footer {
		display: grid;
		gap: 0.85rem;
	}

	.mw-form-card__footer p {
		margin: 0;
		color: #5c6b6a;
		font-size: 0.85rem;
		line-height: 1.55;
	}

	.mw-button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.875rem;
		margin-top: 2rem;
	}

	.mw-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.875rem;
		padding: 0.8rem 1.1rem;
		border-radius: 999px;
		font-size: 0.9375rem;
		font-weight: 800;
		line-height: 1;
	}

	.mw-button--primary {
		border: 1px solid transparent;
		background: #4d7a71;
		color: #ffffff;
	}

	.mw-button--primary:hover {
		background: #3d615a;
		color: #ffffff;
	}

	.mw-button--invert {
		border: 1px solid rgba(255, 255, 255, 0.35);
		background: transparent;
		color: #ffffff;
	}

	.mw-button--invert:hover {
		background: rgba(255, 255, 255, 0.12);
		color: #ffffff;
	}

	.mw-flow {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 2rem;
	}

	.mw-flow__step {
		padding: 1.05rem;
		border: 1px solid rgba(26, 35, 48, 0.09);
		border-radius: 16px;
		background: #ffffff;
	}

	.mw-flow__step span {
		display: inline-flex;
		margin-bottom: 0.6rem;
		color: #4d7a71;
		font-size: 0.75rem;
		font-weight: 800;
	}

	.mw-flow__step p {
		margin: 0;
		color: #1a2330;
		font-weight: 800;
		font-size: 0.9rem;
		line-height: 1.4;
	}

	.mw-final {
		background: #dfe8e6;
	}

	.mw-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border-radius: 22px;
		background: #1a2733;
		box-shadow: 0 24px 60px rgba(26, 35, 48, 0.12);
	}

	.mw-final h2 {
		color: #ffffff;
	}

	@media (max-width: 1040px) {
		.mw-flow {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 820px) {
		.mw-contact-grid,
		.mw-final__card {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 620px) {
		.mw-flow {
			grid-template-columns: 1fr;
		}
	}
</style>
