---
import AsterLayout from '../../../layouts/AsterLayout.astro';
import { services, conditions, faqs } from '../../../data/aster';
---

<AsterLayout
	title="Services & Care Areas | Aster Private Health Demo"
	description="Explore care areas offered at Aster Private Health — private primary care, preventive health, women's wellness, hormone support, metabolic health, functional wellness, and telehealth."
	canonicalUrl="https://futursolutions.vercel.app/demos/solo-practice/services/"
>
	<section class="sp-hero" aria-labelledby="svc-heading">
		<div class="aster-container">
			<a class="sp-back" href="/demos/solo-practice">← Back to Aster Home</a>
			<p class="aster-eyebrow">Services &amp; Care Areas</p>
			<h1 id="svc-heading">Care designed around the whole person.</h1>
			<p class="aster-lead">Each area of care is supported by thorough evaluation, personalized planning, and ongoing follow-up — not a rushed checklist.</p>
			<div class="aster-btn-row">
				<a class="aster-btn aster-btn--primary" href="/demos/solo-practice/new-patients">Book a Consultation</a>
				<a class="aster-btn aster-btn--secondary" href="/demos/solo-practice/#pricing">View Pricing</a>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="grid-heading">
		<div class="aster-container">
			<div class="sp-intro">
				<p class="aster-eyebrow">Overview</p>
				<h2 id="grid-heading">What we help patients with.</h2>
				<p class="aster-lead">Every service begins with a conversation — your goals, your concerns, and a plan that fits your life.</p>
			</div>
			<div class="sp-svc-list">
				{services.map((svc) => (
					<article class="sp-svc-row">
						<div class="sp-svc-head">
							<h3>{svc.title}</h3>
							<p class="sp-svc-best">{svc.bestFor}</p>
						</div>
						<div class="sp-svc-body">
							<p>{svc.description}</p>
							<a class="sp-svc-link" href="/demos/solo-practice/new-patients">
								Book this service
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 14 14" aria-hidden="true"><path stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" d="m5.25 3.5 3.5 3.5-3.5 3.5"/></svg>
							</a>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="conditions-heading">
		<div class="aster-container">
			<div class="sp-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">Areas of focus</p>
				<h2 id="conditions-heading">Common concerns we help patients navigate.</h2>
			</div>
			<div class="sp-tags">
				{conditions.map((cond) => <span class="sp-tag">{cond}</span>)}
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="sp-choose-heading">
		<div class="aster-container">
			<div class="sp-choose-layout">
				<div>
					<p class="aster-eyebrow">Not sure where to start?</p>
					<h2 id="sp-choose-heading">How to choose a care path.</h2>
					<p class="aster-lead">You do not need to know which service you need before your first visit. Your provider will help you find the right approach.</p>
				</div>
				<div class="sp-choose-steps">
					<div class="sp-choose-step">
						<span class="sp-choose-num">1</span>
						<div><strong>Start with a consultation</strong><p>Share your concerns, goals, and health history.</p></div>
					</div>
					<div class="sp-choose-step">
						<span class="sp-choose-num">2</span>
						<div><strong>Provider recommends the right care path</strong><p>Based on your evaluation, your provider suggests the most relevant services.</p></div>
					</div>
					<div class="sp-choose-step">
						<span class="sp-choose-num">3</span>
						<div><strong>Services can overlap</strong><p>Primary care, preventive health, and other areas work together as needed.</p></div>
					</div>
					<div class="sp-choose-step">
						<span class="sp-choose-num">4</span>
						<div><strong>Follow-up adapts over time</strong><p>Your care plan evolves with your health — it is not a rigid track.</p></div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="svc-faq-heading">
		<div class="aster-container">
			<div class="sp-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">FAQ</p>
				<h2 id="svc-faq-heading">Questions about our services?</h2>
			</div>
			<div class="sp-faq-list">
				{faqs.slice(0, 4).map((faq) => (
					<details class="sp-faq-item">
						<summary class="sp-faq-q">
							<span>{faq.question}</span>
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 18 18" aria-hidden="true"><path stroke="currentColor" stroke-width="1.3" stroke-linecap="round" d="M4.5 7l4.5 4.5L13.5 7"/></svg>
						</summary>
						<div class="sp-faq-a"><p>{faq.answer}</p></div>
					</details>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section sp-final" aria-labelledby="final-heading">
		<div class="aster-container">
			<div class="sp-final-card">
				<p class="aster-eyebrow sp-final-ey">Get started</p>
				<h2 id="final-heading">Ready to explore which services fit your goals?</h2>
				<p class="sp-final-lead">Start with a New Patient Consultation and your provider will help you determine the best care pathway.</p>
				<div class="aster-btn-row" style="justify-content:center;">
					<a class="aster-btn sp-cta-p" href="/demos/solo-practice/new-patients">Book a Consultation</a>
					<a class="aster-btn sp-cta-s" href="/demos/solo-practice">Back to Aster Home</a>
				</div>
			</div>
		</div>
	</section>
</AsterLayout>

<style>
.sp-hero { padding-block: clamp(4.5rem, 8vw, 7rem) clamp(3rem, 5vw, 4rem); }
.sp-back { display: inline-flex; margin-bottom: 1.5rem; font-size: 0.82rem; font-weight: 600; color: var(--aster-clay); }
.sp-back:hover { color: var(--aster-clay-dark); }
.sp-intro { max-width: 560px; margin-bottom: clamp(2rem, 4vw, 3rem); }

.sp-svc-list { display: grid; gap: 0; }
.sp-svc-row { display: grid; grid-template-columns: 0.4fr 1fr; gap: clamp(1.5rem, 3vw, 2.5rem); padding-block: clamp(1.25rem, 2.5vw, 1.75rem); border-bottom: 1px solid var(--aster-border); }
.sp-svc-row:first-child { border-top: 1px solid var(--aster-border); }
.sp-svc-head h3 { margin-bottom: 0.25rem; }
.sp-svc-best { margin: 0; color: var(--aster-muted); font-size: 0.78rem; font-style: italic; }
.sp-svc-body p { color: var(--aster-text); font-size: 0.9rem; line-height: 1.65; }
.sp-svc-link { display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.8rem; font-weight: 600; color: var(--aster-clay); }
.sp-svc-link:hover { color: var(--aster-clay-dark); }

.sp-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; max-width: 680px; margin-inline: auto; }
.sp-tag { padding: 0.5rem 1rem; border: 1px solid var(--aster-border); border-radius: 999px; font-size: 0.82rem; font-weight: 500; color: var(--aster-heading); background: var(--aster-white); transition: border-color 0.18s ease, background 0.18s ease; }
.sp-tag:hover { border-color: var(--aster-clay); background: var(--aster-clay-light); }

.sp-choose-layout { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 3.5rem); align-items: start; }
.sp-choose-steps { display: grid; gap: 0; }
.sp-choose-step { display: flex; align-items: flex-start; gap: 0.85rem; padding-block: clamp(0.85rem, 2vw, 1.15rem); border-bottom: 1px solid var(--aster-border); }
.sp-choose-step:first-child { border-top: 1px solid var(--aster-border); }
.sp-choose-num { flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; width: 1.5rem; height: 1.5rem; border-radius: 50%; background: var(--aster-clay-light); font-family: var(--aster-serif); font-size: 0.72rem; font-weight: 600; color: var(--aster-clay); margin-top: 0.1rem; }
.sp-choose-step strong { display: block; font-size: 0.88rem; color: var(--aster-heading); margin-bottom: 0.15rem; }
.sp-choose-step p { margin: 0; font-size: 0.82rem; color: var(--aster-muted); line-height: 1.5; }

.sp-faq-list { max-width: 680px; margin-inline: auto; }
.sp-faq-item { border-bottom: 1px solid var(--aster-border); }
.sp-faq-item:first-child { border-top: 1px solid var(--aster-border); }
.sp-faq-q { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.1rem 0; cursor: pointer; list-style: none; font-weight: 600; font-size: 0.92rem; color: var(--aster-heading); }
.sp-faq-q::-webkit-details-marker { display: none; }
.sp-faq-q::marker { display: none; content: ''; }
.sp-faq-q svg { flex-shrink: 0; color: var(--aster-muted); transition: transform 0.2s ease; }
.sp-faq-item[open] .sp-faq-q svg { transform: rotate(180deg); }
.sp-faq-a { padding-bottom: 1.25rem; }
.sp-faq-a p { margin: 0; color: var(--aster-text); font-size: 0.88rem; line-height: 1.7; }

.sp-final { padding-block: clamp(2.5rem, 5vw, 4rem); }
.sp-final-card { max-width: 680px; margin-inline: auto; padding: clamp(2.5rem, 5vw, 4rem); border-radius: var(--aster-radius-lg); background: var(--aster-aubergine); text-align: center; }
.sp-final-ey { color: var(--aster-clay) !important; opacity: 0.9; }
.sp-final-card h2 { color: var(--aster-white); font-family: var(--aster-serif); font-weight: 500; max-width: 500px; margin-inline: auto; }
.sp-final-lead { max-width: 460px; margin-inline: auto; color: rgba(255,255,255,0.55); font-size: 0.92rem; line-height: 1.65; }
.sp-cta-p { background: var(--aster-clay); color: var(--aster-white); }
.sp-cta-p:hover { background: var(--aster-clay-dark); color: var(--aster-white); }
.sp-cta-s { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.75); }
.sp-cta-s:hover { background: rgba(255,255,255,0.07); color: var(--aster-white); }

@media (max-width: 620px) { .sp-svc-row { grid-template-columns: 1fr; gap: 0.5rem; } .sp-choose-layout { grid-template-columns: 1fr; } }
</style>
