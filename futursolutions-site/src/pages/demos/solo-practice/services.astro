---
import AsterLayout from '../../../layouts/AsterLayout.astro';
import { services, conditions, faqs } from '../../../data/aster';
---

<AsterLayout
	title="Services & Care Areas | Aster Private Health Demo"
	description="Explore care areas offered at Aster Private Health — private primary care, preventive health, women's wellness, hormone support, metabolic health, functional wellness, and telehealth."
	canonicalUrl="https://futursolutions.vercel.app/demos/solo-practice/services/"
>
	<section class="ap-page-hero" aria-labelledby="svc-heading">
		<div class="aster-container">
			<a class="ap-back" href="/demos/solo-practice">← Back to Aster Home</a>
			<p class="aster-eyebrow">Services &amp; Care Areas</p>
			<h1 id="svc-heading">Care designed around the whole person.</h1>
			<p class="aster-lead">Each area of care is supported by thorough evaluation, personalized planning, and ongoing follow-up — not a rushed checklist.</p>
			<div class="aster-btn-row">
				<a class="aster-btn aster-btn--primary" href="/demos/solo-practice/new-patients">Book a Consultation</a>
				<a class="aster-btn aster-btn--secondary" href="/demos/solo-practice/#pricing">View Pricing</a>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--sand" aria-labelledby="grid-heading">
		<div class="aster-container">
			<div class="ap-intro">
				<p class="aster-eyebrow">Overview</p>
				<h2 id="grid-heading">What we help patients with.</h2>
				<p class="aster-lead">Every service begins with a conversation — your goals, your concerns, and a plan that fits your life.</p>
			</div>
			<div class="ap-services-grid">
				{services.map((svc) => (
					<article class="aster-card ap-svc-card">
						<h3>{svc.title}</h3>
						<p class="ap-svc-card__desc">{svc.description}</p>
						<div class="ap-svc-card__meta">
							<strong>Best for:</strong>
							<span>{svc.bestFor}</span>
						</div>
						<a class="ap-svc-card__link" href="/demos/solo-practice/new-patients">
							Book This Service
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 14 14" aria-hidden="true"><path stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" d="m5.25 3.5 3.5 3.5-3.5 3.5"/></svg>
						</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="conditions-heading">
		<div class="aster-container">
			<div class="ap-intro">
				<p class="aster-eyebrow">Areas of focus</p>
				<h2 id="conditions-heading">Common concerns we help patients navigate.</h2>
				<p class="aster-lead">Whether you are seeking answers, symptom relief, or a clearer path forward, these are the concerns our patients most often bring to us.</p>
			</div>
			<div class="ap-conditions-grid">
				{conditions.map((cond) => (
					<div class="ap-condition-item">
						<span class="ap-condition-dot" aria-hidden="true"></span>
						<span>{cond}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--sand" aria-labelledby="svc-faq-heading">
		<div class="aster-container">
			<div class="ap-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">FAQ</p>
				<h2 id="svc-faq-heading">Questions about our services?</h2>
			</div>
			<div class="ap-faq-list">
				{faqs.slice(0, 4).map((faq) => (
					<details class="ap-faq-item">
						<summary class="ap-faq-question">
							<span>{faq.question}</span>
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 20 20" aria-hidden="true"><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M5 8l5 5 5-5"/></svg>
						</summary>
						<div class="ap-faq-answer"><p>{faq.answer}</p></div>
					</details>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section ap-final-section" aria-labelledby="final-heading">
		<div class="aster-container">
			<div class="ap-final-card">
				<p class="aster-eyebrow ap-final-eyebrow">Get started</p>
				<h2 id="final-heading">Ready to explore which services fit your goals?</h2>
				<p class="ap-final-lead">Start with a New Patient Consultation and your provider will help you determine the best care pathway.</p>
				<div class="aster-btn-row" style="justify-content:center;">
					<a class="aster-btn ap-final-btn-primary" href="/demos/solo-practice/new-patients">Book a Consultation</a>
					<a class="aster-btn ap-final-btn-secondary" href="/demos/solo-practice">Back to Aster Home</a>
				</div>
			</div>
		</div>
	</section>
</AsterLayout>

<style>
.ap-page-hero { padding-block: clamp(4rem, 7vw, 6rem) clamp(3rem, 5vw, 4rem); background: linear-gradient(180deg, var(--aster-bg) 0%, color-mix(in srgb, var(--aster-sand) 25%, var(--aster-bg)) 100%); }
.ap-back { display: inline-flex; align-items: center; margin-bottom: 1.5rem; font-size: 0.82rem; font-weight: 600; color: var(--aster-sage); }
.ap-back:hover { color: var(--aster-sage-dark); }
.ap-intro { max-width: 660px; margin-bottom: clamp(2rem, 4vw, 3rem); }

.ap-services-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; }
.ap-svc-card { display: flex; flex-direction: column; padding: 1.35rem; }
.ap-svc-card__desc { flex: 1; color: var(--aster-muted); font-size: 0.88rem; line-height: 1.55; }
.ap-svc-card__meta { margin-bottom: 0.75rem; padding-top: 0.75rem; border-top: 1px solid var(--aster-border); font-size: 0.78rem; color: var(--aster-text); }
.ap-svc-card__meta strong { color: var(--aster-heading); }
.ap-svc-card__link { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.82rem; font-weight: 700; color: var(--aster-sage); }
.ap-svc-card__link:hover { color: var(--aster-sage-dark); }

.ap-conditions-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 0.75rem; }
.ap-condition-item { display: flex; align-items: center; gap: 0.65rem; padding: 0.85rem 1rem; border-radius: 10px; background: var(--aster-sand); border: 1px solid var(--aster-border); font-size: 0.9rem; font-weight: 600; color: var(--aster-heading); transition: background 0.18s ease; }
.ap-condition-item:hover { background: color-mix(in srgb, var(--aster-sage-light) 70%, var(--aster-sand)); }
.ap-condition-dot { flex-shrink: 0; width: 0.4rem; height: 0.4rem; border-radius: 50%; background: var(--aster-sage); }

.ap-faq-list { max-width: 760px; margin-inline: auto; }
.ap-faq-item { border-bottom: 1px solid var(--aster-border); }
.ap-faq-item:first-child { border-top: 1px solid var(--aster-border); }
.ap-faq-question { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.15rem 0; cursor: pointer; list-style: none; font-weight: 700; font-size: 0.95rem; color: var(--aster-heading); }
.ap-faq-question::-webkit-details-marker { display: none; }
.ap-faq-question::marker { display: none; content: ''; }
.ap-faq-question svg { flex-shrink: 0; color: var(--aster-muted); transition: transform 0.2s ease; }
.ap-faq-item[open] .ap-faq-question svg { transform: rotate(180deg); }
.ap-faq-answer { padding-bottom: 1.25rem; }
.ap-faq-answer p { margin: 0; color: var(--aster-text); font-size: 0.9rem; line-height: 1.65; }

.ap-final-section { padding-block: clamp(2.5rem, 5vw, 4rem); background: var(--aster-sand); }
.ap-final-card { max-width: 760px; margin-inline: auto; padding: clamp(2rem, 4vw, 3.5rem); border-radius: var(--aster-radius-lg); background: var(--aster-heading); text-align: center; }
.ap-final-eyebrow { color: var(--aster-warm) !important; }
.ap-final-card h2 { color: var(--aster-white); max-width: 560px; margin-inline: auto; }
.ap-final-lead { max-width: 520px; margin-inline: auto; color: rgba(255,255,255,0.6); font-size: 0.95rem; line-height: 1.6; }
.ap-final-btn-primary { background: var(--aster-sage); color: var(--aster-white); }
.ap-final-btn-primary:hover { background: var(--aster-sage-dark); color: var(--aster-white); }
.ap-final-btn-secondary { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.8); }
.ap-final-btn-secondary:hover { background: rgba(255,255,255,0.08); color: var(--aster-white); }

@media (max-width: 960px) { .ap-services-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
@media (max-width: 860px) { .ap-conditions-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
@media (max-width: 620px) { .ap-conditions-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
@media (max-width: 520px) { .ap-services-grid, .ap-conditions-grid { grid-template-columns: 1fr; } }
</style>
