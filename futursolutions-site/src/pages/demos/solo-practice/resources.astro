---
import AsterLayout from '../../../layouts/AsterLayout.astro';
import { resources } from '../../../data/aster';

const categories = [
	'Private Care', 'Preventive Health', 'Women\'s Wellness',
	'Labs & Follow-Up', 'Telehealth', 'Patient Guides',
];
---

<AsterLayout
	title="Patient Resources | Aster Private Health Demo"
	description="Educational resource hub for a fictional private healthcare practice, including cash-pay care, visit preparation, and longer-visit guidance."
	canonicalUrl="https://futuresolutions.io/demos/solo-practice/resources/"
>
	<section class="rs-hero" aria-labelledby="rs-heading">
		<div class="aster-container">
			<a class="rs-back" href="/demos/solo-practice">← Back to Aster Home</a>
			<p class="aster-eyebrow">Patient Resources</p>
			<h1 id="rs-heading">Straightforward answers to common patient questions.</h1>
			<p class="aster-lead">Short guides covering how private care works, what your first visit looks like, and how to make the most of your appointments.</p>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="rs-feat-heading">
		<div class="aster-container">
			<div class="rs-intro">
				<p class="aster-eyebrow">Featured Resources</p>
				<h2 id="rs-feat-heading">Start here if you are considering a private practice.</h2>
			</div>
			<div class="rs-feat-grid">
				{resources.map((r) => (
					<article class="rs-feat-card">
						<span class="rs-feat-cat">{r.category}</span>
						<h3><a href={r.href}>{r.title}</a></h3>
						<p class="rs-feat-excerpt">{r.excerpt}</p>
						<a class="rs-feat-link" href={r.href}>
							Read article
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 14 14" aria-hidden="true"><path stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" d="m5.25 3.5 3.5 3.5-3.5 3.5"/></svg>
						</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="rs-more-heading">
		<div class="aster-container">
			<div class="rs-intro">
				<p class="aster-eyebrow">More Articles</p>
				<h2 id="rs-more-heading">Continue reading.</h2>
			</div>
			<div class="rs-article-list">
				<article class="rs-article-row">
					<span class="rs-article-cat">Private Care</span>
					<h3>Questions to Ask Before Joining a Cash-Pay Practice</h3>
					<p>Seven practical questions to help you compare direct-pay practices — including what to ask about pricing, cancellations, lab costs, and provider availability.</p>
				</article>
				<article class="rs-article-row">
					<span class="rs-article-cat">Labs &amp; Follow-Up</span>
					<h3>How to Prepare for a Lab Review Visit</h3>
					<p>Bring your results, write down your questions, and know what to ask about reference ranges. Here is how to get more from a 30-minute lab review.</p>
				</article>
				<article class="rs-article-row">
					<span class="rs-article-cat">Telehealth</span>
					<h3>When Telehealth Works Best for Follow-Up Care</h3>
					<p>Lab reviews, medication check-ins, and care plan updates often work well virtually. Here is when telehealth makes sense and when an in-person visit is better.</p>
				</article>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="rs-guide-heading">
		<div class="aster-container">
			<div class="rs-guide-panel">
				<div class="rs-guide-preview" aria-hidden="true">
					<div class="rs-guide-doc">
						<span class="rs-guide-logo">A</span>
						<strong>New Patient Preparation Guide</strong>
						<ul>
							<li>What to bring to your first visit</li>
							<li>How to prepare your health history</li>
							<li>Questions to ask your provider</li>
							<li>Understanding the care plan process</li>
						</ul>
						<span class="rs-guide-badge">PDF Guide</span>
					</div>
				</div>
				<div class="rs-guide-content">
					<p class="aster-eyebrow">Featured Guide</p>
					<h2 id="rs-guide-heading">Get the New Patient Preparation Guide</h2>
					<p class="rs-guide-desc">A short guide covering what to bring, what forms to complete, questions worth asking, and how to get the most from your 60–75 minute consultation.</p>
					<form novalidate onsubmit="return false" aria-label="Patient guide download form" class="rs-guide-form">
						<label><span>Email</span><input type="email" name="email" placeholder="you@email.com" /></label>
						<button class="aster-btn aster-btn--primary" type="button" style="width:100%;">Download Guide</button>
						<p class="rs-guide-disclaimer">This is a demo form — no data is submitted. In a live build, this connects to your email and CRM system.</p>
					</form>
				</div>
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="rs-cat-heading">
		<div class="aster-container">
			<div class="rs-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">Browse by Topic</p>
				<h2 id="rs-cat-heading">Explore resources by category.</h2>
			</div>
			<div class="rs-cat-grid">
				{categories.map((cat) => (
					<div class="rs-cat-tag">{cat}</div>
				))}
			</div>
			<p class="rs-cat-note">In a live build, each category links to a filtered article archive. Additional articles are published on a regular schedule.</p>
		</div>
	</section>

	<section class="aster-section rs-final" aria-labelledby="rs-final-heading">
		<div class="aster-container">
			<div class="rs-final-card">
				<p class="aster-eyebrow rs-final-ey">Ready to take the next step?</p>
				<h2 id="rs-final-heading">Have more questions? Start with a conversation.</h2>
				<p class="rs-final-lead">Book a New Patient Consultation. Your first visit is 60–75 minutes — plenty of time to get your questions answered.</p>
				<div class="aster-btn-row" style="justify-content:center;">
					<a class="aster-btn rs-cta-p" href="/demos/solo-practice/new-patients">Book a Consultation</a>
					<a class="aster-btn rs-cta-s" href="/demos/solo-practice/services">Explore Services</a>
				</div>
			</div>
		</div>
	</section>
</AsterLayout>

<style>
.rs-hero { padding-block: clamp(4.5rem, 8vw, 7rem) clamp(3rem, 5vw, 4rem); }
.rs-back { display: inline-flex; margin-bottom: 1.5rem; font-size: 0.82rem; font-weight: 600; color: var(--aster-clay); }
.rs-back:hover { color: var(--aster-clay-dark); }
.rs-intro { max-width: 560px; margin-bottom: clamp(2rem, 4vw, 3rem); }

.rs-feat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.rs-feat-card { padding: 1.5rem; background: var(--aster-white); border: 1px solid var(--aster-border); border-radius: var(--aster-radius); display: flex; flex-direction: column; }
.rs-feat-cat { display: inline-block; width: fit-content; margin-bottom: 0.65rem; font-size: 0.62rem; font-weight: 700; color: var(--aster-clay); letter-spacing: 0.1em; text-transform: uppercase; }
.rs-feat-card h3 { margin-bottom: 0.4rem; }
.rs-feat-card h3 a { color: var(--aster-heading); }
.rs-feat-card h3 a:hover { color: var(--aster-clay); }
.rs-feat-excerpt { flex: 1; color: var(--aster-muted); font-size: 0.85rem; line-height: 1.6; }
.rs-feat-link { display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.78rem; font-weight: 600; color: var(--aster-clay); }
.rs-feat-link:hover { color: var(--aster-clay-dark); }

.rs-cat-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; max-width: 560px; margin-inline: auto; }
.rs-cat-tag { padding: 0.55rem 1.15rem; border: 1px solid var(--aster-border); border-radius: 999px; font-size: 0.82rem; font-weight: 500; color: var(--aster-heading); background: var(--aster-white); transition: border-color 0.18s ease, background 0.18s ease; cursor: default; }
.rs-cat-tag:hover { border-color: var(--aster-clay); background: var(--aster-clay-light); }
.rs-cat-note { margin-top: 1.5rem; text-align: center; color: var(--aster-muted); font-size: 0.78rem; font-style: italic; }

.rs-article-list { display: grid; gap: 0; max-width: 680px; }
.rs-article-row { padding-block: clamp(1.25rem, 2.5vw, 1.75rem); border-bottom: 1px solid var(--aster-border); }
.rs-article-row:first-child { border-top: 1px solid var(--aster-border); }
.rs-article-cat { display: inline-block; margin-bottom: 0.5rem; font-size: 0.62rem; font-weight: 700; color: var(--aster-clay); letter-spacing: 0.1em; text-transform: uppercase; }
.rs-article-row h3 { margin-bottom: 0.35rem; }
.rs-article-row p { margin: 0; color: var(--aster-muted); font-size: 0.88rem; line-height: 1.6; }

.rs-guide-panel { display: grid; grid-template-columns: 0.45fr 1fr; gap: clamp(2rem, 4vw, 3.5rem); align-items: center; }
.rs-guide-doc { padding: clamp(1.25rem, 3vw, 1.75rem); background: var(--aster-white); border: 1px solid var(--aster-border); border-radius: var(--aster-radius); }
.rs-guide-logo { display: inline-flex; align-items: center; justify-content: center; width: 1.6rem; height: 1.6rem; border-radius: 5px; background: var(--aster-clay); color: var(--aster-white); font-family: var(--aster-serif); font-size: 0.6rem; font-weight: 700; margin-bottom: 0.65rem; }
.rs-guide-doc strong { display: block; font-size: 0.88rem; color: var(--aster-heading); margin-bottom: 0.65rem; }
.rs-guide-doc ul { padding: 0; margin: 0 0 0.75rem; list-style: none; display: grid; gap: 0.35rem; }
.rs-guide-doc li { position: relative; padding-left: 0.75rem; font-size: 0.78rem; color: var(--aster-muted); }
.rs-guide-doc li::before { content: ''; position: absolute; left: 0; top: 0.45rem; width: 3px; height: 3px; border-radius: 50%; background: var(--aster-clay); }
.rs-guide-badge { display: inline-block; padding: 0.25rem 0.6rem; background: var(--aster-clay-light); border-radius: 4px; font-size: 0.62rem; font-weight: 700; color: var(--aster-clay); letter-spacing: 0.05em; text-transform: uppercase; }
.rs-guide-desc { color: var(--aster-text); font-size: 0.92rem; line-height: 1.7; }
.rs-guide-form { display: grid; gap: 0.85rem; max-width: 340px; }
.rs-guide-form label { display: grid; gap: 0.35rem; }
.rs-guide-form label span { font-size: 0.82rem; font-weight: 600; color: var(--aster-heading); }
.rs-guide-form input { width: 100%; border: 1px solid var(--aster-border); border-radius: 8px; background: var(--aster-ivory); color: var(--aster-heading); font-size: 0.92rem; min-height: 2.75rem; padding: 0.65rem 0.8rem; }
.rs-guide-form input:focus { border-color: var(--aster-clay); outline: none; background: var(--aster-white); }
.rs-guide-form input::placeholder { color: var(--aster-muted); }
.rs-guide-disclaimer { margin: 0; color: var(--aster-muted); font-size: 0.72rem; text-align: center; font-style: italic; }

.rs-final { padding-block: clamp(2.5rem, 5vw, 4rem); }
.rs-final-card { max-width: 680px; margin-inline: auto; padding: clamp(2.5rem, 5vw, 4rem); border-radius: var(--aster-radius-lg); background: var(--aster-aubergine); text-align: center; }
.rs-final-ey { color: rgba(255,255,255,0.45) !important; }
.rs-final-card h2 { color: var(--aster-white); font-family: var(--aster-serif); font-weight: 500; max-width: 500px; margin-inline: auto; }
.rs-final-lead { max-width: 460px; margin-inline: auto; color: rgba(255,255,255,0.5); font-size: 0.92rem; line-height: 1.65; }
.rs-cta-p { background: var(--aster-clay); color: var(--aster-white); }
.rs-cta-p:hover { background: var(--aster-clay-dark); color: var(--aster-white); }
.rs-cta-s { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.75); }
.rs-cta-s:hover { background: rgba(255,255,255,0.07); color: var(--aster-white); }

@media (max-width: 768px) { .rs-feat-grid { grid-template-columns: 1fr; max-width: 480px; } .rs-guide-panel { grid-template-columns: 1fr; } }
</style>
