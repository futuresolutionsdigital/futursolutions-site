---
import AsterLayout from '../../../layouts/AsterLayout.astro';
import { brand, provider, careModelSteps, pricingCards, pricingNote, faqs } from '../../../data/aster';

const prepareItems = [
	'A list of your main health questions or concerns',
	'Current medications and supplements',
	'Relevant health history or recent lab results',
	'Your goals — what would better care look like for you?',
	'Insurance or HSA/FSA card (if using for eligible expenses)',
];
---

<AsterLayout
	title="New Patients — Book a Consultation | Aster Private Health Demo"
	description="Learn what to expect as a new patient at Aster Private Health. Understand the consultation process, prepare for your first visit, and book your appointment."
	canonicalUrl="https://futursolutions.vercel.app/demos/solo-practice/new-patients/"
>
	<section class="np-hero" aria-labelledby="np-heading">
		<div class="aster-container">
			<a class="np-back" href="/demos/solo-practice">← Back to Aster Home</a>
			<p class="aster-eyebrow">New Patients</p>
			<h1 id="np-heading">Your first step toward healthcare that listens.</h1>
			<p class="aster-lead">Whether you are exploring a new provider or ready to book, this page will help you understand what to expect and how to prepare.</p>
			<div class="aster-btn-row">
				<a class="aster-btn aster-btn--primary" href="#book">Book a Consultation</a>
				<a class="aster-btn aster-btn--secondary" href="/demos/solo-practice/#pricing">View Pricing</a>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--sand" aria-labelledby="expect-heading">
		<div class="aster-container">
			<div class="np-intro">
				<p class="aster-eyebrow">What to expect</p>
				<h2 id="expect-heading">A calmer, more thorough first visit.</h2>
				<p class="aster-lead">Your New Patient Consultation is 60–75 minutes — enough time to review your full health picture, answer your questions, and build a care plan that fits your life.</p>
			</div>
			<div class="np-steps-grid">
				{careModelSteps.map((s) => (
					<div class="np-step">
						<span class="np-step__num">{s.step}</span>
						<h3>{s.title}</h3>
						<p>{s.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="prep-heading">
		<div class="aster-container np-prep-grid">
			<div>
				<p class="aster-eyebrow">Prepare</p>
				<h2 id="prep-heading">What to bring to your first visit.</h2>
				<p class="aster-lead">Having these items ready helps us make the most of your consultation time.</p>
			</div>
			<div class="np-prep-card aster-card">
				<ul class="np-checklist">
					{prepareItems.map((item) => (
						<li>
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 18 18" aria-hidden="true"><circle cx="9" cy="9" r="8.5" stroke="currentColor" stroke-opacity=".2"/><path fill="currentColor" d="M8 12.2 5.3 9.5l.7-.7L8 10.78l4-4 .7.72L8 12.2Z"/></svg>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--sand" aria-labelledby="provider-heading">
		<div class="aster-container np-provider-grid">
			<div class="np-provider-avatar" aria-hidden="true">
				<div class="np-avatar-circle"><span>{provider.initials}</span></div>
			</div>
			<div>
				<p class="aster-eyebrow">Your provider</p>
				<h2 id="provider-heading">{provider.name}</h2>
				<p class="np-provider-title">{provider.title}</p>
				<p>{provider.bio}</p>
				<blockquote class="np-quote"><p>"{provider.quote}"</p></blockquote>
				<a class="aster-btn aster-btn--secondary" href="/demos/solo-practice/#provider">Read Full Provider Story</a>
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="pricing-heading">
		<div class="aster-container">
			<div class="np-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">Pricing</p>
				<h2 id="pricing-heading">Transparent pricing — no surprises.</h2>
				<p class="aster-lead" style="margin-inline:auto;">Know what your visit costs before you book.</p>
			</div>
			<div class="np-pricing-grid">
				{pricingCards.map((card) => (
					<div class:list={['aster-card', 'np-pricing-card', { 'np-pricing-card--featured': card.featured }]}>
						{card.featured && <span class="np-pricing-badge">Most popular</span>}
						<h3>{card.name}</h3>
						<p class="np-pricing-duration">{card.duration}</p>
						<p class="np-pricing-price">
							<span class="np-pricing-note">{card.priceNote}</span>
							<span class="np-pricing-amount">{card.price}{card.priceSuffix && <small>{card.priceSuffix}</small>}</span>
						</p>
						<p class="np-pricing-desc">{card.description}</p>
					</div>
				))}
			</div>
			<p class="np-pricing-disclaimer">{pricingNote}</p>
		</div>
	</section>

	<section class="aster-section aster-section--sand" id="book" aria-labelledby="book-heading">
		<div class="aster-container np-book-grid">
			<div>
				<p class="aster-eyebrow">Book your consultation</p>
				<h2 id="book-heading">Start with a conversation.</h2>
				<p class="aster-lead">Share a few details and we will follow up to schedule your New Patient Consultation.</p>
			</div>
			<div class="np-form-card aster-card">
				<form novalidate onsubmit="return false" aria-label="Aster Private Health new patient inquiry form">
					<label>
						<span>Full name</span>
						<input type="text" name="name" autocomplete="name" placeholder="Your full name" />
					</label>
					<label>
						<span>Email</span>
						<input type="email" name="email" autocomplete="email" placeholder="you@email.com" />
					</label>
					<label>
						<span>Phone (optional)</span>
						<input type="tel" name="phone" autocomplete="tel" placeholder="(555) 555-5555" />
					</label>
					<label>
						<span>What brings you in?</span>
						<select name="reason">
							<option value="">Select a reason</option>
							<option value="primary-care">Looking for a primary care provider</option>
							<option value="specific-concern">I have a specific health concern</option>
							<option value="second-opinion">Looking for a second opinion</option>
							<option value="preventive">Preventive health / wellness check</option>
							<option value="hormones">Hormone or metabolic questions</option>
							<option value="not-sure">Not sure yet — I want to learn more</option>
						</select>
					</label>
					<label>
						<span>Anything else you'd like us to know?</span>
						<textarea name="message" rows="3" placeholder="Health goals, concerns, or questions..."></textarea>
					</label>
					<input type="hidden" name="source" value="New Patient Page" />
					<input type="hidden" name="leadType" value="New Patient Consultation Request" />
					<div class="np-form-footer">
						<button class="aster-btn aster-btn--primary" type="button" style="width:100%;">Book a Consultation</button>
						<p>This is a demo form — no data is submitted. In a live build, this connects to scheduling, CRM, and follow-up systems.</p>
					</div>
				</form>
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="np-faq-heading">
		<div class="aster-container">
			<div class="np-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">FAQ</p>
				<h2 id="np-faq-heading">Questions before your first visit?</h2>
			</div>
			<div class="np-faq-list">
				{faqs.map((faq) => (
					<details class="np-faq-item">
						<summary class="np-faq-question">
							<span>{faq.question}</span>
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 20 20" aria-hidden="true"><path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M5 8l5 5 5-5"/></svg>
						</summary>
						<div class="np-faq-answer"><p>{faq.answer}</p></div>
					</details>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section np-final-section" aria-labelledby="final-heading">
		<div class="aster-container">
			<div class="np-final-card">
				<p class="aster-eyebrow np-final-eyebrow">Get started</p>
				<h2 id="final-heading">Ready for healthcare that feels more personal?</h2>
				<p class="np-final-lead">Start with a consultation and find out whether Aster Private Health is the right fit for your goals, concerns, and care preferences.</p>
				<div class="aster-btn-row" style="justify-content:center;">
					<a class="aster-btn np-final-btn-primary" href="#book">Book a Consultation</a>
					<a class="aster-btn np-final-btn-secondary" href="/demos/solo-practice/services">Explore Services</a>
				</div>
			</div>
		</div>
	</section>
</AsterLayout>

<style>
.np-hero { padding-block: clamp(4rem, 7vw, 6rem) clamp(3rem, 5vw, 4rem); background: linear-gradient(180deg, var(--aster-bg) 0%, color-mix(in srgb, var(--aster-sand) 25%, var(--aster-bg)) 100%); }
.np-back { display: inline-flex; align-items: center; margin-bottom: 1.5rem; font-size: 0.82rem; font-weight: 600; color: var(--aster-sage); }
.np-back:hover { color: var(--aster-sage-dark); }
.np-intro { max-width: 660px; margin-bottom: clamp(2rem, 4vw, 3rem); }

.np-steps-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1.25rem; }
.np-step { padding: 1.5rem; border-radius: var(--aster-radius); background: var(--aster-white); border: 1px solid var(--aster-border); }
.np-step__num { display: inline-flex; align-items: center; justify-content: center; width: 2.2rem; height: 2.2rem; margin-bottom: 1rem; border-radius: 8px; background: var(--aster-sage-light); color: var(--aster-sage); font-size: 0.72rem; font-weight: 800; }
.np-step p { margin: 0; color: var(--aster-muted); font-size: 0.88rem; line-height: 1.55; }

.np-prep-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
.np-prep-card { padding: 1.75rem; }
.np-checklist { margin: 0; padding: 0; list-style: none; display: grid; gap: 0.85rem; }
.np-checklist li { display: flex; align-items: flex-start; gap: 0.65rem; font-size: 0.92rem; font-weight: 600; color: var(--aster-heading); }
.np-checklist svg { flex-shrink: 0; margin-top: 0.1rem; color: var(--aster-sage); }

.np-provider-grid { display: grid; grid-template-columns: 0.35fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
.np-provider-avatar { display: flex; justify-content: center; padding: 2rem; border-radius: var(--aster-radius-lg); background: linear-gradient(145deg, var(--aster-sage-light) 0%, color-mix(in srgb, var(--aster-warm-light) 40%, var(--aster-sage-light)) 100%); border: 1px solid var(--aster-border); }
.np-avatar-circle { display: flex; align-items: center; justify-content: center; width: 7rem; height: 7rem; border-radius: 50%; background: var(--aster-white); box-shadow: 0 8px 32px rgba(26, 32, 44, 0.06); }
.np-avatar-circle span { font-size: 1.6rem; font-weight: 800; color: var(--aster-sage); }
.np-provider-title { color: var(--aster-sage); font-weight: 600; font-size: 0.92rem; margin-bottom: 0.5rem; }
.np-quote { margin: 1.25rem 0; padding-left: 1.25rem; border-left: 3px solid var(--aster-warm); }
.np-quote p { margin: 0; color: var(--aster-heading); font-size: 1rem; font-style: italic; font-weight: 500; line-height: 1.6; }

.np-pricing-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.25rem; }
.np-pricing-card { position: relative; display: flex; flex-direction: column; padding: 1.75rem; text-align: center; }
.np-pricing-card--featured { border-color: var(--aster-sage); background: linear-gradient(180deg, var(--aster-white) 0%, var(--aster-sage-light) 100%); box-shadow: 0 8px 32px rgba(107, 143, 113, 0.1); }
.np-pricing-badge { position: absolute; top: -0.6rem; left: 50%; transform: translateX(-50%); padding: 0.25rem 0.7rem; border-radius: 6px; background: var(--aster-sage); color: var(--aster-white); font-size: 0.68rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; white-space: nowrap; }
.np-pricing-duration { color: var(--aster-muted); font-size: 0.82rem; margin-bottom: 1rem; }
.np-pricing-price { margin-bottom: 1rem; }
.np-pricing-note { display: block; font-size: 0.72rem; font-weight: 600; color: var(--aster-muted); text-transform: uppercase; letter-spacing: 0.06em; }
.np-pricing-amount { font-size: 2.4rem; font-weight: 800; color: var(--aster-heading); letter-spacing: -0.03em; }
.np-pricing-amount small { font-size: 0.85rem; font-weight: 600; color: var(--aster-muted); }
.np-pricing-desc { flex: 1; color: var(--aster-text); font-size: 0.88rem; line-height: 1.55; }
.np-pricing-disclaimer { max-width: 620px; margin: 1.75rem auto 0; padding: 1rem 1.25rem; border-radius: 10px; background: var(--aster-sand); border: 1px solid var(--aster-border); text-align: center; color: var(--aster-muted); font-size: 0.82rem; line-height: 1.55; }

.np-book-grid { display: grid; grid-template-columns: 0.85fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
.np-form-card { padding: clamp(1.35rem, 3vw, 2rem); }
.np-form-card form, .np-form-card label { display: grid; gap: 1rem; }
.np-form-card label { gap: 0.4rem; }
.np-form-card label span { color: var(--aster-heading); font-size: 0.85rem; font-weight: 700; }
.np-form-card input, .np-form-card select, .np-form-card textarea { width: 100%; border: 1px solid var(--aster-border); border-radius: 10px; background: var(--aster-bg); color: var(--aster-heading); font-size: 0.92rem; }
.np-form-card input, .np-form-card select { min-height: 2.75rem; padding: 0.65rem 0.8rem; }
.np-form-card textarea { resize: vertical; min-height: 5rem; padding: 0.75rem 0.8rem; }
.np-form-card input:focus, .np-form-card select:focus, .np-form-card textarea:focus { border-color: var(--aster-sage); outline: none; background: var(--aster-white); }
.np-form-card input::placeholder, .np-form-card textarea::placeholder { color: var(--aster-muted); }
.np-form-footer { display: grid; gap: 0.75rem; }
.np-form-footer p { margin: 0; color: var(--aster-muted); font-size: 0.78rem; line-height: 1.55; text-align: center; }

.np-faq-list { max-width: 760px; margin-inline: auto; }
.np-faq-item { border-bottom: 1px solid var(--aster-border); }
.np-faq-item:first-child { border-top: 1px solid var(--aster-border); }
.np-faq-question { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.15rem 0; cursor: pointer; list-style: none; font-weight: 700; font-size: 0.95rem; color: var(--aster-heading); }
.np-faq-question::-webkit-details-marker { display: none; }
.np-faq-question::marker { display: none; content: ''; }
.np-faq-question svg { flex-shrink: 0; color: var(--aster-muted); transition: transform 0.2s ease; }
.np-faq-item[open] .np-faq-question svg { transform: rotate(180deg); }
.np-faq-answer { padding-bottom: 1.25rem; }
.np-faq-answer p { margin: 0; color: var(--aster-text); font-size: 0.9rem; line-height: 1.65; }

.np-final-section { padding-block: clamp(2.5rem, 5vw, 4rem); background: var(--aster-sand); }
.np-final-card { max-width: 760px; margin-inline: auto; padding: clamp(2rem, 4vw, 3.5rem); border-radius: var(--aster-radius-lg); background: var(--aster-heading); text-align: center; }
.np-final-eyebrow { color: var(--aster-warm) !important; }
.np-final-card h2 { color: var(--aster-white); max-width: 560px; margin-inline: auto; }
.np-final-lead { max-width: 520px; margin-inline: auto; color: rgba(255,255,255,0.6); font-size: 0.95rem; line-height: 1.6; }
.np-final-btn-primary { background: var(--aster-sage); color: var(--aster-white); }
.np-final-btn-primary:hover { background: var(--aster-sage-dark); color: var(--aster-white); }
.np-final-btn-secondary { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.8); }
.np-final-btn-secondary:hover { background: rgba(255,255,255,0.08); color: var(--aster-white); }

@media (max-width: 860px) {
	.np-steps-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
	.np-prep-grid, .np-provider-grid, .np-book-grid { grid-template-columns: 1fr; }
	.np-provider-avatar { max-width: 220px; }
}
@media (max-width: 768px) { .np-pricing-grid { grid-template-columns: 1fr; max-width: 420px; margin-inline: auto; } }
@media (max-width: 520px) { .np-steps-grid { grid-template-columns: 1fr; } }
</style>
