---
import AsterLayout from '../../../layouts/AsterLayout.astro';
import { brand } from '../../../data/aster';

const portalFeatures = [
	{ title: 'Secure messaging', description: 'Send questions, updates, and follow-up notes to your provider between visits.' },
	{ title: 'Intake and consent forms', description: 'Complete or update paperwork before your appointments.' },
	{ title: 'Appointment details', description: 'View upcoming visit information, times, and preparation instructions.' },
	{ title: 'Follow-up instructions', description: 'Review your care plan, next steps, and provider recommendations.' },
	{ title: 'Care documents', description: 'Access visit summaries, lab orders, and care-plan documents.' },
];
---

<AsterLayout
	title="Patient Portal | Aster Private Health Demo"
	description="Existing patients can use the Aster Private Health patient portal for secure messaging, forms, appointment details, and care-plan follow-up."
	canonicalUrl="https://futursolutions.vercel.app/demos/solo-practice/patient-portal/"
>
	<section class="pp-hero" aria-labelledby="pp-heading">
		<div class="aster-container">
			<a class="pp-back" href="/demos/solo-practice">← Back to Aster Home</a>
			<p class="aster-eyebrow">Patient Portal</p>
			<h1 id="pp-heading">Your care, accessible anytime.</h1>
			<p class="aster-lead">Existing patients can use the portal for secure messages, forms, appointment details, and care-plan follow-up.</p>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="pp-access-heading">
		<div class="aster-container">
			<div class="pp-access-card">
				<h2 id="pp-access-heading">Portal Login</h2>
				<p class="pp-access-desc">Access your patient portal to review care documents, message your provider, and manage your appointments.</p>
				<button class="aster-btn aster-btn--primary" type="button" style="width:100%; max-width:320px;">Portal Login</button>
				<p class="pp-access-note">This is a demo placeholder — no real patient portal is connected. In a live build, this links to your HIPAA-compliant patient portal system.</p>
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="pp-dash-heading">
		<div class="aster-container">
			<div class="pp-intro">
				<p class="aster-eyebrow">Portal Preview</p>
				<h2 id="pp-dash-heading">A look inside the patient experience.</h2>
			</div>
			<div class="pp-dash" aria-label="Demo portal dashboard preview">
				<div class="pp-dash-header">
					<span class="pp-dash-logo">A</span>
					<div>
						<strong>Aster Private Health — Patient Portal</strong>
						<span>Welcome back, Sarah</span>
					</div>
				</div>
				<div class="pp-dash-grid">
					<div class="pp-dash-card">
						<span class="pp-dash-icon" aria-hidden="true">📅</span>
						<strong>Upcoming Appointment</strong>
						<span>Follow-Up Visit · Jun 12, 2026 · 10:00 AM</span>
					</div>
					<div class="pp-dash-card">
						<span class="pp-dash-icon" aria-hidden="true">📋</span>
						<strong>Intake Forms</strong>
						<span>Pre-visit questionnaire · Due by Jun 10</span>
					</div>
					<div class="pp-dash-card">
						<span class="pp-dash-icon" aria-hidden="true">📄</span>
						<strong>Recent Care Plan</strong>
						<span>Updated May 1, 2026 · Thyroid follow-up</span>
					</div>
					<div class="pp-dash-card">
						<span class="pp-dash-icon" aria-hidden="true">💬</span>
						<strong>Secure Message</strong>
						<span>1 new message from Dr. Marrow</span>
					</div>
					<div class="pp-dash-card">
						<span class="pp-dash-icon" aria-hidden="true">🔬</span>
						<strong>Lab Review</strong>
						<span>TSH, CBC results ready for review</span>
					</div>
				</div>
				<p class="pp-dash-disclaimer">This is a fictional demo preview. No real patient data is shown or stored.</p>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="pp-manage-heading">
		<div class="aster-container">
			<div class="pp-intro">
				<p class="aster-eyebrow">What You Can Manage</p>
				<h2 id="pp-manage-heading">Tools available through your patient portal.</h2>
			</div>
			<div class="pp-feature-list">
				{portalFeatures.map((f) => (
					<div class="pp-feature-item">
						<h3>{f.title}</h3>
						<p>{f.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section pp-final" aria-labelledby="pp-final-heading">
		<div class="aster-container">
			<div class="pp-final-card">
				<p class="aster-eyebrow pp-final-ey">Not a patient yet?</p>
				<h2 id="pp-final-heading">Start with a consultation.</h2>
				<p class="pp-final-lead">Book a New Patient Consultation to establish care and gain access to your patient portal.</p>
				<div class="aster-btn-row" style="justify-content:center;">
					<a class="aster-btn pp-cta-p" href="/demos/solo-practice/new-patients">Book a Consultation</a>
					<a class="aster-btn pp-cta-s" href="/demos/solo-practice/about">Meet Your Provider</a>
				</div>
			</div>
		</div>
	</section>
</AsterLayout>

<style>
.pp-hero { padding-block: clamp(4.5rem, 8vw, 7rem) clamp(3rem, 5vw, 4rem); }
.pp-back { display: inline-flex; margin-bottom: 1.5rem; font-size: 0.82rem; font-weight: 600; color: var(--aster-clay); }
.pp-back:hover { color: var(--aster-clay-dark); }
.pp-intro { max-width: 560px; margin-bottom: clamp(2rem, 4vw, 3rem); }

.pp-access-card { max-width: 520px; margin-inline: auto; padding: clamp(2rem, 4vw, 3rem); background: var(--aster-white); border: 1px solid var(--aster-border); border-radius: var(--aster-radius-lg); text-align: center; }
.pp-access-card h2 { font-size: clamp(1.4rem, 1.2rem + 0.8vw, 1.8rem); }
.pp-access-desc { color: var(--aster-text); font-size: 0.92rem; line-height: 1.65; margin-bottom: 1.5rem; }
.pp-access-card .aster-btn { margin-inline: auto; }
.pp-access-note { margin-top: 1.25rem; color: var(--aster-muted); font-size: 0.72rem; line-height: 1.55; font-style: italic; }

.pp-dash { max-width: 680px; border: 1px solid var(--aster-border); border-radius: var(--aster-radius-lg); background: var(--aster-white); overflow: hidden; }
.pp-dash-header { display: flex; align-items: center; gap: 0.65rem; padding: 1rem 1.5rem; background: var(--aster-ivory); border-bottom: 1px solid var(--aster-border); }
.pp-dash-logo { display: inline-flex; align-items: center; justify-content: center; width: 1.8rem; height: 1.8rem; border-radius: 6px; background: var(--aster-clay); color: var(--aster-white); font-family: var(--aster-serif); font-size: 0.65rem; font-weight: 700; }
.pp-dash-header strong { display: block; font-size: 0.82rem; color: var(--aster-heading); }
.pp-dash-header span { font-size: 0.72rem; color: var(--aster-muted); }
.pp-dash-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
.pp-dash-card { display: flex; flex-direction: column; gap: 0.15rem; padding: 1rem 1.5rem; border-bottom: 1px solid var(--aster-border); border-right: 1px solid var(--aster-border); }
.pp-dash-card:nth-child(even) { border-right: none; }
.pp-dash-card:nth-last-child(-n+2) { border-bottom: none; }
.pp-dash-card:last-child:nth-child(odd) { grid-column: span 2; border-right: none; }
.pp-dash-icon { font-size: 1.1rem; }
.pp-dash-card strong { font-size: 0.82rem; color: var(--aster-heading); }
.pp-dash-card > span { font-size: 0.75rem; color: var(--aster-muted); line-height: 1.4; }
.pp-dash-disclaimer { margin: 0; padding: 0.75rem 1.5rem; background: var(--aster-ivory); border-top: 1px solid var(--aster-border); font-size: 0.68rem; color: var(--aster-muted); font-style: italic; text-align: center; }

.pp-feature-list { display: grid; gap: 0; max-width: 600px; }
.pp-feature-item { padding-block: clamp(1.15rem, 2vw, 1.5rem); border-bottom: 1px solid var(--aster-border); }
.pp-feature-item:first-child { border-top: 1px solid var(--aster-border); }
.pp-feature-item h3 { margin-bottom: 0.25rem; }
.pp-feature-item p { margin: 0; color: var(--aster-text); font-size: 0.88rem; line-height: 1.6; }

.pp-final { padding-block: clamp(2.5rem, 5vw, 4rem); }
.pp-final-card { max-width: 680px; margin-inline: auto; padding: clamp(2.5rem, 5vw, 4rem); border-radius: var(--aster-radius-lg); background: var(--aster-aubergine); text-align: center; }
.pp-final-ey { color: rgba(255,255,255,0.45) !important; }
.pp-final-card h2 { color: var(--aster-white); font-family: var(--aster-serif); font-weight: 500; }
.pp-final-lead { max-width: 460px; margin-inline: auto; color: rgba(255,255,255,0.5); font-size: 0.92rem; line-height: 1.65; }
.pp-cta-p { background: var(--aster-clay); color: var(--aster-white); }
.pp-cta-p:hover { background: var(--aster-clay-dark); color: var(--aster-white); }
.pp-cta-s { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.75); }
.pp-cta-s:hover { background: rgba(255,255,255,0.07); color: var(--aster-white); }

@media (max-width: 520px) {
	.pp-dash-grid { grid-template-columns: 1fr; }
	.pp-dash-card { border-right: none !important; }
	.pp-dash-card:last-child:nth-child(odd) { grid-column: span 1; }
}
</style>
