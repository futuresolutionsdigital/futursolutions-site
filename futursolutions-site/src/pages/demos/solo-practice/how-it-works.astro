---
import AsterLayout from '../../../layouts/AsterLayout.astro';
import { careModelSteps, pricingCards, faqs } from '../../../data/aster';

const journey = [
	{ step: '01', title: 'Start with a consultation', description: 'Book a New Patient Consultation online or by phone. Share your health goals, history, and concerns in a 60–75 minute visit.' },
	{ step: '02', title: 'Complete intake forms', description: 'Before your visit, you will receive intake paperwork covering your medical history, medications, lifestyle, and care preferences.' },
	{ step: '03', title: 'Review your full health picture', description: 'Your provider reviews symptoms, labs, lifestyle, medications, and prior care to understand the whole picture — not just one complaint.' },
	{ step: '04', title: 'Build a personalized care plan', description: 'You receive a clear, practical plan with prioritized next steps, recommended labs, lifestyle changes, and follow-up timing.' },
	{ step: '05', title: 'Continue with follow-up or membership care', description: 'Return for follow-up visits, lab reviews, and ongoing support. Members get secure messaging, care coordination, and continuity.' },
];

const comparisons = [
	{ traditional: 'Rushed 10–15 minute visits', aster: 'Longer 60–75 minute first visits, 30–45 minute follow-ups' },
	{ traditional: 'Reactive — address symptoms after they escalate', aster: 'Preventive — proactive planning and early intervention' },
	{ traditional: 'Fragmented — different provider each visit', aster: 'Continuity — same provider who knows your history' },
	{ traditional: 'Surprise billing and insurance complexity', aster: 'Transparent pricing before you book' },
];

const visitOptions = [
	{ name: 'New Patient Consultation', duration: '60–75 min', desc: 'Comprehensive first visit with full health review and care plan', href: '/demos/solo-practice/pricing' },
	{ name: 'Follow-Up Visit', duration: '30–45 min', desc: 'Plan updates, lab review, medication adjustments, and ongoing guidance', href: '/demos/solo-practice/pricing' },
	{ name: 'Private Care Membership', duration: 'Ongoing', desc: 'Longer visits, secure messaging, care coordination, and relationship-based care', href: '/demos/solo-practice/pricing' },
	{ name: 'Telehealth Visit', duration: '30–45 min', desc: 'Virtual appointments for follow-ups, lab reviews, and care coordination', href: '/demos/solo-practice/pricing' },
];
---

<AsterLayout
	title="How Private Care Works | Aster Private Health Demo"
	description="A clear explanation of longer visits, transparent pricing, personalized care plans, and ongoing support in a private healthcare model."
	canonicalUrl="https://futursolutions.vercel.app/demos/solo-practice/how-it-works/"
>
	<section class="hw-hero" aria-labelledby="hw-heading">
		<div class="aster-container">
			<a class="hw-back" href="/demos/solo-practice">← Back to Aster Home</a>
			<p class="aster-eyebrow">How It Works</p>
			<h1 id="hw-heading">Private healthcare, explained simply.</h1>
			<p class="aster-lead">Aster is designed for patients who want longer visits, transparent pricing, and a provider relationship that does not feel rushed.</p>
			<div class="aster-btn-row">
				<a class="aster-btn aster-btn--primary" href="/demos/solo-practice/new-patients">Book a Consultation</a>
				<a class="aster-btn aster-btn--secondary" href="/demos/solo-practice/pricing">View Pricing</a>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="hw-journey-heading">
		<div class="aster-container">
			<div class="hw-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">Your Care Journey</p>
				<h2 id="hw-journey-heading">From first visit to ongoing support.</h2>
				<p class="aster-lead" style="margin-inline:auto;">Every step is designed around clarity, continuity, and respect for your time.</p>
			</div>
			<div class="hw-timeline">
				{journey.map((s) => (
					<div class="hw-tl-step">
						<div class="hw-tl-line" aria-hidden="true"><span class="hw-tl-dot"></span></div>
						<div class="hw-tl-content">
							<span class="hw-tl-num">{s.step}</span>
							<h3>{s.title}</h3>
							<p>{s.description}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="hw-compare-heading">
		<div class="aster-container">
			<div class="hw-intro">
				<p class="aster-eyebrow">What Makes This Different</p>
				<h2 id="hw-compare-heading">Traditional healthcare vs. private care.</h2>
			</div>
			<div class="hw-compare">
				<div class="hw-compare-header">
					<span>Traditional Healthcare</span>
					<span>Aster Private Health</span>
				</div>
				{comparisons.map((c) => (
					<div class="hw-compare-row">
						<div class="hw-compare-cell hw-compare-cell--trad">{c.traditional}</div>
						<div class="hw-compare-cell hw-compare-cell--aster">{c.aster}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="hw-visits-heading">
		<div class="aster-container">
			<div class="hw-intro">
				<p class="aster-eyebrow">Visit Options</p>
				<h2 id="hw-visits-heading">Choose the right visit for where you are.</h2>
			</div>
			<div class="hw-visit-list">
				{visitOptions.map((v) => (
					<div class="hw-visit-item">
						<div class="hw-visit-left">
							<h3>{v.name}</h3>
							<span class="hw-visit-dur">{v.duration}</span>
						</div>
						<div class="hw-visit-right">
							<p>{v.desc}</p>
							<a class="hw-visit-link" href={v.href}>View pricing →</a>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="hw-scope-heading">
		<div class="aster-container hw-scope-grid">
			<div class="hw-scope-card">
				<h3 class="hw-scope-label">What is included</h3>
				<ul>
					<li>Longer visits with dedicated time</li>
					<li>Personalized care plans</li>
					<li>Lab review and clinical interpretation</li>
					<li>Secure messaging for members</li>
					<li>Follow-up recommendations</li>
					<li>Care coordination support</li>
				</ul>
			</div>
			<div class="hw-scope-card hw-scope-card--muted">
				<h3 class="hw-scope-label">What is not included</h3>
				<ul>
					<li>Emergency or urgent care</li>
					<li>Hospital or surgical care</li>
					<li>Outside lab and imaging fees</li>
					<li>Prescription medication costs</li>
					<li>Specialist referral fees</li>
				</ul>
				<p class="hw-scope-note">If you are experiencing a medical emergency, please call 911 or visit your nearest emergency room.</p>
			</div>
		</div>
	</section>

	<section class="aster-section aster-section--paper" aria-labelledby="hw-plan-heading">
		<div class="aster-container">
			<div class="hw-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">What You Leave With</p>
				<h2 id="hw-plan-heading">Your care plan may include</h2>
				<p class="aster-lead" style="margin-inline:auto;">After your consultation, you receive a clear, written plan — not a vague set of instructions.</p>
			</div>
			<div class="hw-plan-doc" aria-label="Sample care plan preview">
				<div class="hw-plan-header">
					<span class="hw-plan-logo">A</span>
					<div>
						<strong>Aster Private Health</strong>
						<span>Care Plan — Sample Preview</span>
					</div>
				</div>
				<div class="hw-plan-body">
					<div class="hw-plan-row"><span class="hw-plan-label">Health priorities</span><span class="hw-plan-value">Fatigue investigation · thyroid follow-up · preventive screening</span></div>
					<div class="hw-plan-row"><span class="hw-plan-label">Lab review notes</span><span class="hw-plan-value">TSH, free T4, CBC, metabolic panel — results reviewed with patient</span></div>
					<div class="hw-plan-row"><span class="hw-plan-label">Lifestyle recommendations</span><span class="hw-plan-value">Sleep hygiene adjustments · stress management · nutrition guidance</span></div>
					<div class="hw-plan-row"><span class="hw-plan-label">Follow-up timeline</span><span class="hw-plan-value">Lab recheck in 6 weeks · follow-up visit in 8 weeks</span></div>
					<div class="hw-plan-row"><span class="hw-plan-label">Referrals</span><span class="hw-plan-value">Endocrinology referral if thyroid values remain elevated</span></div>
					<div class="hw-plan-row"><span class="hw-plan-label">Secure messaging</span><span class="hw-plan-value">Available for questions between visits (membership patients)</span></div>
				</div>
				<p class="hw-plan-disclaimer">This is a fictional sample for demo purposes only. No real patient data is shown.</p>
			</div>
		</div>
	</section>

	<section class="aster-section" aria-labelledby="hw-faq-heading">
		<div class="aster-container">
			<div class="hw-intro" style="text-align:center; margin-inline:auto;">
				<p class="aster-eyebrow">FAQ</p>
				<h2 id="hw-faq-heading">Common questions about how it works.</h2>
			</div>
			<div class="hw-faq-list">
				{[faqs[3], faqs[0], faqs[5], faqs[2]].map((faq) => (
					<details class="hw-faq-item">
						<summary class="hw-faq-q"><span>{faq.question}</span><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 18 18" aria-hidden="true"><path stroke="currentColor" stroke-width="1.3" stroke-linecap="round" d="M4.5 7l4.5 4.5L13.5 7"/></svg></summary>
						<div class="hw-faq-a"><p>{faq.answer}</p></div>
					</details>
				))}
			</div>
		</div>
	</section>

	<section class="aster-section hw-final" aria-labelledby="hw-final-heading">
		<div class="aster-container">
			<div class="hw-final-card">
				<p class="aster-eyebrow hw-final-ey">Your next step</p>
				<h2 id="hw-final-heading">Healthcare built around you is one conversation away.</h2>
				<p class="hw-final-lead">Book a New Patient Consultation — 60 to 75 minutes of dedicated time with your provider.</p>
				<div class="aster-btn-row" style="justify-content:center;">
					<a class="aster-btn hw-cta-p" href="/demos/solo-practice/new-patients">Book a Consultation</a>
					<a class="aster-btn hw-cta-s" href="/demos/solo-practice/pricing">View Pricing</a>
				</div>
			</div>
		</div>
	</section>
</AsterLayout>

<style>
.hw-hero { padding-block: clamp(4.5rem, 8vw, 7rem) clamp(3rem, 5vw, 4rem); }
.hw-back { display: inline-flex; margin-bottom: 1.5rem; font-size: 0.82rem; font-weight: 600; color: var(--aster-clay); }
.hw-back:hover { color: var(--aster-clay-dark); }
.hw-intro { max-width: 560px; margin-bottom: clamp(2rem, 4vw, 3rem); }

.hw-timeline { position: relative; max-width: 560px; margin-inline: auto; padding-left: 2.5rem; }
.hw-timeline::before { content: ''; position: absolute; left: 0.45rem; top: 0.6rem; bottom: 0.6rem; width: 1px; background: var(--aster-border); }
.hw-tl-step { position: relative; padding-bottom: clamp(2rem, 3.5vw, 2.5rem); }
.hw-tl-step:last-child { padding-bottom: 0; }
.hw-tl-line { position: absolute; left: -2.5rem; top: 0.25rem; }
.hw-tl-dot { display: block; width: 0.6rem; height: 0.6rem; border-radius: 50%; background: var(--aster-clay); border: 2px solid var(--aster-paper); }
.hw-tl-num { display: inline-block; margin-bottom: 0.35rem; font-size: 0.68rem; font-weight: 700; color: var(--aster-clay); letter-spacing: 0.08em; text-transform: uppercase; }
.hw-tl-content h3 { font-size: 1.05rem; }
.hw-tl-content p { margin: 0; color: var(--aster-muted); font-size: 0.9rem; line-height: 1.6; }

.hw-compare { max-width: 760px; border: 1px solid var(--aster-border); border-radius: var(--aster-radius); overflow: hidden; }
.hw-compare-header { display: grid; grid-template-columns: 1fr 1fr; background: var(--aster-paper); border-bottom: 1px solid var(--aster-border); }
.hw-compare-header span { padding: 0.85rem 1.25rem; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--aster-muted); }
.hw-compare-header span:last-child { color: var(--aster-clay); }
.hw-compare-row { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 1px solid var(--aster-border); }
.hw-compare-row:last-child { border-bottom: none; }
.hw-compare-cell { padding: 1rem 1.25rem; font-size: 0.88rem; line-height: 1.5; }
.hw-compare-cell--trad { color: var(--aster-muted); background: var(--aster-white); }
.hw-compare-cell--aster { color: var(--aster-heading); font-weight: 500; background: var(--aster-clay-light); }

.hw-visit-list { display: grid; gap: 0; max-width: 720px; }
.hw-visit-item { display: grid; grid-template-columns: 0.4fr 1fr; gap: clamp(1.5rem, 3vw, 2.5rem); padding-block: clamp(1.25rem, 2.5vw, 1.75rem); border-bottom: 1px solid var(--aster-border); }
.hw-visit-item:first-child { border-top: 1px solid var(--aster-border); }
.hw-visit-left h3 { margin-bottom: 0.2rem; }
.hw-visit-dur { font-size: 0.75rem; font-weight: 600; color: var(--aster-muted); }
.hw-visit-right p { color: var(--aster-text); font-size: 0.88rem; line-height: 1.6; }
.hw-visit-link { font-size: 0.8rem; font-weight: 600; color: var(--aster-clay); }
.hw-visit-link:hover { color: var(--aster-clay-dark); }

.hw-scope-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; max-width: 760px; margin-inline: auto; }
.hw-scope-card { padding: 1.5rem 1.65rem; border: 1px solid var(--aster-border); border-radius: var(--aster-radius); background: var(--aster-white); }
.hw-scope-card--muted { background: var(--aster-paper); }
.hw-scope-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--aster-clay); margin-bottom: 0.85rem; }
.hw-scope-card ul { padding: 0; margin: 0; list-style: none; display: grid; gap: 0.45rem; }
.hw-scope-card li { position: relative; padding-left: 0.85rem; font-size: 0.85rem; font-weight: 500; color: var(--aster-text); line-height: 1.5; }
.hw-scope-card li::before { content: ''; position: absolute; left: 0; top: 0.5rem; width: 4px; height: 4px; border-radius: 50%; background: var(--aster-clay); }
.hw-scope-card--muted li::before { background: var(--aster-muted); }
.hw-scope-note { margin-top: 1rem; font-size: 0.78rem; color: var(--aster-muted); font-style: italic; }

.hw-faq-list { max-width: 680px; margin-inline: auto; }
.hw-faq-item { border-bottom: 1px solid var(--aster-border); }
.hw-faq-item:first-child { border-top: 1px solid var(--aster-border); }
.hw-faq-q { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.1rem 0; cursor: pointer; list-style: none; font-weight: 600; font-size: 0.92rem; color: var(--aster-heading); }
.hw-faq-q::-webkit-details-marker { display: none; }
.hw-faq-q::marker { display: none; content: ''; }
.hw-faq-q svg { flex-shrink: 0; color: var(--aster-muted); transition: transform 0.2s ease; }
.hw-faq-item[open] .hw-faq-q svg { transform: rotate(180deg); }
.hw-faq-a { padding-bottom: 1.25rem; }
.hw-faq-a p { margin: 0; color: var(--aster-text); font-size: 0.88rem; line-height: 1.7; }

.hw-final { padding-block: clamp(2.5rem, 5vw, 4rem); }
.hw-final-card { max-width: 680px; margin-inline: auto; padding: clamp(2.5rem, 5vw, 4rem); border-radius: var(--aster-radius-lg); background: var(--aster-aubergine); text-align: center; }
.hw-final-ey { color: rgba(255,255,255,0.45) !important; }
.hw-final-card h2 { color: var(--aster-white); font-family: var(--aster-serif); font-weight: 500; max-width: 500px; margin-inline: auto; }
.hw-final-lead { max-width: 460px; margin-inline: auto; color: rgba(255,255,255,0.5); font-size: 0.92rem; line-height: 1.65; }
.hw-cta-p { background: var(--aster-clay); color: var(--aster-white); }
.hw-cta-p:hover { background: var(--aster-clay-dark); color: var(--aster-white); }
.hw-cta-s { border-color: rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.75); }
.hw-cta-s:hover { background: rgba(255,255,255,0.07); color: var(--aster-white); }

.hw-plan-doc { max-width: 620px; margin-inline: auto; border: 1px solid var(--aster-border); border-radius: var(--aster-radius-lg); background: var(--aster-white); overflow: hidden; }
.hw-plan-header { display: flex; align-items: center; gap: 0.65rem; padding: 1rem 1.5rem; background: var(--aster-ivory); border-bottom: 1px solid var(--aster-border); }
.hw-plan-logo { display: inline-flex; align-items: center; justify-content: center; width: 1.8rem; height: 1.8rem; border-radius: 6px; background: var(--aster-clay); color: var(--aster-white); font-family: var(--aster-serif); font-size: 0.65rem; font-weight: 700; }
.hw-plan-header strong { display: block; font-size: 0.82rem; color: var(--aster-heading); }
.hw-plan-header span { font-size: 0.68rem; color: var(--aster-muted); }
.hw-plan-body { padding: 0.5rem 1.5rem; }
.hw-plan-row { display: flex; gap: 1rem; padding-block: 0.75rem; border-bottom: 1px solid var(--aster-border); }
.hw-plan-row:last-child { border-bottom: none; }
.hw-plan-label { flex-shrink: 0; width: 140px; font-size: 0.72rem; font-weight: 700; color: var(--aster-clay); letter-spacing: 0.06em; text-transform: uppercase; padding-top: 0.1rem; }
.hw-plan-value { font-size: 0.85rem; color: var(--aster-text); line-height: 1.5; }
.hw-plan-disclaimer { margin: 0; padding: 0.75rem 1.5rem; background: var(--aster-ivory); border-top: 1px solid var(--aster-border); font-size: 0.68rem; color: var(--aster-muted); font-style: italic; text-align: center; }

@media (max-width: 620px) {
	.hw-visit-item { grid-template-columns: 1fr; gap: 0.5rem; }
	.hw-scope-grid { grid-template-columns: 1fr; }
	.hw-compare-header, .hw-compare-row { grid-template-columns: 1fr; }
	.hw-compare-cell { border-bottom: none; }
	.hw-compare-cell--aster { border-top: 1px dashed var(--aster-border); }
	.hw-timeline { padding-left: 2rem; }
	.hw-tl-line { left: -2rem; }
	.hw-plan-row { flex-direction: column; gap: 0.25rem; }
	.hw-plan-label { width: auto; }
}
</style>
