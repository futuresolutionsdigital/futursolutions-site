---
import AssociationLayout from '../../../../layouts/AssociationLayout.astro';
import AssociationResourcesHero from '../../../../components/association/AssociationResourcesHero.astro';
import AssociationFinalCTA from '../../../../components/association/AssociationFinalCTA.astro';
import AssociationStatStrip from '../../../../components/association/AssociationStatStrip.astro';
import AssociationFeaturedResources from '../../../../components/association/AssociationFeaturedResources.astro';
import AssociationResourceLibrary from '../../../../components/association/AssociationResourceLibrary.astro';
import AssociationResourceCollections from '../../../../components/association/AssociationResourceCollections.astro';
import AssociationLearningPathways from '../../../../components/association/AssociationLearningPathways.astro';
import AssociationResourceMemberAccess from '../../../../components/association/AssociationResourceMemberAccess.astro';
import AssociationResourceGuidance from '../../../../components/association/AssociationResourceGuidance.astro';
import AssociationResourceNewsletter from '../../../../components/association/AssociationResourceNewsletter.astro';
import AssociationFAQ from '../../../../components/association/AssociationFAQ.astro';
import { routeMetadata, resourceStats, resourceFaqs } from '../../../../data/association';

const meta = routeMetadata['/demos/association/resources'];
---

<AssociationLayout title={meta.title} description={meta.description}>
	<AssociationResourcesHero />
	<AssociationStatStrip stats={resourceStats} ariaLabel="Resource library statistics" />
	<AssociationFeaturedResources />
	<AssociationResourceLibrary />
	<AssociationResourceCollections />
	<AssociationLearningPathways />
	<AssociationResourceMemberAccess />
	<AssociationResourceGuidance />
	<AssociationResourceNewsletter />
	<AssociationFAQ faqs={resourceFaqs} heading="Resource questions, answered." />

	<AssociationFinalCTA
		headline="Build your professional library with MHPA."
		subheadline="Join to access member-only toolkits, CE learning, practical guides, and resources built for every stage of your career."
	/>
</AssociationLayout>
