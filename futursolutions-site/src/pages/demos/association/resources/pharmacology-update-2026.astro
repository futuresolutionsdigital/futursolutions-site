---
import AssociationLayout from '../../../../layouts/AssociationLayout.astro';
import AssociationResourceDetailHero from '../../../../components/association/AssociationResourceDetailHero.astro';
import AssociationFinalCTA from '../../../../components/association/AssociationFinalCTA.astro';
import AssociationQuickFacts from '../../../../components/association/AssociationQuickFacts.astro';
import AssociationResourceLearningObjectives from '../../../../components/association/AssociationResourceLearningObjectives.astro';
import AssociationResourceOutline from '../../../../components/association/AssociationResourceOutline.astro';
import AssociationResourceCEInfo from '../../../../components/association/AssociationResourceCEInfo.astro';
import AssociationResourceAccessPanel from '../../../../components/association/AssociationResourceAccessPanel.astro';
import AssociationRelatedResources from '../../../../components/association/AssociationRelatedResources.astro';
import { routeMetadata, resourceDetailQuickFacts } from '../../../../data/association';

const meta = routeMetadata['/demos/association/resources/pharmacology-update-2026'];
---

<AssociationLayout title={meta.title} description={meta.description}>
	<AssociationResourceDetailHero />
	<AssociationQuickFacts facts={resourceDetailQuickFacts} ariaLabel="Course quick facts" />
	<AssociationResourceLearningObjectives />
	<AssociationResourceOutline />
	<AssociationResourceCEInfo />
	<AssociationResourceAccessPanel />
	<AssociationRelatedResources />

	<AssociationFinalCTA
		headline="Stay current with practical learning built for your profession."
		subheadline="Explore CE courses, clinical guides, and professional resources designed by and for healthcare professionals."
		primaryCta={{ text: 'Start Course', href: '#course-outline' }}
		secondaryCta={{ text: 'Browse All Resources', href: '/demos/association/resources' }}
	/>
</AssociationLayout>
