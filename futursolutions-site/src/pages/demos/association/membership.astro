---
import AssociationLayout from '../../../layouts/AssociationLayout.astro';
import AssociationPageHero from '../../../components/association/AssociationPageHero.astro';
import AssociationMembershipAudience from '../../../components/association/AssociationMembershipAudience.astro';
import AssociationMembershipBenefits from '../../../components/association/AssociationMembershipBenefits.astro';
import AssociationMembershipTiers from '../../../components/association/AssociationMembershipTiers.astro';
import AssociationMembershipComparison from '../../../components/association/AssociationMembershipComparison.astro';
import AssociationMembershipOutcomes from '../../../components/association/AssociationMembershipOutcomes.astro';
import AssociationMembershipAdvocacy from '../../../components/association/AssociationMembershipAdvocacy.astro';
import AssociationMembershipEducation from '../../../components/association/AssociationMembershipEducation.astro';
import AssociationMembershipCommunity from '../../../components/association/AssociationMembershipCommunity.astro';
import AssociationMembershipStories from '../../../components/association/AssociationMembershipStories.astro';
import AssociationMembershipFAQ from '../../../components/association/AssociationMembershipFAQ.astro';
import AssociationFinalCTA from '../../../components/association/AssociationFinalCTA.astro';
import { routeMetadata } from '../../../data/association';

const meta = routeMetadata['/demos/association/membership'];
---

<AssociationLayout title={meta.title} description={meta.description}>
	<AssociationPageHero
		eyebrow="Membership"
		headline="Invest in your profession. Invest in yourself."
		lead="MHPA membership gives you advocacy representation, continuing education, career tools, local chapter access, and a professional community — all in one association."
		primaryCta={{ text: 'Join the Association', href: '#tiers' }}
		secondaryCta={{ text: 'Compare Membership Options', href: '#compare' }}
	/>
	<AssociationMembershipAudience />
	<AssociationMembershipBenefits />
	<AssociationMembershipTiers />
	<AssociationMembershipComparison />
	<AssociationMembershipOutcomes />
	<AssociationMembershipAdvocacy />
	<AssociationMembershipEducation />
	<AssociationMembershipCommunity />
	<AssociationMembershipStories />
	<AssociationMembershipFAQ />
	<AssociationFinalCTA />
</AssociationLayout>
