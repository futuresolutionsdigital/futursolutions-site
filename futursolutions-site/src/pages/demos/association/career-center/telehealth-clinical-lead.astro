---
import AssociationLayout from '../../../../layouts/AssociationLayout.astro';
import AssociationFinalCTA from '../../../../components/association/AssociationFinalCTA.astro';
import {
	routeMetadata,
	careerJobDetailTelehealth as d,
	careerJobDetailTelehealthQuickFacts as quickFacts,
	careerJobDetailTelehealthOverview as overview,
	careerJobDetailTelehealthResponsibilities as responsibilities,
	careerJobDetailTelehealthQualifications as qualifications,
	careerJobDetailTelehealthBenefits as benefits,
	careerJobApplicationProcess as applicationProcess,
	careerJobDetailTelehealthRelatedResources as relatedResources,
	careerTelehealthRelatedJobs as relatedJobs,
} from '../../../../data/association';

const meta = routeMetadata['/demos/association/career-center/telehealth-clinical-lead'];
---

<AssociationLayout title={meta.title} description={meta.description}>
	<!-- Hero -->
	<section class="jdetail-hero" aria-labelledby="jdetail-hero-heading">
		<div class="assoc-container jdetail-hero__inner">
			<a class="jdetail-hero__back" href={d.tertiaryLink.href}>{d.tertiaryLink.text}</a>
			<p class="assoc-eyebrow">{d.eyebrow}</p>
			<h1 id="jdetail-hero-heading">{d.title}</h1>
			<p class="jdetail-hero__employer">{d.employer}</p>
			<p class="jdetail-hero__lead">{d.lead}</p>
			<div class="jdetail-hero__badges">
				{d.badges.map((b) => <span class="jdetail-hero__badge">{b}</span>)}
			</div>
			<p class="jdetail-hero__salary">{d.salaryRange}</p>
			<div class="assoc-btn-row">
				<a class="assoc-btn assoc-btn--primary" href={d.primaryCta.href}>{d.primaryCta.text}</a>
				<a class="assoc-btn assoc-btn--secondary" href={d.secondaryCta.href}>{d.secondaryCta.text}</a>
			</div>
			<p class="jdetail-hero__note">{d.demoNote}</p>
		</div>
	</section>

	<!-- Quick Facts -->
	<section class="assoc-section" aria-label="Job quick facts">
		<div class="assoc-container">
			<div class="jdetail-facts">
				{quickFacts.map((f) => (
					<div class="jdetail-facts__item">
						<span class="jdetail-facts__label">{f.label}</span>
						<span class="jdetail-facts__value">{f.value}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Overview -->
	<section class="assoc-section assoc-section--warm" aria-labelledby="jdetail-overview-heading">
		<div class="assoc-container">
			<p class="assoc-eyebrow">Role Overview</p>
			<h2 id="jdetail-overview-heading">About this role</h2>
			<div class="jdetail-overview">
				{overview.map((p) => <p>{p}</p>)}
			</div>
		</div>
	</section>

	<!-- Responsibilities -->
	<section class="assoc-section" aria-labelledby="jdetail-resp-heading">
		<div class="assoc-container">
			<p class="assoc-eyebrow">Key Responsibilities</p>
			<h2 id="jdetail-resp-heading">What you will do</h2>
			<ul class="jdetail-resp-list">
				{responsibilities.map((r) => (
					<li>
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
						<span>{r}</span>
					</li>
				))}
			</ul>
		</div>
	</section>

	<!-- Qualifications -->
	<section class="assoc-section assoc-section--warm" aria-labelledby="jdetail-qual-heading">
		<div class="assoc-container">
			<p class="assoc-eyebrow">Qualifications</p>
			<h2 id="jdetail-qual-heading">What we are looking for</h2>
			<div class="jdetail-qual-grid">
				<div class="assoc-card jdetail-qual-card">
					<h3>Required</h3>
					<ul>
						{qualifications.required.map((q) => (
							<li>
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
								<span>{q}</span>
							</li>
						))}
					</ul>
				</div>
				<div class="assoc-card jdetail-qual-card jdetail-qual-card--preferred">
					<h3>Preferred</h3>
					<ul>
						{qualifications.preferred.map((q) => (
							<li>
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
								<span>{q}</span>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Benefits -->
	<section class="assoc-section" aria-labelledby="jdetail-benefits-heading">
		<div class="assoc-container">
			<p class="assoc-eyebrow">Why This Role</p>
			<h2 id="jdetail-benefits-heading">What makes this opportunity stand out</h2>
			<div class="jdetail-benefits-grid">
				{benefits.map((b) => (
					<div class="assoc-card jdetail-benefit-card">
						<h3>{b.title}</h3>
						<p>{b.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Application Process -->
	<section class="assoc-section assoc-section--warm" id="application" aria-labelledby="jdetail-app-heading">
		<div class="assoc-container">
			<p class="assoc-eyebrow">How to Apply</p>
			<h2 id="jdetail-app-heading">Application process</h2>
			<div class="jdetail-app-steps">
				{applicationProcess.map((s) => (
					<div class="jdetail-app-step">
						<span class="jdetail-app-step__num">{s.step}</span>
						<div>
							<h3>{s.title}</h3>
							<p>{s.description}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Related Resources -->
	<section class="assoc-section" aria-labelledby="jdetail-resources-heading">
		<div class="assoc-container">
			<p class="assoc-eyebrow">Career Resources</p>
			<h2 id="jdetail-resources-heading">Prepare for your next role</h2>
			<div class="jdetail-resources-grid">
				{relatedResources.map((r) => (
					<a href={r.href} class="assoc-card jdetail-resource-card">
						<span class="jdetail-resource-card__type">{r.type}</span>
						<h3>{r.title}</h3>
						<span class="jdetail-resource-card__link">View Resource →</span>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Related Jobs -->
	<section class="assoc-section assoc-section--warm" aria-labelledby="jdetail-related-heading">
		<div class="assoc-container">
			<p class="assoc-eyebrow">Similar Roles</p>
			<h2 id="jdetail-related-heading">Related opportunities</h2>
			<div class="jdetail-related-grid">
				{relatedJobs.map((j) => (
					<a href={j.href} class="assoc-card jdetail-related-card">
						<h3>{j.title}</h3>
						<p class="jdetail-related-card__employer">{j.employer}</p>
						<div class="jdetail-related-card__meta">
							<span>{j.location}</span>
							<span class="jdetail-related-card__dot" aria-hidden="true">·</span>
							<span>{j.workType}</span>
							<span class="jdetail-related-card__dot" aria-hidden="true">·</span>
							<span>{j.salaryRange}</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<AssociationFinalCTA
		headline="Find a role that fits your next stage."
		subheadline="Explore healthcare opportunities, career resources, and professional connections through the MHPA Career Center."
		primaryCta={{ text: 'Browse All Jobs', href: '/demos/association/career-center#jobs' }}
		secondaryCta={{ text: 'Explore Career Resources', href: '/demos/association/resources' }}
	/>
</AssociationLayout>

<style>
	/* Hero */
	.jdetail-hero { padding-block: clamp(2.5rem, 5vw, 4rem); background: linear-gradient(175deg, var(--assoc-bg) 40%, color-mix(in srgb, var(--assoc-sand) 40%, var(--assoc-bg)) 100%); border-bottom: 1px solid var(--assoc-border); }
	.jdetail-hero__inner { max-width: 720px; }
	.jdetail-hero__back { display: inline-block; margin-bottom: 1rem; font-size: 0.82rem; font-weight: 700; color: var(--assoc-teal); }
	.jdetail-hero__back:hover { color: var(--assoc-navy); }
	.jdetail-hero h1 { text-wrap: balance; margin-bottom: 0.25rem; }
	.jdetail-hero__employer { font-size: 1.05rem; font-weight: 600; color: var(--assoc-teal); margin-bottom: 0.75rem; }
	.jdetail-hero__lead { font-size: clamp(1rem, 0.98rem + 0.15vw, 1.1rem); line-height: 1.6; color: var(--assoc-slate); max-width: 620px; }
	.jdetail-hero__badges { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.75rem; }
	.jdetail-hero__badge { padding: 0.2rem 0.55rem; border-radius: 999px; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; background: color-mix(in srgb, var(--assoc-slate) 8%, var(--assoc-white)); color: var(--assoc-slate); }
	.jdetail-hero__salary { font-size: 1.15rem; font-weight: 800; color: var(--assoc-navy); margin-bottom: 0.5rem; }
	.jdetail-hero__note { font-size: 0.72rem; color: var(--assoc-slate); opacity: 0.55; margin-top: 0.75rem; }

	/* Quick Facts */
	.jdetail-facts { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0; border: 1px solid var(--assoc-border); border-radius: var(--assoc-radius); background: var(--assoc-white); overflow: hidden; }
	.jdetail-facts__item { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 1rem 0.5rem; border-right: 1px solid var(--assoc-border); }
	.jdetail-facts__item:last-child { border-right: none; }
	.jdetail-facts__label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--assoc-slate); margin-bottom: 0.2rem; }
	.jdetail-facts__value { font-size: 0.92rem; font-weight: 800; color: var(--assoc-navy); }

	/* Overview */
	.jdetail-overview p { font-size: 0.95rem; line-height: 1.7; max-width: 680px; }

	/* Responsibilities */
	.jdetail-resp-list { list-style: none; margin: 2rem 0 0; padding: 0; display: grid; gap: 0.85rem; max-width: 680px; }
	.jdetail-resp-list li { display: flex; align-items: flex-start; gap: 0.65rem; font-size: 0.92rem; font-weight: 500; line-height: 1.4; }
	.jdetail-resp-list li svg { display: inline; flex-shrink: 0; margin-top: 0.15rem; color: var(--assoc-teal); }

	/* Qualifications */
	.jdetail-qual-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2rem; }
	.jdetail-qual-card { padding: 1.75rem; }
	.jdetail-qual-card h3 { font-size: 0.82rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--assoc-teal); margin-bottom: 1rem; }
	.jdetail-qual-card--preferred h3 { color: var(--assoc-slate); }
	.jdetail-qual-card ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.65rem; }
	.jdetail-qual-card li { display: flex; align-items: flex-start; gap: 0.55rem; font-size: 0.88rem; line-height: 1.4; }
	.jdetail-qual-card li svg { display: inline; flex-shrink: 0; margin-top: 0.1rem; color: var(--assoc-teal); }
	.jdetail-qual-card--preferred li svg { color: var(--assoc-slate); opacity: 0.5; }

	/* Benefits */
	.jdetail-benefits-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-top: 2rem; }
	.jdetail-benefit-card { padding: 1.5rem; }
	.jdetail-benefit-card h3 { font-size: 1rem; margin-bottom: 0.3rem; }
	.jdetail-benefit-card p { font-size: 0.88rem; line-height: 1.5; margin: 0; }

	/* Application Process */
	.jdetail-app-steps { display: grid; gap: 0.75rem; margin-top: 2rem; max-width: 600px; }
	.jdetail-app-step { display: flex; gap: 0.85rem; align-items: flex-start; }
	.jdetail-app-step__num { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; border-radius: 50%; background: var(--assoc-teal-light); color: var(--assoc-teal); font-size: 0.82rem; font-weight: 800; }
	.jdetail-app-step h3 { font-size: 0.92rem; margin-bottom: 0.1rem; }
	.jdetail-app-step p { font-size: 0.82rem; line-height: 1.45; margin: 0; }

	/* Related Resources */
	.jdetail-resources-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 2rem; }
	.jdetail-resource-card { display: flex; flex-direction: column; padding: 1.25rem; }
	.jdetail-resource-card:hover { border-color: var(--assoc-teal); transform: translateY(-1px); }
	.jdetail-resource-card__type { display: inline-block; align-self: flex-start; margin-bottom: 0.5rem; padding: 0.12rem 0.4rem; border-radius: 4px; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; background: var(--assoc-teal-light); color: var(--assoc-teal); }
	.jdetail-resource-card h3 { font-size: 0.92rem; flex: 1; line-height: 1.3; }
	.jdetail-resource-card__link { font-size: 0.78rem; font-weight: 700; color: var(--assoc-teal); margin-top: 0.5rem; }

	/* Related Jobs */
	.jdetail-related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2rem; }
	.jdetail-related-card { display: flex; flex-direction: column; padding: 1.5rem; }
	.jdetail-related-card:hover { border-color: var(--assoc-teal); transform: translateY(-1px); }
	.jdetail-related-card h3 { font-size: 1rem; margin-bottom: 0.25rem; }
	.jdetail-related-card__employer { font-size: 0.85rem; font-weight: 600; color: var(--assoc-teal); margin-bottom: 0.35rem; }
	.jdetail-related-card__meta { display: flex; flex-wrap: wrap; gap: 0.3rem; font-size: 0.78rem; font-weight: 500; color: var(--assoc-slate); }
	.jdetail-related-card__dot { opacity: 0.35; }

	@media (max-width: 768px) {
		.jdetail-facts { grid-template-columns: repeat(3, 1fr); }
		.jdetail-facts__item:nth-child(3) { border-right: none; }
		.jdetail-qual-grid { grid-template-columns: 1fr; }
		.jdetail-benefits-grid { grid-template-columns: 1fr; }
		.jdetail-resources-grid { grid-template-columns: 1fr 1fr; }
		.jdetail-related-grid { grid-template-columns: 1fr; }
	}
	@media (max-width: 480px) {
		.jdetail-facts { grid-template-columns: repeat(2, 1fr); }
		.jdetail-facts__item:nth-child(even) { border-right: none; }
		.jdetail-resources-grid { grid-template-columns: 1fr; }
	}
</style>
