---
import AssociationLayout from '../../../../layouts/AssociationLayout.astro';
import AssociationCareerHero from '../../../../components/association/AssociationCareerHero.astro';
import AssociationStatStrip from '../../../../components/association/AssociationStatStrip.astro';
import AssociationCareerJobBoard from '../../../../components/association/AssociationCareerJobBoard.astro';
import AssociationCareerPathways from '../../../../components/association/AssociationCareerPathways.astro';
import AssociationCareerSalaryInsights from '../../../../components/association/AssociationCareerSalaryInsights.astro';
import AssociationCareerMentorship from '../../../../components/association/AssociationCareerMentorship.astro';
import AssociationCareerResources from '../../../../components/association/AssociationCareerResources.astro';
import AssociationCareerEmployers from '../../../../components/association/AssociationCareerEmployers.astro';
import AssociationCareerStudentSupport from '../../../../components/association/AssociationCareerStudentSupport.astro';
import AssociationCareerStories from '../../../../components/association/AssociationCareerStories.astro';
import AssociationFAQ from '../../../../components/association/AssociationFAQ.astro';
import AssociationFinalCTA from '../../../../components/association/AssociationFinalCTA.astro';
import { routeMetadata, careerStats, careerFaqs } from '../../../../data/association';

const meta = routeMetadata['/demos/association/career-center'];
---

<AssociationLayout title={meta.title} description={meta.description}>
	<AssociationCareerHero />
	<AssociationStatStrip stats={careerStats} ariaLabel="Career center statistics" />
	<AssociationCareerJobBoard />
	<AssociationCareerPathways />
	<AssociationCareerSalaryInsights />
	<AssociationCareerMentorship />
	<AssociationCareerResources />
	<AssociationCareerEmployers />
	<AssociationCareerStudentSupport />
	<AssociationCareerStories />
	<AssociationFAQ faqs={careerFaqs} heading="Career center questions, answered." />
	<AssociationFinalCTA
		headline="Build the next stage of your career with MHPA."
		subheadline="Explore jobs, resources, mentors, salary insights, and professional connections designed for healthcare professionals."
		primaryCta={{ text: 'Browse Jobs', href: '#jobs' }}
		secondaryCta={{ text: 'Join the Association', href: '/demos/association/membership' }}
	/>
</AssociationLayout>
