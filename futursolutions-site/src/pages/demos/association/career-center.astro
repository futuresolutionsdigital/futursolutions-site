---
import AssociationLayout from '../../../layouts/AssociationLayout.astro';
import AssociationPageHero from '../../../components/association/AssociationPageHero.astro';
import AssociationFinalCTA from '../../../components/association/AssociationFinalCTA.astro';
import { routeMetadata } from '../../../data/association';

const meta = routeMetadata['/demos/association/career-center'];
---

<AssociationLayout title={meta.title} description={meta.description}>
	<AssociationPageHero
		eyebrow="Career Center"
		headline="Your next career move starts here."
		lead="Search curated healthcare jobs, compare salary benchmarks, build your professional CV, and connect with experienced mentors who can guide your path."
		primaryCta={{ text: 'Browse Jobs', href: '/demos/association/career-center' }}
		secondaryCta={{ text: 'View Salary Data', href: '/demos/association/career-center' }}
	/>
	<section class="assoc-section">
		<div class="assoc-container placeholder">
			<div class="placeholder__badge">Coming Soon</div>
			<h2>Job board, salary data, CV builder, and mentorship</h2>
			<p class="assoc-lead">This page will include a searchable job board, regional salary comparisons, resume tools, and a mentorship matching program — all part of the MHPA demo system.</p>
			<a class="assoc-btn assoc-btn--secondary" href="/demos/association">← Back to Homepage</a>
		</div>
	</section>
	<AssociationFinalCTA />
</AssociationLayout>

<style>
	.placeholder { text-align: center; max-width: 600px; margin-inline: auto; }
	.placeholder .assoc-lead { margin-inline: auto; margin-bottom: 2rem; }
	.placeholder__badge { display: inline-block; margin-bottom: 1.5rem; padding: 0.3rem 0.8rem; border-radius: 999px; background: var(--assoc-teal-light); color: var(--assoc-teal); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
</style>
