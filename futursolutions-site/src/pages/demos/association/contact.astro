---
import AssociationLayout from '../../../layouts/AssociationLayout.astro';
import AssociationContactHero from '../../../components/association/AssociationContactHero.astro';
import AssociationContactPaths from '../../../components/association/AssociationContactPaths.astro';
import AssociationContactForm from '../../../components/association/AssociationContactForm.astro';
import AssociationContactProcess from '../../../components/association/AssociationContactProcess.astro';
import AssociationContactQuickLinks from '../../../components/association/AssociationContactQuickLinks.astro';
import AssociationContactDirectory from '../../../components/association/AssociationContactDirectory.astro';
import AssociationFAQ from '../../../components/association/AssociationFAQ.astro';
import AssociationFinalCTA from '../../../components/association/AssociationFinalCTA.astro';
import { routeMetadata, contactFaqs } from '../../../data/association';

const meta = routeMetadata['/demos/association/contact'];
---

<AssociationLayout title={meta.title} description={meta.description}>
	<AssociationContactHero />
	<AssociationContactPaths />
	<AssociationContactForm />
	<AssociationContactProcess />
	<AssociationContactQuickLinks />
	<AssociationContactDirectory />
	<AssociationFAQ faqs={contactFaqs} heading="Contact questions, answered." contactHref="" />
	<AssociationFinalCTA
		headline="Ready to turn association interest into action?"
		subheadline="A modern contact system should route members, sponsors, employers, and stakeholders to the right next step quickly."
		primaryCta={{ text: 'Explore Membership', href: '/demos/association/membership' }}
		secondaryCta={{ text: 'Back to Homepage', href: '/demos/association' }}
	/>
</AssociationLayout>
