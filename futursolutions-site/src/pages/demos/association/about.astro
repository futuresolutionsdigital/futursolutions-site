---
import AssociationLayout from '../../../layouts/AssociationLayout.astro';
import AssociationAboutHero from '../../../components/association/AssociationAboutHero.astro';
import AssociationAboutMission from '../../../components/association/AssociationAboutMission.astro';
import AssociationAboutImpact from '../../../components/association/AssociationAboutImpact.astro';
import AssociationAboutWhatWeDo from '../../../components/association/AssociationAboutWhatWeDo.astro';
import AssociationAboutOperatingModel from '../../../components/association/AssociationAboutOperatingModel.astro';
import AssociationAboutPriorities from '../../../components/association/AssociationAboutPriorities.astro';
import AssociationAboutPublicVoice from '../../../components/association/AssociationAboutPublicVoice.astro';
import AssociationAboutLeadership from '../../../components/association/AssociationAboutLeadership.astro';
import AssociationAboutCouncils from '../../../components/association/AssociationAboutCouncils.astro';
import AssociationAboutGovernance from '../../../components/association/AssociationAboutGovernance.astro';
import AssociationAboutAnnualReport from '../../../components/association/AssociationAboutAnnualReport.astro';
import AssociationAboutTimeline from '../../../components/association/AssociationAboutTimeline.astro';
import AssociationAboutPartners from '../../../components/association/AssociationAboutPartners.astro';
import AssociationAboutRecognition from '../../../components/association/AssociationAboutRecognition.astro';
import AssociationAboutFAQ from '../../../components/association/AssociationAboutFAQ.astro';
import AssociationFinalCTA from '../../../components/association/AssociationFinalCTA.astro';
import { routeMetadata } from '../../../data/association';

const meta = routeMetadata['/demos/association/about'];
---

<AssociationLayout title={meta.title} description={meta.description}>
	<AssociationAboutHero />
	<AssociationAboutMission />
	<AssociationAboutImpact />
	<AssociationAboutWhatWeDo />
	<AssociationAboutOperatingModel />
	<AssociationAboutPriorities />
	<AssociationAboutPublicVoice />
	<AssociationAboutLeadership />
	<AssociationAboutCouncils />
	<AssociationAboutGovernance />
	<AssociationAboutAnnualReport />
	<AssociationAboutTimeline />
	<AssociationAboutPartners />
	<AssociationAboutRecognition />
	<AssociationAboutFAQ />
	<AssociationFinalCTA
		headline="A stronger association story builds stronger member trust."
		subheadline="This demo shows how a professional association can present its mission, scale, leadership, history, and active work in a way that supports membership, advocacy, events, resources, chapters, and careers."
		primaryCta={{ text: 'Explore the Membership System', href: '/demos/association/membership' }}
		secondaryCta={{ text: 'Contact FutureSolutions', href: '/' }}
	/>
</AssociationLayout>
