---
import WellnessLayout from '../../../../layouts/WellnessLayout.astro';
---

<WellnessLayout title="Contrast Therapy — Lumen Health House" description="Alternating infrared sauna and cold plunge sessions for circulation, recovery, inflammation reduction, and stress resilience.">

<!-- ═══ Hero — dark, left-aligned ═══ -->
<section class="wh-section wh-section--dark sp-hero">
	<div class="wh-container">
		<p class="wh-eyebrow">Recovery & Performance</p>
		<h1>Contrast Therapy</h1>
		<p class="sp-hero__headline">Alternating heat and cold to accelerate recovery, reduce inflammation, and build stress resilience.</p>
		<p class="wh-lead">Structured infrared sauna and cold plunge sessions designed to boost circulation, support muscle recovery, and strengthen your body's adaptive response. No consultation required.</p>
		<div class="wh-btn-row">
			<a class="wh-btn wh-btn--primary" href="/demos/premium-wellness-clinic/new-clients">Book a Session &rarr;</a>
			<a class="wh-btn wh-btn--secondary" href="/demos/premium-wellness-clinic/memberships">View Memberships</a>
		</div>
	</div>
	<div class="wh-container sp-facts">
		<div class="sp-facts__strip">
			<div class="sp-facts__item"><span class="sp-facts__label">Duration</span><span class="sp-facts__value">45–60 min</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Best for</span><span class="sp-facts__value">Recovery, inflammation, stress</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Consultation</span><span class="sp-facts__value">Not required</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Starting at</span><span class="sp-facts__value">$85</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Recommended</span><span class="sp-facts__value">1–3x per week</span></div>
		</div>
	</div>
</section>

<!-- ═══ Why People Book — default bg, numbered list ═══ -->
<section class="wh-section sp-benefits">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">Benefits</p>
			<h2>Why people book contrast therapy</h2>
		</div>
		<div class="sp-benefits__list">
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">01</span>
				<div>
					<h3>Muscle recovery</h3>
					<p>Alternating vasodilation and vasoconstriction helps flush metabolic waste and deliver fresh nutrients to fatigued muscles.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">02</span>
				<div>
					<h3>Inflammation reduction</h3>
					<p>Cold exposure constricts blood vessels and reduces swelling, while heat promotes relaxation and tissue repair.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">03</span>
				<div>
					<h3>Improved circulation</h3>
					<p>The repeated cycling between heat and cold trains your vascular system, improving blood flow and cardiovascular efficiency over time.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">04</span>
				<div>
					<h3>Stress resilience</h3>
					<p>Deliberate exposure to temperature extremes activates adaptive stress pathways, building mental and physical resilience.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">05</span>
				<div>
					<h3>Better sleep</h3>
					<p>The deep relaxation that follows a contrast session promotes parasympathetic activation and improved sleep quality.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">06</span>
				<div>
					<h3>Immune support</h3>
					<p>Regular cold exposure has been associated with increased circulation of immune cells and improved immune vigilance.</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ What It Is — default bg, editorial prose ═══ -->
<section class="wh-section sp-what">
	<div class="wh-container sp-what__inner">
		<h2>What is contrast therapy?</h2>
		<p>Contrast therapy alternates between infrared sauna (heat) and cold plunge (cold) in structured intervals. The temperature shifts create a vascular pump effect — expanding and constricting blood vessels to enhance circulation, reduce inflammation, and stimulate your body's natural recovery processes.</p>
		<p>At Lumen Health House, sessions are guided by time and temperature protocols tailored to your experience level. First-time clients begin with shorter cold exposures and gradually build tolerance over multiple visits.</p>
		<p>A typical session includes 3 to 4 rounds of heat and cold, finishing with whichever temperature feels best for your body. The entire session takes 45 to 60 minutes including transition time and a brief cool-down period.</p>
	</div>
</section>

<!-- ═══ Who It's For — surface bg, two-column ═══ -->
<section class="wh-section wh-section--surface sp-who">
	<div class="wh-container sp-who__split">
		<h2>Who is contrast therapy for?</h2>
		<div class="sp-who__col">
			<h3>Goal-based</h3>
			<ul>
				<li>Accelerate recovery between workouts or competitions</li>
				<li>Build mental toughness and stress tolerance</li>
				<li>Improve cardiovascular efficiency and circulation</li>
				<li>Support chronic inflammation management</li>
				<li>Enhance sleep quality and relaxation</li>
			</ul>
		</div>
		<div class="sp-who__col">
			<h3>Symptom-based</h3>
			<ul>
				<li>Persistent muscle soreness after training</li>
				<li>Joint stiffness and general achiness</li>
				<li>Poor circulation or cold extremities</li>
				<li>Difficulty winding down or sleeping deeply</li>
				<li>Low energy or sluggish recovery</li>
			</ul>
		</div>
	</div>
</section>

<!-- ═══ How It Works — dark bg, vertical timeline ═══ -->
<section class="wh-section wh-section--dark sp-process">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">The Process</p>
			<h2>How a contrast therapy session works</h2>
		</div>
		<ol class="sp-process__steps">
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Warm up</h3><p>Begin with 10–15 minutes in the infrared sauna, gradually raising your core temperature.</p></div>
			</li>
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Cold plunge</h3><p>Transition to the cold plunge for 1–3 minutes. Staff guides your breathing and timing.</p></div>
			</li>
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Repeat cycles</h3><p>Alternate between heat and cold for 3–4 rounds, adjusting duration to your comfort level.</p></div>
			</li>
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Cool down</h3><p>Finish with a brief rest period. Hydrate and allow your body to return to baseline before leaving.</p></div>
			</li>
		</ol>
	</div>
</section>

<!-- ═══ What to Expect — default bg, simple sections ═══ -->
<section class="wh-section sp-expect">
	<div class="wh-container">
		<h2>What to expect</h2>
		<div class="sp-expect__phases">
			<div class="sp-expect__phase">
				<h3>Before</h3>
				<p>Arrive hydrated and avoid heavy meals within an hour. Bring a swimsuit or use provided disposable garments. Remove jewelry and electronics.</p>
			</div>
			<div class="sp-expect__phase">
				<h3>During</h3>
				<p>You'll alternate between the warm sauna and cold plunge. Expect the cold to feel intense at first — controlled breathing helps. Staff is available if you need guidance on timing or technique.</p>
			</div>
			<div class="sp-expect__phase">
				<h3>After</h3>
				<p>Most clients feel energized, alert, and deeply relaxed. Some experience mild flushing or tingling that fades within minutes. Drink water and ease back into your day.</p>
			</div>
		</div>
	</div>
</section>

<!-- ═══ Safety — sage bg, editorial ═══ -->
<section class="wh-section wh-section--sage sp-safety">
	<div class="wh-container sp-safety__inner">
		<h2>Safety and medical guidance</h2>
		<p>Contrast therapy is generally well-tolerated, but certain health conditions may require caution or make this service unsuitable. Eligibility may depend on your health history, medications, lab results, and provider review.</p>
		<ul>
			<li>Individuals with uncontrolled high blood pressure, heart conditions, or a history of seizures should consult their physician before booking.</li>
			<li>Pregnant individuals should not use contrast therapy.</li>
			<li>If you have Raynaud's syndrome, cold urticaria, or circulatory disorders, please speak with your provider first.</li>
			<li>You may exit the cold plunge at any time — sessions are self-paced and never forced.</li>
			<li>Contrast therapy is a wellness service and is not intended to diagnose, treat, or cure any medical condition.</li>
		</ul>
	</div>
</section>

<!-- ═══ Packages — default bg, bordered cards ═══ -->
<section class="wh-section sp-packages">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">Save with Memberships</p>
			<h2>Make contrast therapy part of your routine</h2>
		</div>
		<div class="sp-packages__grid">
			<div class="wh-card sp-packages__card">
				<h3>Single Session</h3>
				<p class="sp-packages__price">From $85</p>
				<p>Drop in any time. No membership required.</p>
			</div>
			<div class="wh-card sp-packages__card">
				<h3>Recover Membership</h3>
				<p class="sp-packages__price">$189/mo</p>
				<p>Unlimited contrast sessions, 2 infrared sauna add-ons, and 10% off all recovery services.</p>
				<a class="wh-text-link sp-packages__link" href="/demos/premium-wellness-clinic/memberships">View Details &rarr;</a>
			</div>
			<div class="wh-card sp-packages__card">
				<h3>Recovery Starter Pack</h3>
				<p class="sp-packages__price">$225</p>
				<p>3 contrast therapy sessions. Perfect for trying the protocol and building consistency.</p>
			</div>
		</div>
	</div>
</section>

<!-- ═══ Related Services — surface bg, row list ═══ -->
<section class="wh-section wh-section--surface sp-related">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">Related Services</p>
			<h2>Commonly paired with contrast therapy</h2>
		</div>
		<div class="sp-related__list">
			<a class="sp-related__row" href="/demos/premium-wellness-clinic/services">
				<h3>Infrared Sauna</h3>
				<p>Extended heat sessions for detoxification, relaxation, and deep tissue warmth.</p>
				<span class="sp-related__arrow" aria-hidden="true">&rarr;</span>
			</a>
			<a class="sp-related__row" href="/demos/premium-wellness-clinic/services">
				<h3>Cold Plunge</h3>
				<p>Standalone cold immersion for inflammation reduction and nervous system training.</p>
				<span class="sp-related__arrow" aria-hidden="true">&rarr;</span>
			</a>
			<a class="sp-related__row" href="/demos/premium-wellness-clinic/services">
				<h3>Red Light Therapy</h3>
				<p>Full-body photobiomodulation for tissue repair, skin health, and cellular energy.</p>
				<span class="sp-related__arrow" aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</section>

<!-- ═══ FAQ — split layout ═══ -->
<section class="wh-section sp-faq">
	<div class="wh-container sp-faq__split">
		<div class="sp-faq__left">
			<p class="wh-eyebrow">Questions</p>
			<h2>Contrast Therapy FAQ</h2>
		</div>
		<div class="wh-faq__list">
			<details class="wh-faq__item">
				<summary><span>What is contrast therapy?</span></summary>
				<p>Contrast therapy is the practice of alternating between heat (infrared sauna) and cold (cold plunge) in timed intervals. The temperature shifts stimulate circulation, reduce inflammation, and activate your body's natural recovery pathways.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>How hot and cold are the sessions?</span></summary>
				<p>The infrared sauna typically ranges from 130–150°F, and the cold plunge is maintained between 39–50°F. We adjust based on your experience level and comfort.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>How often should I do contrast therapy?</span></summary>
				<p>Most clients benefit from 1 to 3 sessions per week. Athletes or those using it for active recovery may go more frequently, while once per week is great for general wellness.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>Who should avoid contrast therapy?</span></summary>
				<p>People with uncontrolled hypertension, heart conditions, pregnancy, cold urticaria, or seizure disorders should not participate without physician clearance. If you're unsure, our team can help you determine eligibility.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>Can I combine contrast therapy with other services?</span></summary>
				<p>Absolutely. Many clients pair contrast therapy with IV hydration, red light therapy, or compression therapy. Your wellness team can help you build a recovery stack that fits your goals.</p>
			</details>
		</div>
	</div>
</section>

<!-- ═══ Final CTA — dark, centered ═══ -->
<section class="wh-section wh-section--dark sp-final">
	<div class="wh-container" style="text-align:center; max-width:640px;">
		<h2>Ready to try contrast therapy?</h2>
		<p class="wh-lead" style="margin-inline:auto;">No consultation required. Book a session or speak with our team about the best protocol for your goals.</p>
		<div class="wh-btn-row" style="justify-content:center;">
			<a class="wh-btn wh-btn--primary" href="/demos/premium-wellness-clinic/new-clients">Book a Session &rarr;</a>
			<a class="wh-btn wh-btn--secondary" href="/demos/premium-wellness-clinic/new-clients">Talk to a Provider</a>
		</div>
	</div>
</section>

</WellnessLayout>

<style>
/* ═══════════════════════════════════════════════════════
   SERVICE PAGE — Restrained Clinical Premium
   ═══════════════════════════════════════════════════════ */

/* ─── Hero ─── */
.sp-hero { padding-top: clamp(5rem, 10vw, 9rem); padding-bottom: clamp(3rem, 6vw, 5rem); }
.sp-hero h1 { max-width: none; margin-bottom: 0.5rem; }
.sp-hero__headline { font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem); font-weight: 400; max-width: 620px; margin-bottom: 0.75rem; }

/* ─── Quick Facts Strip ─── */
.sp-facts { margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); }
.sp-facts__strip { display: flex; gap: 2.5rem; flex-wrap: wrap; }
.sp-facts__item { display: flex; flex-direction: column; gap: 0.2rem; }
.sp-facts__label { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--wh-sage); }
.sp-facts__value { font-size: 0.88rem; font-weight: 600; color: var(--wh-white); }

/* ─── Benefits: numbered list ─── */
.sp-benefits__list { display: flex; flex-direction: column; }
.sp-benefits__item { display: flex; gap: 1rem; padding: 1.15rem 0; border-bottom: 1px solid var(--wh-border); }
.sp-benefits__item:first-child { border-top: 1px solid var(--wh-border); }
.sp-benefits__num { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; color: var(--wh-sage); padding-top: 0.15rem; flex-shrink: 0; min-width: 1.5rem; }
.sp-benefits__item h3 { font-size: 0.9rem; margin-bottom: 0.2rem; }
.sp-benefits__item p { font-size: 0.82rem; color: var(--wh-muted); }

/* ─── What It Is ─── */
.sp-what__inner { max-width: 680px; }
.sp-what__inner p { font-size: 0.95rem; line-height: 1.7; color: var(--wh-text); }

/* ─── Who It's For ─── */
.sp-who__split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); }
.sp-who__split > h2 { grid-column: 1 / -1; }
.sp-who__col h3 { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--wh-sage); margin-bottom: 0.75rem; }
.sp-who__col ul { padding-left: 1.1rem; margin: 0; }
.sp-who__col li { font-size: 0.88rem; color: var(--wh-muted); margin-bottom: 0.5rem; line-height: 1.55; }
@media (max-width: 520px) { .sp-who__split { grid-template-columns: 1fr; } }

/* ─── Process: vertical timeline with dots ─── */
.sp-process__steps { list-style: none; margin: 0; padding: 0; max-width: 560px; }
.sp-process__step { display: flex; gap: 1.5rem; position: relative; padding-bottom: 2.5rem; }
.sp-process__step:last-child { padding-bottom: 0; }
.sp-process__dot { position: relative; width: 10px; flex-shrink: 0; padding-top: 0.35rem; }
.sp-process__dot::before { content: ''; display: block; width: 10px; height: 10px; border-radius: 50%; border: 2px solid var(--wh-sage); background: var(--wh-ink); }
.sp-process__step:not(:last-child) .sp-process__dot::after { content: ''; position: absolute; top: 14px; left: 4.5px; width: 1px; height: calc(100% + 2.5rem - 14px); background: rgba(255,255,255,0.1); }
.sp-process__body h3 { font-size: 0.95rem; color: var(--wh-white); margin-bottom: 0.3rem; }
.sp-process__body p { font-size: 0.85rem; color: rgba(255,255,255,0.5); }

/* ─── What to Expect ─── */
.sp-expect__phases { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 1.5rem; }
.sp-expect__phase h3 { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--wh-sage); margin-bottom: 0.75rem; }
.sp-expect__phase p { font-size: 0.88rem; color: var(--wh-muted); line-height: 1.65; }
@media (max-width: 600px) { .sp-expect__phases { grid-template-columns: 1fr; gap: 1.5rem; } }

/* ─── Safety ─── */
.sp-safety__inner { max-width: 680px; }
.sp-safety__inner p { font-size: 0.9rem; line-height: 1.7; }
.sp-safety__inner ul { padding-left: 1.25rem; margin-top: 1rem; }
.sp-safety__inner li { font-size: 0.88rem; color: var(--wh-muted); margin-bottom: 0.5rem; line-height: 1.6; }

/* ─── Packages: bordered cards ─── */
.sp-packages__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
.sp-packages__card { padding: 2rem; display: flex; flex-direction: column; }
.sp-packages__card h3 { font-size: 1rem; margin-bottom: 0.25rem; }
.sp-packages__price { display: block; font-size: 1.5rem; font-weight: 700; color: var(--wh-ink); margin-bottom: 0.75rem; letter-spacing: -0.02em; }
.sp-packages__card p { font-size: 0.82rem; color: var(--wh-muted); }
.sp-packages__link { margin-top: auto; padding-top: 0.75rem; }
@media (max-width: 700px) { .sp-packages__grid { grid-template-columns: 1fr; } }

/* ─── Related Services ─── */
.sp-related__list { display: flex; flex-direction: column; }
.sp-related__row { display: flex; align-items: center; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--wh-border); transition: padding-left var(--wh-transition); }
.sp-related__row:first-child { border-top: 1px solid var(--wh-border); }
.sp-related__row:hover { padding-left: 0.35rem; }
.sp-related__row h3 { font-size: 0.92rem; min-width: 160px; flex-shrink: 0; margin-bottom: 0; }
.sp-related__row p { font-size: 0.82rem; color: var(--wh-muted); flex: 1; margin-bottom: 0; }
.sp-related__arrow { color: var(--wh-sage); font-size: 0.85rem; flex-shrink: 0; }
@media (max-width: 600px) { .sp-related__row { flex-wrap: wrap; } .sp-related__row h3 { min-width: auto; } }

/* ─── FAQ Split Layout ─── */
.sp-faq__split { display: grid; grid-template-columns: 1fr 1.5fr; gap: clamp(3rem, 5vw, 5rem); align-items: start; }
.sp-faq__left { position: sticky; top: 10rem; }
.sp-faq .wh-faq__list { max-width: none; }
@media (max-width: 700px) { .sp-faq__split { grid-template-columns: 1fr; } .sp-faq__left { position: static; } }

/* ─── Final CTA ─── */
.sp-final { border-top: 1px solid rgba(255,255,255,0.06); }
</style>
