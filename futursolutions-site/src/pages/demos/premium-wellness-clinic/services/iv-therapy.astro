---
import WellnessLayout from '../../../../layouts/WellnessLayout.astro';
---

<WellnessLayout title="IV Therapy — Lumen Health House" description="Customized IV drips for hydration, energy, recovery, immune support, and wellness maintenance. Walk-in friendly, no consultation required.">

<!-- ═══ Hero — dark, left-aligned ═══ -->
<section class="wh-section wh-section--dark sp-hero">
	<div class="wh-container">
		<p class="wh-eyebrow">IV & Cellular Wellness</p>
		<h1>IV Therapy</h1>
		<p class="sp-hero__headline">Targeted hydration, nutrients, and recovery — delivered directly where your body can use them.</p>
		<p class="wh-lead">Customized IV drips for energy, hydration, immune support, recovery, and wellness maintenance. No referral or consultation required for most IV protocols.</p>
		<div class="wh-btn-row">
			<a class="wh-btn wh-btn--primary" href="/demos/premium-wellness-clinic/new-clients">Book a Session &rarr;</a>
			<a class="wh-btn wh-btn--secondary" href="/demos/premium-wellness-clinic/memberships">View Memberships</a>
		</div>
	</div>
	<div class="wh-container sp-facts">
		<div class="sp-facts__strip">
			<div class="sp-facts__item"><span class="sp-facts__label">Duration</span><span class="sp-facts__value">30–60 min</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Best for</span><span class="sp-facts__value">Energy, recovery, hydration</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Consultation</span><span class="sp-facts__value">Not required</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Starting at</span><span class="sp-facts__value">$175</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Recommended</span><span class="sp-facts__value">Weekly to monthly</span></div>
		</div>
	</div>
</section>

<!-- ═══ Why People Book — default bg, numbered list ═══ -->
<section class="wh-section sp-benefits">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">Benefits</p>
			<h2>Why people book IV therapy</h2>
		</div>
		<div class="sp-benefits__list">
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">01</span>
				<div>
					<h3>Low energy or fatigue</h3>
					<p>Nutrient-rich IV drips deliver vitamins and minerals directly into your bloodstream, bypassing digestion for faster absorption.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">02</span>
				<div>
					<h3>Post-workout recovery</h3>
					<p>Rehydrate, replenish electrolytes, and reduce muscle soreness after intense training or competition.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">03</span>
				<div>
					<h3>Immune support</h3>
					<p>High-dose vitamin C, zinc, and other immune-supporting nutrients during cold season or travel.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">04</span>
				<div>
					<h3>Dehydration</h3>
					<p>Rapid rehydration after illness, travel, heat exposure, or simply not drinking enough water.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">05</span>
				<div>
					<h3>Skin and wellness</h3>
					<p>Glutathione and biotin drips support skin clarity, brightness, and overall wellness from the inside.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">06</span>
				<div>
					<h3>Hangover recovery</h3>
					<p>Fast relief from nausea, headache, and dehydration with targeted rehydration and anti-nausea support.</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ What It Is — default bg, editorial prose ═══ -->
<section class="wh-section sp-what">
	<div class="wh-container sp-what__inner">
		<h2>What is IV therapy?</h2>
		<p>IV (intravenous) therapy delivers fluids, vitamins, minerals, and amino acids directly into your bloodstream through a small catheter. Because it bypasses the digestive system, your body absorbs a higher percentage of nutrients compared to oral supplements.</p>
		<p>At Lumen Health House, each IV session is prepared with pharmaceutical-grade ingredients and administered in a comfortable, private treatment space. Sessions typically last 30 to 60 minutes depending on the formulation.</p>
		<p>Our most popular drips include hydration blends, energy and recovery formulas, immune-boosting protocols, and custom wellness infusions. Your wellness team can help you choose the right drip based on your goals.</p>
	</div>
</section>

<!-- ═══ Who It's For — surface bg, two-column ═══ -->
<section class="wh-section wh-section--surface sp-who">
	<div class="wh-container sp-who__split">
		<h2>Who is IV therapy for?</h2>
		<div class="sp-who__col">
			<h3>Goal-based</h3>
			<ul>
				<li>Improve energy and reduce afternoon fatigue</li>
				<li>Support athletic performance and recovery</li>
				<li>Boost immune resilience during travel or cold season</li>
				<li>Enhance skin clarity and hydration</li>
				<li>Support overall wellness and nutrient balance</li>
			</ul>
		</div>
		<div class="sp-who__col">
			<h3>Symptom-based</h3>
			<ul>
				<li>Chronic fatigue or low energy despite adequate sleep</li>
				<li>Frequent illness or slow recovery from illness</li>
				<li>Dehydration from exercise, travel, or heat</li>
				<li>Muscle soreness and slow workout recovery</li>
				<li>Brain fog or difficulty concentrating</li>
			</ul>
		</div>
	</div>
</section>

<!-- ═══ How It Works — dark bg, vertical timeline ═══ -->
<section class="wh-section wh-section--dark sp-process">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">The Process</p>
			<h2>How an IV therapy session works</h2>
		</div>
		<ol class="sp-process__steps">
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Choose your drip</h3><p>Select from our menu or let your wellness team recommend a formulation based on your goals.</p></div>
			</li>
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Brief health intake</h3><p>A quick review of your health history, allergies, and current medications before your session.</p></div>
			</li>
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Relax during infusion</h3><p>Settle into a comfortable treatment chair while your IV delivers nutrients over 30–60 minutes.</p></div>
			</li>
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Resume your day</h3><p>No downtime required. Most clients feel the effects within hours and return to normal activities immediately.</p></div>
			</li>
		</ol>
	</div>
</section>

<!-- ═══ What to Expect — default bg, simple sections ═══ -->
<section class="wh-section sp-expect">
	<div class="wh-container">
		<h2>What to expect</h2>
		<div class="sp-expect__phases">
			<div class="sp-expect__phase">
				<h3>Before</h3>
				<p>Arrive hydrated and having eaten recently. Wear comfortable clothing with easy arm access. No fasting required.</p>
			</div>
			<div class="sp-expect__phase">
				<h3>During</h3>
				<p>A small IV catheter is placed in your arm. You may feel a brief pinch. During infusion, you can relax, read, work on your phone, or rest. Staff monitors you throughout.</p>
			</div>
			<div class="sp-expect__phase">
				<h3>After</h3>
				<p>The catheter is removed and a small bandage applied. Most clients feel refreshed and energized. Mild coolness, taste changes, or brief lightheadedness can occur but resolve quickly.</p>
			</div>
		</div>
	</div>
</section>

<!-- ═══ Safety — sage bg, editorial ═══ -->
<section class="wh-section wh-section--sage sp-safety">
	<div class="wh-container sp-safety__inner">
		<h2>Safety and medical guidance</h2>
		<p>IV therapy at Lumen Health House is administered by trained wellness staff under the supervision of our medical director. All formulations use pharmaceutical-grade ingredients.</p>
		<ul>
			<li>A brief health intake is completed before your first session.</li>
			<li>Certain medical conditions, medications, or allergies may affect eligibility for specific formulations.</li>
			<li>Your provider will help determine whether a particular IV protocol is appropriate for your goals and health history.</li>
			<li>IV therapy is a wellness service and is not intended to diagnose, treat, or cure any medical condition.</li>
		</ul>
	</div>
</section>

<!-- ═══ Packages — default bg, bordered cards ═══ -->
<section class="wh-section sp-packages">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">Save with Memberships</p>
			<h2>Make IV therapy part of your routine</h2>
		</div>
		<div class="sp-packages__grid">
			<div class="wh-card sp-packages__card">
				<h3>Single Session</h3>
				<p class="sp-packages__price">From $175</p>
				<p>Walk in or book online. No membership required.</p>
			</div>
			<div class="wh-card sp-packages__card">
				<h3>Optimize Membership</h3>
				<p class="sp-packages__price">$279/mo</p>
				<p>Includes 2 IV sessions per month, recovery credits, monthly body scan, and 15% off add-ons.</p>
				<a class="wh-text-link sp-packages__link" href="/demos/premium-wellness-clinic/memberships">View Details &rarr;</a>
			</div>
			<div class="wh-card sp-packages__card">
				<h3>Energy Optimization Pack</h3>
				<p class="sp-packages__price">$495</p>
				<p>3 IV therapy sessions + Vitamin B12 injection. Ideal for a focused energy reset.</p>
			</div>
		</div>
	</div>
</section>

<!-- ═══ Related Services — surface bg, row list ═══ -->
<section class="wh-section wh-section--surface sp-related">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">Related Services</p>
			<h2>Commonly paired with IV therapy</h2>
		</div>
		<div class="sp-related__list">
			<a class="sp-related__row" href="/demos/premium-wellness-clinic/services">
				<h3>NAD+</h3>
				<p>Cellular repair, mental clarity, and energy support through NAD+ IV therapy.</p>
				<span class="sp-related__arrow" aria-hidden="true">&rarr;</span>
			</a>
			<a class="sp-related__row" href="/demos/premium-wellness-clinic/services">
				<h3>Vitamin Injections</h3>
				<p>Quick B12, glutathione, and custom vitamin injections for targeted nutrient support.</p>
				<span class="sp-related__arrow" aria-hidden="true">&rarr;</span>
			</a>
			<a class="sp-related__row" href="/demos/premium-wellness-clinic/services/contrast-therapy">
				<h3>Contrast Therapy</h3>
				<p>Pair IV hydration with contrast therapy for enhanced recovery and circulation.</p>
				<span class="sp-related__arrow" aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</section>

<!-- ═══ FAQ — split layout ═══ -->
<section class="wh-section sp-faq">
	<div class="wh-container sp-faq__split">
		<div class="sp-faq__left">
			<p class="wh-eyebrow">Questions</p>
			<h2>IV Therapy FAQ</h2>
		</div>
		<div class="wh-faq__list">
			<details class="wh-faq__item">
				<summary><span>Do I need a consultation before IV therapy?</span></summary>
				<p>No. Most IV protocols can be booked directly. A brief health intake is completed at your first visit to ensure safety.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>How long does a session take?</span></summary>
				<p>Most sessions take 30 to 60 minutes depending on the formulation and drip rate.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>How often should I get IV therapy?</span></summary>
				<p>Frequency depends on your goals. Many clients come weekly or biweekly for ongoing wellness, while others book sessions as needed for recovery, travel, or immune support.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>Does it hurt?</span></summary>
				<p>You may feel a brief pinch when the IV is placed. Most clients describe it as very mild. During the infusion, you should feel comfortable.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>What is in the IV?</span></summary>
				<p>Formulations vary but typically include saline, electrolytes, B vitamins, vitamin C, glutathione, amino acids, or other nutrients. Your wellness team will explain exactly what is in your drip.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>Is IV therapy covered by insurance?</span></summary>
				<p>IV therapy at Lumen is a cash-pay wellness service. We provide transparent pricing. Memberships and packages can reduce your per-session cost.</p>
			</details>
		</div>
	</div>
</section>

<!-- ═══ Final CTA — dark, centered ═══ -->
<section class="wh-section wh-section--dark sp-final">
	<div class="wh-container" style="text-align:center; max-width:640px;">
		<h2>Ready to try IV therapy?</h2>
		<p class="wh-lead" style="margin-inline:auto;">No consultation required for most IV drips. Book a session or ask our team for a recommendation.</p>
		<div class="wh-btn-row" style="justify-content:center;">
			<a class="wh-btn wh-btn--primary" href="/demos/premium-wellness-clinic/new-clients">Book a Session &rarr;</a>
			<a class="wh-btn wh-btn--secondary" href="/demos/premium-wellness-clinic/new-clients">Talk to a Provider</a>
		</div>
	</div>
</section>

</WellnessLayout>

<style>
/* ═══════════════════════════════════════════════════════
   SERVICE PAGE — Restrained Clinical Premium
   ═══════════════════════════════════════════════════════ */

/* ─── Hero ─── */
.sp-hero { padding-top: clamp(5rem, 10vw, 9rem); padding-bottom: clamp(3rem, 6vw, 5rem); }
.sp-hero h1 { max-width: none; margin-bottom: 0.5rem; }
.sp-hero__headline { font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem); font-weight: 400; max-width: 620px; margin-bottom: 0.75rem; }

/* ─── Quick Facts Strip ─── */
.sp-facts { margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); }
.sp-facts__strip { display: flex; gap: 2.5rem; flex-wrap: wrap; }
.sp-facts__item { display: flex; flex-direction: column; gap: 0.2rem; }
.sp-facts__label { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--wh-sage); }
.sp-facts__value { font-size: 0.88rem; font-weight: 600; color: var(--wh-white); }

/* ─── Benefits: numbered list ─── */
.sp-benefits__list { display: flex; flex-direction: column; }
.sp-benefits__item { display: flex; gap: 1rem; padding: 1.15rem 0; border-bottom: 1px solid var(--wh-border); }
.sp-benefits__item:first-child { border-top: 1px solid var(--wh-border); }
.sp-benefits__num { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; color: var(--wh-sage); padding-top: 0.15rem; flex-shrink: 0; min-width: 1.5rem; }
.sp-benefits__item h3 { font-size: 0.9rem; margin-bottom: 0.2rem; }
.sp-benefits__item p { font-size: 0.82rem; color: var(--wh-muted); }

/* ─── What It Is ─── */
.sp-what__inner { max-width: 680px; }
.sp-what__inner p { font-size: 0.95rem; line-height: 1.7; color: var(--wh-text); }

/* ─── Who It's For ─── */
.sp-who__split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); }
.sp-who__split > h2 { grid-column: 1 / -1; }
.sp-who__col h3 { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--wh-sage); margin-bottom: 0.75rem; }
.sp-who__col ul { padding-left: 1.1rem; margin: 0; }
.sp-who__col li { font-size: 0.88rem; color: var(--wh-muted); margin-bottom: 0.5rem; line-height: 1.55; }
@media (max-width: 520px) { .sp-who__split { grid-template-columns: 1fr; } }

/* ─── Process: vertical timeline with dots ─── */
.sp-process__steps { list-style: none; margin: 0; padding: 0; max-width: 560px; }
.sp-process__step { display: flex; gap: 1.5rem; position: relative; padding-bottom: 2.5rem; }
.sp-process__step:last-child { padding-bottom: 0; }
.sp-process__dot { position: relative; width: 10px; flex-shrink: 0; padding-top: 0.35rem; }
.sp-process__dot::before { content: ''; display: block; width: 10px; height: 10px; border-radius: 50%; border: 2px solid var(--wh-sage); background: var(--wh-ink); }
.sp-process__step:not(:last-child) .sp-process__dot::after { content: ''; position: absolute; top: 14px; left: 4.5px; width: 1px; height: calc(100% + 2.5rem - 14px); background: rgba(255,255,255,0.1); }
.sp-process__body h3 { font-size: 0.95rem; color: var(--wh-white); margin-bottom: 0.3rem; }
.sp-process__body p { font-size: 0.85rem; color: rgba(255,255,255,0.5); }

/* ─── What to Expect ─── */
.sp-expect__phases { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 1.5rem; }
.sp-expect__phase h3 { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--wh-sage); margin-bottom: 0.75rem; }
.sp-expect__phase p { font-size: 0.88rem; color: var(--wh-muted); line-height: 1.65; }
@media (max-width: 600px) { .sp-expect__phases { grid-template-columns: 1fr; gap: 1.5rem; } }

/* ─── Safety ─── */
.sp-safety__inner { max-width: 680px; }
.sp-safety__inner p { font-size: 0.9rem; line-height: 1.7; }
.sp-safety__inner ul { padding-left: 1.25rem; margin-top: 1rem; }
.sp-safety__inner li { font-size: 0.88rem; color: var(--wh-muted); margin-bottom: 0.5rem; line-height: 1.6; }

/* ─── Packages: bordered cards ─── */
.sp-packages__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
.sp-packages__card { padding: 2rem; display: flex; flex-direction: column; }
.sp-packages__card h3 { font-size: 1rem; margin-bottom: 0.25rem; }
.sp-packages__price { display: block; font-size: 1.5rem; font-weight: 700; color: var(--wh-ink); margin-bottom: 0.75rem; letter-spacing: -0.02em; }
.sp-packages__card p { font-size: 0.82rem; color: var(--wh-muted); }
.sp-packages__link { margin-top: auto; padding-top: 0.75rem; }
@media (max-width: 700px) { .sp-packages__grid { grid-template-columns: 1fr; } }

/* ─── Related Services ─── */
.sp-related__list { display: flex; flex-direction: column; }
.sp-related__row { display: flex; align-items: center; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--wh-border); transition: padding-left var(--wh-transition); }
.sp-related__row:first-child { border-top: 1px solid var(--wh-border); }
.sp-related__row:hover { padding-left: 0.35rem; }
.sp-related__row h3 { font-size: 0.92rem; min-width: 160px; flex-shrink: 0; margin-bottom: 0; }
.sp-related__row p { font-size: 0.82rem; color: var(--wh-muted); flex: 1; margin-bottom: 0; }
.sp-related__arrow { color: var(--wh-sage); font-size: 0.85rem; flex-shrink: 0; }
@media (max-width: 600px) { .sp-related__row { flex-wrap: wrap; } .sp-related__row h3 { min-width: auto; } }

/* ─── FAQ Split Layout ─── */
.sp-faq__split { display: grid; grid-template-columns: 1fr 1.5fr; gap: clamp(3rem, 5vw, 5rem); align-items: start; }
.sp-faq__left { position: sticky; top: 10rem; }
.sp-faq .wh-faq__list { max-width: none; }
@media (max-width: 700px) { .sp-faq__split { grid-template-columns: 1fr; } .sp-faq__left { position: static; } }

/* ─── Final CTA ─── */
.sp-final { border-top: 1px solid rgba(255,255,255,0.06); }
</style>
