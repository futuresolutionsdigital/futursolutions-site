---
import WellnessLayout from '../../../../layouts/WellnessLayout.astro';
---

<WellnessLayout title="Body Composition Scan — Lumen Health House" description="InBody-style body composition analysis tracking muscle, fat, water balance, and metabolic rate. No consultation required.">

<!-- ═══ Hero — dark, left-aligned ═══ -->
<section class="wh-section wh-section--dark sp-hero">
	<div class="wh-container">
		<p class="wh-eyebrow">Diagnostics & Body Composition</p>
		<h1>Body Composition Scan</h1>
		<p class="sp-hero__headline">See beyond the scale. Track muscle, fat, water balance, and metabolic rate with clinical-grade body analysis.</p>
		<p class="wh-lead">An InBody-style body composition scan that gives you real data about your body — not just weight. Use it to set a baseline, track progress, or inform your provider-guided wellness plan.</p>
		<div class="wh-btn-row">
			<a class="wh-btn wh-btn--primary" href="/demos/premium-wellness-clinic/new-clients">Book a Scan &rarr;</a>
			<a class="wh-btn wh-btn--secondary" href="/demos/premium-wellness-clinic/memberships">View Memberships</a>
		</div>
	</div>
	<div class="wh-container sp-facts">
		<div class="sp-facts__strip">
			<div class="sp-facts__item"><span class="sp-facts__label">Duration</span><span class="sp-facts__value">15–20 min</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Best for</span><span class="sp-facts__value">Progress tracking</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Consultation</span><span class="sp-facts__value">Not required</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Starting at</span><span class="sp-facts__value">$75</span></div>
			<div class="sp-facts__item"><span class="sp-facts__label">Recommended</span><span class="sp-facts__value">Monthly or quarterly</span></div>
		</div>
	</div>
</section>

<!-- ═══ Why People Book — default bg, numbered list ═══ -->
<section class="wh-section sp-benefits">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">Benefits</p>
			<h2>Why people book a body composition scan</h2>
		</div>
		<div class="sp-benefits__list">
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">01</span>
				<div>
					<h3>See beyond the scale</h3>
					<p>Weight alone does not tell the full story. A body scan separates muscle from fat, water from lean mass.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">02</span>
				<div>
					<h3>Track real progress</h3>
					<p>Monthly or quarterly scans show whether your program is building muscle, reducing fat, or improving balance.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">03</span>
				<div>
					<h3>Set a wellness baseline</h3>
					<p>First-time clients use body scans to establish a starting point before beginning a new wellness or weight plan.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">04</span>
				<div>
					<h3>Inform your provider</h3>
					<p>Your provider can use body scan data alongside labs to build or adjust your personalized wellness plan.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">05</span>
				<div>
					<h3>Measure metabolic rate</h3>
					<p>Understand your basal metabolic rate to inform nutrition guidance and caloric targets.</p>
				</div>
			</div>
			<div class="sp-benefits__item">
				<span class="sp-benefits__num">06</span>
				<div>
					<h3>Monitor water balance</h3>
					<p>Track hydration and water distribution between intracellular and extracellular compartments.</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ What It Is — default bg, editorial prose ═══ -->
<section class="wh-section sp-what">
	<div class="wh-container sp-what__inner">
		<h2>What is a body composition scan?</h2>
		<p>A body composition scan uses bioelectrical impedance analysis (BIA) to measure how your body is composed — breaking down total weight into muscle mass, body fat, water balance, and more.</p>
		<p>At Lumen Health House, we use an InBody-style clinical-grade scanner. You stand on the device and hold the hand electrodes for approximately 60 seconds. The scan is non-invasive, painless, and fully clothed.</p>
		<p>Your results print immediately and include skeletal muscle mass, body fat percentage, visceral fat level, basal metabolic rate, water balance, and segmental lean analysis. A team member reviews your results with you and can connect you with a provider for deeper interpretation.</p>
	</div>
</section>

<!-- ═══ Results Dashboard Visual — surface bg ═══ -->
<section class="wh-section wh-section--surface sp-dashboard">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">Sample Results</p>
			<h2>What your scan report looks like.</h2>
		</div>
		<div class="sp-dashboard__panel">
			<div class="sp-dashboard__header">
				<span class="sp-dashboard__title">Lumen Body Composition Report</span>
				<span class="sp-dashboard__meta">Sample · Age 38 · Female</span>
			</div>
			<div class="sp-dashboard__grid">
				<div class="sp-dashboard__metric">
					<span class="sp-dashboard__label">Lean Mass</span>
					<span class="sp-dashboard__value">104.2 lb</span>
					<span class="sp-dashboard__bar" style="width:62%"></span>
				</div>
				<div class="sp-dashboard__metric">
					<span class="sp-dashboard__label">Body Fat</span>
					<span class="sp-dashboard__value">28.4%</span>
					<span class="sp-dashboard__bar" style="width:48%"></span>
				</div>
				<div class="sp-dashboard__metric">
					<span class="sp-dashboard__label">Visceral Fat</span>
					<span class="sp-dashboard__value">Level 6</span>
					<span class="sp-dashboard__bar" style="width:40%"></span>
				</div>
				<div class="sp-dashboard__metric">
					<span class="sp-dashboard__label">Hydration</span>
					<span class="sp-dashboard__value">56.8%</span>
					<span class="sp-dashboard__bar" style="width:57%"></span>
				</div>
				<div class="sp-dashboard__metric">
					<span class="sp-dashboard__label">BMR</span>
					<span class="sp-dashboard__value">1,420 kcal</span>
					<span class="sp-dashboard__bar" style="width:65%"></span>
				</div>
				<div class="sp-dashboard__metric">
					<span class="sp-dashboard__label">Phase Angle</span>
					<span class="sp-dashboard__value">5.8°</span>
					<span class="sp-dashboard__bar" style="width:55%"></span>
				</div>
			</div>
			<div class="sp-dashboard__footer">
				Baseline scan — follow-up recommended in 90 days
			</div>
		</div>
		<p class="sp-dashboard__disclaimer">Sample visual for demonstration only. Results vary and should be interpreted with provider guidance.</p>
	</div>
</section>

<!-- ═══ Who It's For — surface bg, two-column ═══ -->
<section class="wh-section wh-section--surface sp-who">
	<div class="wh-container sp-who__split">
		<h2>Who is a body composition scan for?</h2>
		<div class="sp-who__col">
			<h3>Goal-based</h3>
			<ul>
				<li>Track progress during a weight loss or fitness program</li>
				<li>Establish a health baseline before starting wellness services</li>
				<li>Monitor body composition changes over time</li>
				<li>Support athletic performance and training goals</li>
				<li>Pair with provider consultations for data-driven planning</li>
			</ul>
		</div>
		<div class="sp-who__col">
			<h3>Symptom-based</h3>
			<ul>
				<li>Weight changes that do not match effort or diet</li>
				<li>Uncertainty about body fat vs. muscle ratio</li>
				<li>Slow metabolism or difficulty losing weight</li>
				<li>Water retention or swelling concerns</li>
				<li>Need for objective data to discuss with a provider</li>
			</ul>
		</div>
	</div>
</section>

<!-- ═══ How It Works — dark bg, vertical timeline ═══ -->
<section class="wh-section wh-section--dark sp-process">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">The Process</p>
			<h2>How a body composition scan works</h2>
		</div>
		<ol class="sp-process__steps">
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Book your scan</h3><p>Schedule online or walk in. No consultation or preparation required for a standalone scan.</p></div>
			</li>
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Step on the scanner</h3><p>Stand on the device barefoot and hold the hand electrodes. The scan takes approximately 60 seconds.</p></div>
			</li>
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Review your results</h3><p>Your detailed report prints immediately. A team member walks you through your numbers.</p></div>
			</li>
			<li class="sp-process__step">
				<div class="sp-process__dot" aria-hidden="true"></div>
				<div class="sp-process__body"><h3>Use your data</h3><p>Use scan results to guide your wellness plan, track changes at follow-up scans, or share with your provider.</p></div>
			</li>
		</ol>
	</div>
</section>

<!-- ═══ What to Expect — default bg, simple sections ═══ -->
<section class="wh-section sp-expect">
	<div class="wh-container">
		<h2>What to expect</h2>
		<div class="sp-expect__phases">
			<div class="sp-expect__phase">
				<h3>Before</h3>
				<p>Avoid eating or exercising 2 hours before for best accuracy. Wear light clothing. Remove shoes and socks for the scan.</p>
			</div>
			<div class="sp-expect__phase">
				<h3>During</h3>
				<p>Stand still on the scanner and hold the hand electrodes. The scan is painless, takes about 60 seconds, and you remain fully clothed.</p>
			</div>
			<div class="sp-expect__phase">
				<h3>After</h3>
				<p>Receive your printed report immediately. A team member explains your results. If you want deeper clinical interpretation, we can connect you with a provider.</p>
			</div>
		</div>
	</div>
</section>

<!-- ═══ Scan Guidance — sage bg ═══ -->
<section class="wh-section wh-section--sage sp-safety">
	<div class="wh-container">
		<div class="sp-safety__split">
			<div class="sp-safety__left">
				<p class="wh-eyebrow">Scan Guidance</p>
				<h2>Understanding Your Results</h2>
			</div>
			<div class="sp-safety__right">
				<p>Body composition scan results are educational and designed to give you a clearer picture of where you are today. They are not a medical diagnosis and should be interpreted alongside your goals, health history, and overall context.</p>
				<p>For the most useful interpretation, we recommend pairing your scan with a provider review. Your provider can explain what the numbers mean for you specifically and help you set realistic, measurable goals.</p>
				<p>Body composition data can change based on hydration, time of day, recent exercise, and other factors. Consistent scan conditions improve comparability over time. No specific outcomes are guaranteed.</p>
			</div>
		</div>
	</div>
</section>

<!-- ═══ Packages — default bg, bordered cards ═══ -->
<section class="wh-section sp-packages">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">Pricing & Memberships</p>
			<h2>Make body scans part of your progress tracking</h2>
		</div>
		<div class="sp-packages__grid">
			<div class="wh-card sp-packages__card">
				<h3>Single Scan</h3>
				<p class="sp-packages__price">$75</p>
				<p>Walk in or book online. No membership required.</p>
			</div>
			<div class="wh-card sp-packages__card">
				<h3>Recover Membership</h3>
				<p class="sp-packages__price">$149/mo</p>
				<p>Includes 1 body composition scan per quarter plus recovery therapy credits.</p>
				<a class="wh-text-link sp-packages__link" href="/demos/premium-wellness-clinic/memberships">View Details &rarr;</a>
			</div>
			<div class="wh-card sp-packages__card">
				<h3>Scan + Wellness Review</h3>
				<p class="sp-packages__price">$195</p>
				<p>Body composition scan plus a 30-minute provider review to interpret results and build a plan.</p>
			</div>
		</div>
	</div>
</section>

<!-- ═══ Related Services — surface bg, row list ═══ -->
<section class="wh-section wh-section--surface sp-related">
	<div class="wh-container">
		<div class="wh-section-header">
			<p class="wh-eyebrow">Related Services</p>
			<h2>Commonly paired with body composition scans</h2>
		</div>
		<div class="sp-related__list">
			<a class="sp-related__row" href="/demos/premium-wellness-clinic/services/medical-weight-loss">
				<h3>Medical Weight Loss</h3>
				<p>Use body scan data to track progress and adjust your medical weight loss plan.</p>
				<span class="sp-related__arrow" aria-hidden="true">&rarr;</span>
			</a>
			<a class="sp-related__row" href="/demos/premium-wellness-clinic/services">
				<h3>Wellness Consultation</h3>
				<p>Combine a body scan with a provider consult for a comprehensive wellness baseline.</p>
				<span class="sp-related__arrow" aria-hidden="true">&rarr;</span>
			</a>
			<a class="sp-related__row" href="/demos/premium-wellness-clinic/services">
				<h3>Progress Tracking</h3>
				<p>Schedule follow-up scans to monitor changes and keep your plan on track.</p>
				<span class="sp-related__arrow" aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</section>

<!-- ═══ FAQ — split layout ═══ -->
<section class="wh-section sp-faq">
	<div class="wh-container sp-faq__split">
		<div class="sp-faq__left">
			<p class="wh-eyebrow">Questions</p>
			<h2>Body Composition Scan FAQ</h2>
		</div>
		<div class="wh-faq__list">
			<details class="wh-faq__item">
				<summary><span>What does the scan measure?</span></summary>
				<p>The scan measures skeletal muscle mass, body fat percentage, visceral fat level, basal metabolic rate, total body water, intracellular and extracellular water balance, and segmental lean analysis (arms, legs, trunk).</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>How accurate is it?</span></summary>
				<p>InBody-style BIA scanners are among the most accurate non-invasive body composition tools available commercially. They are widely used in clinical, research, and fitness settings. For best consistency, scan under similar conditions each time.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>How should I prepare?</span></summary>
				<p>For best accuracy, avoid eating or drinking large amounts of fluids 2 hours before your scan. Avoid intense exercise beforehand. Wear light clothing and remove shoes, socks, and heavy jewelry.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>How often should I scan?</span></summary>
				<p>Monthly scans work well for clients actively working toward a goal. Quarterly scans are great for general wellness tracking. Your provider can recommend a schedule based on your plan.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>Do I need a membership to get a scan?</span></summary>
				<p>No. Body composition scans are available to anyone as a single session. Memberships include scans at reduced or no additional cost depending on your tier.</p>
			</details>
			<details class="wh-faq__item">
				<summary><span>Can I get a provider to review my results?</span></summary>
				<p>Yes. You can book a standalone scan and add a provider review, or combine it with a wellness consultation for deeper interpretation and planning.</p>
			</details>
		</div>
	</div>
</section>

<!-- ═══ Final CTA — dark, centered ═══ -->
<section class="wh-section wh-section--dark sp-final">
	<div class="wh-container" style="text-align:center; max-width:640px;">
		<h2>Ready to see your body composition data?</h2>
		<p class="wh-lead" style="margin-inline:auto;">No consultation required. Book a scan online or walk in during clinic hours.</p>
		<div class="wh-btn-row" style="justify-content:center;">
			<a class="wh-btn wh-btn--primary" href="/demos/premium-wellness-clinic/new-clients">Book a Scan &rarr;</a>
			<a class="wh-btn wh-btn--secondary" href="/demos/premium-wellness-clinic/new-clients">Talk to a Provider</a>
		</div>
	</div>
</section>

</WellnessLayout>

<style>
/* ═══════════════════════════════════════════════════════
   SERVICE PAGE — Restrained Clinical Premium
   ═══════════════════════════════════════════════════════ */

/* ─── Hero ─── */
.sp-hero { padding-top: clamp(5rem, 10vw, 9rem); padding-bottom: clamp(3rem, 6vw, 5rem); }
.sp-hero h1 { max-width: none; margin-bottom: 0.5rem; }
.sp-hero__headline { font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem); font-weight: 400; max-width: 620px; margin-bottom: 0.75rem; }

/* ─── Quick Facts Strip ─── */
.sp-facts { margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); }
.sp-facts__strip { display: flex; gap: 2.5rem; flex-wrap: wrap; }
.sp-facts__item { display: flex; flex-direction: column; gap: 0.2rem; }
.sp-facts__label { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--wh-sage); }
.sp-facts__value { font-size: 0.88rem; font-weight: 600; color: var(--wh-white); }

/* ─── Benefits: numbered list ─── */
.sp-benefits__list { display: flex; flex-direction: column; }
.sp-benefits__item { display: flex; gap: 1rem; padding: 1.15rem 0; border-bottom: 1px solid var(--wh-border); }
.sp-benefits__item:first-child { border-top: 1px solid var(--wh-border); }
.sp-benefits__num { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; color: var(--wh-sage); padding-top: 0.15rem; flex-shrink: 0; min-width: 1.5rem; }
.sp-benefits__item h3 { font-size: 0.9rem; margin-bottom: 0.2rem; }
.sp-benefits__item p { font-size: 0.82rem; color: var(--wh-muted); }

/* ─── What It Is ─── */
.sp-what__inner { max-width: 680px; }
.sp-what__inner p { font-size: 0.95rem; line-height: 1.7; color: var(--wh-text); }

/* ─── Results Dashboard ─── */
.sp-dashboard__panel { background: var(--wh-ink); border-radius: var(--wh-radius); padding: 2rem; margin-top: 1.5rem; }
.sp-dashboard__header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 1.25rem; margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
.sp-dashboard__title { font-size: 0.75rem; font-weight: 600; color: var(--wh-white); letter-spacing: 0.02em; }
.sp-dashboard__meta { font-size: 0.65rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.08em; }
.sp-dashboard__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.75rem; }
.sp-dashboard__metric { display: flex; flex-direction: column; gap: 0.35rem; }
.sp-dashboard__label { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); }
.sp-dashboard__value { font-size: 1.5rem; font-weight: 700; color: var(--wh-white); letter-spacing: -0.02em; }
.sp-dashboard__bar { display: block; height: 4px; border-radius: 2px; background: var(--wh-sage); margin-top: 0.25rem; }
.sp-dashboard__footer { margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid rgba(255,255,255,0.08); font-size: 0.7rem; color: rgba(255,255,255,0.4); text-align: center; }
.sp-dashboard__disclaimer { font-size: 0.75rem; color: var(--wh-muted); margin-top: 1rem; text-align: center; }
@media (max-width: 600px) { .sp-dashboard__grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; } .sp-dashboard__header { flex-direction: column; align-items: flex-start; gap: 0.35rem; } }

/* ─── Who It's For ─── */
.sp-who__split { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); }
.sp-who__split > h2 { grid-column: 1 / -1; }
.sp-who__col h3 { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--wh-sage); margin-bottom: 0.75rem; }
.sp-who__col ul { padding-left: 1.1rem; margin: 0; }
.sp-who__col li { font-size: 0.88rem; color: var(--wh-muted); margin-bottom: 0.5rem; line-height: 1.55; }
@media (max-width: 520px) { .sp-who__split { grid-template-columns: 1fr; } }

/* ─── Process: vertical timeline with dots ─── */
.sp-process__steps { list-style: none; margin: 0; padding: 0; max-width: 560px; }
.sp-process__step { display: flex; gap: 1.5rem; position: relative; padding-bottom: 2.5rem; }
.sp-process__step:last-child { padding-bottom: 0; }
.sp-process__dot { position: relative; width: 10px; flex-shrink: 0; padding-top: 0.35rem; }
.sp-process__dot::before { content: ''; display: block; width: 10px; height: 10px; border-radius: 50%; border: 2px solid var(--wh-sage); background: var(--wh-ink); }
.sp-process__step:not(:last-child) .sp-process__dot::after { content: ''; position: absolute; top: 14px; left: 4.5px; width: 1px; height: calc(100% + 2.5rem - 14px); background: rgba(255,255,255,0.1); }
.sp-process__body h3 { font-size: 0.95rem; color: var(--wh-white); margin-bottom: 0.3rem; }
.sp-process__body p { font-size: 0.85rem; color: rgba(255,255,255,0.5); }

/* ─── What to Expect ─── */
.sp-expect__phases { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 1.5rem; }
.sp-expect__phase h3 { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--wh-sage); margin-bottom: 0.75rem; }
.sp-expect__phase p { font-size: 0.88rem; color: var(--wh-muted); line-height: 1.65; }
@media (max-width: 600px) { .sp-expect__phases { grid-template-columns: 1fr; gap: 1.5rem; } }

/* ─── Safety / Scan Guidance: sage bg, split layout ─── */
.sp-safety__split { display: grid; grid-template-columns: 1fr 1.3fr; gap: clamp(3rem, 5vw, 5rem); align-items: start; }
.sp-safety__left h2 { max-width: 320px; }
.sp-safety__right p { font-size: 0.92rem; color: var(--wh-text); line-height: 1.7; margin-bottom: 0.75rem; }
@media (max-width: 700px) { .sp-safety__split { grid-template-columns: 1fr; } }

/* ─── Packages: bordered cards ─── */
.sp-packages__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
.sp-packages__card { padding: 2rem; display: flex; flex-direction: column; }
.sp-packages__card h3 { font-size: 1rem; margin-bottom: 0.25rem; }
.sp-packages__price { display: block; font-size: 1.5rem; font-weight: 700; color: var(--wh-ink); margin-bottom: 0.75rem; letter-spacing: -0.02em; }
