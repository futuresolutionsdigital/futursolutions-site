---
import WellnessLayout from '../../../layouts/WellnessLayout.astro';
import { resources, brand } from '../../../data/wellness';

const categories = [
	'Energy & Fatigue',
	'Weight & Metabolism',
	'Recovery & Performance',
	'Hormones & Vitality',
	'IV Therapy',
	'Body Composition',
	'New Client Guides',
	'Safety & FAQs',
];
---

<WellnessLayout title="Wellness Resources — Lumen Health House" description="Explore articles and guides on IV therapy, recovery, weight loss, hormones, body composition, and more — written to help you make informed wellness decisions.">

<!-- ─── Hero ─── -->
<section class="wh-section wh-section--dark rs-hero">
	<div class="wh-container">
		<p class="wh-eyebrow">Learn Before You Book</p>
		<h1>Wellness Resources</h1>
		<p class="wh-lead">Understand your options, what to expect from each service, and which treatments may be right for your goals — before you schedule your first visit.</p>
	</div>
</section>

<!-- ─── Category Filter: inline links on default bg ─── -->
<section class="rs-categories">
	<div class="wh-container">
		<div class="rs-categories__strip">
			<span class="rs-categories__label">Browse by topic:</span>
			{categories.map((cat) => (
				<span class="rs-categories__link">{cat}</span>
			))}
		</div>
	</div>
</section>

<!-- ─── Article List: clean row list (like homepage) ─── -->
<section class="wh-section rs-articles">
	<div class="wh-container">
		<div class="rs-articles__list">
			{resources.map((r) => (
				<a class="rs-articles__row" href={r.href}>
					<span class="rs-articles__cat">{r.category}</span>
					<span class="rs-articles__title">{r.title}</span>
					<span class="rs-articles__arrow" aria-hidden="true">&rarr;</span>
				</a>
			))}
		</div>
	</div>
</section>

<!-- ─── CTA ─── -->
<section class="wh-section wh-section--dark rs-final">
	<div class="wh-container">
		<p class="wh-eyebrow">Have Questions?</p>
		<h2>Our team is here to help you find the right starting point.</h2>
		<p class="wh-lead">Whether you have read every article or are just beginning to explore, a consultation is the best way to get personalized guidance.</p>
		<div class="wh-btn-row">
			<a class="wh-btn wh-btn--primary" href="/demos/premium-wellness-clinic/new-clients">Book a Consultation</a>
			<a class="wh-btn wh-btn--secondary" href="/demos/premium-wellness-clinic/contact">Contact Us</a>
		</div>
	</div>
</section>

<!-- ─── Demo Disclaimer ─── -->
<section class="wh-section rs-disclaimer-section">
	<div class="wh-container">
		<p class="rs-disclaimer">{brand.disclaimer}</p>
	</div>
</section>

</WellnessLayout>

<style>
/* ═══════════════════════════════════════════════════════
   RESOURCES — Restrained Clinical Premium
   ═══════════════════════════════════════════════════════ */

/* ─── Hero ─── */
.rs-hero { padding-top: clamp(5rem, 10vw, 9rem); padding-bottom: clamp(3rem, 6vw, 5rem); }
.rs-hero h1 { max-width: 520px; }
.rs-hero .wh-lead { max-width: 520px; }

/* ─── Category Filter: inline links ─── */
.rs-categories { padding-block: 1.5rem; border-bottom: 1px solid var(--wh-border); }
.rs-categories__strip { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem 1rem; }
.rs-categories__label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--wh-muted); margin-right: 0.5rem; }
.rs-categories__link { font-size: 0.78rem; font-weight: 500; color: var(--wh-sage); cursor: default; transition: color var(--wh-transition); }
.rs-categories__link:hover { color: var(--wh-ink); }

/* ─── Article List: clean row list ─── */
.rs-articles__list { display: flex; flex-direction: column; }
.rs-articles__row { display: flex; align-items: center; gap: 1rem; padding: 0.9rem 0; border-bottom: 1px solid var(--wh-border); transition: padding-left var(--wh-transition); }
.rs-articles__row:first-child { border-top: 1px solid var(--wh-border); }
.rs-articles__row:hover { padding-left: 0.35rem; }
.rs-articles__cat { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--wh-sage); min-width: 140px; flex-shrink: 0; }
.rs-articles__title { font-size: 0.88rem; font-weight: 500; color: var(--wh-ink); flex: 1; }
.rs-articles__arrow { color: var(--wh-muted); font-size: 0.85rem; }
@media (max-width: 600px) { .rs-articles__row { flex-wrap: wrap; } .rs-articles__cat { min-width: auto; width: 100%; } }

/* ─── Final CTA ─── */
.rs-final h2 { max-width: 560px; }

/* ─── Disclaimer ─── */
.rs-disclaimer-section { padding-top: 0; }
.rs-disclaimer { font-size: 0.72rem; color: var(--wh-muted); font-style: italic; max-width: 640px; }
</style>
