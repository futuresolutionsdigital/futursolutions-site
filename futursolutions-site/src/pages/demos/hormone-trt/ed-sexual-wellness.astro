---
import VantageLayout from '../../../layouts/VantageLayout.astro';
import { brand } from '../../../data/vantage';
---

<VantageLayout title="ED & Sexual Wellness — VANTAGE Men's Health" description="Private, provider-led treatment for erectile dysfunction, low libido, and sexual health concerns.">

<!-- ═══ HERO ═══ -->
<section class="vt-s vt-s--black ed-hero">
	<div class="vt-w ed-hero__layout">
		<div class="ed-hero__copy">
			<span class="vt-e">ED &amp; Sexual Wellness</span>
			<h1>Private, provider-led sexual health care for men.</h1>
			<p class="vt-sub">Erectile dysfunction and low libido are medical issues — not personal failures. We evaluate the underlying causes, discuss treatment options, and provide discreet, ongoing care.</p>
			<div class="vt-btn-row">
				<a class="vt-btn vt-btn--red" href="/demos/hormone-trt/assessment">Take the Assessment &rarr;</a>
				<a class="vt-btn vt-btn--dark" href="/demos/hormone-trt/book-consultation">Book Consultation</a>
			</div>
		</div>
		<div class="ed-hero__card" aria-hidden="true">
			<div class="ed-hero__card-hdr">Prevalence Data</div>
			<div class="ed-hero__card-row"><span class="ed-hero__card-val">52%</span><span class="ed-hero__card-label">of men experience some form of ED</span></div>
			<div class="ed-hero__card-row"><span class="ed-hero__card-val">70%</span><span class="ed-hero__card-label">of ED cases have a physical cause</span></div>
			<div class="ed-hero__card-row"><span class="ed-hero__card-val">85%+</span><span class="ed-hero__card-label">may respond to appropriate treatment</span></div>
		</div>
	</div>
</section>

<!-- ═══ PRIVACY & DISCRETION BAND ═══ -->
<div class="vt-s vt-s--carbon ed-privacy-band">
	<div class="vt-w">
		<div class="ed-shield">
			<span class="ed-shield__icon">&#9670;</span>
			<div>
				<span class="vt-e">Private Care</span>
				<p class="ed-shield__text">All sexual health consultations, evaluations, and treatments are handled with complete confidentiality. No shared records. No judgment. Provider-patient discretion at every step.</p>
			</div>
		</div>
	</div>
</div>

<!-- ═══ A MEDICAL ISSUE — stacked rows with numbers + red accent ═══ -->
<section class="vt-s vt-s--charcoal ed-medical">
	<div class="vt-w">
		<span class="vt-e">A Medical Issue</span>
		<h2>ED affects over 50% of men between 40 and 70. It's far more common than most realize.</h2>
		<p class="vt-sub">Erectile dysfunction is not about willpower or attraction. It can be caused by hormonal imbalances, vascular issues, medication side effects, stress, or a combination of factors. A proper evaluation can help identify the cause.</p>
		<p class="ed-medical__body">At VANTAGE, your sexual health is treated with the same clinical rigor and discretion as any other medical concern. No judgment. No sales pressure. Just data-driven care.</p>
	</div>
</section>

<!-- ═══ TREATMENT APPROACH — stacked rows with red markers ═══ -->
<section class="vt-s vt-s--carbon ed-approach">
	<div class="vt-w">
		<span class="vt-e">Treatment Approach</span>
		<h2>Comprehensive evaluation, personalized options</h2>
		<p class="vt-sub">We don't prescribe without understanding. Your provider evaluates potential causes before recommending a treatment plan.</p>
		<div class="ed-approach__list">
			<div class="ed-approach__row">
				<span class="ed-approach__num">01</span>
				<span class="vt-redline"></span>
				<div class="ed-approach__content">
					<h3>Hormone evaluation</h3>
					<p>Low testosterone is a common contributor to ED and reduced libido. Labs help determine whether hormone optimization may be beneficial.</p>
				</div>
			</div>
			<div class="ed-approach__row">
				<span class="ed-approach__num">02</span>
				<span class="vt-redline"></span>
				<div class="ed-approach__content">
					<h3>Oral medications</h3>
					<p>PDE5 inhibitors (sildenafil, tadalafil) can be evaluated as part of a broader treatment strategy when clinically appropriate.</p>
				</div>
			</div>
			<div class="ed-approach__row">
				<span class="ed-approach__num">03</span>
				<span class="vt-redline"></span>
				<div class="ed-approach__content">
					<h3>Combination protocols</h3>
					<p>Some men benefit from addressing both hormonal and vascular factors simultaneously, under close provider supervision.</p>
				</div>
			</div>
			<div class="ed-approach__row">
				<span class="ed-approach__num">04</span>
				<span class="vt-redline"></span>
				<div class="ed-approach__content">
					<h3>Lifestyle & vascular health</h3>
					<p>Cardiovascular fitness, sleep, and metabolic health all influence erectile function. Your provider may recommend targeted lifestyle modifications.</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ PRIVACY — bordered grid items ═══ -->
<section class="vt-s vt-s--charcoal ed-privacy">
	<div class="vt-w">
		<span class="vt-e">Your Privacy</span>
		<h2>Discreet care from start to finish</h2>
		<p class="vt-sub">We understand that sexual health is deeply personal. Every aspect of your care at VANTAGE is handled with complete confidentiality.</p>
		<div class="ed-privacy__grid">
			<div class="ed-privacy__item"><span class="ed-privacy__marker"></span><span>Private consultations — in-person or telehealth</span></div>
			<div class="ed-privacy__item"><span class="ed-privacy__marker"></span><span>Discreet communication and billing</span></div>
			<div class="ed-privacy__item"><span class="ed-privacy__marker"></span><span>No shared waiting rooms for sexual health visits</span></div>
			<div class="ed-privacy__item"><span class="ed-privacy__marker"></span><span>Provider-patient confidentiality upheld at every step</span></div>
			<div class="ed-privacy__item"><span class="ed-privacy__marker"></span><span>Secure patient portal for messaging and records</span></div>
		</div>
	</div>
</section>

<!-- ═══ FAQ — accordion ═══ -->
<section class="vt-s vt-s--black ed-faq">
	<div class="vt-w">
		<span class="vt-e">Common Questions</span>
		<h2>Frequently asked questions about ED treatment</h2>
		<div class="ed-faq__list">
			<details class="ed-faq__item">
				<summary>Do I need labs before treatment?</summary>
				<p>Yes. Labs help identify hormonal, metabolic, or vascular contributors to ED. Treatment is most effective when guided by data.</p>
			</details>
			<details class="ed-faq__item">
				<summary>Is this just a prescription service?</summary>
				<p>No. We provide comprehensive evaluations. Medications are one tool among many, and are only recommended when clinically appropriate.</p>
			</details>
			<details class="ed-faq__item">
				<summary>Can low testosterone cause ED?</summary>
				<p>It can be a contributing factor. Many men with ED also have suboptimal testosterone levels. Both can be evaluated and addressed together.</p>
			</details>
			<details class="ed-faq__item">
				<summary>Will my partner know?</summary>
				<p>Your care is confidential. We do not share information with anyone unless you provide written consent.</p>
			</details>
		</div>
	</div>
</section>

<!-- ═══ FINAL CTA — red background panel ═══ -->
<section class="ed-final">
	<div class="vt-w ed-final__inner">
		<span class="vt-e">Take the Next Step</span>
		<h2>Private evaluation. Real answers. No judgment.</h2>
		<p class="vt-sub">Start with a confidential assessment and let your provider guide you toward the right approach.</p>
		<div class="vt-btn-row" style="margin-top:1.5rem;">
			<a class="vt-btn vt-btn--red" href="/demos/hormone-trt/assessment">Take the Assessment &rarr;</a>
			<a class="vt-btn vt-btn--dark" href="/demos/hormone-trt/book-consultation">Book Consultation</a>
		</div>
	</div>
</section>

<!-- ═══ DISCLAIMER ═══ -->
<div class="vt-s--black" style="padding:0 0 2rem;">
	<div class="vt-w">
		<p class="ed-disc">{brand.disclaimer}</p>
	</div>
</div>

</VantageLayout>

<style>
/* ═══ HERO — dark compact with prevalence data card ═══ */
.ed-hero { padding: clamp(5rem, 10vw, 8rem) 0 clamp(3rem, 6vw, 4rem); position: relative; overflow: hidden; }
.ed-hero__layout { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: clamp(2rem, 4vw, 4rem); align-items: center; }
.ed-hero__copy h1 { max-width: 620px; }
.ed-hero__copy .vt-sub { margin-bottom: 1.5rem; }
.ed-hero__card { background: var(--vt-charcoal); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--vt-r); overflow: hidden; border-top: 3px solid var(--vt-red); }
.ed-hero__card-hdr { padding: 0.75rem 1rem; font-size: 0.58rem; font-weight: 900; letter-spacing: 0.16em; text-transform: uppercase; color: var(--vt-white); border-bottom: 1px solid rgba(255,255,255,0.06); }
.ed-hero__card-row { display: flex; align-items: baseline; gap: 0.75rem; padding: 0.75rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.04); }
.ed-hero__card-row:last-child { border-bottom: none; }
.ed-hero__card-val { font-size: 1.1rem; font-weight: 900; color: var(--vt-red); min-width: 3.5rem; }
.ed-hero__card-label { font-size: 0.72rem; color: rgba(244,239,231,0.5); }
@media (max-width: 768px) { .ed-hero__layout { grid-template-columns: 1fr; } .ed-hero__card { max-width: 360px; } }

/* ═══ A MEDICAL ISSUE ═══ */
.ed-medical h2 { max-width: 600px; margin-bottom: 0.5rem; }
.ed-medical .vt-sub { margin-bottom: 0.75rem; }
.ed-medical__body { font-size: 0.82rem; color: rgba(244,239,231,0.5); line-height: 1.55; max-width: 560px; }

/* ═══ TREATMENT APPROACH — stacked numbered rows ═══ */
.ed-approach h2 { max-width: 480px; margin-bottom: 0.5rem; }
.ed-approach .vt-sub { margin-bottom: 2rem; }
.ed-approach__list { display: flex; flex-direction: column; }
.ed-approach__row { display: flex; align-items: flex-start; gap: 1rem; padding: 1.25rem 0; border-bottom: 1px solid var(--vt-border); }
.ed-approach__row:last-child { border-bottom: none; }
.ed-approach__num { flex-shrink: 0; font-size: 0.6rem; font-weight: 900; letter-spacing: 0.1em; color: var(--vt-red); padding-top: 0.15rem; min-width: 1.8rem; }
.ed-approach__row .vt-redline { margin-top: 0.55rem; flex-shrink: 0; }
.ed-approach__content h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.2rem; }
.ed-approach__content p { font-size: 0.78rem; color: rgba(244,239,231,0.5); line-height: 1.55; }

/* ═══ PRIVACY — bordered grid ═══ */
.ed-privacy h2 { margin-bottom: 0.5rem; }
.ed-privacy .vt-sub { margin-bottom: 2rem; }
.ed-privacy__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(255,255,255,0.04); border-radius: var(--vt-r); overflow: hidden; }
.ed-privacy__item { display: flex; align-items: center; gap: 0.65rem; padding: 0.85rem 1.25rem; font-size: 0.78rem; color: rgba(244,239,231,0.55); background: var(--vt-carbon); }
.ed-privacy__marker { flex-shrink: 0; width: 6px; height: 6px; border-radius: 50%; background: var(--vt-red); }
.ed-privacy__item:last-child:nth-child(odd) { grid-column: 1 / -1; }
@media (max-width: 600px) { .ed-privacy__grid { grid-template-columns: 1fr; } .ed-privacy__item:last-child:nth-child(odd) { grid-column: auto; } }

/* ═══ FAQ — single-column accordion ═══ */
.ed-faq h2 { margin-bottom: 2rem; }
.ed-faq__list { max-width: 680px; }
.ed-faq__item { border-bottom: 1px solid rgba(255,255,255,0.06); }
.ed-faq__item summary { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 0; font-size: 0.85rem; font-weight: 600; color: var(--vt-bone); cursor: pointer; list-style: none; }
.ed-faq__item summary::-webkit-details-marker { display: none; }
.ed-faq__item summary::after { content: '+'; font-size: 1rem; font-weight: 400; color: var(--vt-red); }
.ed-faq__item[open] summary::after { content: '\2212'; }
.ed-faq__item p { font-size: 0.8rem; color: rgba(244,239,231,0.5); line-height: 1.6; padding-bottom: 1rem; max-width: 560px; }

/* ═══ FINAL CTA — red background panel ═══ */
.ed-final { background: var(--vt-red); padding: clamp(3rem, 6vw, 5rem) 0; position: relative; overflow: hidden; }
.ed-final::before { content: ''; position: absolute; top: -30%; right: -5%; width: 40%; height: 160%; background: rgba(0,0,0,0.08); transform: skewX(-12deg); pointer-events: none; }
.ed-final__inner { position: relative; z-index: 1; max-width: 560px; }
.ed-final h2 { color: var(--vt-white); }
.ed-final .vt-e { color: rgba(255,255,255,0.5); }
.ed-final .vt-sub { color: rgba(255,255,255,0.7); }
.ed-final .vt-btn--red { background: var(--vt-white); color: var(--vt-red); border-color: var(--vt-white); }
.ed-final .vt-btn--red:hover { background: var(--vt-bone); }
.ed-final .vt-btn--dark { background: transparent; color: var(--vt-white); border-color: rgba(255,255,255,0.3); }
.ed-final .vt-btn--dark:hover { border-color: var(--vt-white); }

/* ═══ PRIVACY & DISCRETION BAND ═══ */
.ed-shield { display: flex; gap: 1.25rem; align-items: start; padding: 1.5rem; border: 1px solid var(--vt-border-red); border-radius: 3px; background: rgba(215,25,32,0.02); }
.ed-shield__icon { font-size: 1.1rem; color: var(--vt-red); flex-shrink: 0; margin-top: 0.15rem; }
.ed-shield__text { font-size: 0.8rem; color: rgba(244,239,231,0.5); line-height: 1.55; }

/* ═══ DISCLAIMER ═══ */
.ed-disc { font-size: 0.55rem; color: rgba(244,239,231,0.12); font-style: italic; max-width: 560px; }
</style>
