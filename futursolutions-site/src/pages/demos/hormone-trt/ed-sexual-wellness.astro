---
import VantageLayout from '../../../layouts/VantageLayout.astro';
import { brand } from '../../../data/vantage';
---

<VantageLayout title="ED & Sexual Wellness — VANTAGE Men's Health" description="Private, provider-led treatment for erectile dysfunction, low libido, and sexual health concerns.">

<!-- Hero -->
<section class="vt-section vt-section--dark ed-hero">
	<div class="vt-container">
		<p class="vt-eyebrow">ED & Sexual Wellness</p>
		<h1>Private, provider-led sexual health care for men.</h1>
		<p class="vt-lead">Erectile dysfunction and low libido are medical issues — not personal failures. We evaluate the underlying causes, discuss treatment options, and provide discreet, ongoing care.</p>
		<div class="vt-btn-row">
			<a class="vt-btn vt-btn--primary" href="/demos/hormone-trt/assessment">Take the Assessment &rarr;</a>
			<a class="vt-btn vt-btn--secondary" href="/demos/hormone-trt/book-consultation">Book Consultation</a>
		</div>
	</div>
</section>

<!-- This is a medical issue -->
<section class="vt-section vt-section--charcoal ed-reassurance">
	<div class="vt-container ed-reassurance__layout">
		<div class="ed-reassurance__text">
			<p class="vt-eyebrow">A Medical Issue</p>
			<h2>ED affects over 50% of men between 40 and 70. It's far more common than most realize.</h2>
			<p class="vt-lead">Erectile dysfunction is not about willpower or attraction. It can be caused by hormonal imbalances, vascular issues, medication side effects, stress, or a combination of factors. A proper evaluation can help identify the cause.</p>
			<p>At VANTAGE, your sexual health is treated with the same clinical rigor and discretion as any other medical concern. No judgment. No sales pressure. Just data-driven care.</p>
		</div>
		<div class="ed-reassurance__stats">
			<div class="ed-reassurance__stat">
				<span class="ed-reassurance__num">52%</span>
				<span class="ed-reassurance__label">of men experience some form of ED</span>
			</div>
			<div class="ed-reassurance__stat">
				<span class="ed-reassurance__num">70%</span>
				<span class="ed-reassurance__label">of ED cases have a physical cause</span>
			</div>
			<div class="ed-reassurance__stat">
				<span class="ed-reassurance__num">85%+</span>
				<span class="ed-reassurance__label">may respond to appropriate treatment</span>
			</div>
		</div>
	</div>
</section>

<!-- Treatment approach -->
<section class="vt-section vt-section--slate ed-approach">
	<div class="vt-container">
		<div class="vt-section-header">
			<p class="vt-eyebrow">Treatment Approach</p>
			<h2>Comprehensive evaluation, personalized options</h2>
			<p class="vt-lead">We don't prescribe without understanding. Your provider evaluates potential causes before recommending a treatment plan.</p>
		</div>
		<div class="ed-approach__grid">
			<div class="vt-card">
				<h3>Hormone evaluation</h3>
				<p>Low testosterone is a common contributor to ED and reduced libido. Labs help determine whether hormone optimization may be beneficial.</p>
			</div>
			<div class="vt-card">
				<h3>Oral medications</h3>
				<p>PDE5 inhibitors (sildenafil, tadalafil) can be evaluated as part of a broader treatment strategy when clinically appropriate.</p>
			</div>
			<div class="vt-card">
				<h3>Combination protocols</h3>
				<p>Some men benefit from addressing both hormonal and vascular factors simultaneously, under close provider supervision.</p>
			</div>
			<div class="vt-card">
				<h3>Lifestyle & vascular health</h3>
				<p>Cardiovascular fitness, sleep, and metabolic health all influence erectile function. Your provider may recommend targeted lifestyle modifications.</p>
			</div>
		</div>
	</div>
</section>

<!-- Privacy emphasis -->
<section class="vt-section vt-section--dark ed-privacy">
	<div class="vt-container ed-privacy__layout">
		<div>
			<p class="vt-eyebrow">Your Privacy</p>
			<h2>Discreet care from start to finish</h2>
			<p class="vt-lead">We understand that sexual health is deeply personal. Every aspect of your care at VANTAGE is handled with complete confidentiality.</p>
		</div>
		<ul class="ed-privacy__list">
			<li>Private consultations — in-person or telehealth</li>
			<li>Discreet communication and billing</li>
			<li>No shared waiting rooms for sexual health visits</li>
			<li>Provider-patient confidentiality upheld at every step</li>
			<li>Secure patient portal for messaging and records</li>
		</ul>
	</div>
</section>

<!-- FAQ -->
<section class="vt-section vt-section--charcoal ed-faq">
	<div class="vt-container">
		<div class="vt-section-header">
			<p class="vt-eyebrow">Common Questions</p>
			<h2>Frequently asked questions about ED treatment</h2>
		</div>
		<div class="ed-faq__list">
			<div class="ed-faq__item">
				<h3>Do I need labs before treatment?</h3>
				<p>Yes. Labs help identify hormonal, metabolic, or vascular contributors to ED. Treatment is most effective when guided by data.</p>
			</div>
			<div class="ed-faq__item">
				<h3>Is this just a prescription service?</h3>
				<p>No. We provide comprehensive evaluations. Medications are one tool among many, and are only recommended when clinically appropriate.</p>
			</div>
			<div class="ed-faq__item">
				<h3>Can low testosterone cause ED?</h3>
				<p>It can be a contributing factor. Many men with ED also have suboptimal testosterone levels. Both can be evaluated and addressed together.</p>
			</div>
			<div class="ed-faq__item">
				<h3>Will my partner know?</h3>
				<p>Your care is confidential. We do not share information with anyone unless you provide written consent.</p>
			</div>
		</div>
	</div>
</section>

<!-- CTA -->
<section class="vt-section vt-section--slate ed-cta">
	<div class="vt-container ed-cta__inner">
		<p class="vt-eyebrow">Take the Next Step</p>
		<h2>Private evaluation. Real answers. No judgment.</h2>
		<p class="vt-lead">Start with a confidential assessment and let your provider guide you toward the right approach.</p>
		<div class="vt-btn-row">
			<a class="vt-btn vt-btn--primary" href="/demos/hormone-trt/assessment">Take the Assessment &rarr;</a>
			<a class="vt-btn vt-btn--secondary" href="/demos/hormone-trt/book-consultation">Book Consultation</a>
		</div>
	</div>
</section>

<!-- Disclaimer -->
<section class="vt-section vt-section--dark ed-disclaimer">
	<div class="vt-container">
		<p class="ed-disclaimer__text">{brand.disclaimer}</p>
	</div>
</section>

</VantageLayout>

<style>
.ed-hero { padding-top: clamp(5rem, 10vw, 8rem); padding-bottom: clamp(4rem, 8vw, 6rem); }
.ed-hero h1 { max-width: 680px; }
.ed-hero .vt-lead { max-width: 600px; margin-bottom: 2rem; }

.ed-reassurance__layout { display: grid; grid-template-columns: 1.4fr 1fr; gap: 3rem; align-items: center; }
.ed-reassurance__text p:last-of-type { color: var(--vt-gray); font-size: 0.9rem; margin-top: 1.5rem; }
.ed-reassurance__stats { display: flex; flex-direction: column; gap: 1.5rem; }
.ed-reassurance__stat { padding: 1.25rem; border: 1px solid var(--vt-border); border-radius: var(--vt-radius); }
.ed-reassurance__num { display: block; font-size: 1.75rem; font-weight: 800; color: var(--vt-bronze); margin-bottom: 0.25rem; }
.ed-reassurance__label { font-size: 0.8rem; color: var(--vt-gray); }

.ed-approach__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
.ed-approach__grid h3 { color: var(--vt-ivory); }
.ed-approach__grid p { color: var(--vt-gray); font-size: 0.875rem; }

.ed-privacy__layout { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
.ed-privacy__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; }
.ed-privacy__list li { padding-left: 1.25rem; position: relative; color: var(--vt-gray); font-size: 0.9rem; }
.ed-privacy__list li::before { content: ''; position: absolute; left: 0; top: 0.5em; width: 6px; height: 6px; background: var(--vt-bronze); border-radius: 50%; }

.ed-faq__list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
.ed-faq__item { padding: 1.5rem; border: 1px solid var(--vt-border); border-radius: var(--vt-radius); }
.ed-faq__item h3 { color: var(--vt-ivory); font-size: 0.95rem; }
.ed-faq__item p { color: var(--vt-gray); font-size: 0.85rem; }

.ed-cta__inner { text-align: center; max-width: 600px; margin-inline: auto; }
.ed-cta__inner .vt-lead { margin-inline: auto; margin-bottom: 2rem; }
.ed-cta__inner .vt-btn-row { justify-content: center; }

.ed-disclaimer__text { font-size: 0.7rem; color: var(--vt-gray); opacity: 0.6; font-style: italic; max-width: 640px; text-align: center; margin-inline: auto; }

@media (max-width: 768px) {
	.ed-reassurance__layout { grid-template-columns: 1fr; }
	.ed-approach__grid { grid-template-columns: 1fr; }
	.ed-privacy__layout { grid-template-columns: 1fr; }
	.ed-faq__list { grid-template-columns: 1fr; }
}
</style>
