---
import VantageLayout from '../../../layouts/VantageLayout.astro';
import { brand } from '../../../data/vantage';
---

<VantageLayout title="Testosterone Optimization — VANTAGE Men's Health" description="Lab-guided TRT and testosterone optimization for men with clinically low or suboptimal hormone levels.">

<!-- ═══ HERO ═══ -->
<section class="vt-sec vt-sec--ink to-hero">
	<div class="vt-contain">
		<p class="vt-eye">Testosterone Optimization</p>
		<h1>Lab-guided testosterone care for men who want clarity — not guesswork.</h1>
		<p class="vt-sub">If you're experiencing fatigue, low drive, mood changes, or declining body composition, suboptimal testosterone may be a contributing factor. We evaluate, test, and treat based on your data.</p>
		<div class="vt-btn-row">
			<a class="vt-btn vt-btn--bronze" href="/demos/hormone-trt/assessment">Take the Assessment &rarr;</a>
			<a class="vt-btn vt-btn--outline" href="/demos/hormone-trt/book-consultation">Book Consultation</a>
		</div>
	</div>
</section>

<!-- ═══ WHY MEN SEEK HELP — stacked rows ═══ -->
<section class="vt-sec vt-sec--graphite to-reasons">
	<div class="vt-contain">
		<p class="vt-eye">Why Men Seek Help</p>
		<h2>Common reasons men explore testosterone optimization</h2>
		<p class="vt-sub">These symptoms may overlap — a comprehensive lab panel helps identify what's actually driving them.</p>
		<div class="to-reasons__list">
			<div class="to-reasons__row">
				<span class="to-reasons__num">01</span>
				<div class="to-reasons__content">
					<h3>Persistent fatigue</h3>
					<p>Exhaustion that persists despite adequate sleep, affecting work, relationships, and daily motivation.</p>
				</div>
			</div>
			<div class="to-reasons__row">
				<span class="to-reasons__num">02</span>
				<div class="to-reasons__content">
					<h3>Declining body composition</h3>
					<p>Increased abdominal fat and reduced lean mass despite consistent training and dietary effort.</p>
				</div>
			</div>
			<div class="to-reasons__row">
				<span class="to-reasons__num">03</span>
				<div class="to-reasons__content">
					<h3>Low libido & sexual health concerns</h3>
					<p>Reduced interest in intimacy, weaker erections, or a general sense of disconnection.</p>
				</div>
			</div>
			<div class="to-reasons__row">
				<span class="to-reasons__num">04</span>
				<div class="to-reasons__content">
					<h3>Mood changes & brain fog</h3>
					<p>Irritability, difficulty concentrating, memory issues, or a subtle loss of motivation and confidence.</p>
				</div>
			</div>
			<div class="to-reasons__row">
				<span class="to-reasons__num">05</span>
				<div class="to-reasons__content">
					<h3>Poor workout recovery</h3>
					<p>Extended soreness, diminishing gains, and slower return to baseline after exercise.</p>
				</div>
			</div>
			<div class="to-reasons__row">
				<span class="to-reasons__num">06</span>
				<div class="to-reasons__content">
					<h3>Sleep disturbances</h3>
					<p>Difficulty falling or staying asleep, or waking unrefreshed — potentially linked to hormone imbalance.</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ PROCESS — horizontal connected step track ═══ -->
<section class="vt-sec vt-sec--steel to-proto">
	<div class="vt-contain">
		<p class="vt-eye">The Process</p>
		<h2>What testosterone optimization looks like at VANTAGE</h2>
		<div class="to-proto__track">
			<div class="to-proto__step to-proto__step--active">
				<div class="to-proto__dot"></div>
				<span class="to-proto__num">Step 01</span>
				<span class="to-proto__label">Private assessment</span>
				<p class="to-proto__desc">Complete a 2-minute questionnaire about your symptoms, goals, and health history.</p>
			</div>
			<div class="to-proto__step">
				<div class="to-proto__dot"></div>
				<span class="to-proto__num">Step 02</span>
				<span class="to-proto__label">Comprehensive lab panel</span>
				<p class="to-proto__desc">Your provider orders targeted bloodwork — Total T, Free T, SHBG, estradiol, metabolic markers, and more.</p>
			</div>
			<div class="to-proto__step">
				<div class="to-proto__dot"></div>
				<span class="to-proto__num">Step 03</span>
				<span class="to-proto__label">Provider consultation</span>
				<p class="to-proto__desc">Review your results one-on-one. Your provider explains what the numbers mean and whether treatment is appropriate.</p>
			</div>
			<div class="to-proto__step">
				<div class="to-proto__dot"></div>
				<span class="to-proto__num">Step 04</span>
				<span class="to-proto__label">Personalized protocol</span>
				<p class="to-proto__desc">If clinically indicated, your provider designs a protocol tailored to your labs, symptoms, and lifestyle.</p>
			</div>
			<div class="to-proto__step">
				<div class="to-proto__dot"></div>
				<span class="to-proto__num">Step 05</span>
				<span class="to-proto__label">Ongoing monitoring</span>
				<p class="to-proto__desc">Regular lab follow-ups ensure your levels stay optimized and your plan adjusts as you progress.</p>
			</div>
		</div>
	</div>
</section>

<!-- ═══ SAFETY — 2-column bordered items panel ═══ -->
<section class="vt-sec vt-sec--graphite to-safety">
	<div class="vt-contain">
		<p class="vt-eye">Safety & Monitoring</p>
		<h2>Responsible care is non-negotiable</h2>
		<p class="vt-sub">Testosterone optimization requires ongoing medical oversight. We monitor labs, manage side effects, and adjust protocols based on your response.</p>
		<div class="to-safety__panel">
			<div class="to-safety__item">
				<span class="vt-dot vt-dot--bronze"></span>
				<div>
					<h3>Quarterly lab monitoring</h3>
					<p>Hematocrit, PSA, estradiol, liver markers, and hormone levels checked regularly during the first year.</p>
				</div>
			</div>
			<div class="to-safety__item">
				<span class="vt-dot vt-dot--bronze"></span>
				<div>
					<h3>Fertility considerations</h3>
					<p>Fertility preservation is discussed before any protocol begins. HCG and supportive options are available.</p>
				</div>
			</div>
			<div class="to-safety__item">
				<span class="vt-dot vt-dot--bronze"></span>
				<div>
					<h3>Dose adjustments</h3>
					<p>Your provider adjusts dosing based on lab response — not arbitrary timelines or one-size-fits-all approaches.</p>
				</div>
			</div>
			<div class="to-safety__item">
				<span class="vt-dot vt-dot--bronze"></span>
				<div>
					<h3>Side effect management</h3>
					<p>Estradiol management, injection site rotation, and symptom tracking are part of every protocol review.</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ PACKAGES — side-by-side bordered panels ═══ -->
<section class="vt-sec vt-sec--ink to-plans">
	<div class="vt-contain">
		<p class="vt-eye">Care Plans</p>
		<h2>Transparent pricing, no hidden fees</h2>
		<p class="vt-sub">Every plan starts with a comprehensive evaluation. Ongoing memberships include monitoring, follow-ups, and provider access.</p>
		<div class="to-plans__row">
			<div class="to-plans__tier">
				<div class="to-plans__top">
					<h3>Initial Evaluation</h3>
					<span class="to-plans__price">Starting at $295</span>
				</div>
				<p>Includes consultation, comprehensive labs, and treatment recommendations.</p>
			</div>
			<div class="to-plans__tier to-plans__tier--featured">
				<span class="to-plans__badge">Recommended</span>
				<div class="to-plans__top">
					<h3>Optimization Membership</h3>
					<span class="to-plans__price">Starting at $199/mo</span>
				</div>
				<p>Ongoing follow-ups, quarterly labs, plan adjustments, and provider messaging.</p>
			</div>
		</div>
		<div style="margin-top:1.5rem;">
			<a class="vt-btn vt-btn--outline" href="/demos/hormone-trt/pricing">View Full Pricing &rarr;</a>
		</div>
	</div>
</section>

<!-- ═══ CTA — left-aligned with data strip ═══ -->
<section class="vt-sec vt-sec--steel to-cta">
	<div class="vt-contain to-cta__inner">
		<div class="to-cta__copy">
			<p class="vt-eye">Get Started</p>
			<h2>Find out if testosterone optimization may be appropriate for you.</h2>
			<p class="vt-sub">A private, no-pressure assessment is the first step. Your provider will guide you from there.</p>
			<div class="vt-btn-row" style="margin-top:1.25rem;">
				<a class="vt-btn vt-btn--bronze" href="/demos/hormone-trt/assessment">Take the Assessment &rarr;</a>
				<a class="vt-btn vt-btn--outline" href="/demos/hormone-trt/book-consultation">Book Consultation</a>
			</div>
		</div>
		<div class="to-cta__strip" aria-hidden="true">
			<div class="to-cta__stat"><span class="to-cta__stat-val">5</span><span class="to-cta__stat-lbl">Protocol Steps</span></div>
			<div class="to-cta__stat"><span class="to-cta__stat-val">40+</span><span class="to-cta__stat-lbl">Lab Markers</span></div>
			<div class="to-cta__stat"><span class="to-cta__stat-val">90-day</span><span class="to-cta__stat-lbl">First Review</span></div>
		</div>
	</div>
</section>

<!-- ═══ DISCLAIMER ═══ -->
<div class="vt-sec--ink" style="padding:0 0 2rem;">
	<div class="vt-contain">
		<p class="to-disc">{brand.disclaimer}</p>
	</div>
</div>

</VantageLayout>

<style>
/* ═══ HERO ═══ */
.to-hero { padding: clamp(4rem, 8vw, 6rem) 0 clamp(2rem, 4vw, 3rem); }
.to-hero h1 { max-width: 680px; }
.to-hero .vt-sub { max-width: 560px; margin-bottom: 1.5rem; }

/* ═══ WHY MEN SEEK HELP — stacked bordered rows ═══ */
.to-reasons h2 { max-width: 520px; margin-bottom: 0.5rem; }
.to-reasons .vt-sub { margin-bottom: 2rem; }
.to-reasons__list { display: flex; flex-direction: column; }
.to-reasons__row { display: flex; align-items: flex-start; gap: 1.25rem; padding: 1.25rem 0; border-bottom: 1px solid var(--vt-border); }
.to-reasons__row:last-child { border-bottom: none; }
.to-reasons__num { flex-shrink: 0; font-size: 0.6rem; font-weight: 800; letter-spacing: 0.1em; color: var(--vt-bronze); padding-top: 0.15rem; min-width: 2rem; }
.to-reasons__content h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.2rem; }
.to-reasons__content p { font-size: 0.78rem; color: rgba(244,237,226,0.4); line-height: 1.55; }

/* ═══ PROCESS — horizontal connected step track ═══ */
.to-proto h2 { max-width: 520px; margin-bottom: 2rem; }
.to-proto__track { display: flex; gap: 0; border: 1px solid var(--vt-border); border-radius: var(--vt-r); overflow: hidden; }
.to-proto__step { flex: 1; padding: 1.25rem 1rem; border-right: 1px solid var(--vt-border); position: relative; }
.to-proto__step:last-child { border-right: none; }
.to-proto__dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.1); border: 1.5px solid rgba(255,255,255,0.12); margin-bottom: 0.75rem; }
.to-proto__step--active .to-proto__dot { background: var(--vt-bronze); border-color: var(--vt-bronze); box-shadow: 0 0 6px rgba(180,134,82,0.3); }
.to-proto__num { display: block; font-size: 0.55rem; font-weight: 800; letter-spacing: 0.1em; color: var(--vt-bronze); margin-bottom: 0.2rem; }
.to-proto__label { display: block; font-size: 0.82rem; font-weight: 700; color: var(--vt-bone); margin-bottom: 0.3rem; }
.to-proto__desc { font-size: 0.68rem; color: rgba(244,237,226,0.4); line-height: 1.45; }
@media (max-width: 768px) { .to-proto__track { flex-direction: column; } .to-proto__step { border-right: none; border-bottom: 1px solid var(--vt-border); } .to-proto__step:last-child { border-bottom: none; } }

/* ═══ SAFETY — 2-column bordered items ═══ */
.to-safety h2 { margin-bottom: 0.5rem; }
.to-safety .vt-sub { margin-bottom: 2rem; }
.to-safety__panel { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--vt-border); border-radius: var(--vt-r); overflow: hidden; }
.to-safety__item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 1.25rem; border-bottom: 1px solid var(--vt-border); border-right: 1px solid var(--vt-border); }
.to-safety__item:nth-child(2n) { border-right: none; }
.to-safety__item:nth-last-child(-n+2) { border-bottom: none; }
.to-safety__item .vt-dot { margin-top: 0.25rem; flex-shrink: 0; }
.to-safety__item h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.2rem; }
.to-safety__item p { font-size: 0.78rem; color: rgba(244,237,226,0.4); line-height: 1.55; }
@media (max-width: 600px) { .to-safety__panel { grid-template-columns: 1fr; } .to-safety__item { border-right: none; border-bottom: 1px solid var(--vt-border); } .to-safety__item:last-child { border-bottom: none; } }

/* ═══ PACKAGES — side-by-side bordered panels ═══ */
.to-plans h2 { margin-bottom: 0.5rem; }
.to-plans .vt-sub { margin-bottom: 2rem; }
.to-plans__row { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--vt-border); border-radius: var(--vt-r); overflow: hidden; }
.to-plans__tier { padding: 1.75rem; border-right: 1px solid var(--vt-border); position: relative; }
.to-plans__tier:last-child { border-right: none; }
.to-plans__tier--featured { background: rgba(180,134,82,0.04); }
.to-plans__badge { position: absolute; top: 0; right: 1rem; font-size: 0.5rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.5rem; background: var(--vt-bronze); color: var(--vt-ink); border-radius: 0 0 var(--vt-r) var(--vt-r); }
.to-plans__top { margin-bottom: 0.75rem; }
.to-plans__top h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.3rem; }
.to-plans__price { font-size: 1rem; font-weight: 800; color: var(--vt-bone); letter-spacing: -0.02em; }
.to-plans__tier p { font-size: 0.78rem; color: rgba(244,237,226,0.4); line-height: 1.55; }
@media (max-width: 600px) { .to-plans__row { grid-template-columns: 1fr; } .to-plans__tier { border-right: none; border-bottom: 1px solid var(--vt-border); } .to-plans__tier:last-child { border-bottom: none; } }

/* ═══ CTA — left-aligned with data strip ═══ */
.to-cta__inner { display: grid; grid-template-columns: 1.5fr 1fr; gap: 3rem; align-items: center; }
.to-cta__copy h2 { max-width: 400px; }
.to-cta__strip { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--vt-border); border-radius: var(--vt-r); overflow: hidden; }
.to-cta__stat { display: flex; align-items: baseline; gap: 0.75rem; padding: 0.85rem 1.25rem; border-bottom: 1px solid var(--vt-border); }
.to-cta__stat:last-child { border-bottom: none; }
.to-cta__stat-val { font-size: 1.1rem; font-weight: 900; color: var(--vt-bone); min-width: 3.5rem; }
.to-cta__stat-lbl { font-size: 0.62rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(244,237,226,0.35); }
@media (max-width: 700px) { .to-cta__inner { grid-template-columns: 1fr; } .to-cta__strip { flex-direction: row; } .to-cta__stat { flex: 1; border-bottom: none; border-right: 1px solid var(--vt-border); flex-direction: column; gap: 0.2rem; } .to-cta__stat:last-child { border-right: none; } }

/* ═══ DISCLAIMER ═══ */
.to-disc { font-size: 0.58rem; color: rgba(244,237,226,0.15); font-style: italic; max-width: 560px; }
</style>
