---
import VantageLayout from '../../../layouts/VantageLayout.astro';
import { brand } from '../../../data/vantage';
---

<VantageLayout title="Testosterone Optimization — VANTAGE Men's Health" description="Lab-guided TRT and testosterone optimization for men with clinically low or suboptimal hormone levels.">

<!-- ═══ HERO ═══ -->
<section class="vt-s vt-s--black to-hero">
	<div class="vt-w to-hero__layout">
		<div class="to-hero__copy">
			<span class="vt-e">Testosterone Optimization</span>
			<h1>Lab-guided testosterone care for men who want clarity — not guesswork.</h1>
			<p class="vt-sub">If you're experiencing fatigue, low drive, mood changes, or declining body composition, suboptimal testosterone may be a contributing factor. We evaluate, test, and treat based on your data.</p>
			<div class="vt-btn-row">
				<a class="vt-btn vt-btn--red" href="/demos/hormone-trt/assessment">Take the Assessment &rarr;</a>
				<a class="vt-btn vt-btn--dark" href="/demos/hormone-trt/book-consultation">Book Consultation</a>
			</div>
		</div>
		<div class="to-hero__card" aria-hidden="true">
			<div class="to-hero__card-hdr">Key Facts</div>
			<div class="to-hero__card-row"><span class="to-hero__card-label">Protocol Steps</span><span class="to-hero__card-val">5</span></div>
			<div class="to-hero__card-row"><span class="to-hero__card-label">Lab Markers</span><span class="to-hero__card-val">40+</span></div>
			<div class="to-hero__card-row"><span class="to-hero__card-label">First Review</span><span class="to-hero__card-val">90-day</span></div>
			<div class="to-hero__card-row"><span class="to-hero__card-label">Monitoring</span><span class="to-hero__card-val">Quarterly</span></div>
		</div>
		<div class="vt-img to-hero__img"><span class="vt-img__label">Hormone Performance Lab</span></div>
	</div>
</section>

<!-- ═══ KEY MARKERS REVIEWED ═══ -->
<div class="vt-s vt-s--charcoal to-markers">
	<div class="vt-w">
		<span class="vt-e">Key Markers Reviewed</span>
		<div class="to-markers__row">
			<span>Total T</span><span>Free T</span><span>SHBG</span><span>Estradiol</span><span>CBC</span><span>Lipids</span><span>PSA</span><span>Thyroid</span>
		</div>
	</div>
</div>

<!-- ═══ WHY MEN SEEK HELP — stacked rows with numbers ═══ -->
<section class="vt-s vt-s--charcoal to-reasons">
	<div class="vt-w">
		<span class="vt-e">Why Men Seek Help</span>
		<h2>Common reasons men explore testosterone optimization</h2>
		<p class="vt-sub">These symptoms may overlap — a comprehensive lab panel helps identify what's actually driving them.</p>
		<div class="to-reasons__list">
			<div class="to-reasons__row">
				<span class="to-reasons__num">01</span>
				<span class="vt-redline"></span>
				<div class="to-reasons__content">
					<h3>Persistent fatigue</h3>
					<p>Exhaustion that persists despite adequate sleep, affecting work, relationships, and daily motivation.</p>
				</div>
			</div>
			<div class="to-reasons__row">
				<span class="to-reasons__num">02</span>
				<span class="vt-redline"></span>
				<div class="to-reasons__content">
					<h3>Declining body composition</h3>
					<p>Increased abdominal fat and reduced lean mass despite consistent training and dietary effort.</p>
				</div>
			</div>
			<div class="to-reasons__row">
				<span class="to-reasons__num">03</span>
				<span class="vt-redline"></span>
				<div class="to-reasons__content">
					<h3>Low libido & sexual health concerns</h3>
					<p>Reduced interest in intimacy, weaker erections, or a general sense of disconnection.</p>
				</div>
			</div>
			<div class="to-reasons__row">
				<span class="to-reasons__num">04</span>
				<span class="vt-redline"></span>
				<div class="to-reasons__content">
					<h3>Mood changes & brain fog</h3>
					<p>Irritability, difficulty concentrating, memory issues, or a subtle loss of motivation and confidence.</p>
				</div>
			</div>
			<div class="to-reasons__row">
				<span class="to-reasons__num">05</span>
				<span class="vt-redline"></span>
				<div class="to-reasons__content">
					<h3>Poor workout recovery</h3>
					<p>Extended soreness, diminishing gains, and slower return to baseline after exercise.</p>
				</div>
			</div>
			<div class="to-reasons__row">
				<span class="to-reasons__num">06</span>
				<span class="vt-redline"></span>
				<div class="to-reasons__content">
					<h3>Sleep disturbances</h3>
					<p>Difficulty falling or staying asleep, or waking unrefreshed — potentially linked to hormone imbalance.</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ THE PROCESS — horizontal connected steps with red markers ═══ -->
<section class="vt-s vt-s--carbon to-proto">
	<div class="vt-w">
		<span class="vt-e">The Process</span>
		<h2>What testosterone optimization looks like at VANTAGE</h2>
		<div class="to-proto__track">
			<div class="to-proto__step to-proto__step--active">
				<div class="to-proto__dot"></div>
				<span class="to-proto__num">Step 01</span>
				<span class="to-proto__label">Private assessment</span>
				<p class="to-proto__desc">Complete a 2-minute questionnaire about your symptoms, goals, and health history.</p>
			</div>
			<div class="to-proto__step">
				<div class="to-proto__dot"></div>
				<span class="to-proto__num">Step 02</span>
				<span class="to-proto__label">Comprehensive lab panel</span>
				<p class="to-proto__desc">Your provider orders targeted bloodwork — Total T, Free T, SHBG, estradiol, metabolic markers, and more.</p>
			</div>
			<div class="to-proto__step">
				<div class="to-proto__dot"></div>
				<span class="to-proto__num">Step 03</span>
				<span class="to-proto__label">Provider consultation</span>
				<p class="to-proto__desc">Review your results one-on-one. Your provider explains what the numbers mean and whether treatment is appropriate.</p>
			</div>
			<div class="to-proto__step">
				<div class="to-proto__dot"></div>
				<span class="to-proto__num">Step 04</span>
				<span class="to-proto__label">Personalized protocol</span>
				<p class="to-proto__desc">If clinically indicated, your provider designs a protocol tailored to your labs, symptoms, and lifestyle.</p>
			</div>
			<div class="to-proto__step">
				<div class="to-proto__dot"></div>
				<span class="to-proto__num">Step 05</span>
				<span class="to-proto__label">Ongoing monitoring</span>
				<p class="to-proto__desc">Regular lab follow-ups ensure your levels stay optimized and your plan adjusts as you progress.</p>
			</div>
		</div>
	</div>
</section>

<!-- ═══ SAFETY — 2-column bordered grid ═══ -->
<section class="vt-s vt-s--charcoal to-safety">
	<div class="vt-w">
		<span class="vt-e">Safety &amp; Monitoring</span>
		<h2>Responsible care is non-negotiable</h2>
		<p class="vt-sub">Testosterone optimization requires ongoing medical oversight. We monitor labs, manage side effects, and adjust protocols based on your response.</p>
		<div class="to-safety__grid">
			<div class="to-safety__item">
				<span class="to-safety__marker"></span>
				<div>
					<h3>Quarterly lab monitoring</h3>
					<p>Hematocrit, PSA, estradiol, liver markers, and hormone levels checked regularly during the first year.</p>
				</div>
			</div>
			<div class="to-safety__item">
				<span class="to-safety__marker"></span>
				<div>
					<h3>Fertility considerations</h3>
					<p>Fertility preservation is discussed before any protocol begins. HCG and supportive options are available.</p>
				</div>
			</div>
			<div class="to-safety__item">
				<span class="to-safety__marker"></span>
				<div>
					<h3>Dose adjustments</h3>
					<p>Your provider adjusts dosing based on lab response — not arbitrary timelines or one-size-fits-all approaches.</p>
				</div>
			</div>
			<div class="to-safety__item">
				<span class="to-safety__marker"></span>
				<div>
					<h3>Side effect management</h3>
					<p>Estradiol management, injection site rotation, and symptom tracking are part of every protocol review.</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ PRICING — 2-col comparison ═══ -->
<section class="vt-s vt-s--black to-plans">
	<div class="vt-w">
		<span class="vt-e">Care Plans</span>
		<h2>Transparent pricing, no hidden fees</h2>
		<p class="vt-sub">Every plan starts with a comprehensive evaluation. Ongoing memberships include monitoring, follow-ups, and provider access.</p>
		<div class="to-plans__board">
			<div class="to-plans__tier">
				<div class="to-plans__top">
					<h3>Initial Evaluation</h3>
					<span class="to-plans__price">Starting at $295</span>
				</div>
				<p>Includes consultation, comprehensive labs, and treatment recommendations.</p>
			</div>
			<div class="to-plans__tier to-plans__tier--featured">
				<span class="to-plans__badge">Recommended</span>
				<div class="to-plans__top">
					<h3>Optimization Membership</h3>
					<span class="to-plans__price">Starting at $199/mo</span>
				</div>
				<p>Ongoing follow-ups, quarterly labs, plan adjustments, and provider messaging.</p>
			</div>
		</div>
		<div style="margin-top:1.5rem;">
			<a class="vt-btn vt-btn--dark" href="/demos/hormone-trt/pricing">View Full Pricing &rarr;</a>
		</div>
	</div>
</section>

<!-- ═══ FINAL CTA — red background panel ═══ -->
<section class="to-final">
	<div class="vt-w to-final__inner">
		<span class="vt-e">Get Started</span>
		<h2>Find out if testosterone optimization may be appropriate for you.</h2>
		<p class="vt-sub">A private, no-pressure assessment is the first step. Your provider will guide you from there.</p>
		<div class="vt-btn-row" style="margin-top:1.5rem;">
			<a class="vt-btn vt-btn--red" href="/demos/hormone-trt/assessment">Take the Assessment &rarr;</a>
			<a class="vt-btn vt-btn--dark" href="/demos/hormone-trt/book-consultation">Book Consultation</a>
		</div>
	</div>
</section>

<!-- ═══ DISCLAIMER ═══ -->
<div class="vt-s--black" style="padding:0 0 2rem;">
	<div class="vt-w">
		<p class="to-disc">{brand.disclaimer}</p>
	</div>
</div>

</VantageLayout>

<style>
/* ═══ HERO — dark compact with key facts card ═══ */
.to-hero { padding: clamp(5rem, 10vw, 8rem) 0 clamp(3rem, 6vw, 4rem); position: relative; overflow: hidden; }
.to-hero__layout { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: clamp(2rem, 4vw, 4rem); align-items: center; }
.to-hero__copy h1 { max-width: 680px; }
.to-hero__copy .vt-sub { margin-bottom: 1.5rem; }
.to-hero__card { background: var(--vt-charcoal); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--vt-r); overflow: hidden; border-top: 3px solid var(--vt-red); }
.to-hero__card-hdr { padding: 0.75rem 1rem; font-size: 0.58rem; font-weight: 900; letter-spacing: 0.16em; text-transform: uppercase; color: var(--vt-white); border-bottom: 1px solid rgba(255,255,255,0.06); }
.to-hero__card-row { display: flex; justify-content: space-between; align-items: center; padding: 0.65rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.04); }
.to-hero__card-row:last-child { border-bottom: none; }
.to-hero__card-label { font-size: 0.65rem; font-weight: 600; color: rgba(244,239,231,0.4); letter-spacing: 0.04em; text-transform: uppercase; }
.to-hero__card-val { font-size: 0.9rem; font-weight: 900; color: var(--vt-white); }
@media (max-width: 768px) { .to-hero__layout { grid-template-columns: 1fr; } .to-hero__card { max-width: 360px; } }

/* ═══ WHY MEN SEEK HELP — stacked rows with numbers + red lines ═══ */
.to-reasons h2 { max-width: 520px; margin-bottom: 0.5rem; }
.to-reasons .vt-sub { margin-bottom: 2rem; }
.to-reasons__list { display: flex; flex-direction: column; }
.to-reasons__row { display: flex; align-items: flex-start; gap: 1rem; padding: 1.25rem 0; border-bottom: 1px solid var(--vt-border); }
.to-reasons__row:last-child { border-bottom: none; }
.to-reasons__num { flex-shrink: 0; font-size: 0.6rem; font-weight: 900; letter-spacing: 0.1em; color: var(--vt-red); padding-top: 0.15rem; min-width: 1.8rem; }
.to-reasons__row .vt-redline { margin-top: 0.55rem; flex-shrink: 0; }
.to-reasons__content h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.2rem; }
.to-reasons__content p { font-size: 0.78rem; color: rgba(244,239,231,0.5); line-height: 1.55; }

/* ═══ PROCESS — horizontal connected step track ═══ */
.to-proto h2 { max-width: 520px; margin-bottom: 2rem; }
.to-proto__track { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1px; background: rgba(255,255,255,0.04); border-radius: var(--vt-r); overflow: hidden; }
.to-proto__step { padding: 1.25rem 1rem; background: var(--vt-charcoal); position: relative; }
.to-proto__dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.08); border: 1.5px solid rgba(255,255,255,0.1); margin-bottom: 0.75rem; }
.to-proto__step--active .to-proto__dot { background: var(--vt-red); border-color: var(--vt-red); box-shadow: 0 0 6px rgba(215,25,32,0.3); }
.to-proto__num { display: block; font-size: 0.55rem; font-weight: 900; letter-spacing: 0.1em; color: var(--vt-red); margin-bottom: 0.2rem; }
.to-proto__label { display: block; font-size: 0.82rem; font-weight: 700; color: var(--vt-bone); margin-bottom: 0.3rem; }
.to-proto__desc { font-size: 0.68rem; color: rgba(244,239,231,0.45); line-height: 1.45; }
@media (max-width: 768px) { .to-proto__track { grid-template-columns: 1fr; } }

/* ═══ SAFETY — 2-column bordered grid ═══ */
.to-safety h2 { margin-bottom: 0.5rem; }
.to-safety .vt-sub { margin-bottom: 2rem; }
.to-safety__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(255,255,255,0.04); border-radius: var(--vt-r); overflow: hidden; }
.to-safety__item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 1.25rem; background: var(--vt-carbon); }
.to-safety__marker { flex-shrink: 0; width: 6px; height: 6px; border-radius: 50%; background: var(--vt-red); margin-top: 0.35rem; }
.to-safety__item h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.2rem; }
.to-safety__item p { font-size: 0.78rem; color: rgba(244,239,231,0.5); line-height: 1.55; }
@media (max-width: 600px) { .to-safety__grid { grid-template-columns: 1fr; } }

/* ═══ PRICING — 2-col comparison board ═══ */
.to-plans h2 { margin-bottom: 0.5rem; }
.to-plans .vt-sub { margin-bottom: 2rem; }
.to-plans__board { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(255,255,255,0.04); border-radius: var(--vt-r); overflow: hidden; }
.to-plans__tier { padding: 1.75rem; background: var(--vt-charcoal); position: relative; }
.to-plans__tier--featured { background: rgba(215,25,32,0.04); border-top: 3px solid var(--vt-red); }
.to-plans__badge { position: absolute; top: 0; right: 1rem; font-size: 0.5rem; font-weight: 900; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.5rem; background: var(--vt-red); color: var(--vt-white); border-radius: 0 0 var(--vt-r) var(--vt-r); }
.to-plans__top { margin-bottom: 0.75rem; }
.to-plans__top h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.3rem; }
.to-plans__price { font-size: 1.1rem; font-weight: 900; color: var(--vt-white); letter-spacing: -0.02em; }
.to-plans__tier p { font-size: 0.78rem; color: rgba(244,239,231,0.5); line-height: 1.55; }
@media (max-width: 600px) { .to-plans__board { grid-template-columns: 1fr; } }

/* ═══ FINAL CTA — red background panel ═══ */
.to-final { background: var(--vt-red); padding: clamp(3rem, 6vw, 5rem) 0; position: relative; overflow: hidden; }
.to-final::before { content: ''; position: absolute; top: -30%; right: -5%; width: 40%; height: 160%; background: rgba(0,0,0,0.08); transform: skewX(-12deg); pointer-events: none; }
.to-final__inner { position: relative; z-index: 1; max-width: 560px; }
.to-final h2 { color: var(--vt-white); }
.to-final .vt-e { color: rgba(255,255,255,0.5); }
.to-final .vt-sub { color: rgba(255,255,255,0.7); }
.to-final .vt-btn--red { background: var(--vt-white); color: var(--vt-red); border-color: var(--vt-white); }
.to-final .vt-btn--red:hover { background: var(--vt-bone); }
.to-final .vt-btn--dark { background: transparent; color: var(--vt-white); border-color: rgba(255,255,255,0.3); }
.to-final .vt-btn--dark:hover { border-color: var(--vt-white); }

/* ═══ HERO IMAGE PLACEHOLDER ═══ */
.to-hero__img { min-height: 100px; margin-top: 2rem; grid-column: 1 / -1; }
@media (max-width: 768px) { .to-hero__img { display: none; } }

/* ═══ KEY MARKERS BAND ═══ */
.to-markers__row { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.to-markers__row span { font-size: 0.68rem; font-weight: 700; padding: 0.35rem 0.75rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 3px; color: var(--vt-bone); }

/* ═══ REASON ROW HOVER ═══ */
.to-reasons__row { transition: border-color 0.2s; border-left: 3px solid transparent; padding-left: 0.75rem; }
.to-reasons__row:hover { border-left-color: var(--vt-red); }

/* ═══ DISCLAIMER ═══ */
.to-disc { font-size: 0.55rem; color: rgba(244,239,231,0.12); font-style: italic; max-width: 560px; }
</style>
