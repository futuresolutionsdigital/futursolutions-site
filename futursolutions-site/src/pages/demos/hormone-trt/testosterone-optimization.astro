---
import VantageLayout from '../../../layouts/VantageLayout.astro';
import { brand } from '../../../data/vantage';
---

<VantageLayout title="Testosterone Optimization — VANTAGE Men's Health" description="Lab-guided TRT and testosterone optimization for men with clinically low or suboptimal hormone levels.">

<!-- Hero -->
<section class="vt-section vt-section--dark to-hero">
	<div class="vt-container">
		<p class="vt-eyebrow">Testosterone Optimization</p>
		<h1>Lab-guided testosterone care for men who want clarity — not guesswork.</h1>
		<p class="vt-lead">If you're experiencing fatigue, low drive, mood changes, or declining body composition, suboptimal testosterone may be a contributing factor. We evaluate, test, and treat based on your data.</p>
		<div class="vt-btn-row">
			<a class="vt-btn vt-btn--primary" href="/demos/hormone-trt/assessment">Take the Assessment &rarr;</a>
			<a class="vt-btn vt-btn--secondary" href="/demos/hormone-trt/book-consultation">Book Consultation</a>
		</div>
	</div>
</section>

<!-- Why men seek testosterone optimization -->
<section class="vt-section vt-section--charcoal to-benefits">
	<div class="vt-container">
		<div class="vt-section-header">
			<p class="vt-eyebrow">Why Men Seek Help</p>
			<h2>Common reasons men explore testosterone optimization</h2>
			<p class="vt-lead">These symptoms may overlap — a comprehensive lab panel helps identify what's actually driving them.</p>
		</div>
		<div class="to-benefits__grid">
			<div class="to-benefits__item">
				<span class="to-benefits__num">01</span>
				<h3>Persistent fatigue</h3>
				<p>Exhaustion that persists despite adequate sleep, affecting work, relationships, and daily motivation.</p>
			</div>
			<div class="to-benefits__item">
				<span class="to-benefits__num">02</span>
				<h3>Declining body composition</h3>
				<p>Increased abdominal fat and reduced lean mass despite consistent training and dietary effort.</p>
			</div>
			<div class="to-benefits__item">
				<span class="to-benefits__num">03</span>
				<h3>Low libido & sexual health concerns</h3>
				<p>Reduced interest in intimacy, weaker erections, or a general sense of disconnection.</p>
			</div>
			<div class="to-benefits__item">
				<span class="to-benefits__num">04</span>
				<h3>Mood changes & brain fog</h3>
				<p>Irritability, difficulty concentrating, memory issues, or a subtle loss of motivation and confidence.</p>
			</div>
			<div class="to-benefits__item">
				<span class="to-benefits__num">05</span>
				<h3>Poor workout recovery</h3>
				<p>Extended soreness, diminishing gains, and slower return to baseline after exercise.</p>
			</div>
			<div class="to-benefits__item">
				<span class="to-benefits__num">06</span>
				<h3>Sleep disturbances</h3>
				<p>Difficulty falling or staying asleep, or waking unrefreshed — potentially linked to hormone imbalance.</p>
			</div>
		</div>
	</div>
</section>

<!-- Process timeline -->
<section class="vt-section vt-section--slate to-process">
	<div class="vt-container">
		<div class="vt-section-header">
			<p class="vt-eyebrow">The Process</p>
			<h2>What testosterone optimization looks like at VANTAGE</h2>
		</div>
		<div class="to-process__timeline">
			<div class="to-process__step">
				<span class="to-process__marker">1</span>
				<div>
					<h3>Private assessment</h3>
					<p>Complete a 2-minute questionnaire about your symptoms, goals, and health history.</p>
				</div>
			</div>
			<div class="to-process__step">
				<span class="to-process__marker">2</span>
				<div>
					<h3>Comprehensive lab panel</h3>
					<p>Your provider orders targeted bloodwork — Total T, Free T, SHBG, estradiol, metabolic markers, and more.</p>
				</div>
			</div>
			<div class="to-process__step">
				<span class="to-process__marker">3</span>
				<div>
					<h3>Provider consultation</h3>
					<p>Review your results one-on-one. Your provider explains what the numbers mean and whether treatment is appropriate.</p>
				</div>
			</div>
			<div class="to-process__step">
				<span class="to-process__marker">4</span>
				<div>
					<h3>Personalized protocol</h3>
					<p>If clinically indicated, your provider designs a protocol tailored to your labs, symptoms, and lifestyle.</p>
				</div>
			</div>
			<div class="to-process__step">
				<span class="to-process__marker">5</span>
				<div>
					<h3>Ongoing monitoring</h3>
					<p>Regular lab follow-ups ensure your levels stay optimized and your plan adjusts as you progress.</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Safety & monitoring -->
<section class="vt-section vt-section--charcoal to-safety">
	<div class="vt-container">
		<div class="vt-section-header">
			<p class="vt-eyebrow">Safety & Monitoring</p>
			<h2>Responsible care is non-negotiable</h2>
			<p class="vt-lead">Testosterone optimization requires ongoing medical oversight. We monitor labs, manage side effects, and adjust protocols based on your response.</p>
		</div>
		<div class="to-safety__grid">
			<div class="vt-card">
				<h3>Quarterly lab monitoring</h3>
				<p>Hematocrit, PSA, estradiol, liver markers, and hormone levels checked regularly during the first year.</p>
			</div>
			<div class="vt-card">
				<h3>Fertility considerations</h3>
				<p>Fertility preservation is discussed before any protocol begins. HCG and supportive options are available.</p>
			</div>
			<div class="vt-card">
				<h3>Dose adjustments</h3>
				<p>Your provider adjusts dosing based on lab response — not arbitrary timelines or one-size-fits-all approaches.</p>
			</div>
			<div class="vt-card">
				<h3>Side effect management</h3>
				<p>Estradiol management, injection site rotation, and symptom tracking are part of every protocol review.</p>
			</div>
		</div>
	</div>
</section>

<!-- Packages preview -->
<section class="vt-section vt-section--dark to-packages">
	<div class="vt-container">
		<div class="vt-section-header">
			<p class="vt-eyebrow">Care Plans</p>
			<h2>Transparent pricing, no hidden fees</h2>
			<p class="vt-lead">Every plan starts with a comprehensive evaluation. Ongoing memberships include monitoring, follow-ups, and provider access.</p>
		</div>
		<div class="to-packages__grid">
			<div class="vt-card">
				<h3>Initial Evaluation</h3>
				<p class="to-packages__price">Starting at $295</p>
				<p>Includes consultation, comprehensive labs, and treatment recommendations.</p>
			</div>
			<div class="vt-card to-packages__featured">
				<h3>Optimization Membership</h3>
				<p class="to-packages__price">Starting at $199/mo</p>
				<p>Ongoing follow-ups, quarterly labs, plan adjustments, and provider messaging.</p>
			</div>
		</div>
		<div class="vt-btn-row" style="margin-top:2rem;justify-content:center;">
			<a class="vt-btn vt-btn--secondary" href="/demos/hormone-trt/pricing">View Full Pricing &rarr;</a>
		</div>
	</div>
</section>

<!-- CTA -->
<section class="vt-section vt-section--slate to-cta">
	<div class="vt-container to-cta__inner">
		<p class="vt-eyebrow">Get Started</p>
		<h2>Find out if testosterone optimization may be appropriate for you.</h2>
		<p class="vt-lead">A private, no-pressure assessment is the first step. Your provider will guide you from there.</p>
		<div class="vt-btn-row">
			<a class="vt-btn vt-btn--primary" href="/demos/hormone-trt/assessment">Take the Assessment &rarr;</a>
			<a class="vt-btn vt-btn--secondary" href="/demos/hormone-trt/book-consultation">Book Consultation</a>
		</div>
	</div>
</section>

<!-- Disclaimer -->
<section class="vt-section vt-section--dark to-disclaimer">
	<div class="vt-container">
		<p class="to-disclaimer__text">{brand.disclaimer}</p>
	</div>
</section>

</VantageLayout>

<style>
.to-hero { padding-top: clamp(5rem, 10vw, 8rem); padding-bottom: clamp(4rem, 8vw, 6rem); }
.to-hero h1 { max-width: 700px; }
.to-hero .vt-lead { max-width: 600px; margin-bottom: 2rem; }

.to-benefits__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
.to-benefits__item { padding: 1.5rem; border: 1px solid var(--vt-border); border-radius: var(--vt-radius); }
.to-benefits__num { display: block; font-size: 0.7rem; font-weight: 700; color: var(--vt-bronze); letter-spacing: 0.1em; margin-bottom: 0.75rem; }
.to-benefits__item h3 { color: var(--vt-ivory); }
.to-benefits__item p { color: var(--vt-gray); font-size: 0.875rem; }

.to-process__timeline { display: flex; flex-direction: column; gap: 2rem; max-width: 640px; }
.to-process__step { display: flex; gap: 1.25rem; align-items: flex-start; }
.to-process__marker { flex-shrink: 0; width: 2.25rem; height: 2.25rem; display: flex; align-items: center; justify-content: center; background: var(--vt-bronze); color: var(--vt-graphite); font-weight: 700; font-size: 0.8rem; border-radius: 50%; }
.to-process__step h3 { color: var(--vt-ivory); margin-bottom: 0.25rem; }
.to-process__step p { color: var(--vt-gray); font-size: 0.875rem; }

.to-safety__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
.to-safety__grid h3 { color: var(--vt-ivory); }
.to-safety__grid p { color: var(--vt-gray); font-size: 0.875rem; }

.to-packages__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 700px; margin-inline: auto; }
.to-packages__price { font-size: 1.25rem; font-weight: 700; color: var(--vt-bronze); margin-bottom: 0.5rem; }
.to-packages__featured { border-color: var(--vt-bronze); }
.to-packages__grid h3 { color: var(--vt-ivory); }
.to-packages__grid p { color: var(--vt-gray); font-size: 0.875rem; }

.to-cta__inner { text-align: center; max-width: 600px; margin-inline: auto; }
.to-cta__inner .vt-lead { margin-inline: auto; margin-bottom: 2rem; }
.to-cta__inner .vt-btn-row { justify-content: center; }

.to-disclaimer__text { font-size: 0.7rem; color: var(--vt-gray); opacity: 0.6; font-style: italic; max-width: 640px; text-align: center; margin-inline: auto; }

@media (max-width: 768px) {
	.to-benefits__grid { grid-template-columns: 1fr; }
	.to-safety__grid { grid-template-columns: 1fr; }
	.to-packages__grid { grid-template-columns: 1fr; }
}
</style>
