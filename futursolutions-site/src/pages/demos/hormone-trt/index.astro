---
import VantageLayout from '../../../layouts/VantageLayout.astro';
import { brand, trustBar, symptoms, symptomCategories, pathways, protocol, treatments, treatmentMatrix, labCategories, providers, pricingTiers, testimonials, faqs, pillars } from '../../../data/vantage';
---

<VantageLayout title="VANTAGE Men's Health — Hormone, Sexual Health & Performance Medicine" description="Data-guided testosterone optimization, ED treatment, medical weight loss, peptide therapy, and longevity care for men. Private evaluations. Lab-based plans. Ongoing monitoring.">

<!-- ═══ 1. HERO — full-bleed with overlapping diagnostic console ═══ -->
<section class="hero">
	<div class="vt-contain hero__inner">
		<div class="hero__copy">
			<p class="vt-eye">Private Men's Performance Medicine</p>
			<h1>Stop guessing.<br/>Start with the data.</h1>
			<p class="hero__lead">Hormone, sexual health, weight, and performance care for men — guided by labs, licensed providers, and a plan built around your goals.</p>
			<div class="vt-btn-row">
				<a class="vt-btn vt-btn--bronze" href="/demos/hormone-trt/assessment">Run the 2-Minute Assessment &rarr;</a>
				<a class="vt-btn vt-btn--outline" href="/demos/hormone-trt/book-consultation">Book a Private Consult</a>
			</div>
			<p class="hero__micro">Private &middot; Lab-based &middot; Provider-led</p>
		</div>
	</div>
	<div class="vt-contain hero__console-wrap">
		<div class="hero__console" aria-hidden="true">
			<div class="vt-panel__head"><span>VANTAGE Diagnostic Console</span><span>Sample · Provider Review</span></div>
			<div class="hero__console-body">
				<div class="hero__markers">
					<div class="hero__marker">
						<span class="hero__marker-label">Total T</span>
						<span class="hero__marker-val">312 <small>ng/dL</small></span>
						<div class="hero__range"><div class="hero__range-fill" style="width:32%;left:0"></div><div class="hero__range-opt" style="left:45%;width:35%"></div></div>
					</div>
					<div class="hero__marker">
						<span class="hero__marker-label">Free T</span>
						<span class="hero__marker-val">6.8 <small>pg/mL</small></span>
						<div class="hero__range"><div class="hero__range-fill" style="width:22%;left:0"></div><div class="hero__range-opt" style="left:40%;width:40%"></div></div>
					</div>
					<div class="hero__marker">
						<span class="hero__marker-label">SHBG</span>
						<span class="hero__marker-val">52 <small>nmol/L</small></span>
						<div class="hero__range"><div class="hero__range-fill hero__range-fill--high" style="width:18%;left:65%"></div><div class="hero__range-opt" style="left:20%;width:35%"></div></div>
					</div>
					<div class="hero__marker">
						<span class="hero__marker-label">Estradiol</span>
						<span class="hero__marker-val">32 <small>pg/mL</small></span>
						<div class="hero__range"><div class="hero__range-fill" style="width:15%;left:50%"></div><div class="hero__range-opt" style="left:25%;width:30%"></div></div>
					</div>
				</div>
				<div class="hero__profile">
					<div class="hero__profile-head">Symptom Profile</div>
					<div class="hero__chips">
						<span>Low energy</span><span>Brain fog</span><span>Weight gain</span><span>Low libido</span>
					</div>
					<div class="hero__status">
						<span class="vt-dot vt-dot--bronze"></span>
						<span>Provider review complete</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ 2. STATUS RAIL — thin data strip ═══ -->
<div class="rail">
	<div class="vt-contain rail__inner">
		{trustBar.map((item) => (
			<div class="rail__item">
				<span class="vt-dot vt-dot--bronze"></span>
				<span>{item}</span>
			</div>
		))}
	</div>
</div>

<!-- ═══ 3. PILLARS — operating system strip ═══ -->
<section class="vt-sec vt-sec--graphite pillars">
	<div class="vt-contain">
		<p class="vt-eye">The VANTAGE System</p>
		<h2>Men's health care built like a system — not a sales funnel.</h2>
		<div class="pillars__track">
			{pillars.map((p) => (
				<div class="pillars__block">
					<span class="pillars__num">{p.num}</span>
					<h3>{p.title}</h3>
					<p>{p.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

<!-- ═══ 4. SYMPTOM DOSSIER — categorized chips with side panel ═══ -->
<section class="vt-sec vt-sec--ink dossier" id="conditions">
	<div class="vt-contain dossier__layout">
		<div class="dossier__main">
			<p class="vt-eye">Symptom Intelligence</p>
			<h2>Build your symptom profile.</h2>
			<p class="vt-sub">Men rarely come in for "hormones." They come in because something feels off. These symptoms overlap — the right starting point is a private evaluation, not guesswork.</p>
			<div class="dossier__clusters">
				{symptomCategories.map((cat) => (
					<div class="dossier__cluster">
						<span class="dossier__cat">{cat.category}</span>
						<div class="dossier__chips">
							{cat.items.map((item) => (
								<span class="dossier__chip">{item}</span>
							))}
						</div>
					</div>
				))}
			</div>
		</div>
		<div class="dossier__side">
			<div class="vt-panel">
				<div class="vt-panel__head"><span>Next Step</span><span>Assessment</span></div>
				<div class="vt-panel__body">
					<p class="dossier__side-lead">Identify your pattern. Get a private evaluation.</p>
					<div class="dossier__side-steps">
						<div class="dossier__side-step"><span class="vt-dot vt-dot--bronze"></span><span>Complete the 2-minute assessment</span></div>
						<div class="dossier__side-step"><span class="vt-dot vt-dot--steel"></span><span>Provider reviews your profile</span></div>
						<div class="dossier__side-step"><span class="vt-dot vt-dot--steel"></span><span>Labs ordered based on symptoms</span></div>
					</div>
					<a class="vt-btn vt-btn--bronze dossier__cta" href="/demos/hormone-trt/assessment">Build My Profile &rarr;</a>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ 5. CARE TRACKS — offset numbered panels ═══ -->
<section class="vt-sec vt-sec--charcoal tracks">
	<div class="vt-contain">
		<p class="vt-eye">Care Tracks</p>
		<h2>Choose the path that sounds most like you.</h2>
		<div class="tracks__list">
			{pathways.map((p, i) => (
				<a class="tracks__item" href={p.href}>
					<div class="tracks__left">
						<span class="tracks__num">Track 0{i + 1}</span>
						<h3>{p.title}</h3>
						<p>{p.description}</p>
					</div>
					<div class="tracks__right">
						{p.services.map((s) => (
							<span class="tracks__service"><span class="vt-dot vt-dot--bronze"></span>{s}</span>
						))}
						<span class="vt-link">Explore this path &rarr;</span>
					</div>
				</a>
			))}
		</div>
	</div>
</section>

<!-- ═══ 6. PROTOCOL TIMELINE — horizontal connected steps ═══ -->
<section class="vt-sec vt-sec--steel proto">
	<div class="vt-contain">
		<p class="vt-eye">The Protocol</p>
		<h2>From symptoms to strategy.</h2>
		<div class="proto__track">
			{protocol.map((s, i) => (
				<div class:list={['proto__step', { 'proto__step--active': i === 0 }]}>
					<div class="proto__dot"></div>
					<span class="proto__num">{s.step}</span>
					<span class="proto__label">{s.label}</span>
					<p class="proto__desc">{s.description}</p>
				</div>
			))}
		</div>
		<p class="proto__note">Treatment decisions are based on symptoms, lab results, health history, goals, and ongoing follow-up — not one-size-fits-all protocols.</p>
		<a class="vt-btn vt-btn--bronze" href="/demos/hormone-trt/assessment" style="margin-top:1.25rem;">Start With the Assessment &rarr;</a>
	</div>
</section>

<!-- ═══ 7. TREATMENT MATRIX — categorized rows ═══ -->
<section class="vt-sec vt-sec--ink matrix" id="treatments">
	<div class="vt-contain">
		<p class="vt-eye">Treatment Map</p>
		<h2>Integrated care for hormones, performance, and long-term vitality.</h2>
		<div class="matrix__grid">
			{treatmentMatrix.map((group) => (
				<div class="matrix__row">
					<span class="matrix__cat">{group.category}</span>
					<div class="matrix__items">
						{group.items.map((item) => (
							<a class="matrix__item" href={item.href}>
								<span>{item.title}</span>
								<span class="matrix__arrow">&rarr;</span>
							</a>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<!-- ═══ 8. LAB DASHBOARD — full-width mock interface ═══ -->
<section class="vt-sec vt-sec--graphite labs">
	<div class="vt-contain">
		<div class="labs__intro">
			<p class="vt-eye">Lab Intelligence</p>
			<h2>Your labs become the map.</h2>
			<p class="vt-sub">VANTAGE uses comprehensive lab testing, provider consultation, and follow-up monitoring to determine whether treatments may be appropriate. Not every symptom is low testosterone — we look at the broader picture.</p>
		</div>
		<div class="labs__dashboard" aria-hidden="true">
			<div class="vt-panel__head"><span>Comprehensive Lab Panel</span><span>Panels customized per patient</span></div>
			<div class="labs__grid">
				{labCategories.map((cat, i) => (
					<div class="labs__cell">
						<span class="labs__cell-num">0{i + 1}</span>
						<span class="labs__cell-name">{cat}</span>
					</div>
				))}
			</div>
			<div class="labs__footer">
				<span class="vt-dot vt-dot--bronze"></span>
				<span>Results reviewed with provider · Not every patient is a candidate for every treatment</span>
			</div>
		</div>
	</div>
</section>

<!-- ═══ 9. PROVIDERS — editorial layout ═══ -->
<section class="vt-sec vt-sec--ink provs" id="providers">
	<div class="vt-contain">
		<div class="provs__header">
			<p class="vt-eye">Your Care Team</p>
			<h2>Provider-led care with guardrails.</h2>
			<p class="vt-sub">Every treatment plan is built and monitored by a licensed provider — with medical review before treatment, ongoing monitoring, adjustments over time, and fertility and safety considerations built in.</p>
		</div>
		<div class="provs__list">
			{providers.map((prov) => (
				<div class="provs__card">
					<div class="provs__initials">{prov.initials}</div>
					<div class="provs__info">
						<h3>{prov.name}</h3>
						<span class="provs__role">{prov.role}</span>
						<p class="provs__focus"><strong>Focus:</strong> {prov.specialties}</p>
						<p class="provs__bio">{prov.bio}</p>
					</div>
				</div>
			))}
		</div>
		<div class="provs__rails">
			<div class="provs__rail"><span class="vt-dot vt-dot--bronze"></span>Medical review before any treatment</div>
			<div class="provs__rail"><span class="vt-dot vt-dot--bronze"></span>Ongoing lab monitoring and adjustments</div>
			<div class="provs__rail"><span class="vt-dot vt-dot--bronze"></span>Fertility and safety considerations</div>
			<div class="provs__rail"><span class="vt-dot vt-dot--bronze"></span>Not every patient is a candidate</div>
		</div>
	</div>
</section>

<!-- ═══ 10. PRICING — horizontal comparison ═══ -->
<section class="vt-sec vt-sec--charcoal pricing">
	<div class="vt-contain">
		<p class="vt-eye">Care Plans</p>
		<h2>Built for ongoing care, not one-off injections.</h2>
		<div class="pricing__row">
			{pricingTiers.map((tier) => (
				<div class:list={['pricing__tier', { 'pricing__tier--featured': tier.featured }]}>
					{tier.featured && <span class="pricing__badge">Most Popular</span>}
					<div class="pricing__top">
						<h3>{tier.name}</h3>
						<p class="pricing__tag">{tier.tagline}</p>
						<span class="pricing__price">{tier.price}</span>
					</div>
					<ul class="pricing__includes">
						{tier.includes.map((item) => <li>{item}</li>)}
					</ul>
					<a class="vt-btn vt-btn--bronze pricing__cta" href="/demos/hormone-trt/pricing">{tier.cta}</a>
				</div>
			))}
		</div>
		<p class="pricing__note">Labs, medications, and follow-up costs are explained before treatment begins. No hidden fees.</p>
	</div>
</section>

<!-- ═══ 11. PATIENT NOTES — dossier format ═══ -->
<section class="vt-sec vt-sec--ink notes">
	<div class="vt-contain">
		<p class="vt-eye">Patient Experiences</p>
		<h2>Real care should create clarity, not hype.</h2>
		<div class="notes__list">
			{testimonials.map((t, i) => (
				<div class="notes__entry">
					<div class="notes__meta">
						<span class="notes__num">Note 0{i + 1}</span>
						<span class="notes__ctx">{t.context}</span>
					</div>
					<blockquote class="notes__quote">&ldquo;{t.text}&rdquo;</blockquote>
					<span class="notes__author">{t.author}</span>
				</div>
			))}
		</div>
		<p class="notes__disc">Individual results vary. Treatment requires provider evaluation. These are fictional testimonials for demonstration purposes.</p>
	</div>
</section>

<!-- ═══ 12. FAQ — inline accordion ═══ -->
<section class="vt-sec vt-sec--graphite faq" id="faq">
	<div class="vt-contain">
		<p class="vt-eye">Common Questions</p>
		<h2>Objection handling.</h2>
		<div class="faq__list">
			{faqs.map((faq) => (
				<details class="faq__item">
					<summary>{faq.q}</summary>
					<p>{faq.a}</p>
				</details>
			))}
		</div>
	</div>
</section>

<!-- ═══ 13. FINAL CTA — command decision panel ═══ -->
<section class="vt-sec vt-sec--steel final">
	<div class="vt-contain final__inner">
		<div class="final__copy">
			<p class="vt-eye">Decision Point</p>
			<h2>Get the data. Know your options.</h2>
			<p class="vt-sub">Take the private assessment and see whether a men's health evaluation may be the right next step.</p>
			<div class="vt-btn-row" style="margin-top:1.25rem;">
				<a class="vt-btn vt-btn--bronze" href="/demos/hormone-trt/assessment">Run the Assessment &rarr;</a>
				<a class="vt-btn vt-btn--outline" href="/demos/hormone-trt/book-consultation">Book a Private Consult</a>
			</div>
		</div>
		<div class="final__strip" aria-hidden="true">
			<div class="final__stat"><span class="final__stat-val">6</span><span class="final__stat-lbl">Protocol Steps</span></div>
			<div class="final__stat"><span class="final__stat-val">40+</span><span class="final__stat-lbl">Lab Markers</span></div>
			<div class="final__stat"><span class="final__stat-val">90-day</span><span class="final__stat-lbl">First Review</span></div>
		</div>
	</div>
</section>

<!-- ═══ DISCLAIMER ═══ -->
<div class="vt-sec--ink" style="padding:0 0 2rem;">
	<div class="vt-contain">
		<p class="disc">{brand.disclaimer}</p>
	</div>
</div>

</VantageLayout>

<style>
/* ═══════════════════════════════════════════════════════
   HOMEPAGE — VANTAGE Clinical Command Center
   Every section uses a DISTINCT layout pattern.
   ═══════════════════════════════════════════════════════ */

/* ─── 1. HERO: full-bleed with offset console ─── */
.hero { background: var(--vt-ink); padding: clamp(5rem, 10vw, 8rem) 0 0; }
.hero__copy { max-width: 580px; }
.hero__lead { font-size: 0.92rem; color: rgba(244,237,226,0.5); line-height: 1.6; max-width: 500px; margin-bottom: 1.5rem; }
.hero__micro { font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(244,237,226,0.2); margin-top: 1.5rem; }
.hero__console-wrap { margin-top: 3rem; padding-bottom: clamp(2rem, 4vw, 3rem); }
.hero__console { background: var(--vt-graphite); border: 1px solid var(--vt-border); border-radius: var(--vt-r); overflow: hidden; max-width: 780px; }
.hero__console-body { display: grid; grid-template-columns: 1.4fr 1fr; }
.hero__markers { padding: 1.25rem; display: flex; flex-direction: column; gap: 0.85rem; border-right: 1px solid var(--vt-border); }
.hero__marker { display: flex; align-items: center; gap: 0.75rem; }
.hero__marker-label { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(244,237,226,0.35); min-width: 4.5rem; }
.hero__marker-val { font-size: 0.72rem; font-weight: 800; color: var(--vt-bone); font-variant-numeric: tabular-nums; min-width: 5.5rem; text-align: right; }
.hero__marker-val small { font-size: 0.55rem; font-weight: 500; color: rgba(244,237,226,0.3); margin-left: 0.15rem; }
.hero__range { position: relative; flex: 1; height: 3px; background: rgba(255,255,255,0.04); border-radius: 2px; min-width: 80px; }
.hero__range-fill { position: absolute; top: 0; height: 100%; background: var(--vt-bronze); border-radius: 2px; }
.hero__range-fill--high { background: var(--vt-steel); }
.hero__range-opt { position: absolute; top: -1px; height: 5px; border: 1px solid rgba(255,255,255,0.08); border-radius: 2px; }
.hero__profile { padding: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; }
.hero__profile-head { font-size: 0.55rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--vt-bronze); }
.hero__chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.hero__chips span { font-size: 0.55rem; font-weight: 600; letter-spacing: 0.04em; padding: 0.2rem 0.5rem; border: 1px solid var(--vt-border); border-radius: var(--vt-r); color: var(--vt-sand); }
.hero__status { display: flex; align-items: center; gap: 0.4rem; font-size: 0.55rem; color: rgba(244,237,226,0.35); margin-top: auto; }
@media (max-width: 700px) { .hero__console-body { grid-template-columns: 1fr; } .hero__markers { border-right: none; border-bottom: 1px solid var(--vt-border); } .hero__marker { flex-wrap: wrap; } .hero__range { min-width: 60px; } }

/* ─── 2. STATUS RAIL ─── */
.rail { padding: 0.65rem 0; background: var(--vt-graphite); border-top: 1px solid var(--vt-border); border-bottom: 1px solid var(--vt-border); }
.rail__inner { display: flex; flex-wrap: wrap; gap: 0.75rem 2rem; justify-content: center; }
.rail__item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.62rem; font-weight: 600; color: rgba(244,237,226,0.35); letter-spacing: 0.03em; }

/* ─── 3. PILLARS — operating system strip ─── */
.pillars h2 { max-width: 520px; margin-bottom: 2.5rem; }
.pillars__track { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border: 1px solid var(--vt-border); border-radius: var(--vt-r); overflow: hidden; }
.pillars__block { padding: 1.5rem; border-right: 1px solid var(--vt-border); }
.pillars__block:last-child { border-right: none; }
.pillars__num { font-size: 0.6rem; font-weight: 800; color: var(--vt-bronze); letter-spacing: 0.08em; display: block; margin-bottom: 0.5rem; }
.pillars__block h3 { font-size: 0.9rem; }
.pillars__block p { font-size: 0.75rem; color: rgba(244,237,226,0.4); line-height: 1.5; }
@media (max-width: 768px) { .pillars__track { grid-template-columns: 1fr 1fr; } .pillars__block:nth-child(2) { border-right: none; } .pillars__block:nth-child(-n+2) { border-bottom: 1px solid var(--vt-border); } }
@media (max-width: 480px) { .pillars__track { grid-template-columns: 1fr; } .pillars__block { border-right: none; border-bottom: 1px solid var(--vt-border); } .pillars__block:last-child { border-bottom: none; } }

/* ─── 4. SYMPTOM DOSSIER ─── */
.dossier__layout { display: grid; grid-template-columns: 1.6fr 1fr; gap: clamp(2rem, 4vw, 4rem); align-items: start; }
.dossier__clusters { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2rem; }
.dossier__cat { display: block; font-size: 0.55rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--vt-steel); margin-bottom: 0.5rem; }
.dossier__chips { display: flex; flex-wrap: wrap; gap: 0.3rem; }
.dossier__chip { font-size: 0.68rem; font-weight: 500; padding: 0.3rem 0.65rem; background: rgba(255,255,255,0.03); border: 1px solid var(--vt-border); border-radius: var(--vt-r); color: rgba(244,237,226,0.6); transition: border-color var(--vt-ease); }
.dossier__chip:hover { border-color: var(--vt-border-bronze); }
.dossier__side-lead { font-size: 0.82rem; color: var(--vt-bone); margin-bottom: 1rem; font-weight: 600; }
.dossier__side-steps { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.25rem; }
.dossier__side-step { display: flex; align-items: center; gap: 0.5rem; font-size: 0.72rem; color: rgba(244,237,226,0.5); }
.dossier__cta { width: 100%; text-align: center; }
@media (max-width: 768px) { .dossier__layout { grid-template-columns: 1fr; } .dossier__clusters { grid-template-columns: 1fr; } }

/* ─── 5. CARE TRACKS — stacked rows ─── */
.tracks__list { display: flex; flex-direction: column; gap: 0; margin-top: 2rem; }
.tracks__item { display: grid; grid-template-columns: 1.3fr 1fr; gap: 2rem; padding: 1.5rem 0; border-bottom: 1px solid var(--vt-border); text-decoration: none; transition: background var(--vt-ease); }
.tracks__item:first-child { padding-top: 0; }
.tracks__item:last-child { border-bottom: none; }
.tracks__item:hover { background: rgba(255,255,255,0.015); }
.tracks__num { font-size: 0.55rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: var(--vt-bronze); display: block; margin-bottom: 0.3rem; }
.tracks__left h3 { font-size: 1.1rem; margin-bottom: 0.3rem; }
.tracks__left p { font-size: 0.8rem; color: rgba(244,237,226,0.45); }
.tracks__right { display: flex; flex-direction: column; gap: 0.35rem; }
.tracks__service { display: flex; align-items: center; gap: 0.4rem; font-size: 0.72rem; color: rgba(244,237,226,0.5); }
.tracks__right .vt-link { margin-top: 0.5rem; }
@media (max-width: 600px) { .tracks__item { grid-template-columns: 1fr; gap: 0.75rem; } }

/* ─── 6. PROTOCOL TIMELINE — horizontal track ─── */
