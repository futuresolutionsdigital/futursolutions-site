---
import VantageLayout from '../../../layouts/VantageLayout.astro';
import { brand, performanceStandard, performanceBreakdown, gamePlanTracks, gameplan, treatmentStack, labCategories, providers, pricingTiers, patientWins, faqs } from '../../../data/vantage';
---

<VantageLayout title="VANTAGE Men's Health — Hormone, Sexual Health & Performance Medicine" description="Data-guided testosterone optimization, ED treatment, medical weight loss, peptide therapy, and longevity care for men. Private evaluations. Lab-based plans. Ongoing monitoring.">

<!-- ═══ 1. HERO — cinematic sports-performance intro ═══ -->
<section class="hero">
	<div class="hero__stripe" aria-hidden="true"></div>
	<div class="hero__stripe hero__stripe--2" aria-hidden="true"></div>
	<div class="vt-w--wide hero__grid">
		<div class="hero__copy">
			<span class="vt-e">Elite Men's Performance Medicine</span>
			<h1>Build your<br/><span class="hero__accent">comeback</span> plan.</h1>
			<p class="hero__lead">Hormone optimization, ED care, medical weight loss, and longevity medicine for men — guided by labs, licensed providers, and ongoing performance tracking.</p>
			<div class="vt-btn-row">
				<a class="vt-btn vt-btn--red" href="/demos/hormone-trt/assessment">Start My Assessment &rarr;</a>
				<a class="vt-btn vt-btn--dark" href="/demos/hormone-trt/book-consultation">Book a Private Consult</a>
			</div>
		</div>
		<div class="hero__visual" aria-hidden="true">
			<div class="vt-img hero__img"><span class="vt-img__label">Performance Lab</span></div>
			<div class="hero__stat-card">
				<div class="hero__stat-hdr">Performance Scoreboard</div>
				<div class="hero__stat-row"><span class="hero__label">Energy</span><span class="hero__bar"><span class="hero__fill" style="width:35%"></span></span><span class="hero__val">Low</span></div>
				<div class="hero__stat-row"><span class="hero__label">Libido</span><span class="hero__bar"><span class="hero__fill" style="width:28%"></span></span><span class="hero__val">Low</span></div>
				<div class="hero__stat-row"><span class="hero__label">Recovery</span><span class="hero__bar"><span class="hero__fill" style="width:42%"></span></span><span class="hero__val">Below</span></div>
				<div class="hero__stat-row"><span class="hero__label">Body Comp</span><span class="hero__bar"><span class="hero__fill" style="width:50%"></span></span><span class="hero__val">Mid</span></div>
				<div class="hero__stat-row"><span class="hero__label">Hormones</span><span class="hero__bar"><span class="hero__fill hero__fill--alert" style="width:25%"></span></span><span class="hero__val">Flag</span></div>
				<div class="hero__stat-foot">
					<span class="hero__badge">Provider Review Required</span>
					<span class="hero__pending">Lab Work Pending</span>
				</div>
			</div>
		</div>
	</div>
	<div class="vt-w--wide hero__status">
		<span>Assessment</span><span class="hero__dot"></span>
		<span>Labs</span><span class="hero__dot"></span>
		<span>Provider Review</span><span class="hero__dot"></span>
		<span>Plan</span><span class="hero__dot"></span>
		<span>Monitoring</span>
	</div>
</section>

<!-- ═══ 2. PERFORMANCE STANDARD — bold band ═══ -->
<section class="standard">
	<div class="vt-w">
		<span class="standard__title">The VANTAGE Standard</span>
		<div class="standard__pillars">
			{performanceStandard.map((p) => (
				<div class="standard__pillar">
					<span class="standard__num">{p.num}</span>
					<div>
						<h3>{p.title}</h3>
						<p>{p.description}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<!-- ═══ 3. PERFORMANCE BREAKDOWN — scoreboard stat blocks ═══ -->
<section class="vt-s vt-s--black breakdown" id="problems">
	<div class="vt-w">
		<span class="vt-e">Performance Breakdown</span>
		<h2>Where are you losing performance?</h2>
		<p class="vt-sub">Men rarely come in for "hormones." They come in because something feels off. These signals overlap — the right starting point is a private evaluation, not guesswork.</p>
		<div class="breakdown__grid">
			{performanceBreakdown.map((item) => (
				<a class="breakdown__card" href={item.href}>
					<span class="breakdown__signal">{item.signal}</span>
					<span class="vt-redline"></span>
					<p class="breakdown__issue">{item.issue}</p>
					<span class="breakdown__path">{item.pathway} &rarr;</span>
				</a>
			))}
		</div>
	</div>
</section>

<!-- ═══ 4. GAME PLAN TRACKS — playbook panels ═══ -->
<section class="vt-s vt-s--charcoal tracks">
	<div class="vt-w">
		<span class="vt-e">Game Plans</span>
		<h2>Choose your starting game plan.</h2>
		<div class="tracks__list">
			{gamePlanTracks.map((track) => (
				<a class="tracks__panel" href={track.href}>
					<div class="tracks__head">
						<span class="tracks__num">Game Plan {track.num}</span>
						<h3>{track.title}</h3>
					</div>
					<div class="tracks__body">
						<div class="tracks__col">
							<span class="tracks__col-label">Common Signs</span>
							{track.signs.map((s) => <span class="tracks__tag">{s}</span>)}
						</div>
						<div class="tracks__col">
							<span class="tracks__col-label">What We Evaluate</span>
							{track.evaluates.map((e) => <span class="tracks__eval">{e}</span>)}
						</div>
						<div class="tracks__col">
							<span class="tracks__col-label">Possible Treatments</span>
							{track.treatments.map((t) => <span class="tracks__treat">{t}</span>)}
						</div>
					</div>
					<div class="tracks__foot">
						<span class="tracks__first">First step: {track.firstStep}</span>
						<span class="vt-link">Explore this plan &rarr;</span>
					</div>
				</a>
			))}
		</div>
	</div>
</section>

<!-- ═══ 5. THE VANTAGE GAME PLAN — field-line horizontal steps ═══ -->
<section class="vt-s vt-s--bone gp">
	<div class="vt-w">
		<span class="vt-e">The Process</span>
		<h2>The VANTAGE Game Plan.</h2>
		<p class="vt-sub">Treatment decisions are based on symptoms, lab results, health history, goals, and ongoing follow-up — not one-size-fits-all protocols.</p>
		<div class="gp__field">
			<div class="gp__line" aria-hidden="true"></div>
			{gameplan.map((s, i) => (
				<div class:list={['gp__step', { 'gp__step--first': i === 0 }]}>
					<span class="gp__marker">{s.step}</span>
					<span class="gp__label">{s.label}</span>
					<p class="gp__desc">{s.description}</p>
				</div>
			))}
		</div>
		<a class="vt-btn vt-btn--red" href="/demos/hormone-trt/assessment" style="margin-top:2rem;">Start With the Assessment &rarr;</a>
	</div>
</section>

<!-- ═══ 6. PERFORMANCE MEDICINE STACK — stacked category bands ═══ -->
<section class="vt-s vt-s--black stack" id="treatments">
	<div class="vt-w">
		<span class="vt-e">Treatment Map</span>
		<h2>Performance medicine stack.</h2>
		<p class="vt-sub">Integrated care for hormones, performance, and long-term vitality.</p>
		<div class="stack__bands">
			{treatmentStack.map((group) => (
				<div class="stack__band">
					<span class="stack__cat">{group.category}</span>
					<div class="stack__items">
						{group.items.map((item) => (
							<a class="stack__item" href={item.href}>{item.title}<span>&rarr;</span></a>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<!-- ═══ 7. LAB SECTION — sports science biomarker tiles ═══ -->
<section class="vt-s vt-s--charcoal labs">
	<div class="vt-w--wide">
		<div class="labs__split">
			<div class="labs__text">
				<span class="vt-e">Lab Intelligence</span>
				<h2>Labs turn symptoms into a strategy.</h2>
				<p class="vt-sub">Not every man with low energy needs TRT. VANTAGE looks at hormones, metabolic health, recovery markers, history, and goals before recommending treatment.</p>
				<div class="vt-img labs__img"><span class="vt-img__label">Biomarker Review</span></div>
				<a class="vt-btn vt-btn--red" href="/demos/hormone-trt/how-it-works" style="margin-top:1.25rem;">See the Full Process &rarr;</a>
			</div>
			<div class="labs__tiles" aria-hidden="true">
				<div class="labs__tiles-hdr">Comprehensive Panel</div>
				<div class="labs__tiles-inner">
					{labCategories.map((cat, i) => (
						<div class="labs__tile">
							<span class="labs__tile-group">{cat.group}</span>
							<span class="labs__tile-name">{cat.name}</span>
							<div class="labs__tile-bar"><div class="labs__tile-fill" style={`width:${[65,45,82,70,55,60,78,48][i]}%`}></div></div>
						</div>
					))}
				</div>
				<div class="labs__tiles-foot">Results reviewed with provider · Treatment only when appropriate</div>
			</div>
		</div>
	</div>
</section>

<!-- ═══ 8. PROVIDERS — roster-style ═══ -->
<section class="vt-s vt-s--black roster" id="providers">
	<div class="vt-w">
		<span class="vt-e">Performance Medical Team</span>
		<h2>Provider-led care with guardrails.</h2>
		<p class="vt-sub" style="margin-bottom:2rem;">Every treatment plan is built and monitored by a licensed provider. Medical review before treatment. Ongoing monitoring. Fertility and safety considered.</p>
		<div class="roster__list">
			{providers.map((prov) => (
				<div class="roster__card">
					<div class="roster__id">
						<span class="roster__initials">{prov.initials}</span>
						<div class="roster__name-block">
							<h3>{prov.name}</h3>
							<span class="roster__role">{prov.role}</span>
						</div>
					</div>
					<span class="roster__creds">{prov.credentials}</span>
					<div class="roster__tags">
						{prov.specialties.map((s) => <span class="roster__tag">{s}</span>)}
					</div>
					<p class="roster__bio">{prov.bio}</p>
				</div>
			))}
		</div>
		<div class="roster__rails">
			<span>Medical review before any treatment</span>
			<span>Ongoing lab monitoring and adjustments</span>
			<span>Fertility and safety considerations</span>
			<span>Not every patient is a candidate</span>
		</div>
	</div>
</section>

<!-- ═══ 9. PRICING — club membership board ═══ -->
<section class="vt-s vt-s--carbon pricing">
	<div class="vt-w">
		<span class="vt-e">Care Plans</span>
		<h2>Built for ongoing optimization — not one-off injections.</h2>
		<div class="pricing__board">
			{pricingTiers.map((tier) => (
				<div class:list={['pricing__col', { 'pricing__col--featured': tier.featured }]}>
					{tier.featured && <span class="pricing__badge">Recommended</span>}
					<h3>{tier.name}</h3>
					<p class="pricing__tag">{tier.tagline}</p>
					<span class="pricing__price">{tier.price}</span>
					<ul class="pricing__list">
						{tier.includes.map((item) => <li>{item}</li>)}
					</ul>
					<a class="vt-btn vt-btn--red pricing__cta" href="/demos/hormone-trt/pricing">{tier.cta}</a>
				</div>
			))}
		</div>
		<p class="pricing__note">Labs, medications, and follow-up costs are explained before treatment begins. No hidden fees.</p>
	</div>
</section>

<!-- ═══ 10. PATIENT WINS — numbered entries ═══ -->
<section class="vt-s vt-s--black wins">
	<div class="vt-w">
		<span class="vt-e">Patient Wins</span>
		<h2>Real care creates clarity, not hype.</h2>
		<div class="wins__grid">
			{patientWins.map((w) => (
				<div class="wins__card">
					<span class="wins__num">Win {w.num}</span>
					<div class="wins__meta"><strong>Concern:</strong> {w.concern}</div>
					<div class="wins__meta"><strong>Result:</strong> {w.result}</div>
					<blockquote class="wins__quote">&ldquo;{w.quote}&rdquo;</blockquote>
					<span class="wins__author">{w.author}</span>
				</div>
			))}
		</div>
		<p class="wins__disc">Individual results vary. Treatment requires provider evaluation. These are fictional testimonials for demonstration purposes.</p>
	</div>
</section>

<!-- ═══ 11. FAQ — grouped accordion ═══ -->
<section class="vt-s vt-s--charcoal faq" id="faq">
	<div class="vt-w">
		<span class="vt-e">Common Questions</span>
		<h2>Straight answers.</h2>
		<div class="faq__list">
			{faqs.map((f) => (
				<details class="faq__item">
					<summary>
						<span class="faq__group">{f.group}</span>
						<span class="faq__q">{f.q}</span>
					</summary>
					<p>{f.a}</p>
				</details>
			))}
		</div>
	</div>
</section>

<!-- ═══ 12. FINAL CTA — decisive action ═══ -->
<section class="final">
	<div class="vt-w final__inner">
		<span class="vt-e">Decision Time</span>
		<h2>Ready to build your plan?</h2>
		<p class="vt-sub">Start with a private assessment. If care is appropriate, your provider will guide the next step.</p>
		<div class="vt-btn-row" style="margin-top:1.5rem;">
			<a class="vt-btn vt-btn--red" href="/demos/hormone-trt/assessment">Start My Assessment &rarr;</a>
			<a class="vt-btn vt-btn--dark" href="/demos/hormone-trt/book-consultation">Book a Private Consult</a>
		</div>
	</div>
</section>

<!-- ═══ DISCLAIMER ═══ -->
<div class="vt-s--black" style="padding:0 0 2rem;">
	<div class="vt-w">
		<p class="disc">{brand.disclaimer}</p>
	</div>
</div>

</VantageLayout>

<style>
/* ═══════════════════════════════════════════════════════
   HOMEPAGE — VANTAGE Sports Performance Medicine
   ═══════════════════════════════════════════════════════ */

/* 1. HERO — cinematic sports-performance */
.hero { background: var(--vt-black); padding: clamp(5rem, 10vw, 9rem) 0 0; position: relative; overflow: hidden; }
.hero__stripe { position: absolute; top: -40%; right: -10%; width: 45%; height: 180%; background: var(--vt-red); transform: skewX(-12deg); opacity: 0.05; pointer-events: none; }
.hero__stripe--2 { top: -60%; right: 5%; width: 20%; opacity: 0.025; }
.hero__grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 4rem); align-items: start; }
.hero__copy { position: relative; z-index: 1; padding-bottom: clamp(2rem, 4vw, 3rem); }
.hero__accent { color: var(--vt-red); }
.hero__lead { font-size: 0.92rem; color: rgba(244,239,231,0.55); max-width: 460px; margin-bottom: 1.75rem; line-height: 1.6; }
.hero__visual { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 0.75rem; }
.hero__img { min-height: 120px; }
.hero__stat-card { background: var(--vt-charcoal); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--vt-r); overflow: hidden; border-top: 3px solid var(--vt-red); }
.hero__stat-hdr { padding: 0.75rem 1rem; font-size: 0.58rem; font-weight: 900; letter-spacing: 0.16em; text-transform: uppercase; color: var(--vt-white); border-bottom: 1px solid rgba(255,255,255,0.06); background: repeating-linear-gradient(135deg, transparent, transparent 20px, rgba(255,255,255,0.008) 20px, rgba(255,255,255,0.008) 21px); }
.hero__stat-row { display: flex; align-items: center; gap: 0.6rem; padding: 0.55rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.04); }
.hero__label { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: rgba(244,239,231,0.4); min-width: 5.5rem; }
.hero__bar { flex: 1; height: 5px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden; }
.hero__fill { display: block; height: 100%; background: var(--vt-steel); border-radius: 2px; }
.hero__fill--alert { background: var(--vt-red); }
.hero__val { font-size: 0.58rem; font-weight: 800; color: var(--vt-silver); min-width: 2.5rem; text-align: right; letter-spacing: 0.04em; text-transform: uppercase; }
.hero__stat-foot { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 1rem; }
.hero__badge { font-size: 0.52rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--vt-red); }
.hero__pending { font-size: 0.5rem; color: rgba(244,239,231,0.2); letter-spacing: 0.06em; }
.hero__status { display: flex; align-items: center; gap: 0.5rem; padding: 1rem 0; border-top: 1px solid rgba(255,255,255,0.04); margin-top: 1.5rem; }
.hero__status span { font-size: 0.55rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(244,239,231,0.25); }
.hero__dot { width: 3px; height: 3px; background: var(--vt-red); border-radius: 50%; flex-shrink: 0; }
@media (max-width: 768px) { .hero__grid { grid-template-columns: 1fr; } .hero__img { display: none; } .hero__visual { max-width: 420px; } }

/* 2. PERFORMANCE STANDARD — bold red band */
.standard { padding: 0; background: var(--vt-charcoal); border-top: 1px solid rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.04); }
.standard__title { display: block; font-size: 0.55rem; font-weight: 900; letter-spacing: 0.22em; text-transform: uppercase; color: var(--vt-red); padding: 0.85rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
.standard__pillars { display: grid; grid-template-columns: repeat(4, 1fr); }
.standard__pillar { display: flex; gap: 0.65rem; padding: 1.1rem 1rem 1.1rem 0; border-right: 1px solid rgba(255,255,255,0.04); align-items: start; }
.standard__pillar:last-child { border-right: none; }
.standard__num { font-size: 1.6rem; font-weight: 900; color: var(--vt-red); line-height: 1; min-width: 1.8rem; opacity: 0.7; }
.standard__pillar h3 { font-size: 0.78rem; margin-bottom: 0.15rem; }
.standard__pillar p { font-size: 0.68rem; color: rgba(244,239,231,0.4); line-height: 1.45; }
@media (max-width: 768px) { .standard__pillars { grid-template-columns: 1fr 1fr; } .standard__pillar:nth-child(2) { border-right: none; } .standard__pillar:nth-child(-n+2) { border-bottom: 1px solid rgba(255,255,255,0.04); } }
@media (max-width: 480px) { .standard__pillars { grid-template-columns: 1fr; } .standard__pillar { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.04); } .standard__pillar:last-child { border-bottom: none; } }

/* 3. PERFORMANCE BREAKDOWN — scoreboard cards */
.breakdown h2 { max-width: 480px; margin-bottom: 0.5rem; }
.breakdown .vt-sub { margin-bottom: 2.5rem; }
.breakdown__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(255,255,255,0.04); border-radius: var(--vt-r); overflow: hidden; }
.breakdown__card { display: flex; flex-direction: column; gap: 0.5rem; padding: 1.5rem; padding-left: 1.25rem; background: var(--vt-charcoal); text-decoration: none; transition: background var(--vt-ease), border-color var(--vt-ease); border-left: 3px solid transparent; }
.breakdown__card:hover { background: var(--vt-carbon); border-left-color: var(--vt-red); }
.breakdown__signal { font-size: 0.95rem; font-weight: 900; color: var(--vt-white); letter-spacing: -0.01em; }
.breakdown__issue { font-size: 0.75rem; color: rgba(244,239,231,0.5); line-height: 1.5; flex: 1; }
.breakdown__path { font-size: 0.62rem; font-weight: 700; color: var(--vt-red); letter-spacing: 0.04em; text-transform: uppercase; margin-top: 0.25rem; }
@media (max-width: 768px) { .breakdown__grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 480px) { .breakdown__grid { grid-template-columns: 1fr; } }

/* 4. GAME PLAN TRACKS — stacked playbook panels */
.tracks__list { display: flex; flex-direction: column; gap: 1px; margin-top: 2rem; background: rgba(255,255,255,0.04); border-radius: var(--vt-r); overflow: hidden; }
.tracks__panel { display: block; background: var(--vt-carbon); padding: 1.5rem; padding-left: 1.25rem; text-decoration: none; transition: background var(--vt-ease), border-color var(--vt-ease); border-left: 3px solid transparent; }
.tracks__panel:hover { background: rgba(255,255,255,0.03); border-left-color: var(--vt-red); }
.tracks__head { display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.04); padding-bottom: 0.75rem; }
.tracks__num { font-size: 0.55rem; font-weight: 900; letter-spacing: 0.12em; text-transform: uppercase; color: var(--vt-red); white-space: nowrap; }
.tracks__head h3 { font-size: 1.05rem; }
.tracks__body { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 1rem; }
.tracks__col-label { display: block; font-size: 0.52rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--vt-steel); margin-bottom: 0.4rem; }
.tracks__tag, .tracks__eval, .tracks__treat { display: block; font-size: 0.72rem; color: rgba(244,239,231,0.5); padding: 0.15rem 0; }
.tracks__foot { display: flex; justify-content: space-between; align-items: center; padding-top: 0.75rem; border-top: 1px solid rgba(255,255,255,0.04); }
.tracks__first { font-size: 0.68rem; color: rgba(244,239,231,0.35); font-style: italic; }
@media (max-width: 600px) { .tracks__body { grid-template-columns: 1fr; gap: 0.75rem; } .tracks__head { flex-direction: column; gap: 0.3rem; } }

/* 5. GAME PLAN — field-line steps on bone */
.gp { position: relative; }
.gp::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(90deg, transparent, transparent 79px, rgba(0,0,0,0.025) 79px, rgba(0,0,0,0.025) 80px); pointer-events: none; }
.gp h2 { max-width: 380px; position: relative; }
.gp .vt-sub { margin-bottom: 2.5rem; }
.gp__field { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0; position: relative; }
.gp__line { position: absolute; top: 1.15rem; left: 1.5rem; right: 1.5rem; height: 2px; background: var(--vt-border-light); z-index: 0; }
.gp__step { position: relative; z-index: 1; text-align: center; }
.gp__marker { display: flex; align-items: center; justify-content: center; width: 2.3rem; height: 2.3rem; margin: 0 auto 0.75rem; font-size: 0.7rem; font-weight: 900; color: var(--vt-white); background: var(--vt-charcoal); border: 2px solid var(--vt-charcoal); border-radius: 50%; }
.gp__step--first .gp__marker { background: var(--vt-red); border-color: var(--vt-red); }
