---
import AureaLayout from '../../../../layouts/AureaLayout.astro';
import { treatmentCategories, featuredTreatments } from '../../../../data/aurea';

const categoryTreatmentMap: Record<string, string[]> = {
	'Injectables': ['Botox / Wrinkle Relaxers', 'Dermal Fillers', 'Lip Filler'],
	'Lasers & Light': ['Morpheus8', 'IPL Photofacial'],
	'Skin Treatments': ['Hydrafacial', 'Chemical Peels'],
	'Wellness & Weight Support': ['Medical Weight Loss'],
};

const categoryTreatments = treatmentCategories
	.filter((cat) => categoryTreatmentMap[cat.title])
	.map((cat) => ({
		...cat,
		treatments: featuredTreatments.filter((t) => categoryTreatmentMap[cat.title]?.includes(t.name)),
	}));

const treatmentFaqs = [
	{
		question: 'How do I know which treatment is right for me?',
		answer: 'Your provider will help you understand options during your consultation. They\u2019ll review your goals, anatomy, and medical history to recommend a treatment plan that fits you specifically.',
	},
	{
		question: 'Can I combine treatments?',
		answer: 'Yes, many patients benefit from combination approaches. For example, Botox with fillers for facial balancing, or Hydrafacials between laser sessions. Your provider will design a plan that makes sense for your goals and timeline.',
	},
	{
		question: 'Is there downtime?',
		answer: 'It depends on the treatment. Many injectable treatments have minimal downtime, while laser and RF treatments may involve a few days of recovery. Your provider will explain what to expect before you begin.',
	},
	{
		question: 'Who performs the treatments?',
		answer: 'All treatments are performed by licensed professionals\u2014including physicians, nurse practitioners, and licensed aestheticians\u2014under medical oversight at our Temecula clinic.',
	},
];
---

<AureaLayout
	title="Treatments | Auréa Skin & Aesthetics"
	description="Explore injectables, laser treatments, skin therapies, and wellness services at Auréa Skin & Aesthetics in Temecula, CA."
>
	<section class="treatments-hero" aria-labelledby="treatments-heading">
		<div class="aurea-container">
			<p class="aurea-eyebrow">Treatment Menu</p>
			<h1 id="treatments-heading">Explore treatments designed around your goals.</h1>
			<p class="aurea-lead">
				Browse injectables, laser treatments, skin therapies, body options, and wellness support — then start with a consultation when you're ready.
			</p>
			<div class="aurea-btn-row">
				<a class="aurea-btn aurea-btn--primary" href="/demos/med-spa/contact">Book a Consultation</a>
				<a class="aurea-btn aurea-btn--secondary" href="/demos/med-spa/#concerns">Find My Treatment Path</a>
			</div>
		</div>
	</section>

	{categoryTreatments.map((category) => (
		<section class="aurea-section aurea-section--warm treatments-category" aria-labelledby={`cat-${category.title.toLowerCase().replace(/[^a-z]+/g, '-')}`}>
			<div class="aurea-container">
				<div class="treatments-category__header">
					<h2 id={`cat-${category.title.toLowerCase().replace(/[^a-z]+/g, '-')}`}>{category.title}</h2>
					<p>{category.description}</p>
				</div>
				<div class="treatments-grid">
					{category.treatments.map((treatment) => (
						<article class="treatment-card aurea-card">
							<h3>{treatment.name}</h3>
							<p class="treatment-card__benefit">{treatment.benefit}</p>
							<div class="treatment-card__tags">
								{treatment.tags.map((tag) => (
									<span class="treatment-card__pill">{tag}</span>
								))}
							</div>
							{treatment.href !== '/demos/med-spa/contact' && (
							<a class="treatment-card__link" href={treatment.href}>Learn More &rarr;</a>
						)}
						<a class="treatment-card__link" href="/demos/med-spa/contact">Book Consultation &rarr;</a>
						</article>
					))}
				</div>
			</div>
		</section>
	))}

	<section class="aurea-section" aria-labelledby="guidance-heading">
		<div class="aurea-container">
			<div class="guidance-panel aurea-card">
				<h2 id="guidance-heading">Not sure where to start?</h2>
				<p>Use our concern-based guide to find the right treatment path, or book a consultation and let your provider help you decide.</p>
				<div class="aurea-btn-row">
					<a class="aurea-btn aurea-btn--primary" href="/demos/med-spa/#concerns">Find My Treatment Path</a>
					<a class="aurea-btn aurea-btn--secondary" href="/demos/med-spa/contact">Book Consultation</a>
				</div>
			</div>
		</div>
	</section>

	<section class="aurea-section aurea-section--warm" aria-labelledby="faq-heading">
		<div class="aurea-container">
			<div class="treatments-faq__header">
				<p class="aurea-eyebrow">FAQ</p>
				<h2 id="faq-heading">Common treatment questions</h2>
			</div>
			<div class="treatments-faq__list">
				{treatmentFaqs.map((faq) => (
					<details class="treatments-faq__item">
						<summary>{faq.question}</summary>
						<p>{faq.answer}</p>
					</details>
				))}
			</div>
		</div>
	</section>

	<section class="treatments-final" aria-labelledby="final-heading">
		<div class="aurea-container">
			<div class="treatments-final__inner">
				<h2 id="final-heading">Ready to begin your treatment plan?</h2>
				<p>Book a consultation and your provider will help you choose the right path.</p>
				<div class="aurea-btn-row treatments-final__actions">
					<a class="aurea-btn aurea-btn--champagne" href="/demos/med-spa/contact">Book a Consultation</a>
					<a class="aurea-btn treatments-final__ghost" href="/demos/med-spa">Back to Home</a>
				</div>
			</div>
		</div>
	</section>
</AureaLayout>

<style>
	.treatments-hero {
		padding-block: clamp(4rem, 8vw, 7rem);
		background:
			radial-gradient(ellipse at 75% 20%, color-mix(in srgb, var(--aurea-champagne) 12%, transparent), transparent 55%),
			linear-gradient(180deg, var(--aurea-bg) 0%, var(--aurea-ivory) 100%);
	}

	.treatments-hero h1 {
		max-width: 820px;
	}

	.treatments-category {
		border-bottom: none;
	}

	.treatments-category + .treatments-category {
		padding-top: 0;
	}

	.treatments-category__header {
		max-width: 680px;
		margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
	}

	.treatments-category__header p {
		color: var(--aurea-muted);
		font-size: clamp(1rem, 0.95rem + 0.2vw, 1.1rem);
		line-height: 1.6;
	}

	.treatments-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.treatment-card {
		padding: clamp(1.5rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
	}

	.treatment-card h3 {
		margin-bottom: 0.5rem;
	}

	.treatment-card__benefit {
		color: var(--aurea-muted);
		font-size: 0.95rem;
		line-height: 1.6;
		flex: 1;
	}

	.treatment-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 1.25rem;
	}

	.treatment-card__pill {
		display: inline-flex;
		align-items: center;
		padding: 0.35rem 0.75rem;
		border-radius: 999px;
		background: var(--aurea-bg-warm);
		border: 1px solid var(--aurea-border);
		color: var(--aurea-muted);
		font-size: 0.78rem;
		font-weight: 600;
		white-space: nowrap;
	}

	.treatment-card__link {
		display: inline-flex;
		align-items: center;
		margin-top: 1.25rem;
		padding-top: 1rem;
		border-top: 1px solid var(--aurea-border);
		color: var(--aurea-charcoal);
		font-size: 0.9rem;
		font-weight: 700;
	}

	.treatment-card__link:hover {
		color: var(--aurea-champagne);
	}

	.guidance-panel {
		padding: clamp(2rem, 4vw, 3.5rem);
		text-align: center;
		max-width: 720px;
		margin-inline: auto;
	}

	.guidance-panel p {
		color: var(--aurea-muted);
		font-size: clamp(1rem, 0.95rem + 0.2vw, 1.1rem);
		line-height: 1.65;
		max-width: 560px;
		margin-inline: auto;
	}

	.guidance-panel .aurea-btn-row {
		justify-content: center;
	}

	.treatments-faq__header {
		max-width: 680px;
		margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
	}

	.treatments-faq__list {
		display: grid;
		gap: 0.75rem;
		max-width: 800px;
	}

	.treatments-faq__item {
		border: 1px solid var(--aurea-border);
		border-radius: var(--aurea-radius);
		background: var(--aurea-white);
		overflow: hidden;
		transition: box-shadow 0.2s ease;
	}

	.treatments-faq__item:hover {
		box-shadow: 0 8px 24px rgba(36, 35, 33, 0.04);
	}

	.treatments-faq__item[open] {
		box-shadow: 0 8px 24px rgba(36, 35, 33, 0.06);
	}

	.treatments-faq__item summary {
		padding: 1.25rem 1.5rem;
		font-weight: 700;
		font-size: 1rem;
		color: var(--aurea-charcoal);
		cursor: pointer;
		list-style: none;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.treatments-faq__item summary::-webkit-details-marker {
		display: none;
	}

	.treatments-faq__item summary::after {
		content: '+';
		flex-shrink: 0;
		width: 1.5rem;
		height: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: var(--aurea-bg-warm);
		color: var(--aurea-champagne);
		font-size: 1.1rem;
		font-weight: 700;
		transition: transform 0.2s ease;
	}

	.treatments-faq__item[open] summary::after {
		content: '\2212';
		transform: rotate(180deg);
	}

	.treatments-faq__item p {
		padding: 0 1.5rem 1.25rem;
		margin: 0;
		color: var(--aurea-muted);
		font-size: 0.95rem;
		line-height: 1.65;
	}

	.treatments-final {
		padding-block: clamp(5.5rem, 10vw, 9rem);
		background: var(--aurea-charcoal);
	}

	.treatments-final__inner {
		text-align: center;
		max-width: 640px;
		margin-inline: auto;
	}

	.treatments-final h2 {
		color: var(--aurea-white);
	}

	.treatments-final p {
		color: rgba(255, 255, 255, 0.6);
		font-size: clamp(1.05rem, 1rem + 0.2vw, 1.15rem);
		line-height: 1.6;
	}

	.treatments-final__actions {
		justify-content: center;
	}

	.treatments-final__ghost {
		border-color: rgba(255, 255, 255, 0.2);
		background: transparent;
		color: rgba(255, 255, 255, 0.8);
	}

	.treatments-final__ghost:hover {
		border-color: rgba(255, 255, 255, 0.4);
		background: rgba(255, 255, 255, 0.06);
		color: var(--aurea-white);
	}

	@media (max-width: 700px) {
		.treatments-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
