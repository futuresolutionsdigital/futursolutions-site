---
import AureaLayout from '../../../../layouts/AureaLayout.astro';
import AureaTreatmentQuickFacts from '../../../../components/AureaTreatmentQuickFacts.astro';

const quickFacts = [
	{ label: 'Treatment time', value: '15–30 minutes' },
	{ label: 'Downtime', value: 'Minimal' },
	{ label: 'Results begin', value: '3–7 days' },
	{ label: 'Full results', value: 'About 2 weeks' },
	{ label: 'Lasts', value: 'Typically 3–4 months' },
	{ label: 'Best for', value: 'Forehead lines, frown lines, crow\'s feet' },
	{ label: 'Provider', value: 'Licensed medical provider' },
	{ label: 'Pricing', value: 'Consultation required' },
];

const treatmentAreas = [
	{ title: 'Forehead lines', description: 'Horizontal lines that appear when raising the brows, often among the first signs of facial aging.' },
	{ title: 'Frown lines / "11s"', description: 'Vertical creases between the brows caused by squinting, concentrating, or frowning.' },
	{ title: 'Crow\'s feet', description: 'Fine lines radiating from the outer corners of the eyes, most visible when smiling or squinting.' },
	{ title: 'Brow lift refinement', description: 'Subtle relaxation of the muscles that pull the brow downward, helping create a more open, refreshed appearance.' },
	{ title: 'Bunny lines', description: 'Fine diagonal wrinkles across the bridge of the nose, often visible when scrunching or laughing.' },
	{ title: 'Chin dimpling', description: 'A textured, "orange peel" appearance on the chin caused by overactive mentalis muscle contractions.' },
	{ title: 'Jawline / masseter', description: 'Treatment of the masseter muscle may help slim the jawline and relieve tension.', note: 'Candidacy varies — your provider will assess your anatomy and goals.' },
];

const goodFit = [
	'You want to soften expression lines',
	'You prefer subtle, natural-looking results',
	'You are new to aesthetics and want a conservative first step',
	'You want a low-downtime treatment',
	'You are comfortable starting with a consultation',
];

const notRight = [
	'You are pregnant or breastfeeding',
	'You have certain neuromuscular conditions',
	'You have an active infection near the treatment area',
	'You want permanent results',
	'Your provider recommends another option',
];

const timeline = [
	{ step: 'Consultation', description: 'We discuss your goals, facial movement, medical history, and preferred level of correction.' },
	{ step: 'Treatment plan', description: 'Your provider maps conservative placement based on your anatomy.' },
	{ step: 'Treatment', description: 'Small injections are placed in targeted areas. Most appointments take 15–30 minutes.' },
	{ step: 'Results develop', description: 'You may begin noticing softening in 3–7 days, with full results around 2 weeks.' },
	{ step: 'Maintenance', description: 'Results typically last 3–4 months. Your provider can recommend a maintenance rhythm.' },
];

const beforeAfterAreas = [
	{ area: 'Forehead lines', id: 'forehead' },
	{ area: 'Frown lines', id: 'frown' },
	{ area: 'Crow\'s feet', id: 'crows-feet' },
];

const pricingCards = [
	{ title: 'New patient consultation', description: 'Your first visit includes a complete assessment and treatment recommendation.' },
	{ title: 'Per-unit treatment planning', description: 'Pricing is based on the number of units your provider recommends for optimal results.' },
	{ title: 'Maintenance visits', description: 'Returning patients benefit from streamlined appointments and continued treatment refinement.' },
	{ title: 'Membership savings', description: 'Members receive preferred pricing, priority booking, and bundled treatment benefits.' },
];

const safetyItems = [
	{ title: 'Licensed medical providers', description: 'Every injection is performed or supervised by trained, licensed medical professionals.' },
	{ title: 'Conservative first-time approach', description: 'First-time patients receive conservative dosing to build confidence and allow your provider to refine your treatment plan.' },
	{ title: 'Facial anatomy assessment', description: 'Your provider evaluates your facial structure, movement patterns, and skin quality before recommending placement.' },
	{ title: 'Clear aftercare guidance', description: 'You\'ll receive written aftercare instructions and know exactly what to expect during your recovery.' },
	{ title: 'Follow-up recommendations', description: 'We recommend a follow-up visit to assess your results and fine-tune your treatment if needed.' },
	{ title: 'Realistic expectations', description: 'We discuss what wrinkle relaxers can and cannot achieve so you feel confident and informed before treatment.' },
];

const faqs = [
	{ question: 'Will I still look natural?', answer: 'That\'s our priority. Your provider uses conservative placement designed to soften lines while preserving your natural expressions. The goal is a refreshed look, not a frozen one.' },
	{ question: 'Does Botox hurt?', answer: 'Most patients describe it as a brief pinch. The needles are very fine, and treatment is quick — typically under 30 minutes. Your provider can discuss comfort options if needed.' },
	{ question: 'How long does treatment take?', answer: 'Most wrinkle relaxer appointments take 15–30 minutes, including consultation and treatment time.' },
	{ question: 'When will I see results?', answer: 'You may begin to notice softening within 3–7 days. Full results typically develop over about 2 weeks.' },
	{ question: 'How long does Botox last?', answer: 'Results typically last 3–4 months. Your provider can recommend a maintenance schedule that keeps results consistent over time.' },
	{ question: 'Is there downtime?', answer: 'Most patients return to normal activities the same day. Your provider will advise on a few simple precautions to follow in the hours after treatment.' },
	{ question: 'Can I combine Botox with fillers or skin treatments?', answer: 'Yes. Many patients combine wrinkle relaxers with fillers for facial balancing, or with treatments like Hydrafacial or Morpheus8 for comprehensive results. Your provider will design a plan that makes sense.' },
	{ question: 'How do I know how many units I need?', answer: 'Unit count depends on the treatment area, your facial anatomy, and your desired outcome. Your provider will recommend a specific plan during your consultation.' },
	{ question: 'What should I avoid after treatment?', answer: 'Your provider will give you detailed aftercare instructions. Common recommendations include avoiding strenuous exercise, lying flat, and rubbing the treatment area for several hours.' },
	{ question: 'Who performs the treatment?', answer: 'All wrinkle relaxer treatments at Auréa are performed by licensed medical providers — including physicians and nurse practitioners — with specialized training in facial anatomy and injection technique.' },
];

const relatedTreatments = [
	{ title: 'Dermal Fillers', description: 'Restore lost volume in areas like cheeks, lips, and under-eyes for a more balanced, refreshed contour. Often combined with Botox for full facial balancing.', href: '/demos/med-spa/treatments' },
	{ title: 'Sculptra', description: 'A collagen-stimulating injectable that gradually restores facial volume over a series of treatments, ideal for patients seeking subtle, long-term improvement.', href: '/demos/med-spa/treatments' },
	{ title: 'Morpheus8', description: 'RF microneedling that firms, smooths, and remodels skin texture — a strong complement to injectables for patients focused on skin quality.', href: '/demos/med-spa/treatments' },
	{ title: 'Hydrafacial', description: 'A gentle, no-downtime facial that deeply cleanses and hydrates — a popular add-on to keep skin healthy between injectable appointments.', href: '/demos/med-spa/treatments' },
];
---

<AureaLayout
	title="Botox & Wrinkle Relaxers | Auréa Skin & Aesthetics"
	description="Explore natural-looking Botox and wrinkle relaxer treatments from Auréa Skin & Aesthetics, a premium med spa demo focused on consultation-first care, medical guidance, and refined aesthetic results."
>
	<!-- 1. Treatment Hero -->
	<section class="botox-hero" aria-labelledby="botox-hero-heading">
		<div class="aurea-container botox-hero__inner">
			<div class="botox-hero__content">
				<p class="aurea-eyebrow">Injectables</p>
				<h1 id="botox-hero-heading">Smooth expression lines without losing expression.</h1>
				<p class="aurea-lead">
					Wrinkle relaxer treatments designed to soften forehead lines, frown lines, and crow's feet while keeping your results balanced, natural, and true to your features.
				</p>
				<div class="aurea-btn-row">
					<a class="aurea-btn aurea-btn--primary" href="/demos/med-spa/contact">Book a Consultation</a>
					<a class="aurea-btn aurea-btn--secondary" href="#before-after">View Before &amp; After</a>
				</div>
				<ul class="botox-hero__trust" aria-label="Trust highlights">
					<li><span aria-hidden="true"></span>Licensed medical providers</li>
					<li><span aria-hidden="true"></span>Consultation-first approach</li>
					<li><span aria-hidden="true"></span>Natural-looking results</li>
				</ul>
			</div>

			<div class="botox-hero__visual" aria-hidden="true">
				<div class="botox-hero__panel">
					<div class="botox-hero__panel-corner"></div>
					<div class="botox-hero__panel-ambiance">
						<div class="botox-hero__panel-orb botox-hero__panel-orb--1"></div>
						<div class="botox-hero__panel-orb botox-hero__panel-orb--2"></div>
						<div class="botox-hero__panel-lines">
							<div></div><div></div><div></div>
						</div>
					</div>

					<div class="botox-hero__detail-card">
						<div class="botox-hero__detail-accent"></div>
						<div class="botox-hero__detail-name">Wrinkle Relaxer</div>
						<div class="botox-hero__detail-tags">Forehead &middot; Frown lines &middot; Crow's feet</div>
					</div>
				</div>

				<div class="botox-hero__stat-badge">
					<div class="botox-hero__stat-icon">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
					</div>
					<div class="botox-hero__stat-text">
						<span class="botox-hero__stat-value">15–30 min</span>
						<span class="botox-hero__stat-label">Treatment time</span>
					</div>
				</div>

				<div class="botox-hero__consult-badge">
					<span class="botox-hero__consult-dot"></span>
					Minimal downtime
				</div>
			</div>
		</div>
	</section>

	<!-- 2. Quick Facts Panel -->
	<section class="aurea-section" id="botox-facts" aria-labelledby="botox-facts-heading">
		<div class="aurea-container botox-facts__wrap">
			<AureaTreatmentQuickFacts facts={quickFacts} />
		</div>
	</section>

	<!-- 3. Overview Section -->
	<section class="aurea-section" id="botox-overview" aria-labelledby="botox-overview-heading">
		<div class="aurea-container">
			<div class="botox-section-header">
				<p class="aurea-eyebrow">Overview</p>
				<h2 id="botox-overview-heading">A refreshed look, not a different face.</h2>
				<p class="aurea-lead">
					Botox and other wrinkle relaxers work by temporarily relaxing targeted facial muscles that contribute to expression lines. The goal is subtlety — softening visible creases while preserving the natural movement, balance, and character of your face. Your provider's understanding of facial anatomy and conservative placement is what makes the difference between a natural result and an overdone one.
				</p>
			</div>
			<div class="botox-overview__grid">
				<article class="aurea-card botox-overview__card">
					<div class="botox-overview__card-icon" aria-hidden="true">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
					</div>
					<h3>Softens visible expression lines</h3>
					<p>Wrinkle relaxers are designed to reduce the appearance of dynamic lines that develop from repeated facial expressions.</p>
				</article>
				<article class="aurea-card botox-overview__card">
					<div class="botox-overview__card-icon" aria-hidden="true">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M16 16s-1.5-2-4-2-4 2-4 2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
					</div>
					<h3>Helps prevent deeper creasing</h3>
					<p>When used over time, treatment may help slow the progression of expression lines into deeper, more permanent creases.</p>
				</article>
				<article class="aurea-card botox-overview__card">
					<div class="botox-overview__card-icon" aria-hidden="true">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
					</div>
					<h3>Preserves natural facial movement</h3>
					<p>Thoughtful, conservative placement focuses on softening lines while maintaining the expressions that make your face yours.</p>
				</article>
			</div>
		</div>
	</section>

	<!-- 4. Treatment Areas -->
	<section class="aurea-section aurea-section--warm" id="botox-areas" aria-labelledby="botox-areas-heading">
		<div class="aurea-container">
			<div class="botox-section-header">
				<p class="aurea-eyebrow">Treatment Areas</p>
				<h2 id="botox-areas-heading">Areas wrinkle relaxers can address.</h2>
			</div>
			<div class="botox-areas__grid">
				{treatmentAreas.map((area) => (
					<article class="aurea-card botox-areas__card">
						<h3>{area.title}</h3>
						<p>{area.description}</p>
						{area.note && <p class="botox-areas__note"><em>{area.note}</em></p>}
					</article>
				))}
			</div>
			<div class="botox-areas__disclaimer">
				<p>Not every area is appropriate for every patient. Your provider will assess your facial anatomy and recommend only the treatment areas that align with your goals.</p>
			</div>
		</div>
	</section>

	<!-- 5. Best Candidate Section -->
	<section class="aurea-section" id="botox-candidate" aria-labelledby="botox-candidate-heading">
		<div class="aurea-container">
			<div class="botox-section-header">
				<p class="aurea-eyebrow">Candidacy</p>
				<h2 id="botox-candidate-heading">Is Botox right for you?</h2>
				<p class="aurea-lead">
					Wrinkle relaxers are one of the most popular aesthetic treatments, but they're not for everyone. Here's a general guide — your provider will make a personalized recommendation during your consultation.
				</p>
			</div>
			<div class="botox-candidate__grid">
				<div class="aurea-card botox-candidate__card botox-candidate__card--good">
					<h3>
						<span class="botox-candidate__icon botox-candidate__icon--good" aria-hidden="true">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
						</span>
						Good fit if:
					</h3>
					<ul>
						{goodFit.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
				<div class="aurea-card botox-candidate__card botox-candidate__card--not">
					<h3>
						<span class="botox-candidate__icon botox-candidate__icon--not" aria-hidden="true">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
						</span>
						May not be right if:
					</h3>
					<ul>
						{notRight.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
			</div>
			<div class="botox-candidate__note aurea-card">
				<p>Your provider will review your goals, health history, and facial anatomy before recommending treatment.</p>
			</div>
		</div>
	</section>

	<!-- 6. Treatment Process Timeline -->
	<section class="aurea-section aurea-section--warm" id="botox-process" aria-labelledby="botox-process-heading">
		<div class="aurea-container">
			<div class="botox-section-header">
				<p class="aurea-eyebrow">Your Visit</p>
				<h2 id="botox-process-heading">What to expect from consultation to results.</h2>
			</div>
			<div class="botox-timeline">
				{timeline.map((item, i) => (
					<div class="botox-timeline__item">
						<div class="botox-timeline__marker">
							<span class="botox-timeline__number">{i + 1}</span>
							{i < timeline.length - 1 && <div class="botox-timeline__line" aria-hidden="true"></div>}
						</div>
						<div class="botox-timeline__content">
							<h3>{item.step}</h3>
							<p>{item.description}</p>
						</div>
					</div>
				))}
			</div>
			<div class="botox-timeline__cta">
				<a class="aurea-btn aurea-btn--primary" href="/demos/med-spa/contact">Book Your Consultation</a>
			</div>
		</div>
	</section>

	<!-- 7. Before & After Preview -->
	<section class="aurea-section" id="before-after" aria-labelledby="botox-ba-heading">
		<div class="aurea-container">
			<div class="botox-section-header">
				<p class="aurea-eyebrow">Results</p>
				<h2 id="botox-ba-heading">Real improvement. Realistic expectations.</h2>
			</div>
			<div class="botox-ba__grid">
				{beforeAfterAreas.map((item) => (
					<article class="aurea-card botox-ba__card">
						<h3>{item.area}</h3>
						<div class="botox-ba__visual">
							<div class={`botox-ba__side botox-ba__side--before botox-ba__side--${item.id}`}>
								<span class="botox-ba__label">Before</span>
							</div>
							<div class="botox-ba__divider" aria-hidden="true"></div>
							<div class={`botox-ba__side botox-ba__side--after botox-ba__side--${item.id}`}>
								<span class="botox-ba__label">After</span>
							</div>
						</div>
					</article>
				))}
			</div>
			<p class="botox-ba__disclaimer">
				Individual results vary. Images are for demonstration purposes in this template. A consultation is required to determine candidacy.
			</p>
		</div>
	</section>

	<!-- 8. Pricing / Membership Section -->
	<section class="aurea-section aurea-section--warm" id="botox-pricing" aria-labelledby="botox-pricing-heading">
		<div class="aurea-container">
			<div class="botox-section-header">
				<p class="aurea-eyebrow">Pricing</p>
				<h2 id="botox-pricing-heading">Pricing is personalized to your treatment plan.</h2>
				<p class="aurea-lead">
					Wrinkle relaxer pricing depends on treatment area, dosage, provider recommendation, and your goals. During your consultation, we'll review your options before treatment begins.
				</p>
			</div>
			<div class="botox-pricing__grid">
				{pricingCards.map((card) => (
					<article class="aurea-card botox-pricing__card">
						<h3>{card.title}</h3>
						<p>{card.description}</p>
					</article>
				))}
			</div>
			<div class="botox-pricing__cta">
				<a class="aurea-btn aurea-btn--primary" href="/demos/med-spa/contact">Ask About Pricing</a>
			</div>
		</div>
	</section>

	<!-- 9. Safety / Trust Section -->
	<section class="aurea-section aurea-section--warm" id="botox-safety" aria-labelledby="botox-safety-heading">
		<div class="aurea-container">
			<div class="botox-section-header">
				<p class="aurea-eyebrow">Safety &amp; Standards</p>
				<h2 id="botox-safety-heading">Designed with restraint, anatomy, and safety in mind.</h2>
				<p class="aurea-lead">
					At Auréa, every treatment decision is guided by medical expertise, conservative technique, and your individual anatomy — not trends or pressure.
				</p>
			</div>
			<div class="botox-safety__grid">
				{safetyItems.map((item) => (
					<article class="aurea-card botox-safety__card">
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- 10. FAQ Section -->
	<section class="aurea-section" id="botox-faq" aria-labelledby="botox-faq-heading">
		<div class="aurea-container">
			<div class="botox-section-header">
				<p class="aurea-eyebrow">FAQ</p>
				<h2 id="botox-faq-heading">Botox questions, answered honestly.</h2>
			</div>
			<div class="botox-faq__list">
				{faqs.map((faq) => (
					<details class="botox-faq__item">
						<summary>{faq.question}</summary>
						<p>{faq.answer}</p>
					</details>
				))}
			</div>
		</div>
	</section>

	<!-- 11. Related Treatments -->
	<section class="aurea-section aurea-section--warm" id="botox-related" aria-labelledby="botox-related-heading">
		<div class="aurea-container">
			<div class="botox-section-header">
				<p class="aurea-eyebrow">Related Treatments</p>
				<h2 id="botox-related-heading">Treatments that complement wrinkle relaxers.</h2>
			</div>
			<div class="botox-related__grid">
				{relatedTreatments.map((t) => (
					<article class="aurea-card botox-related__card">
						<h3>{t.title}</h3>
						<p>{t.description}</p>
						<a class="botox-related__link" href={t.href}>Learn More &rarr;</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<!-- 12. Final CTA -->
	<section class="botox-final" id="botox-cta" aria-labelledby="botox-final-heading">
		<div class="aurea-container">
			<div class="botox-final__inner">
				<h2 id="botox-final-heading">Ready to start with a natural-looking refresh?</h2>
				<p>Book a consultation and we'll help you understand whether wrinkle relaxers are the right first step for your goals.</p>
				<div class="aurea-btn-row botox-final__actions">
					<a class="aurea-btn aurea-btn--champagne" href="/demos/med-spa/contact">Book a Consultation</a>
					<a class="aurea-btn botox-final__ghost" href="/demos/med-spa/treatments">Explore All Treatments</a>
				</div>
			</div>
		</div>
	</section>
</AureaLayout>

<style>
	/* ===== 1. Hero ===== */

	.botox-hero {
		padding-block: clamp(6rem, 10vw, 10rem) clamp(5rem, 8vw, 8rem);
		background:
			radial-gradient(ellipse at 80% 12%, color-mix(in srgb, var(--aurea-champagne) 16%, transparent), transparent 55%),
			radial-gradient(ellipse at 15% 90%, color-mix(in srgb, var(--aurea-sage) 10%, transparent), transparent 45%),
			radial-gradient(circle at 50% 50%, color-mix(in srgb, var(--aurea-champagne) 4%, transparent), transparent 70%),
			linear-gradient(175deg, var(--aurea-white) 0%, var(--aurea-bg) 60%, var(--aurea-bg-warm) 100%);
	}

	.botox-hero__inner {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(360px, 0.82fr);
		gap: clamp(3rem, 6vw, 6rem);
		align-items: center;
	}

	.botox-hero__content h1 {
		max-width: 15ch;
	}

	.botox-hero__trust {
		display: flex;
		flex-wrap: wrap;
		gap: 1.35rem;
		margin: 2.25rem 0 0;
		padding: 0;
		list-style: none;
	}

	.botox-hero__trust li {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--aurea-muted);
	}

	.botox-hero__trust span {
		display: block;
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 999px;
		background: var(--aurea-champagne);
	}

	.botox-hero__visual {
		position: relative;
		min-height: 480px;
	}

	.botox-hero__panel {
