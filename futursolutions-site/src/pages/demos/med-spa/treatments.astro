---
import DemoLayout from '../../../layouts/DemoLayout.astro';

const treatments = [
	{
		title: 'Injectables',
		description:
			'Consultation-based options designed to support natural-looking refinement, guided by your goals, preferences, and candidacy questions.',
		bestFor: 'Clients who want to understand options before deciding what feels right.',
	},
	{
		title: 'Skin Rejuvenation',
		description:
			'Education-focused skin care guidance that helps you understand what each visit may involve, what to expect over time, and how to plan next steps.',
		bestFor: 'Clients interested in texture, tone, and a steady, informed approach.',
	},
	{
		title: 'Medical Weight Loss',
		description:
			'A structured, consultation-led pathway designed to support accountability and clarity—without promising specific outcomes.',
		bestFor: 'Clients looking for guided support and a clearer conversation about wellness goals.',
	},
	{
		title: 'Hormone Support',
		description:
			'Education-first visits that help you explore symptoms and options with a provider, so you can make informed decisions at your own pace.',
		bestFor: 'Clients who want a calm setting to ask questions and understand next steps.',
	},
	{
		title: 'IV Therapy',
		description:
			'Wellness-focused hydration services presented with practical expectations, safety-minded framing, and a simple path to book or ask questions.',
		bestFor: 'Clients interested in supportive wellness visits with clear communication.',
	},
	{
		title: 'Wellness Consultation',
		description:
			'A dedicated entry point when you are not sure where to start—focused on listening, guidance, and routing you toward the right conversation.',
		bestFor: 'New clients who want help choosing a sensible first step.',
	},
];

const faqs = [
	{
		question: 'How do I know which treatment is right for me?',
		answer:
			'Most clients start with a consultation so a provider can review your goals, explain candidacy in general terms, and recommend a sensible path forward.',
	},
	{
		question: 'Why are treatments organized as separate pages?',
		answer:
			'Separate pages keep education focused, make expectations easier to scan, and give you a calm place to read before you reach out.',
	},
	{
		question: 'Can my local community find detailed service information online?',
		answer:
			'Yes. When pages are structured clearly, practices can reinforce helpful headings, descriptive content, internal links between related services, and location-relevant detail.',
	},
	{
		question: 'Can consultation requests connect to scheduling or follow-up?',
		answer:
			'Many practices route inquiries through email, scheduling tools, or a CRM so the team can respond consistently and stay organized.',
	},
];
---

<DemoLayout
	title="Treatments | Luma Aesthetics Demo"
	description="Explore Luma Aesthetics treatment categories with clear descriptions, practical expectations, and consultation-focused next steps."
	canonicalUrl="https://futursolutions.vercel.app/demos/med-spa/treatments/"
>
	<section class="luma-page-hero" aria-labelledby="treatments-heading">
		<div class="site-container">
			<p class="luma-eyebrow">Treatments</p>
			<h1 id="treatments-heading">Care options explained with patience, clarity, and room for questions.</h1>
			<p class="luma-lead">
				Explore treatment categories with clear descriptions, practical expectations, and consultation-focused next steps.
			</p>
			<div class="luma-button-row">
				<a class="luma-button luma-button--primary" href="/demos/med-spa/contact">Book Consultation</a>
			</div>
		</div>
	</section>

	<section class="luma-section luma-section--muted" aria-labelledby="treatment-grid-heading">
		<div class="site-container">
			<div class="luma-section__intro">
				<p class="luma-eyebrow">Overview</p>
				<h2 id="treatment-grid-heading">Services framed for clarity, questions, and consultation.</h2>
			</div>
			<div class="luma-treatment-grid">
				{treatments.map((treatment) => (
					<article class="luma-treatment-card">
						<h3>{treatment.title}</h3>
						<p>{treatment.description}</p>
						<div class="luma-treatment-card__meta">
							<strong>Best for</strong>
							<span>{treatment.bestFor}</span>
						</div>
						<a href="/demos/med-spa/contact">Ask About This Treatment</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="luma-section" aria-labelledby="structure-heading">
		<div class="site-container luma-callout">
			<p class="luma-eyebrow">How content can grow</p>
			<h2 id="structure-heading">Room to grow with dedicated treatment pages.</h2>
			<p class="luma-lead">
				For a real med spa website, each treatment can become a dedicated page with education, FAQs, trust signals, local SEO structure, and booking prompts.
			</p>
		</div>
	</section>

	<section class="luma-section luma-section--muted" aria-labelledby="faq-heading">
		<div class="site-container">
			<div class="luma-section__intro">
				<p class="luma-eyebrow">FAQ</p>
				<h2 id="faq-heading">Questions clients often ask first.</h2>
			</div>
			<div class="luma-faq-grid">
				{faqs.map((faq) => (
					<article class="luma-faq-card">
						<h3>{faq.question}</h3>
						<p>{faq.answer}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="luma-section luma-final" aria-labelledby="final-heading">
		<div class="site-container luma-final__card">
			<div>
				<p class="luma-eyebrow">Future Solutions template</p>
				<h2 id="final-heading">Ready to adapt this treatment structure?</h2>
			</div>
			<div class="luma-button-row">
				<a class="luma-button luma-button--primary" href="/audit?template=med-spa">Get This Template Customized</a>
				<a class="luma-button luma-button--secondary" href="/demos/med-spa">Back to Demo Home</a>
			</div>
		</div>
	</section>
</DemoLayout>

<style>
	.luma-page-hero,
	.luma-section {
		padding-block: clamp(4.5rem, 8vw, 7rem);
	}

	.luma-page-hero {
		background:
			radial-gradient(circle at 82% 12%, rgba(143, 111, 99, 0.16), transparent 30%),
			linear-gradient(180deg, #ffffff 0%, #fbfaf7 78%);
	}

	.luma-eyebrow {
		margin-bottom: 1rem;
		color: #8f6f63;
		font-size: 0.8125rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.luma-page-hero h1,
	.luma-section h2 {
		max-width: 900px;
		color: #17202a;
	}

	.luma-lead {
		max-width: 720px;
		color: #64706f;
		font-size: clamp(1.08rem, 1rem + 0.32vw, 1.25rem);
		line-height: 1.65;
	}

	.luma-button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.875rem;
		margin-top: 2rem;
	}

	.luma-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.875rem;
		padding: 0.8rem 1.1rem;
		border: 1px solid transparent;
		border-radius: 999px;
		font-size: 0.9375rem;
		font-weight: 800;
		line-height: 1;
	}

	.luma-button--primary {
		background: #8f6f63;
		color: #ffffff;
	}

	.luma-button--primary:hover {
		background: #6f554b;
		color: #ffffff;
	}

	.luma-button--secondary {
		border-color: rgba(42, 54, 65, 0.12);
		background: #ffffff;
		color: #17202a;
	}

	.luma-button--secondary:hover {
		background: #efe7e1;
		color: #6f554b;
	}

	.luma-section--muted {
		border-block: 1px solid rgba(42, 54, 65, 0.1);
		background: #f5f0eb;
	}

	.luma-section__intro {
		max-width: 780px;
	}

	.luma-treatment-grid,
	.luma-faq-grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.luma-treatment-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.luma-faq-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.luma-treatment-card,
	.luma-faq-card,
	.luma-callout {
		border: 1px solid rgba(42, 54, 65, 0.1);
		border-radius: 22px;
		background: #ffffff;
		box-shadow: 0 20px 52px rgba(42, 54, 65, 0.05);
	}

	.luma-treatment-card,
	.luma-faq-card {
		padding: 1.25rem;
	}

	.luma-treatment-card h3,
	.luma-faq-card h3 {
		color: #17202a;
		font-size: 1.12rem;
		letter-spacing: -0.02em;
	}

	.luma-treatment-card p,
	.luma-faq-card p {
		color: #64706f;
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.luma-treatment-card__meta {
		display: grid;
		gap: 0.35rem;
		margin-top: 1.25rem;
		padding-top: 1rem;
		border-top: 1px solid rgba(42, 54, 65, 0.1);
	}

	.luma-treatment-card__meta strong {
		color: #8f6f63;
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.luma-treatment-card__meta span {
		color: #64706f;
		font-size: 0.9rem;
		line-height: 1.5;
	}

	.luma-treatment-card a {
		display: inline-flex;
		margin-top: 1.25rem;
		color: #17202a;
		font-size: 0.9375rem;
		font-weight: 800;
	}

	.luma-treatment-card a:hover {
		color: #6f554b;
	}

	.luma-callout {
		padding: clamp(1.5rem, 4vw, 3rem);
	}

	.luma-final {
		background: #efe7e1;
	}

	.luma-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid rgba(42, 54, 65, 0.1);
		border-radius: 24px;
		background: #17202a;
	}

	.luma-final h2 {
		color: #ffffff;
	}

	@media (max-width: 980px) {
		.luma-treatment-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.luma-final__card {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 700px) {
		.luma-treatment-grid,
		.luma-faq-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
