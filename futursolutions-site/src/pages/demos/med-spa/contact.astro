---
import DemoLayout from '../../../layouts/DemoLayout.astro';

const treatmentOptions = ['Injectables', 'Skin Rejuvenation', 'Medical Weight Loss', 'Hormone Support', 'IV Therapy', 'Not sure yet'];
const nextSteps = ['Consultation', 'Ask a question', 'Learn about pricing', 'Not sure yet'];
const flowSteps = ['Inquiry received', 'Team review', 'Interest noted', 'Follow-up', 'Consultation pathway'];
---

<DemoLayout
	title="Book Consultation | Luma Aesthetics Demo"
	description="Request a consultation at Luma Aesthetics. Share your interests and the team will help guide your next steps."
	canonicalUrl="https://futursolutions.vercel.app/demos/med-spa/contact/"
>
	<section class="luma-page-hero" aria-labelledby="contact-heading">
		<div class="site-container">
			<p class="luma-eyebrow">Consultation</p>
			<h1 id="contact-heading">A clearer path from interest to consultation.</h1>
			<p class="luma-lead">
				Share what you are interested in and the team will help guide you toward the right consultation path.
			</p>
		</div>
	</section>

	<section class="luma-section luma-section--muted" aria-labelledby="form-heading">
		<div class="site-container luma-contact-grid">
			<div>
				<p class="luma-eyebrow">Consultation request</p>
				<h2 id="form-heading">Request a consultation.</h2>
				<p class="luma-lead">
					This form structure keeps the first step simple while collecting enough information to route the inquiry.
				</p>
			</div>
			<div class="luma-form-card">
				<form novalidate onsubmit="return false" aria-label="Luma Aesthetics demo consultation form">
					<label>
						<span>Name</span>
						<input type="text" name="name" autocomplete="name" />
					</label>
					<label>
						<span>Email</span>
						<input type="email" name="email" autocomplete="email" />
					</label>
					<label>
						<span>Treatment interest</span>
						<select name="treatment-interest">
							<option value="">Select treatment interest</option>
							{treatmentOptions.map((option) => <option value={option}>{option}</option>)}
						</select>
					</label>
					<label>
						<span>Preferred next step</span>
						<select name="preferred-next-step">
							<option value="">Select preferred next step</option>
							{nextSteps.map((option) => <option value={option}>{option}</option>)}
						</select>
					</label>
					<label>
						<span>Message</span>
						<textarea name="message" rows="4"></textarea>
					</label>
					<div class="luma-form-card__footer">
						<button class="luma-button luma-button--primary" type="button">Request Consultation</button>
						<p>This is a demo form. In a real build, this could connect to GoHighLevel for lead capture, booking, CRM follow-up, and pipeline tracking.</p>
					</div>
				</form>
			</div>
		</div>
	</section>

	<section class="luma-section" aria-labelledby="backend-heading">
		<div class="site-container">
			<div class="luma-section__intro">
				<p class="luma-eyebrow">What happens next</p>
				<h2 id="backend-heading">After you reach out, the practice can route your inquiry cleanly.</h2>
				<p class="luma-lead">
					Many clinics keep follow-up structured so no question gets missed—often through scheduling tools, secure email, or a CRM that tracks treatment interest.
					In a full Future Solutions build, this pathway can tie into workflows like tagging, reminders, and pipeline organization.
				</p>
			</div>
			<div class="luma-flow" aria-label="Typical inquiry follow-up pathway">
				{flowSteps.map((step, index) => (
					<div class="luma-flow__step">
						<span>{String(index + 1).padStart(2, '0')}</span>
						<p>{step}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="luma-section luma-final" aria-labelledby="final-heading">
		<div class="site-container luma-final__card">
			<div>
				<p class="luma-eyebrow">Future Solutions template</p>
				<h2 id="final-heading">Want this booking flow customized for your business?</h2>
			</div>
			<div class="luma-button-row">
				<a class="luma-button luma-button--primary" href="/audit?template=med-spa">Get This Template Customized</a>
				<a class="luma-button luma-button--secondary" href="/templates">Back to Templates</a>
			</div>
		</div>
	</section>
</DemoLayout>

<style>
	.luma-page-hero,
	.luma-section {
		padding-block: clamp(4.5rem, 8vw, 7rem);
	}

	.luma-page-hero {
		background:
			radial-gradient(circle at 82% 12%, rgba(143, 111, 99, 0.16), transparent 30%),
			linear-gradient(180deg, #ffffff 0%, #fbfaf7 78%);
	}

	.luma-eyebrow {
		margin-bottom: 1rem;
		color: #8f6f63;
		font-size: 0.8125rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.luma-page-hero h1,
	.luma-section h2 {
		max-width: 900px;
		color: #17202a;
	}

	.luma-lead {
		max-width: 720px;
		color: #64706f;
		font-size: clamp(1.08rem, 1rem + 0.32vw, 1.25rem);
		line-height: 1.65;
	}

	.luma-section--muted {
		border-block: 1px solid rgba(42, 54, 65, 0.1);
		background: #f5f0eb;
	}

	.luma-contact-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(360px, 0.75fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: start;
	}

	.luma-form-card {
		padding: clamp(1.35rem, 3vw, 2rem);
		border: 1px solid rgba(42, 54, 65, 0.1);
		border-radius: 24px;
		background: #ffffff;
		box-shadow: 0 20px 52px rgba(42, 54, 65, 0.05);
	}

	.luma-form-card form,
	.luma-form-card label {
		display: grid;
		gap: 1rem;
	}

	.luma-form-card label {
		gap: 0.45rem;
	}

	.luma-form-card label span {
		color: #17202a;
		font-size: 0.875rem;
		font-weight: 800;
	}

	.luma-form-card input,
	.luma-form-card select,
	.luma-form-card textarea {
		width: 100%;
		border: 1px solid rgba(42, 54, 65, 0.14);
		border-radius: 12px;
		background: #fbfaf7;
		color: #17202a;
		font-size: 0.95rem;
	}

	.luma-form-card input,
	.luma-form-card select {
		min-height: 2.85rem;
		padding: 0.7rem 0.8rem;
	}

	.luma-form-card textarea {
		resize: vertical;
		min-height: 7rem;
		padding: 0.8rem;
	}

	.luma-form-card input:focus,
	.luma-form-card select:focus,
	.luma-form-card textarea:focus {
		border-color: rgba(143, 111, 99, 0.55);
		outline: none;
		background: #ffffff;
	}

	.luma-form-card__footer {
		display: grid;
		gap: 0.85rem;
	}

	.luma-form-card__footer p {
		margin: 0;
		color: #64706f;
		font-size: 0.85rem;
		line-height: 1.55;
	}

	.luma-button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.875rem;
		margin-top: 2rem;
	}

	.luma-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.875rem;
		padding: 0.8rem 1.1rem;
		border: 1px solid transparent;
		border-radius: 999px;
		font-size: 0.9375rem;
		font-weight: 800;
		line-height: 1;
	}

	.luma-button--primary {
		background: #8f6f63;
		color: #ffffff;
	}

	.luma-button--primary:hover {
		background: #6f554b;
		color: #ffffff;
	}

	.luma-button--secondary {
		border-color: rgba(42, 54, 65, 0.12);
		background: #ffffff;
		color: #17202a;
	}

	.luma-button--secondary:hover {
		background: #efe7e1;
		color: #6f554b;
	}

	.luma-section__intro {
		max-width: 780px;
	}

	.luma-flow {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 2rem;
	}

	.luma-flow__step {
		padding: 1.2rem;
		border: 1px solid rgba(42, 54, 65, 0.1);
		border-radius: 22px;
		background: #ffffff;
		box-shadow: 0 20px 52px rgba(42, 54, 65, 0.05);
	}

	.luma-flow__step span {
		display: inline-flex;
		margin-bottom: 1rem;
		color: #8f6f63;
		font-size: 0.75rem;
		font-weight: 800;
	}

	.luma-flow__step p {
		margin: 0;
		color: #17202a;
		font-size: 0.95rem;
		font-weight: 800;
		line-height: 1.4;
	}

	.luma-final {
		background: #efe7e1;
	}

	.luma-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid rgba(42, 54, 65, 0.1);
		border-radius: 24px;
		background: #17202a;
	}

	.luma-final h2 {
		color: #ffffff;
	}

	@media (max-width: 1040px) {
		.luma-flow {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 820px) {
		.luma-contact-grid,
		.luma-final__card {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 620px) {
		.luma-flow {
			grid-template-columns: 1fr;
		}
	}
</style>
