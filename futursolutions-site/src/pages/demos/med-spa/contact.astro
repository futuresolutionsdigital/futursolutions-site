---
import AureaLayout from '../../../layouts/AureaLayout.astro';
import AureaPageHero from '../../../components/AureaPageHero.astro';

const treatmentInterests = [
	'Injectables',
	'Skin Rejuvenation',
	'Laser Treatments',
	'Body Contouring',
	'Medical Weight Loss',
	'Not sure yet',
];

const nextSteps = [
	{ step: '01', title: 'We review your goals' },
	{ step: '02', title: 'We match you with the right provider' },
	{ step: '03', title: 'You receive next-step guidance' },
	{ step: '04', title: 'You confirm your appointment' },
];

const contactFaqs = [
	{
		question: 'Do I need to know which treatment I want?',
		answer: 'Not at all. Many patients come in unsure of what they need\u2014that\u2019s what the consultation is for. Your provider will help you understand your options based on your goals and concerns.',
	},
	{
		question: 'Can I book a consultation before committing?',
		answer: 'Absolutely. The consultation is the first step\u2014not a commitment. It\u2019s a chance for you to ask questions, understand your options, and decide what feels right before moving forward.',
	},
	{
		question: 'Who will I meet with?',
		answer: 'You\u2019ll be matched with the provider best suited to your area of interest\u2014whether that\u2019s a physician, nurse practitioner, or licensed aesthetician.',
	},
	{
		question: 'Can I ask about pricing?',
		answer: 'Yes. During your consultation, we\u2019ll discuss treatment options and pricing so you can make an informed decision. We also offer memberships and financing for flexibility.',
	},
];
---

<AureaLayout
	title="Book Consultation | Auréa Skin & Aesthetics"
	description="Request a consultation at Auréa Skin & Aesthetics in Temecula, CA. Share your goals and our team will guide your next step."
>
	<AureaPageHero
		eyebrow="Consultation"
		headline="Start with a consultation."
		lead="Tell us what you're considering and our team will help you choose the right next step."
		primaryCta={{ text: 'Call Now', href: 'tel:+19515550147' }}
		secondaryCta={{ text: 'Explore Treatments', href: '/demos/med-spa/treatments' }}
	/>

	<section class="aurea-section" aria-labelledby="form-heading">
		<div class="aurea-container contact-grid">
			<div class="contact-info">
				<h2 id="form-heading">Request your consultation</h2>
				<p class="contact-info__desc">
					Share a few details about what you're considering. Our team will review your request and reach out to help you choose the right next step — no commitment required.
				</p>
				<div class="contact-details">
					<div class="contact-details__item">
						<strong>Location</strong>
						<span>123 V&iacute;a Belleza<br />Temecula, CA 92590</span>
					</div>
					<div class="contact-details__item">
						<strong>Phone</strong>
						<a href="tel:+19515550147">(951) 555-0147</a>
					</div>
					<div class="contact-details__item">
						<strong>Hours</strong>
						<span>Mon–Fri: 9:00 AM – 6:00 PM<br />Sat: 9:00 AM – 2:00 PM<br />Sun: Closed</span>
					</div>
				</div>
			</div>

			<div class="contact-form-card">
				<form novalidate onsubmit="return false" aria-label="Auréa consultation request form">
					<div class="form-row form-row--half">
						<label>
							<span>First name</span>
							<input type="text" name="first-name" autocomplete="given-name" />
						</label>
						<label>
							<span>Last name</span>
							<input type="text" name="last-name" autocomplete="family-name" />
						</label>
					</div>
					<div class="form-row form-row--half">
						<label>
							<span>Email</span>
							<input type="email" name="email" autocomplete="email" />
						</label>
						<label>
							<span>Phone</span>
							<input type="tel" name="phone" autocomplete="tel" />
						</label>
					</div>
					<label>
						<span>Treatment interest</span>
						<select name="treatment-interest">
							<option value="">Select treatment interest</option>
							{treatmentInterests.map((option) => <option value={option}>{option}</option>)}
						</select>
					</label>
					<label>
						<span>Patient type</span>
						<select name="patient-type">
							<option value="">Select patient type</option>
							<option value="new">New Patient</option>
							<option value="returning">Returning Patient</option>
						</select>
					</label>
					<label>
						<span>Preferred appointment time</span>
						<select name="preferred-time">
							<option value="">Select preferred time</option>
							<option value="morning">Morning</option>
							<option value="afternoon">Afternoon</option>
							<option value="no-preference">No preference</option>
						</select>
					</label>
					<label>
						<span>Message</span>
						<textarea name="message" rows="4"></textarea>
					</label>
					<div class="form-footer">
						<button class="aurea-btn aurea-btn--primary form-submit" type="button">Request Consultation</button>
						<p class="form-disclaimer">This is a demo form. In a full build, this connects to GoHighLevel for booking, CRM, and follow-up.</p>
					</div>
				</form>
			</div>
		</div>
	</section>

	<section class="aurea-section aurea-section--warm" aria-labelledby="process-heading">
		<div class="aurea-container">
			<div class="contact-process__header">
				<p class="aurea-eyebrow">What happens next</p>
				<h2 id="process-heading">From inquiry to appointment</h2>
			</div>
			<div class="contact-process__grid">
				{nextSteps.map((item) => (
					<div class="contact-process__step">
						<span class="contact-process__badge">{item.step}</span>
						<p>{item.title}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="aurea-section" aria-labelledby="contact-faq-heading">
		<div class="aurea-container">
			<div class="contact-faq__header">
				<p class="aurea-eyebrow">FAQ</p>
				<h2 id="contact-faq-heading">Questions about booking</h2>
			</div>
			<div class="contact-faq__list">
				{contactFaqs.map((faq) => (
					<details class="contact-faq__item">
						<summary>{faq.question}</summary>
						<p>{faq.answer}</p>
					</details>
				))}
			</div>
		</div>
	</section>

	<section class="contact-final" aria-labelledby="final-heading">
		<div class="aurea-container">
			<div class="contact-final__inner">
				<h2 id="final-heading">Natural results. Medical precision. Designed around you.</h2>
				<div class="aurea-btn-row contact-final__actions">
					<a class="aurea-btn aurea-btn--champagne" href="tel:+19515550147">Call (951) 555-0147</a>
					<a class="aurea-btn contact-final__ghost" href="/demos/med-spa/treatments">Explore Treatments</a>
				</div>
			</div>
		</div>
	</section>
</AureaLayout>

<style>
	.contact-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(380px, 1fr);
		gap: clamp(2.5rem, 5vw, 5rem);
		align-items: start;
	}

	.contact-info h2 {
		margin-bottom: 1rem;
	}

	.contact-info__desc {
		color: var(--aurea-muted);
		font-size: clamp(1rem, 0.95rem + 0.2vw, 1.1rem);
		line-height: 1.65;
		max-width: 480px;
	}

	.contact-details {
		display: grid;
		gap: 1.5rem;
		margin-top: 2.5rem;
		padding-top: 2rem;
		border-top: 1px solid var(--aurea-border);
	}

	.contact-details__item {
		display: grid;
		gap: 0.3rem;
	}

	.contact-details__item strong {
		color: var(--aurea-champagne);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.contact-details__item span,
	.contact-details__item a {
		color: var(--aurea-charcoal);
		font-size: 0.95rem;
		line-height: 1.55;
	}

	.contact-details__item a:hover {
		color: var(--aurea-champagne);
	}

	.contact-form-card {
		padding: clamp(1.75rem, 3vw, 2.5rem);
		border: 1px solid var(--aurea-border);
		border-radius: var(--aurea-radius-lg);
		background: var(--aurea-white);
		box-shadow: 0 16px 48px rgba(36, 35, 33, 0.05);
	}

	.contact-form-card form {
		display: grid;
		gap: 1.1rem;
	}

	.form-row--half {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.contact-form-card label {
		display: grid;
		gap: 0.4rem;
	}

	.contact-form-card label span {
		color: var(--aurea-charcoal);
		font-size: 0.875rem;
		font-weight: 700;
	}

	.contact-form-card input,
	.contact-form-card select,
	.contact-form-card textarea {
		width: 100%;
		min-height: 3rem;
		padding: 0.75rem 0.9rem;
		border: 1px solid var(--aurea-border);
		border-radius: 14px;
		background: var(--aurea-bg);
		color: var(--aurea-charcoal);
		font-size: 0.95rem;
		transition: border-color 0.2s ease, background 0.2s ease;
	}

	.contact-form-card textarea {
		min-height: auto;
		resize: vertical;
	}

	.contact-form-card input:focus,
	.contact-form-card select:focus,
	.contact-form-card textarea:focus {
		outline: none;
		border-color: var(--aurea-champagne);
		background: var(--aurea-white);
	}

	.form-footer {
		display: grid;
		gap: 0.85rem;
		margin-top: 0.5rem;
	}

	.form-submit {
		width: 100%;
	}

	.form-disclaimer {
		margin: 0;
		color: var(--aurea-muted);
		font-size: 0.8rem;
		line-height: 1.5;
		text-align: center;
	}

	.contact-process__header {
		max-width: 680px;
		margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
	}

	.contact-process__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.contact-process__step {
		padding: 1.5rem;
		border: 1px solid var(--aurea-border);
		border-radius: var(--aurea-radius);
		background: var(--aurea-white);
		box-shadow: 0 8px 24px rgba(36, 35, 33, 0.03);
	}

	.contact-process__badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		margin-bottom: 1rem;
		border-radius: 50%;
		background: var(--aurea-bg-warm);
		border: 1px solid var(--aurea-border);
		color: var(--aurea-champagne);
		font-size: 0.78rem;
		font-weight: 800;
	}

	.contact-process__step p {
		margin: 0;
		color: var(--aurea-charcoal);
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.4;
	}

	.contact-faq__header {
		max-width: 680px;
		margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
	}

	.contact-faq__list {
		display: grid;
		gap: 0.75rem;
		max-width: 800px;
	}

	.contact-faq__item {
		border: 1px solid var(--aurea-border);
		border-radius: var(--aurea-radius);
		background: var(--aurea-white);
		overflow: hidden;
		transition: box-shadow 0.2s ease;
	}

	.contact-faq__item:hover {
		box-shadow: 0 8px 24px rgba(36, 35, 33, 0.04);
	}

	.contact-faq__item[open] {
		box-shadow: 0 8px 24px rgba(36, 35, 33, 0.06);
	}

	.contact-faq__item summary {
		padding: 1.25rem 1.5rem;
		font-weight: 700;
		font-size: 1rem;
		color: var(--aurea-charcoal);
		cursor: pointer;
		list-style: none;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.contact-faq__item summary::-webkit-details-marker {
		display: none;
	}

	.contact-faq__item summary::after {
		content: '+';
		flex-shrink: 0;
		width: 1.5rem;
		height: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: var(--aurea-bg-warm);
		color: var(--aurea-champagne);
		font-size: 1.1rem;
		font-weight: 700;
		transition: transform 0.2s ease;
	}

	.contact-faq__item[open] summary::after {
		content: '\2212';
		transform: rotate(180deg);
	}

	.contact-faq__item p {
		padding: 0 1.5rem 1.25rem;
		margin: 0;
		color: var(--aurea-muted);
		font-size: 0.95rem;
		line-height: 1.65;
	}

	.contact-final {
		padding-block: clamp(5.5rem, 10vw, 9rem);
		background: var(--aurea-charcoal);
	}

	.contact-final__inner {
		text-align: center;
		max-width: 640px;
		margin-inline: auto;
	}

	.contact-final h2 {
		color: var(--aurea-white);
	}

	.contact-final__actions {
		justify-content: center;
	}

	.contact-final__ghost {
		border-color: rgba(255, 255, 255, 0.2);
		background: transparent;
		color: rgba(255, 255, 255, 0.8);
	}

	.contact-final__ghost:hover {
		border-color: rgba(255, 255, 255, 0.4);
		background: rgba(255, 255, 255, 0.06);
		color: var(--aurea-white);
	}

	@media (max-width: 900px) {
		.contact-grid {
			grid-template-columns: 1fr;
		}

		.contact-process__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 600px) {
		.form-row--half {
			grid-template-columns: 1fr;
		}

		.contact-process__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
