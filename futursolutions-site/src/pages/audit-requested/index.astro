---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { auditTemplateSlugToName } from '../../data/templates';

const pageTitle = 'Audit Request Received | FutureSolutions';
const pageDescription =
	'Your FutureSolutions Website and Systems Audit request has been received. Learn what happens next and explore the Foundation library while you wait.';
const canonicalUrl = 'https://futursolutions.io/audit-requested/';

const nextSteps = [
	{
		step: '01',
		title: 'Request received',
		text: 'Your website, business type, and goals are reviewed.',
	},
	{
		step: '02',
		title: 'Site review',
		text: 'We look at trust, service clarity, local visibility, conversion paths, and lead follow-up.',
	},
	{
		step: '03',
		title: 'Recommendation',
		text: 'You get a practical next-step recommendation: Website Foundations, Signature Custom Website, Local Visibility, Growth System, or Care and Optimization.',
	},
	{
		step: '04',
		title: 'Next conversation',
		text: 'If there is a fit, we can map the cleanest path forward for your business.',
	},
];

const templates = [
	{
		name: 'Med Spa Website System',
		description: 'A premium website system for treatment-based health and wellness businesses.',
		href: '/templates/med-spa',
	},
	{
		name: 'Aster Private Health \u2014 Solo Practice Website',
		description: 'A warm editorial website system for solo NPs, private primary care, concierge-style care, and cash-pay healthcare providers.',
		href: '/templates/solo-practice',
	},
	{
		name: 'Professional Association Website System',
		description: 'A structured website system for healthcare associations and member organizations.',
		href: '/templates/association',
	},
	{
		name: "VANTAGE Men's Health — Premium Hormone & TRT Clinic",
		description: "A red/black sports-performance men's health Foundation for TRT, ED care, hormone optimization, medical weight loss, and longevity clinics.",
		href: '/templates/hormone-trt',
	},
	{
		name: 'Lumen Health House — Premium Wellness Clinic',
		description: 'A calm, editorial Foundation for wellness, IV therapy, recovery, and membership-based functional medicine clinics.',
		href: '/templates/premium-wellness-clinic',
	},
];

---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section audit-requested-hero" aria-labelledby="audit-requested-heading">
		<div class="site-container audit-requested-hero__inner">
			<p class="eyebrow" id="audit-requested-eyebrow">Audit Request Received</p>
			<h1 id="audit-requested-heading">Your audit request is in.</h1>
			<p class="lead" id="audit-requested-lead">
				We will review your website and look for opportunities to improve trust, service clarity, local visibility, conversion flow, and backend follow-up.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/templates">Explore Live Demos</a>
				<a class="button button-secondary" href="/audit">Back to Audit Page</a>
			</div>
			<p class="audit-requested-hero__note">
				A confirmation is on its way to your inbox. We typically review submissions and reply within
				two business days. If you don't see anything, check your spam folder or email us directly.
			</p>
		</div>
	</section>

	<section class="section section-muted audit-requested-process" aria-labelledby="audit-requested-process-heading">
		<div class="site-container">
			<div class="audit-requested__intro">
				<p class="eyebrow">Next steps</p>
				<h2 id="audit-requested-process-heading">What happens next?</h2>
			</div>
			<div class="audit-requested__grid audit-requested__grid--4">
				{nextSteps.map((step) => (
					<article class="card audit-requested-step">
						<span>{step.step}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section audit-requested-templates" aria-labelledby="audit-requested-templates-heading">
		<div class="site-container">
			<div class="audit-requested__intro">
				<p class="eyebrow">Demo library</p>
				<h2 id="audit-requested-templates-heading">While you wait, explore the live demo library.</h2>
				<p class="lead">
					If you are still comparing options, walk through the live Foundations built for med spas, solo practices, men's health / TRT clinics, wellness clinics, and healthcare associations.
				</p>
			</div>
			<div class="audit-requested__grid audit-requested__grid--3">
				{templates.map((template) => (
					<article class="card audit-requested-card">
						<h3>{template.name}</h3>
						<p>{template.description}</p>
						<a href={template.href}>View Demo</a>
					</article>
				))}
			</div>
		</div>
	</section>

</BaseLayout>

<script define:vars={{ templateLabels: auditTemplateSlugToName }}>
	(() => {
		var params = new URLSearchParams(window.location.search);
		var slug = params.get('template');
		if (!slug || !templateLabels[slug]) return;

		var label = templateLabels[slug];
		var eyebrow = document.getElementById('audit-requested-eyebrow');
		var heading = document.getElementById('audit-requested-heading');
		var lead = document.getElementById('audit-requested-lead');

		if (eyebrow) eyebrow.textContent = 'Foundation Customization Request Received';
		if (heading) heading.textContent = 'Thanks \u2014 we received your Foundation customization request.';
		if (lead) lead.textContent = 'We will review your practice details and recommend how to adapt the ' + label + ' Website Foundation around your provider story, services, and goals.';
	})();
</script>

<style>
	.audit-requested-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.audit-requested-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 76% 14%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.audit-requested-hero__inner,
	.audit-requested__intro {
		max-width: 820px;
	}

	.audit-requested-hero h1 {
		max-width: 820px;
	}

	.audit-requested-hero__note {
		max-width: 620px;
		margin-top: 1.5rem;
		padding: 0.75rem 0.85rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: color-mix(in srgb, var(--color-white) 78%, transparent);
		font-size: 0.875rem;
		line-height: 1.55;
	}

	.audit-requested__grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.audit-requested__grid--3 {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.audit-requested__grid--4 {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.audit-requested-step,
	.audit-requested-card {
		padding: 1.25rem;
	}

	.audit-requested-step span {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 1.25rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}

	.audit-requested-step h3,
	.audit-requested-card h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	.audit-requested-step p,
	.audit-requested-card p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.audit-requested-card a {
		display: inline-flex;
		width: fit-content;
		margin-top: 0.5rem;
		color: var(--color-text);
		font-size: 0.9375rem;
		font-weight: 800;
	}

	.audit-requested-card a:hover {
		color: var(--color-accent-dark);
	}

	@media (max-width: 1040px) {
		.audit-requested__grid--3,
		.audit-requested__grid--4 {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.audit-requested__grid--3,
		.audit-requested__grid--4 {
			grid-template-columns: 1fr;
		}
	}
</style>
