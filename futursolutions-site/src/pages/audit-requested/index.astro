---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'Audit Request Received | Future Solutions';
const pageDescription =
	'Your Future Solutions website audit request has been received. Learn what happens next and explore template systems while you wait.';
const canonicalUrl = 'https://futursolutions.vercel.app/audit-requested/';

const nextSteps = [
	{
		step: '01',
		title: 'Request received',
		text: 'Your website, business type, and goals are reviewed.',
	},
	{
		step: '02',
		title: 'Site review',
		text: 'We look at trust, service clarity, local visibility, conversion paths, and lead follow-up.',
	},
	{
		step: '03',
		title: 'Recommendation',
		text: 'You get a practical next-step recommendation: template setup, custom website, SEO foundation, backend system, or ongoing optimization.',
	},
	{
		step: '04',
		title: 'Next conversation',
		text: 'If there is a fit, we can map the cleanest path forward for your business.',
	},
];

const templates = [
	{
		name: 'Med Spa Website System',
		description: 'A premium website system for treatment-based health and wellness businesses.',
		href: '/templates/med-spa',
	},
	{
		name: 'Solo Practice Website System',
		description: 'A calm, professional website system for independent providers and boutique practices.',
		href: '/templates/solo-practice',
	},
	{
		name: 'Medical Association Website System',
		description: 'A structured website system for healthcare associations and member organizations.',
		href: '/templates/association',
	},
];

const usefulLinks = [
	{
		title: 'View Services',
		text: 'Understand the full service ecosystem: templates, custom websites, SEO, backend systems, and ongoing optimization.',
		href: '/services',
	},
	{
		title: 'Explore Backend Systems',
		text: 'See how website inquiries can connect to lead capture, booking, follow-up, and pipeline tracking.',
		href: '/backend',
	},
	{
		title: 'Read Resources',
		text: 'Browse planned guides about website trust, conversion, local visibility, and backend lead systems.',
		href: '/resources',
	},
];
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section audit-requested-hero" aria-labelledby="audit-requested-heading">
		<div class="site-container audit-requested-hero__inner">
			<p class="eyebrow">Audit Request Received</p>
			<h1 id="audit-requested-heading">Your audit request is in.</h1>
			<p class="lead">
				We’ll review your website and look for opportunities to improve trust, service clarity, local visibility, conversion flow, and backend follow-up.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/templates">View Templates</a>
				<a class="button button-secondary" href="/audit">Back to Audit Page</a>
			</div>
			<p class="audit-requested-hero__note">
				This page is ready for the future GoHighLevel form redirect. The audit form itself is not connected yet.
			</p>
		</div>
	</section>

	<section class="section section-muted audit-requested-process" aria-labelledby="audit-requested-process-heading">
		<div class="site-container">
			<div class="audit-requested__intro">
				<p class="eyebrow">Next steps</p>
				<h2 id="audit-requested-process-heading">What happens next?</h2>
			</div>
			<div class="audit-requested__grid audit-requested__grid--4">
				{nextSteps.map((step) => (
					<article class="card audit-requested-step">
						<span>{step.step}</span>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section audit-requested-templates" aria-labelledby="audit-requested-templates-heading">
		<div class="site-container">
			<div class="audit-requested__intro">
				<p class="eyebrow">Template systems</p>
				<h2 id="audit-requested-templates-heading">While you wait, explore launch-ready website systems.</h2>
				<p class="lead">
					If you are still comparing options, review the template systems built for med spas, solo practices, and healthcare associations.
				</p>
			</div>
			<div class="audit-requested__grid audit-requested__grid--3">
				{templates.map((template) => (
					<article class="card audit-requested-card">
						<h3>{template.name}</h3>
						<p>{template.description}</p>
						<a href={template.href}>View Template</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="section section-muted audit-requested-links" aria-labelledby="audit-requested-links-heading">
		<div class="site-container">
			<div class="audit-requested__intro">
				<p class="eyebrow">Useful links</p>
				<h2 id="audit-requested-links-heading">Useful next steps.</h2>
			</div>
			<div class="audit-requested__grid audit-requested__grid--3">
				{usefulLinks.map((link) => (
					<a class="card audit-requested-link" href={link.href}>
						<h3>{link.title}</h3>
						<p>{link.text}</p>
						<span>Explore</span>
					</a>
				))}
			</div>
		</div>
	</section>

	<section class="section audit-requested-final" aria-labelledby="audit-requested-final-heading">
		<div class="site-container">
			<div class="audit-requested-final__card">
				<div>
					<p class="eyebrow">Keep exploring</p>
					<h2 id="audit-requested-final-heading">Want to keep exploring your options?</h2>
					<p class="lead">
						Review the template systems or service paths while the audit flow is being finalized.
					</p>
				</div>
				<div class="button-row">
					<a class="button button-primary" href="/templates">View Templates</a>
					<a class="button button-secondary" href="/services">View Services</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.audit-requested-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.audit-requested-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 76% 14%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.audit-requested-hero__inner,
	.audit-requested__intro {
		max-width: 820px;
	}

	.audit-requested-hero h1 {
		max-width: 820px;
	}

	.audit-requested-hero__note {
		max-width: 620px;
		margin-top: 1.5rem;
		padding: 0.75rem 0.85rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		background: color-mix(in srgb, var(--color-white) 78%, transparent);
		font-size: 0.875rem;
		line-height: 1.55;
	}

	.audit-requested__grid {
		display: grid;
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.audit-requested__grid--3 {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.audit-requested__grid--4 {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.audit-requested-step,
	.audit-requested-card,
	.audit-requested-link {
		padding: 1.25rem;
	}

	.audit-requested-step span {
		display: inline-flex;
		width: fit-content;
		margin-bottom: 1.25rem;
		padding: 0.35rem 0.52rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
		border-radius: 999px;
		background: var(--color-accent-light);
		color: var(--color-accent-dark);
		font-size: 0.72rem;
		font-weight: 800;
		line-height: 1;
	}

	.audit-requested-step h3,
	.audit-requested-card h3,
	.audit-requested-link h3 {
		font-size: 1.1rem;
		letter-spacing: -0.02em;
	}

	.audit-requested-step p,
	.audit-requested-card p,
	.audit-requested-link p {
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.audit-requested-card a,
	.audit-requested-link span {
		display: inline-flex;
		width: fit-content;
		margin-top: 0.5rem;
		color: var(--color-text);
		font-size: 0.9375rem;
		font-weight: 800;
	}

	.audit-requested-card a:hover,
	.audit-requested-link:hover span {
		color: var(--color-accent-dark);
	}

	.audit-requested-link {
		display: grid;
		align-content: start;
		transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
	}

	.audit-requested-link:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--color-accent) 34%, var(--color-border));
		box-shadow: 0 20px 48px rgba(15, 23, 42, 0.06);
	}

	.audit-requested-final {
		background: var(--color-accent-light);
	}

	.audit-requested-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
		border-radius: 20px;
		background: var(--color-text);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.audit-requested-final .eyebrow {
		color: color-mix(in srgb, var(--color-accent-light) 84%, var(--color-white));
	}

	.audit-requested-final h2,
	.audit-requested-final .lead {
		color: var(--color-white);
	}

	.audit-requested-final .lead {
		opacity: 0.78;
	}

	.audit-requested-final .button-row {
		justify-content: flex-end;
		margin-top: 0;
	}

	.audit-requested-final .button-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.22);
		color: var(--color-white);
	}

	.audit-requested-final .button-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.38);
		color: var(--color-white);
	}

	@media (max-width: 1040px) {
		.audit-requested__grid--3,
		.audit-requested__grid--4 {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.audit-requested__grid--3,
		.audit-requested__grid--4,
		.audit-requested-final__card {
			grid-template-columns: 1fr;
		}

		.audit-requested-final .button-row {
			justify-content: flex-start;
		}
	}
</style>
