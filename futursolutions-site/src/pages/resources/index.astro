---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { resources } from '../../data/resources';

const pageTitle = 'Resources | FutureSolutions';
const pageDescription =
	'Practical website strategy, local visibility, conversion, and Growth System insights for healthcare and high-trust service businesses.';
const canonicalUrl = 'https://futursolutions.io/resources/';

const pillars = [
	{
		title: 'Trust and Credibility',
		text: 'Healthcare websites must earn confidence quickly.',
		lane: 'custom',
		label: 'Brand',
	},
	{
		title: 'Conversion and Booking Flow',
		text: 'A website should guide visitors toward the next step.',
		lane: 'audit',
		label: 'Conversion',
	},
	{
		title: 'Local Visibility',
		text: 'Search visibility starts with structure, service clarity, and useful content.',
		lane: 'foundation',
		label: 'Visibility',
	},
	{
		title: 'Growth Systems',
		text: 'A lead is only useful if it is captured, organized, and followed up with.',
		lane: 'growth',
		label: 'Systems',
	},
	{
		title: 'Website Foundations',
		text: 'Website Foundations are valuable when they are niche-specific and strategically structured.',
		lane: 'foundation',
		label: 'Foundations',
	},
];

const categoryLane: Record<string, { lane: string; pillar: string }> = {
	'Website Strategy': { lane: 'custom', pillar: 'Trust and Credibility' },
	'Conversion': { lane: 'audit', pillar: 'Conversion and Booking Flow' },
	'Med Spa Websites': { lane: 'custom', pillar: 'Trust and Credibility' },
	'Solo Practices': { lane: 'custom', pillar: 'Trust and Credibility' },
	'Local Visibility': { lane: 'foundation', pillar: 'Local Visibility' },
	'Growth Systems': { lane: 'growth', pillar: 'Growth Systems' },
	'Foundations': { lane: 'foundation', pillar: 'Website Foundations' },
};

const published = resources.filter((r) => r.status === 'Published' && r.article);

const featured = published.map((r) => ({
	...r,
	lane: categoryLane[r.category]?.lane ?? 'foundation',
	pillar: categoryLane[r.category]?.pillar ?? r.category,
	dateLabel: new Date(r.article!.datePublished).toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	}),
}));
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section resources-hero" aria-labelledby="resources-heading">
		<div class="site-container resources-hero__inner">
			<p class="eyebrow">Resources</p>
			<h1 id="resources-heading">Practical website strategy for health and wellness businesses.</h1>
			<p class="lead">
				Guides and insights on healthcare website trust, service clarity, local visibility, conversion flow, and Growth Systems.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
				<a class="button button-secondary" href="/templates">Explore Live Demos</a>
			</div>
		</div>
	</section>

	<section class="section resources-pillars" aria-labelledby="resources-pillars-heading">
		<div class="site-container">
			<div class="resources-pillars__intro">
				<p class="eyebrow">Content pillars</p>
				<h2 id="resources-pillars-heading">What FutureSolutions writes about.</h2>
				<p class="lead">
					Every resource is designed to help health and wellness businesses understand how trust, clarity, visibility, and follow-up affect website performance.
				</p>
			</div>
			<ul class="resources-pillars__rail">
				{pillars.map((pillar) => (
					<li class={`resources-pillars__chip resources-pillars__chip--${pillar.lane}`}>
						<span class={`lane-tag lane-tag--${pillar.lane}`}>{pillar.label}</span>
						<div class="resources-pillars__chip-text">
							<p class="resources-pillars__chip-title">{pillar.title}</p>
							<p class="resources-pillars__chip-sub">{pillar.text}</p>
						</div>
					</li>
				))}
			</ul>
		</div>
	</section>

	<section id="featured-resources" class="section resources-published" aria-labelledby="resources-published-heading">
		<div class="site-container">
			<div class="resources-published__intro">
				<p class="eyebrow">Latest articles</p>
				<h2 id="resources-published-heading">Published guides.</h2>
				<p class="lead">
					Practical, no-fluff reads on the things that actually move the needle for healthcare websites.
				</p>
			</div>
			<div class="resources-published__grid">
				{featured.map((item) => (
					<a class={`card resources-article-card resources-article-card--${item.lane}`} href={`/resources/${item.slug}`}>
						<div class="resources-article-card__meta">
							<span class={`lane-tag lane-tag--${item.lane}`}>{item.pillar}</span>
							<span class="resources-article-card__time">{item.article?.readingTime}</span>
						</div>
						<h3>{item.title}</h3>
						<p>{item.excerpt}</p>
						<div class="resources-article-card__foot">
							<span class="resources-article-card__date">{item.dateLabel}</span>
							<span class="resources-article-card__link">
								Read article
								<span aria-hidden="true">&rarr;</span>
							</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<section class="section resources-final" aria-labelledby="resources-final-heading">
		<div class="site-container">
			<div class="resources-final__card">
				<div>
					<p class="eyebrow">Next step</p>
					<h2 id="resources-final-heading">Want to know which issues matter most on your site?</h2>
					<p class="lead">
						Start with a Website and Systems Audit and get a clear recommendation based on trust, visibility, conversion, and follow-up.
					</p>
				</div>
				<div class="button-row">
					<a class="button button-primary" href="/audit">Get a Website Audit</a>
					<a class="button button-secondary" href="/services">View Services</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.resources-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.resources-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 76% 14%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.resources-hero__inner,
	.resources-pillars__intro {
		max-width: 820px;
	}

	.resources-hero h1 {
		max-width: 860px;
	}

	.resources-pillars__rail {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 0.65rem;
		margin: clamp(2rem, 4vw, 3rem) 0 0;
		padding: 0;
		list-style: none;
	}

	.resources-pillars__chip {
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 0.65rem;
		padding: 1rem 1.1rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-white);
		transition: border-color var(--transition-base), background var(--transition-base);
	}

	.resources-pillars__chip--foundation:hover { background: color-mix(in srgb, var(--lane-foundation-tint) 40%, var(--color-white)); border-color: color-mix(in srgb, var(--lane-foundation) 32%, var(--color-border)); }
	.resources-pillars__chip--custom:hover     { background: color-mix(in srgb, var(--lane-custom-tint) 40%, var(--color-white));     border-color: color-mix(in srgb, var(--lane-custom) 30%, var(--color-border)); }
	.resources-pillars__chip--growth:hover     { background: color-mix(in srgb, var(--lane-growth-tint) 40%, var(--color-white));     border-color: color-mix(in srgb, var(--lane-growth) 32%, var(--color-border)); }
	.resources-pillars__chip--audit:hover      { background: color-mix(in srgb, var(--lane-audit-tint) 40%, var(--color-white));      border-color: color-mix(in srgb, var(--lane-audit) 34%, var(--color-border)); }
	.resources-pillars__chip--care:hover       { background: color-mix(in srgb, var(--lane-care-tint) 40%, var(--color-white));       border-color: color-mix(in srgb, var(--lane-care) 32%, var(--color-border)); }

	.resources-pillars__chip .lane-tag {
		align-self: flex-start;
	}

	.resources-pillars__chip-title {
		margin: 0;
		color: var(--color-text);
		font-size: 0.96rem;
		font-weight: 700;
		letter-spacing: -0.015em;
		line-height: 1.25;
	}

	.resources-pillars__chip-sub {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.85rem;
		line-height: 1.5;
	}

	.resources-published__intro {
		max-width: 820px;
	}

	.resources-published__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: clamp(2rem, 4vw, 3rem);
	}

	.resources-article-card {
		display: grid;
		grid-template-rows: auto auto 1fr auto;
		gap: 0.7rem;
		padding: 1.4rem;
		border-left-width: 3px;
		transition: transform 280ms var(--ease-out-quart), border-color var(--transition-base), box-shadow var(--transition-base);
	}

	.resources-article-card--foundation { border-left-color: var(--lane-foundation); }
	.resources-article-card--custom     { border-left-color: var(--lane-custom); }
	.resources-article-card--growth     { border-left-color: var(--lane-growth); }
	.resources-article-card--audit      { border-left-color: var(--lane-audit); }
	.resources-article-card--care       { border-left-color: var(--lane-care); }

	.resources-article-card:hover {
		transform: translateY(-3px);
		border-color: color-mix(in srgb, var(--color-accent) 32%, var(--color-border));
		box-shadow: 0 24px 52px rgba(15, 23, 42, 0.08);
	}

	.resources-article-card__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
	}

	.resources-article-card__time {
		color: var(--color-muted);
		font-size: 0.78rem;
		font-weight: 600;
	}

	.resources-article-card h3 {
		margin: 0;
		color: var(--color-text);
		font-size: 1.12rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.3;
	}

	.resources-article-card p {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.9rem;
		line-height: 1.55;
	}

	.resources-article-card__foot {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-top: 0.35rem;
		padding-top: 0.85rem;
		border-top: 1px solid var(--color-border-soft);
	}

	.resources-article-card__date {
		color: var(--color-muted-soft);
		font-size: 0.8rem;
		font-weight: 600;
	}

	.resources-article-card__link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--color-accent-dark);
		font-size: 0.85rem;
		font-weight: 800;
	}

	.resources-article-card__link span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.resources-article-card:hover .resources-article-card__link span {
		transform: translateX(3px);
	}

	.resources-final {
		background: var(--color-accent-light);
	}

	.resources-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
		border-radius: 20px;
		background: var(--color-text);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.resources-final .eyebrow {
		color: color-mix(in srgb, var(--color-accent-light) 84%, var(--color-white));
	}

	.resources-final h2,
	.resources-final .lead {
		color: var(--color-white);
	}

	.resources-final .lead {
		opacity: 0.78;
	}

	.resources-final .button-row {
		justify-content: flex-end;
		margin-top: 0;
	}

	.resources-final .button-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.22);
		color: var(--color-white);
	}

	.resources-final .button-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.38);
		color: var(--color-white);
	}

	@media (max-width: 1100px) {
		.resources-pillars__rail {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 920px) {
		.resources-published__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 760px) {
		.resources-pillars__rail,
		.resources-published__grid,
		.resources-final__card {
			grid-template-columns: 1fr;
		}

		.resources-final .button-row {
			justify-content: flex-start;
		}
	}
</style>
