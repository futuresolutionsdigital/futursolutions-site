---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { resources } from '../../data/resources';

const pageTitle = 'Resources | FutureSolutions';
const pageDescription =
	'Practical website strategy, local visibility, conversion, and Growth System insights for healthcare and high-trust service businesses.';
const canonicalUrl = 'https://futursolutions.vercel.app/resources/';

const pillars = [
	{
		title: 'Trust and Credibility',
		text: 'Healthcare websites must earn confidence quickly.',
		lane: 'custom',
		label: 'Brand',
	},
	{
		title: 'Conversion and Booking Flow',
		text: 'A website should guide visitors toward the next step.',
		lane: 'audit',
		label: 'Conversion',
	},
	{
		title: 'Local Visibility',
		text: 'Search visibility starts with structure, service clarity, and useful content.',
		lane: 'foundation',
		label: 'Visibility',
	},
	{
		title: 'Growth Systems',
		text: 'A lead is only useful if it is captured, organized, and followed up with.',
		lane: 'growth',
		label: 'Systems',
	},
	{
		title: 'Website Foundations',
		text: 'Website Foundations are valuable when they are niche-specific and strategically structured.',
		lane: 'foundation',
		label: 'Foundations',
	},
];

const categoryLane: Record<string, { lane: string; pillar: string }> = {
	'Website Strategy': { lane: 'custom', pillar: 'Trust and Credibility' },
	'Conversion': { lane: 'audit', pillar: 'Conversion and Booking Flow' },
	'Med Spa Websites': { lane: 'custom', pillar: 'Trust and Credibility' },
	'Solo Practices': { lane: 'custom', pillar: 'Trust and Credibility' },
	'Local Visibility': { lane: 'foundation', pillar: 'Local Visibility' },
	'Growth Systems': { lane: 'growth', pillar: 'Growth Systems' },
	'Foundations': { lane: 'foundation', pillar: 'Website Foundations' },
};

const roadmap = resources.map((r, i) => ({
	...r,
	number: String(i + 1).padStart(2, '0'),
	lane: categoryLane[r.category]?.lane ?? 'foundation',
	pillar: categoryLane[r.category]?.pillar ?? r.category,
}));
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
	canonicalUrl={canonicalUrl}
	ogTitle={pageTitle}
	ogDescription={pageDescription}
	ogUrl={canonicalUrl}
>
	<section class="section resources-hero" aria-labelledby="resources-heading">
		<div class="site-container resources-hero__inner">
			<p class="eyebrow">Resources</p>
			<h1 id="resources-heading">Practical website strategy for health and wellness businesses.</h1>
			<p class="lead">
				Guides and insights on healthcare website trust, service clarity, local visibility, conversion flow, and Growth Systems.
			</p>
			<div class="button-row">
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
				<a class="button button-secondary" href="/templates">Explore Live Demos</a>
			</div>
		</div>
	</section>

	<section class="section resources-pillars" aria-labelledby="resources-pillars-heading">
		<div class="site-container">
			<div class="resources-pillars__intro">
				<p class="eyebrow">Content pillars</p>
				<h2 id="resources-pillars-heading">What FutureSolutions writes about.</h2>
				<p class="lead">
					Every resource is designed to help health and wellness businesses understand how trust, clarity, visibility, and follow-up affect website performance.
				</p>
			</div>
			<ul class="resources-pillars__rail">
				{pillars.map((pillar) => (
					<li class={`resources-pillars__chip resources-pillars__chip--${pillar.lane}`}>
						<span class={`lane-tag lane-tag--${pillar.lane}`}>{pillar.label}</span>
						<div class="resources-pillars__chip-text">
							<p class="resources-pillars__chip-title">{pillar.title}</p>
							<p class="resources-pillars__chip-sub">{pillar.text}</p>
						</div>
					</li>
				))}
			</ul>
		</div>
	</section>

	<section id="featured-resources" class="section section-muted resources-roadmap" aria-labelledby="resources-roadmap-heading">
		<div class="site-container">
			<div class="resources-roadmap__intro">
				<div class="resources-roadmap__intro-head">
				<span class="resources-roadmap__status">
					<span class="resources-roadmap__status-dot" aria-hidden="true"></span>
					Active content roadmap
				</span>
					<span class="resources-roadmap__count">{resources.length} articles planned</span>
				</div>
				<h2 id="resources-roadmap-heading">Content roadmap — in development.</h2>
				<p class="lead">
					This is the publishing plan, not a missing-articles page. Each piece below is mapped to a specific buyer question. They release as we ship them; in the meantime, the audit is the fastest way to get a written recommendation tailored to your business.
				</p>
			</div>

			<ol class="resources-roadmap__list" aria-label="Planned resource articles">
				{roadmap.map((item) => (
					<li class={`resources-roadmap__item resources-roadmap__item--${item.lane}`}>
						<span class="resources-roadmap__num" aria-hidden="true">{item.number}</span>
						<div class="resources-roadmap__main">
							<div class="resources-roadmap__meta">
								<span class={`lane-tag lane-tag--${item.lane}`}>{item.pillar}</span>
								<span class="resources-roadmap__pill">
									<span class="resources-roadmap__pill-dot" aria-hidden="true"></span>
									In development
								</span>
							</div>
							<h3 class="resources-roadmap__title">{item.title}</h3>
							<p class="resources-roadmap__excerpt">{item.excerpt}</p>
							<div class="resources-roadmap__foot">
								<span class="resources-roadmap__related">
									<strong>Related</strong>
									<span>{item.relatedService}</span>
								</span>
								<a class="resources-roadmap__cta" href={item.ctaHref}>
									{item.ctaLabel}
									<span aria-hidden="true">&rarr;</span>
								</a>
							</div>
						</div>
					</li>
				))}
			</ol>

			<aside class="resources-roadmap__note">
				<strong>Want the answer for your business now?</strong>
				<span>The audit gives you a written recommendation faster than waiting for a specific article to publish.</span>
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
			</aside>
		</div>
	</section>

	<section class="section scorecard-preview" aria-labelledby="scorecard-preview-heading">
		<div class="site-container">
			<div class="scorecard-preview__card card">
				<div>
					<p class="eyebrow">Coming later</p>
					<h2 id="scorecard-preview-heading">Healthcare Website Trust & Conversion Scorecard</h2>
					<p class="lead">
						A simple scorecard to help health and wellness businesses identify hidden issues in trust, service clarity, CTA visibility, local SEO, mobile experience, and follow-up systems.
					</p>
				</div>
				<a class="button button-primary" href="/audit">Get a Website Audit</a>
			</div>
		</div>
	</section>

	<section class="section resources-final" aria-labelledby="resources-final-heading">
		<div class="site-container">
			<div class="resources-final__card">
				<div>
					<p class="eyebrow">Next step</p>
					<h2 id="resources-final-heading">Want to know which issues matter most on your site?</h2>
					<p class="lead">
						Start with a Website and Systems Audit and get a clear recommendation based on trust, visibility, conversion, and follow-up.
					</p>
				</div>
				<div class="button-row">
					<a class="button button-primary" href="/audit">Get a Website Audit</a>
					<a class="button button-secondary" href="/services">View Services</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.resources-hero {
		position: relative;
		overflow: hidden;
		padding-block: clamp(5rem, 8vw, 8rem);
	}

	.resources-hero::before {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(circle at 76% 14%, rgba(95, 143, 139, 0.12), transparent 30%),
			linear-gradient(180deg, var(--color-white) 0%, var(--color-bg) 72%);
		content: '';
	}

	.resources-hero__inner,
	.resources-pillars__intro,
	.resources-roadmap__intro {
		max-width: 820px;
	}

	.resources-hero h1 {
		max-width: 860px;
	}

	.resources-pillars__rail {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 0.65rem;
		margin: clamp(2rem, 4vw, 3rem) 0 0;
		padding: 0;
		list-style: none;
	}

	.resources-pillars__chip {
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 0.65rem;
		padding: 1rem 1.1rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-white);
		transition: border-color var(--transition-base), background var(--transition-base);
	}

	.resources-pillars__chip--foundation:hover { background: color-mix(in srgb, var(--lane-foundation-tint) 40%, var(--color-white)); border-color: color-mix(in srgb, var(--lane-foundation) 32%, var(--color-border)); }
	.resources-pillars__chip--custom:hover     { background: color-mix(in srgb, var(--lane-custom-tint) 40%, var(--color-white));     border-color: color-mix(in srgb, var(--lane-custom) 30%, var(--color-border)); }
	.resources-pillars__chip--growth:hover     { background: color-mix(in srgb, var(--lane-growth-tint) 40%, var(--color-white));     border-color: color-mix(in srgb, var(--lane-growth) 32%, var(--color-border)); }
	.resources-pillars__chip--audit:hover      { background: color-mix(in srgb, var(--lane-audit-tint) 40%, var(--color-white));      border-color: color-mix(in srgb, var(--lane-audit) 34%, var(--color-border)); }
	.resources-pillars__chip--care:hover       { background: color-mix(in srgb, var(--lane-care-tint) 40%, var(--color-white));       border-color: color-mix(in srgb, var(--lane-care) 32%, var(--color-border)); }

	.resources-pillars__chip .lane-tag {
		align-self: flex-start;
	}

	.resources-pillars__chip-title {
		margin: 0;
		color: var(--color-text);
		font-size: 0.96rem;
		font-weight: 700;
		letter-spacing: -0.015em;
		line-height: 1.25;
	}

	.resources-pillars__chip-sub {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.85rem;
		line-height: 1.5;
	}

	.resources-roadmap__intro-head {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1rem;
		margin-bottom: 0.85rem;
	}

	.resources-roadmap__status {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.35rem 0.7rem;
		border: 1px solid color-mix(in srgb, var(--lane-audit) 32%, var(--color-border));
		border-radius: 999px;
		background: color-mix(in srgb, var(--lane-audit-tint) 70%, var(--color-white));
		color: var(--lane-audit-ink);
		font-size: 0.74rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.resources-roadmap__status-dot {
		width: 7px;
		height: 7px;
		border-radius: 999px;
		background: var(--lane-audit-ink);
		box-shadow: 0 0 0 3px color-mix(in srgb, var(--lane-audit) 22%, transparent);
		animation: roadmap-pulse 2.4s ease-in-out infinite;
	}

	@keyframes roadmap-pulse {
		0%, 100% { opacity: 1; box-shadow: 0 0 0 3px color-mix(in srgb, var(--lane-audit) 22%, transparent); }
		50%      { opacity: 0.7; box-shadow: 0 0 0 6px color-mix(in srgb, var(--lane-audit) 8%, transparent); }
	}

	@media (prefers-reduced-motion: reduce) {
		.resources-roadmap__status-dot { animation: none; }
	}

	.resources-roadmap__count {
		color: var(--color-muted);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.resources-roadmap__list {
		display: grid;
		gap: 0.85rem;
		margin: clamp(2rem, 4vw, 2.75rem) 0 clamp(2rem, 4vw, 2.75rem) 0;
		padding: 0;
		list-style: none;
		counter-reset: roadmap;
	}

	.resources-roadmap__item {
		display: grid;
		grid-template-columns: 3.5rem minmax(0, 1fr);
		gap: 1rem;
		padding: 1.2rem 1.4rem;
		border: 1px solid var(--color-border);
		border-left-width: 3px;
		border-radius: var(--radius-md);
		background: var(--color-white);
		transition: background var(--transition-base), border-color var(--transition-base), transform 280ms var(--ease-out-quart);
	}

	.resources-roadmap__item:hover {
		transform: translateX(2px);
	}

	.resources-roadmap__item--foundation { border-left-color: var(--lane-foundation); }
	.resources-roadmap__item--custom     { border-left-color: var(--lane-custom); }
	.resources-roadmap__item--growth     { border-left-color: var(--lane-growth); }
	.resources-roadmap__item--audit      { border-left-color: var(--lane-audit); }
	.resources-roadmap__item--care       { border-left-color: var(--lane-care); }

	.resources-roadmap__item--foundation:hover { background: color-mix(in srgb, var(--lane-foundation-tint) 22%, var(--color-white)); }
	.resources-roadmap__item--custom:hover     { background: color-mix(in srgb, var(--lane-custom-tint) 22%, var(--color-white)); }
	.resources-roadmap__item--growth:hover     { background: color-mix(in srgb, var(--lane-growth-tint) 22%, var(--color-white)); }
	.resources-roadmap__item--audit:hover      { background: color-mix(in srgb, var(--lane-audit-tint) 22%, var(--color-white)); }
	.resources-roadmap__item--care:hover       { background: color-mix(in srgb, var(--lane-care-tint) 22%, var(--color-white)); }

	.resources-roadmap__num {
		color: var(--color-muted);
		font-size: 1.1rem;
		font-weight: 800;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.06em;
		line-height: 1;
		padding-top: 0.1rem;
	}

	.resources-roadmap__main {
		display: grid;
		gap: 0.5rem;
	}

	.resources-roadmap__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 0.65rem;
	}

	.resources-roadmap__pill {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.22rem 0.55rem;
		border: 1px dashed color-mix(in srgb, var(--color-muted) 38%, var(--color-border));
		border-radius: 999px;
		background: var(--color-bg);
		color: var(--color-muted);
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		line-height: 1;
		text-transform: uppercase;
	}

	.resources-roadmap__pill-dot {
		width: 5px;
		height: 5px;
		border-radius: 999px;
		background: var(--color-muted);
	}

	.resources-roadmap__title {
		margin: 0;
		color: var(--color-text);
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.3;
	}

	.resources-roadmap__excerpt {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.93rem;
		line-height: 1.55;
	}

	.resources-roadmap__foot {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.85rem 1.5rem;
		justify-content: space-between;
		margin-top: 0.25rem;
		padding-top: 0.75rem;
		border-top: 1px solid var(--color-border-soft);
	}

	.resources-roadmap__related {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.4rem;
		font-size: 0.82rem;
	}

	.resources-roadmap__related strong {
		color: var(--color-muted);
		font-weight: 700;
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.resources-roadmap__related span {
		color: var(--color-text);
		font-weight: 600;
	}

	.resources-roadmap__cta {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--color-text);
		font-size: 0.875rem;
		font-weight: 700;
		transition: gap var(--transition-base);
	}

	.resources-roadmap__cta:hover {
		gap: 0.55rem;
	}

	.resources-roadmap__cta span {
		display: inline-block;
		transition: transform 220ms var(--ease-out-quart);
	}

	.resources-roadmap__cta:hover span {
		transform: translateX(2px);
	}

	.resources-roadmap__note {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: 0.75rem 1.5rem;
		padding: 1.25rem 1.5rem;
		border: 1px solid color-mix(in srgb, var(--lane-audit) 26%, var(--color-border));
		border-radius: var(--radius-md);
		background: color-mix(in srgb, var(--lane-audit-tint) 60%, var(--color-white));
	}

	.resources-roadmap__note strong {
		grid-column: 1;
		color: var(--color-text);
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.resources-roadmap__note span {
		grid-column: 1;
		color: var(--color-text);
		font-size: 0.9rem;
		line-height: 1.5;
	}

	.resources-roadmap__note .button {
		grid-column: 2;
		grid-row: 1 / span 2;
		align-self: center;
		white-space: nowrap;
	}

	.scorecard-preview {
		background: var(--color-accent-light);
	}

	.scorecard-preview__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border-color: color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
		border-radius: 22px;
	}

	.scorecard-preview h2 {
		max-width: 760px;
	}

	.scorecard-preview .lead {
		max-width: 760px;
	}

	.resources-final {
		background: var(--color-accent-light);
	}

	.resources-final__card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: end;
		padding: clamp(1.5rem, 4vw, 3rem);
		border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
		border-radius: 20px;
		background: var(--color-text);
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
	}

	.resources-final .eyebrow {
		color: color-mix(in srgb, var(--color-accent-light) 84%, var(--color-white));
	}

	.resources-final h2,
	.resources-final .lead {
		color: var(--color-white);
	}

	.resources-final .lead {
		opacity: 0.78;
	}

	.resources-final .button-row {
		justify-content: flex-end;
		margin-top: 0;
	}

	.resources-final .button-secondary {
		background: transparent;
		border-color: rgba(255, 255, 255, 0.22);
		color: var(--color-white);
	}

	.resources-final .button-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.38);
		color: var(--color-white);
	}

	@media (max-width: 1100px) {
		.resources-pillars__rail {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 760px) {
		.resources-pillars__rail,
		.scorecard-preview__card,
		.resources-final__card {
			grid-template-columns: 1fr;
		}

		.resources-roadmap__item {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}

		.resources-roadmap__num {
			font-size: 0.95rem;
		}

		.resources-roadmap__note {
			grid-template-columns: 1fr;
		}

		.resources-roadmap__note .button {
			grid-column: 1;
			grid-row: auto;
			justify-self: start;
		}

		.resources-final .button-row {
			justify-content: flex-start;
		}
	}
</style>
